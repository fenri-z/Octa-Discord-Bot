<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
.cmd-page { max-width: 960px; margin: 0 auto; padding: 3rem 1.5rem 5rem; }

/* Header */
.cmd-header { text-align: center; margin-bottom: 2.5rem; }
.cmd-header h1 { font-size: clamp(1.6rem,5vw,2.2rem); font-weight: 800; margin-bottom: .5rem; }
.cmd-header p  { color: var(--text-muted); font-size: .9rem; }

/* Search */
.cmd-search-wrap {
    position: relative; max-width: 460px; margin: 0 auto 2rem;
}
.cmd-search-icon {
    position: absolute; left: .85rem; top: 50%; transform: translateY(-50%);
    color: var(--text-muted); width: 16px; height: 16px;
    pointer-events: none; display: block; flex-shrink: 0;
}
.cmd-search {
    width: 100%; padding: .7rem .9rem .7rem 2.6rem;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; color: var(--text); font-size: .88rem;
    outline: none; transition: border-color .15s;
    box-sizing: border-box;
}
.cmd-search:focus { border-color: rgba(88,101,242,.5); }

/* Category tabs */
.cmd-tabs {
    display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2rem;
    justify-content: center;
}
.cmd-tab {
    padding: .4rem 1rem; border-radius: 20px; font-size: .82rem; font-weight: 600;
    cursor: pointer; border: 1px solid var(--border); background: var(--bg2);
    color: var(--text-muted); transition: all .15s;
}
.cmd-tab:hover  { border-color: rgba(88,101,242,.4); color: var(--text); }
.cmd-tab.active { background: rgba(88,101,242,.15); border-color: rgba(88,101,242,.4); color: #8b95f7; }

/* Category section */
.cmd-category { margin-bottom: 2.5rem; }
.cmd-cat-label {
    display: flex; align-items: center; gap: .65rem;
    font-size: .72rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: .09em; color: var(--text-muted);
    margin-bottom: 1rem; padding-bottom: .5rem;
    border-bottom: 1px solid var(--border);
}
.cmd-cat-label .cat-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.cmd-count { margin-left: auto; font-size: .68rem; background: rgba(255,255,255,.06); padding: .1rem .45rem; border-radius: 20px; }

/* Command cards */
.cmd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .75rem;
}
@media (max-width: 720px) {
    .cmd-grid { grid-template-columns: repeat(2, 1fr); }
}
.cmd-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 1rem 1.1rem;
    transition: border-color .15s, transform .15s;
    cursor: default;
}
.cmd-card:hover { border-color: rgba(88,101,242,.35); transform: translateY(-1px); }
.cmd-card-name {
    font-size: .88rem; font-weight: 700; color: var(--text);
    font-family: 'Courier New', monospace;
    margin-bottom: .35rem; display: flex; align-items: center; gap: .4rem; flex-wrap: wrap;
}
.cmd-card-name code {
    background: rgba(88,101,242,.12); color: #8b95f7;
    padding: .1rem .45rem; border-radius: 5px; font-size: .82rem;
}
.cmd-card-desc { font-size: .8rem; color: var(--text-muted); line-height: 1.6; }
.cmd-perm-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .65rem; font-weight: 700; padding: .1rem .4rem;
    border-radius: 4px; margin-top: .5rem;
}
.cmd-perm-badge.admin { background: rgba(237,66,69,.12); color: #ed4245; }
.cmd-perm-badge.mod   { background: rgba(240,160,50,.12); color: #F0A032; }

/* No results */
.cmd-empty { text-align: center; padding: 3rem 1rem; color: var(--text-muted); font-size: .9rem; }

@media (max-width: 600px) {
    .cmd-page { padding: 2rem 1rem 4rem; }
    .cmd-grid { grid-template-columns: 1fr; }
}
</style>

