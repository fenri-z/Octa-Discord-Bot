<script>
let activeTab = 'all';

function setTab(tab, el) {
    activeTab = tab;
    document.querySelectorAll('.cmd-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    filterCommands();
}

function filterCommands() {
    const q = document.getElementById('cmdSearch').value.toLowerCase().trim();
    let anyVisible = false;

    document.querySelectorAll('.cmd-category').forEach(cat => {
        const catKey  = cat.dataset.cat;
        const cards   = cat.querySelectorAll('.cmd-card');
        let catHasMatch = false;

        cards.forEach(card => {
            const name = (card.dataset.name || '').toLowerCase();
            const desc = card.querySelector('.cmd-card-desc')?.textContent.toLowerCase() || '';
            const match = (name.includes(q) || desc.includes(q));
            const tabOk = activeTab === 'all' || catKey === activeTab;
            card.style.display = (match && tabOk) ? '' : 'none';
            if (match && tabOk) catHasMatch = true;
        });

        cat.style.display = catHasMatch ? '' : 'none';
        if (catHasMatch) anyVisible = true;
    });

    document.getElementById('cmdEmpty').style.display = anyVisible ? 'none' : 'block';
}
</script>

