<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
.rb-page {
    max-width: 900px; margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
}

/* ── Header ──────────────────────────────────────────────────────────────── */
.rb-header { text-align: center; margin-bottom: 2.5rem; }
.rb-illustration {
    width: 200px; height: auto; margin: 0 auto 1.5rem; display: block;
    filter: drop-shadow(0 8px 32px rgba(88,101,242,.25));
}
.rb-header h1 {
    font-size: clamp(1.6rem, 5vw, 2.2rem); font-weight: 800;
    margin-bottom: .5rem;
    background: linear-gradient(135deg, #fff 30%, #8b95f7 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
}
.rb-header p { font-size: .9rem; color: var(--text-muted); line-height: 1.65; max-width: 440px; margin: 0 auto; }

/* ── Form card ───────────────────────────────────────────────────────────── */
.rb-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem 2rem 1.75rem;
}

.rb-row { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; margin-bottom: .85rem; }
.rb-field { margin-bottom: .85rem; }
.rb-field:last-of-type { margin-bottom: 0; }

.rb-label {
    display: block; font-size: .8rem; font-weight: 600;
    color: var(--text-muted); margin-bottom: .4rem;
}
.rb-label span { color: #ed4245; }

.rb-input, .rb-textarea {
    width: 100%; padding: .65rem .85rem;
    background: var(--bg3, #2a2b38); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); font-size: .875rem;
    outline: none; transition: border-color .15s; box-sizing: border-box;
    font-family: inherit;
}
.rb-input:focus, .rb-textarea:focus { border-color: rgba(88,101,242,.5); }
.rb-input::placeholder, .rb-textarea::placeholder { color: var(--text-muted); opacity: .6; }
.rb-textarea { resize: vertical; min-height: 120px; line-height: 1.6; }

/* ── Upload area ─────────────────────────────────────────────────────────── */
.rb-upload-label { display: block; font-size: .8rem; font-weight: 600; color: var(--text-muted); margin-bottom: .4rem; }
.rb-upload-area {
    border: 1.5px dashed rgba(255,255,255,.15);
    border-radius: 8px; padding: 1.5rem 1rem;
    text-align: center; cursor: pointer;
    transition: border-color .15s, background .15s;
    background: rgba(255,255,255,.02);
    position: relative; overflow: hidden;
}
.rb-upload-area:hover { border-color: rgba(88,101,242,.4); background: rgba(88,101,242,.04); }
.rb-upload-area input[type=file] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
.rb-upload-icon {
    width: 36px; height: 36px; margin: 0 auto .6rem;
    color: var(--text-muted);
}
.rb-upload-text { font-size: .85rem; font-weight: 600; color: var(--text-muted); margin-bottom: .2rem; }
.rb-upload-hint { font-size: .75rem; color: var(--text-muted); opacity: .6; }
.rb-upload-preview {
    display: none; margin-top: .75rem;
    font-size: .78rem; color: #57F287;
    align-items: center; gap: .4rem; justify-content: center;
}

/* ── Submit row ──────────────────────────────────────────────────────────── */
.rb-submit-row {
    margin-top: 1.5rem;
    display: flex; justify-content: flex-end;
}
.rb-btn {
    padding: .75rem 2.25rem; font-size: .9rem; font-weight: 700;
    border-radius: 8px; background: var(--accent); color: #fff;
    border: none; cursor: pointer;
    transition: background .15s, transform .1s, box-shadow .15s;
    box-shadow: 0 4px 20px rgba(88,101,242,.35);
    display: inline-flex; align-items: center; gap: .5rem;
}
.rb-btn:hover { background: var(--accent-h); transform: translateY(-1px); box-shadow: 0 6px 28px rgba(88,101,242,.45); }
.rb-btn:active { transform: translateY(0); }
.rb-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }

/* ── Success / Error message ─────────────────────────────────────────────── */
.rb-msg {
    margin-top: 1rem; padding: .75rem 1rem;
    border-radius: 8px; font-size: .85rem; display: none;
}
.rb-msg.success { background: rgba(87,242,135,.1); border: 1px solid rgba(87,242,135,.25); color: #57F287; }
.rb-msg.error   { background: rgba(237,66,69,.1);  border: 1px solid rgba(237,66,69,.25);  color: #ed4245; }

/* ── Tips ────────────────────────────────────────────────────────────────── */
.rb-tips {
    margin-top: 1.5rem;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: 10px; padding: 1rem 1.25rem;
}
.rb-tips-title {
    font-size: .78rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .07em;
    margin-bottom: .65rem; display: flex; align-items: center; gap: .4rem;
}
.rb-tips-list {
    display: flex; flex-direction: column; gap: .4rem;
    padding: 0; margin: 0; list-style: none;
}
.rb-tips-list li {
    font-size: .8rem; color: var(--text-muted); line-height: 1.55;
    display: flex; align-items: flex-start; gap: .5rem;
}
.rb-tips-list li::before {
    content: '✦'; color: var(--accent); flex-shrink: 0; margin-top: .05rem; font-size: .7rem;
}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 560px) {
    .rb-page   { padding: 2rem 1rem 4rem; }
    .rb-card   { padding: 1.25rem 1rem 1.25rem; }
    .rb-row    { grid-template-columns: 1fr; gap: 0; }
    .rb-submit-row { justify-content: stretch; }
    .rb-btn    { width: 100%; justify-content: center; }
}
</style>

<div class="rb-page">
    <!-- Header dengan ilustrasi SVG -->
    <div class="rb-header">
        <svg class="rb-illustration" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Monitor -->
            <rect x="30" y="20" width="140" height="95" rx="8" fill="#1e1f2e" stroke="rgba(88,101,242,.4)" stroke-width="1.5"/>
            <rect x="40" y="30" width="120" height="75" rx="4" fill="#13141e"/>
            <!-- Screen grid (people icons) -->
            <rect x="44" y="34" width="54" height="34" rx="3" fill="#2a2b40"/>
            <circle cx="58" cy="45" r="6" fill="#5865F2" opacity=".7"/>
            <rect x="52" y="53" width="12" height="8" rx="2" fill="#5865F2" opacity=".5"/>
            <circle cx="82" cy="45" r="6" fill="#57F287" opacity=".7"/>
            <rect x="76" y="53" width="12" height="8" rx="2" fill="#57F287" opacity=".5"/>
            <rect x="44" y="72" width="54" height="28" rx="3" fill="#2a2b40"/>
            <circle cx="58" cy="82" r="6" fill="#F0A032" opacity=".7"/>
            <rect x="52" y="90" width="12" height="5" rx="2" fill="#F0A032" opacity=".5"/>
            <circle cx="82" cy="82" r="6" fill="#ED4245" opacity=".7"/>
            <rect x="76" y="90" width="12" height="5" rx="2" fill="#ED4245" opacity=".5"/>
            <!-- Side panel -->
            <rect x="102" y="34" width="54" height="67" rx="3" fill="#2a2b40"/>
            <rect x="108" y="42" width="38" height="4" rx="2" fill="#5865F2" opacity=".6"/>
            <rect x="108" y="50" width="28" height="3" rx="1.5" fill="rgba(255,255,255,.15)"/>
            <rect x="108" y="56" width="32" height="3" rx="1.5" fill="rgba(255,255,255,.15)"/>
            <rect x="108" y="62" width="24" height="3" rx="1.5" fill="rgba(255,255,255,.15)"/>
            <rect x="108" y="72" width="38" height="20" rx="3" fill="#5865F2" opacity=".2"/>
            <rect x="116" y="79" width="22" height="7" rx="3" fill="#5865F2" opacity=".6"/>
            <!-- Stand -->
            <rect x="90" y="115" width="20" height="6" rx="2" fill="#1e1f2e" stroke="rgba(88,101,242,.3)" stroke-width="1"/>
            <rect x="78" y="120" width="44" height="5" rx="2" fill="#1e1f2e" stroke="rgba(88,101,242,.3)" stroke-width="1"/>
            <!-- Decorative dots -->
            <circle cx="22" cy="35" r="4" fill="#5865F2" opacity=".3"/>
            <circle cx="178" cy="110" r="5" fill="#57F287" opacity=".25"/>
            <circle cx="165" cy="18" r="3" fill="#F0A032" opacity=".35"/>
            <!-- Bug icon -->
            <circle cx="168" cy="55" r="14" fill="rgba(237,66,69,.15)" stroke="rgba(237,66,69,.35)" stroke-width="1.5"/>
            <text x="168" y="60" text-anchor="middle" font-size="13" fill="#ED4245">🐛</text>
        </svg>
        <h1>Report Bug</h1>
        <p>Temukan bug atau punya saran? Isi form di bawah dan tim kami akan segera menindaklanjuti laporan kamu.</p>
    </div>

    <!-- Form -->
    <div class="rb-card">
        <form id="rbForm" onsubmit="submitReport(event)">
            <!-- Nama -->
            <div class="rb-row">
                <div>
                    <label class="rb-label" for="rbFirstName">First Name <span>*</span></label>
                    <input class="rb-input" id="rbFirstName" type="text" placeholder="e.g., Andri" required maxlength="50">
                </div>
                <div>
                    <label class="rb-label" for="rbLastName">Last Name <span>*</span></label>
                    <input class="rb-input" id="rbLastName" type="text" placeholder="e.g., Hermawan" required maxlength="50">
                </div>
            </div>

            <!-- Discord info -->
            <div class="rb-row">
                <div>
                    <label class="rb-label" for="rbDiscordUser">
                        Discord Username <span>*</span>
                        <span style="font-weight:400;color:var(--text-muted);font-size:.72rem;margin-left:.3rem;">— untuk kami hubungi jika perlu klarifikasi</span>
                    </label>
                    <input class="rb-input" id="rbDiscordUser" type="text" placeholder="username"
                           required maxlength="100"
                           value="<%= locals.reportUser ? locals.reportUser.username : '' %>"
                           <%= locals.reportUser ? 'readonly style="opacity:.7;cursor:not-allowed;"' : '' %>>
                </div>
                <div>
                    <label class="rb-label" for="rbDiscordId">
                        Discord ID <span>*</span>
                        <span style="font-weight:400;color:var(--text-muted);font-size:.72rem;margin-left:.3rem;">— ID unik akun Discord kamu</span>
                    </label>
                    <input class="rb-input" id="rbDiscordId" type="text" placeholder="123456789012345678"
                           required maxlength="20" pattern="\d{15,20}"
                           value="<%= locals.reportUser ? locals.reportUser.id : '' %>"
                           <%= locals.reportUser ? 'readonly style="opacity:.7;cursor:not-allowed;"' : '' %>>
                </div>
            </div>
            <% if (locals.reportUser) { %>
            <p style="font-size:.75rem;color:var(--text-muted);margin:-0.4rem 0 .85rem;opacity:.7;">
                ✓ Info Discord diisi otomatis dari akun yang sedang login.
            </p>
            <% } %>

            <!-- Pesan -->
            <div class="rb-field">
                <label class="rb-label" for="rbMessage">Message <span>*</span></label>
                <textarea class="rb-textarea" id="rbMessage" placeholder="Deskripsikan bug yang kamu temukan — fitur apa, apa yang terjadi, dan langkah reproduksi..." required maxlength="2000"></textarea>
            </div>

            <!-- Upload gambar -->
            <div class="rb-field">
                <label class="rb-upload-label">Image <span style="font-weight:400;color:var(--text-muted);font-size:.75rem;">(Optional)</span></label>
                <div class="rb-upload-area" onclick="document.getElementById('rbFile').click()">
                    <input type="file" id="rbFile" accept="image/jpeg,image/png,image/gif,image/webp" style="display:none;" onchange="previewFile(this)">
                    <svg class="rb-upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="17 8 12 3 7 8"/>
                        <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <div class="rb-upload-text">Drag &amp; drop an image here, or click to select</div>
                    <div class="rb-upload-hint">Recommended max: 1280×1280, JPG/PNG/GIF/WEBP</div>
                    <div class="rb-upload-preview" id="rbFilePreview">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>
                        <span id="rbFileName"></span>
                    </div>
                </div>
            </div>

            <!-- Submit -->
            <div class="rb-submit-row">
                <button type="submit" class="rb-btn" id="rbSubmitBtn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Send Message
                </button>
            </div>

            <div class="rb-msg" id="rbMsg"></div>
        </form>
    </div>

    <!-- Tips -->
    <div class="rb-tips">
        <div class="rb-tips-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;color:#F0A032;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Tips laporan yang baik
        </div>
        <ul class="rb-tips-list">
            <li>Jelaskan bug secara spesifik — fitur apa, di mana, dan kapan terjadi.</li>
            <li>Sertakan langkah reproduksi agar kami bisa mengulangi masalahnya.</li>
            <li>Lampirkan screenshot atau pesan error jika ada.</li>
            <li>Sebutkan perilaku yang diharapkan vs yang sebenarnya terjadi.</li>
        </ul>
    </div>
</div>

<script>
function previewFile(input) {
    const previewEl  = document.getElementById('rbFilePreview');
    const fileNameEl = document.getElementById('rbFileName');
    if (input.files && input.files[0]) {
        fileNameEl.textContent = input.files[0].name;
        previewEl.style.display = 'flex';
    } else {
        previewEl.style.display = 'none';
    }
}

// Drag & drop
const uploadArea = document.querySelector('.rb-upload-area');
['dragenter','dragover'].forEach(ev => uploadArea.addEventListener(ev, e => {
    e.preventDefault(); uploadArea.style.borderColor = 'rgba(88,101,242,.6)';
}));
['dragleave','drop'].forEach(ev => uploadArea.addEventListener(ev, e => {
    e.preventDefault(); uploadArea.style.borderColor = '';
}));
uploadArea.addEventListener('drop', e => {
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        const input = document.getElementById('rbFile');
        const dt    = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        previewFile(input);
    }
});

async function submitReport(e) {
    e.preventDefault();
    const btn  = document.getElementById('rbSubmitBtn');
    const msgEl = document.getElementById('rbMsg');
    const orig = btn.innerHTML;

    const firstName       = document.getElementById('rbFirstName').value.trim();
    const lastName        = document.getElementById('rbLastName').value.trim();
    const discordUsername = document.getElementById('rbDiscordUser').value.trim();
    const discordId       = document.getElementById('rbDiscordId').value.trim();
    const message         = document.getElementById('rbMessage').value.trim();
    const hasImage        = !!document.getElementById('rbFile').files[0];

    btn.disabled  = true;
    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;animation:spin .7s linear infinite;"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Mengirim...';
    msgEl.style.display = 'none';

    try {
        const r    = await fetch('/report-bug', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ firstName, lastName, discordUsername, discordId, message, hasImage: String(hasImage) }),
        });
        const data = await r.json();

        msgEl.className   = `rb-msg ${data.success ? 'success' : 'error'}`;
        msgEl.textContent = data.success
            ? '✅ ' + data.message
            : '❌ ' + data.message;
        msgEl.style.display = 'block';

        if (data.success) {
            document.getElementById('rbForm').reset();
            document.getElementById('rbFilePreview').style.display = 'none';
            setTimeout(() => { msgEl.style.display = 'none'; }, 6000);
        }
    } catch (err) {
        msgEl.className   = 'rb-msg error';
        msgEl.textContent = '❌ Gagal terhubung ke server. Periksa koneksi internet kamu.';
        msgEl.style.display = 'block';
    } finally {
        btn.disabled  = false;
        btn.innerHTML = orig;
        if (window.lucide) lucide.createIcons();
    }
}

const style = document.createElement('style');
style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
document.head.appendChild(style);
</script>

<%- include('../partials/footer') %>
