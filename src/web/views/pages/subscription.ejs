<script>
function switchTier(tier) {
    var secP = document.getElementById('section-premium');
    var secPr = document.getElementById('section-pro');
    var tabs = document.querySelectorAll('.sub-tier-tab');
    var isPro = tier === 'pro';
    secP.style.display  = isPro ? 'none' : '';
    secPr.style.display = isPro ? '' : 'none';
    tabs.forEach(function(t) {
        t.classList.toggle('active', t.dataset.tier === tier);
    });
}
</script>

