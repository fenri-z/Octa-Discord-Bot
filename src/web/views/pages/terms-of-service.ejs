        <div class="legal-section" id="s8">
            <h2><span class="sec-num">8</span> <%= t('tos.s8_title') %></h2>
            <p><%= t('tos.s8_p1') %></p>
        </div>

        <div class="legal-section" id="s9">
            <h2><span class="sec-num">9</span> <%= t('tos.s9_title') %></h2>
            <p><%= t('tos.s9_p1') %></p>
            <ul>
                <li><strong><%= t('tos.s9_li1_label') %></strong> — <a href="https://discord.gg/DMPvHf46gu" target="_blank" rel="noopener noreferrer"><%= t('tos.s9_li1_link') %></a></li>
                <li><strong><%= t('tos.s9_li2_label') %></strong> — <a href="/report-bug" target="_blank" rel="noopener noreferrer"><%= t('tos.s9_li2_link') %></a></li>
            </ul>
        </div>
    </main>
</div>

<script>
const sections = document.querySelectorAll('.legal-section');
const tocLinks  = document.querySelectorAll('.legal-toc a');
const observer  = new IntersectionObserver(entries => {
    entries.forEach(e => {
        if (e.isIntersecting) {
            tocLinks.forEach(a => a.classList.remove('active'));
            const active = document.querySelector(`.legal-toc a[href="#${e.target.id}"]`);
            if (active) active.classList.add('active');
        }
    });
}, { rootMargin: '-20% 0px -70% 0px' });
sections.forEach(s => observer.observe(s));
</script>

<%- include('../partials/footer') %>
