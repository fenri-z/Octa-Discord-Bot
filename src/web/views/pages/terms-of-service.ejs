<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
.legal-wrap {
    max-width: 860px; margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
}
.legal-toc {
    position: sticky; top: calc(var(--navbar-h, 56px) + 1.5rem);
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 1.1rem;
}
.legal-toc-title {
    font-size: .7rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: .09em; color: var(--text-muted); margin-bottom: .75rem;
}
.legal-toc a {
    display: block; font-size: .8rem; color: var(--text-muted);
    text-decoration: none; padding: .3rem .4rem; border-radius: 5px;
    transition: background .15s, color .15s; line-height: 1.4;
}
.legal-toc a:hover { background: rgba(255,255,255,.05); color: var(--text); }
.legal-toc a.active { background: rgba(240,160,50,.1); color: #F0A032; }
.legal-content { min-width: 0; }
.legal-header   { margin-bottom: 2rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border); }
.legal-header h1 { font-size: 1.75rem; font-weight: 800; margin-bottom: .4rem; }
.legal-meta { font-size: .8rem; color: var(--text-muted); }
.legal-meta span { color: #F0A032; }
.legal-section { margin-bottom: 2.5rem; }
.legal-section h2 {
    font-size: 1.05rem; font-weight: 700;
    color: var(--text); margin-bottom: .85rem;
    padding-bottom: .5rem; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: .6rem;
}
.legal-section h2 .sec-num {
    width: 24px; height: 24px; border-radius: 6px; flex-shrink: 0;
    background: rgba(240,160,50,.15); color: #F0A032;
    display: flex; align-items: center; justify-content: center;
    font-size: .72rem; font-weight: 800;
}
.legal-section p  { font-size: .875rem; color: var(--text-muted); line-height: 1.8; margin-bottom: .75rem; }
.legal-section ul { padding-left: 1.25rem; margin-bottom: .75rem; }
.legal-section ul li { font-size: .875rem; color: var(--text-muted); line-height: 1.8; margin-bottom: .2rem; }
.legal-section a  { color: var(--accent); text-decoration: none; }
.legal-section a:hover { text-decoration: underline; }
.legal-notice {
    background: rgba(240,160,50,.07); border: 1px solid rgba(240,160,50,.2);
    border-radius: 8px; padding: .85rem 1rem;
    font-size: .82rem; color: var(--text-muted); line-height: 1.65;
    margin-bottom: 2rem;
}
@media (max-width: 700px) {
    .legal-wrap { grid-template-columns: 1fr; padding: 2rem 1rem 4rem; gap: 1.5rem; }
    .legal-toc   { position: static; }
}
</style>

<div class="legal-wrap">
    <aside class="legal-toc">
        <div class="legal-toc-title"><%= t('tos.toc_title') %></div>
        <a href="#s1"><%= t('tos.toc_1') %></a>
        <a href="#s2"><%= t('tos.toc_2') %></a>
        <a href="#s3"><%= t('tos.toc_3') %></a>
        <a href="#s4"><%= t('tos.toc_4') %></a>
        <a href="#s5"><%= t('tos.toc_5') %></a>
        <a href="#s6"><%= t('tos.toc_6') %></a>
        <a href="#s7"><%= t('tos.toc_7') %></a>
        <a href="#s8"><%= t('tos.toc_8') %></a>
        <a href="#s9"><%= t('tos.toc_9') %></a>
    </aside>

    <main class="legal-content">
        <div class="legal-header">
            <h1>Terms of Service</h1>
            <div class="legal-meta">
                <%= t('tos.last_updated') %> <span>1 Juni 2026</span> &nbsp;·&nbsp;
                <%= t('tos.applies_to') %> <span><%- locals.botNavName || 'Bot' %></span>
            </div>
        </div>

        <div class="legal-notice">
            <%= t('tos.notice') %>
        </div>

        <div class="legal-section" id="s1">
            <h2><span class="sec-num">1</span> <%= t('tos.s1_title') %></h2>
            <p><%= t('tos.s1_p1', { name: locals.botNavName || 'Bot' }) %></p>
            <p><%= t('tos.s1_p2') %></p>
        </div>

        <div class="legal-section" id="s2">
            <h2><span class="sec-num">2</span> <%= t('tos.s2_title') %></h2>
            <p><%= t('tos.s2_p1', { name: locals.botNavName || 'Bot' }) %></p>
            <ul>
                <li><%= t('tos.s2_li1') %></li>
                <li><%= t('tos.s2_li2') %></li>
                <li><%= t('tos.s2_li3') %></li>
                <li><%= t('tos.s2_li4') %></li>
            </ul>
            <p><%= t('tos.s2_p2') %></p>
        </div>

        <div class="legal-section" id="s3">
            <h2><span class="sec-num">3</span> <%= t('tos.s3_title') %></h2>
            <p><%= t('tos.s3_p1') %></p>
            <ul>
                <li><%- t('tos.s3_li1') %></li>
                <li><%= t('tos.s3_li2') %></li>
                <li><%= t('tos.s3_li3') %></li>
                <li><%= t('tos.s3_li4') %></li>
            </ul>
        </div>

        <div class="legal-section" id="s4">
            <h2><span class="sec-num">4</span> <%= t('tos.s4_title') %></h2>
            <p><%= t('tos.s4_p1') %></p>
            <ul>
                <li><%= t('tos.s4_li1') %></li>
                <li><%= t('tos.s4_li2') %></li>
                <li><%= t('tos.s4_li3') %></li>
                <li><%= t('tos.s4_li4') %></li>
                <li><%= t('tos.s4_li5') %></li>
            </ul>
        </div>

        <div class="legal-section" id="s5">
            <h2><span class="sec-num">5</span> <%= t('tos.s5_title') %></h2>
            <p><%= t('tos.s5_p1') %></p>
            <ul>
                <li><%= t('tos.s5_li1') %></li>
                <li><%= t('tos.s5_li2') %></li>
                <li><%= t('tos.s5_li3') %></li>
            </ul>
            <p><%= t('tos.s5_p2') %></p>
        </div>

        <div class="legal-section" id="s6">
            <h2><span class="sec-num">6</span> <%= t('tos.s6_title') %></h2>
            <p><%= t('tos.s6_p1') %></p>
            <ul>
                <li><%= t('tos.s6_li1') %></li>
                <li><%= t('tos.s6_li2') %></li>
                <li><%= t('tos.s6_li3') %></li>
                <li><%= t('tos.s6_li4') %></li>
            </ul>
        </div>

        <div class="legal-section" id="s7">
            <h2><span class="sec-num">7</span> <%= t('tos.s7_title') %></h2>
            <p><%= t('tos.s7_p1', { name: locals.botNavName || 'Bot' }) %></p>
            <ul>
                <li><%= t('tos.s7_li1') %></li>
                <li><%= t('tos.s7_li2') %></li>
            </ul>
            <p><%= t('tos.s7_p2') %></p>
