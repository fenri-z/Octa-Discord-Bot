<style>
.booster-editor-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 900px) {
    .booster-editor-layout { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
    .settings-card [style*="grid-template-columns"] { grid-template-columns: 1fr !important; }
}
</style>

<script>
const GUILD_ID = '<%= guild.id %>';
const CHANNELS = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;
const ROLES = <%- JSON.stringify(Object.fromEntries((locals.roles||[]).map(r=>[r.id,{name:r.name,color:r.color}]))) %>;

const I18N_BOOST_FIELD_MBR   = '<%= t("booster.field_member") %>';
const I18N_BOOST_FIELD_TOT   = '<%= t("booster.field_total_boost") %>';
const I18N_BOOST_FIELD_LVL   = '<%= t("booster.field_level_server") %>';
const I18N_BOOST_LEFT_BG     = '<%= t("booster.card_left_bg") %>';
const I18N_BOOST_BG_COLOR    = '<%= t("booster.card_bg_color") %>';
const I18N_BOOST_PH_MENTION  = '<%= t("booster.ph_mention") %>';
const I18N_BOOST_PH_USERNAME = '<%= t("booster.ph_username") %>';
const I18N_BOOST_PH_TAG      = '<%= t("booster.ph_tag") %>';
const I18N_BOOST_PH_SERVER   = '<%= t("booster.ph_server") %>';
const I18N_BOOST_PH_BOOSTS   = '<%= t("booster.ph_boosts") %>';
const I18N_BOOST_PH_LEVEL    = '<%= t("booster.ph_level") %>';
const I18N_BOOST_ERR_NO_CH   = '<%= t("booster.err_no_channel") %>';
const I18N_BOOST_ERR_CLR     = '<%= t("booster.err_invalid_color", { example: "#ED4245" }) %>';

const SAMPLE = {
    member:    '@<%= loginUser ? loginUser.displayName.replace(/'/g,"") : "BoostUser" %>',
    username:  '<%= loginUser ? loginUser.username.replace(/'/g,"") : "BoostUser" %>',
    tag:       '<%= loginUser ? loginUser.username.replace(/'/g,"") : "BoostUser" %>#0',
    server:    '<%- guild.name.replace(/'/g,"\\'") %>',
    boosts:    '<%= guild.premiumSubscriptionCount ?? 0 %>',
    level:     '<%= guild.premiumTier %>',
    avatarUrl: '<%- loginUser ? loginUser.avatarUrl : "https://cdn.discordapp.com/embed/avatars/0.png" %>',
};

// ── Toggle tipe pesan ──────────────────────────────────────────────────────
function toggleUnboostType() {
    const isPlain = (document.getElementById('unboostMessageType')?.value || 'plain') === 'plain';
    document.getElementById('unboostPlainPanel').style.display = isPlain ? 'block' : 'none';
    document.getElementById('unboostEmbedPanel').style.display = isPlain ? 'none'  : 'block';
    if (isPlain) mbResizeArea(document.getElementById('unboostPlainText'));
    updateUnboostPreview();
    drawUnboostCard();
}
document.getElementById('unboostMessageType')?.addEventListener('change', toggleUnboostType);

// ── Custom Discord emoji dalam preview ────────────────────────────────────
function resolveEmoji(html) {
    if (!html) return '';
    return html
        .replace(/&lt;a:(\w+):(\d+)&gt;/g, (_, name, id) => `<img src="https://cdn.discordapp.com/emojis/${id}.gif" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`)
        .replace(/&lt;:(\w+):(\d+)&gt;/g,  (_, name, id) => `<img src="https://cdn.discordapp.com/emojis/${id}.webp" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`);
}

// ── Markdown → HTML ────────────────────────────────────────────────────────
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function mdToHtml(text) {
    if (!text) return '';
    function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function inline(s) {
        return s
            .replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,'<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
            .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
            .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
            .replace(/\*(.+?)\*/g,'<em>$1</em>')
            .replace(/__(.+?)__/g,'<u>$1</u>')
            .replace(/~~(.+?)~~/g,'<s>$1</s>')
            .replace(/(href="[^"]*")|((https?:\/\/[^\s<>"']+))/g,(m,h,_,u)=>{ if(h) return m; const c=u.replace(/[.,;:!?)\]>]+$/,''); return `<a href="${c}" target="_blank" rel="noopener noreferrer">${c}</a>`; });
    }
    const lines = text.split('\n'), out = [];
    for (const raw of lines) out.push(inline(esc(raw)));
    let result = '';
    for (let j = 0; j < out.length; j++) {
        if (j > 0) result += '<br>';
        result += out[j];
    }
    return result;
}

function mbadge(color, text) { return `<span style="color:${color};background:rgba(88,101,242,.15);border-radius:3px;padding:0 2px;font-weight:600;">${text}</span>`; }
function resolvePh(text) {
    if (!text) return '';
    let html = text
        .replace(/\{member\}/g,   `<span style="color:#7289da;background:rgba(88,101,242,.15);border-radius:3px;padding:0 2px;font-weight:600;">${SAMPLE.member}</span>`)
        .replace(/\{username\}/g, SAMPLE.username)
        .replace(/\{tag\}/g,      SAMPLE.tag)
        .replace(/\{server\}/g,   SAMPLE.server)
        .replace(/\{boosts\}/g,   `<strong>${SAMPLE.boosts}</strong>`)
        .replace(/\{level\}/g,    `<strong>${SAMPLE.level}</strong>`);
    html = html
        .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => { const r = ROLES[id]; return r ? mbadge(r.color, '@'+r.name) : `@unknown`; })
        .replace(/&lt;@!?(\d+)&gt;/g, () => mbadge('#7289da', '@User'))
        .replace(/&lt;#(\d+)&gt;/g, (_, id) => { const n = CHANNELS[id]; return n ? mbadge('#7289da', '#'+n) : '#unknown'; })
        .replace(/@everyone/g, mbadge('#7289da', '@everyone'))
        .replace(/@here/g,     mbadge('#7289da', '@here'));
    return html;
}

// ── Card color sync helpers ────────────────────────────────────────────────
function bcSync(inputId, pickerId) { document.getElementById(inputId).value = document.getElementById(pickerId).value; }
function bcSyncP(inputId, pickerId) { const v = document.getElementById(inputId).value; if (/^#[0-9A-Fa-f]{6}$/.test(v)) document.getElementById(pickerId).value = v; }

// ── Card toggle ────────────────────────────────────────────────────────────
document.getElementById('unboostCardEnabled').addEventListener('change', function() {
    document.getElementById('unboostCardPanel').style.display = this.checked ? 'block' : 'none';
    drawUnboostCard();
});
document.getElementById('unboostCardBgType')?.addEventListener('change', drawUnboostCard);
document.getElementById('unboostCardAvatarShape')?.addEventListener('change', drawUnboostCard);
document.getElementById('unboostCardLayout')?.addEventListener('change', drawUnboostCard);
['unboostCardWelcomeText','unboostCardSubText','unboostCardBgImageUrl'].forEach(id => {
    const el = document.getElementById(id); if (el) el.addEventListener('input', drawUnboostCard);
});
document.getElementById('unboostCardFont')?.addEventListener('change', drawUnboostCard);

// ── Card placement sync ────────────────────────────────────────────────────
function _syncCardPlacement() {
    const enabled  = document.getElementById('unboostCardEnabled')?.checked;
    const wrap     = document.getElementById('unboostCardPreviewWrap');
    const imgEmbed = document.getElementById('unboostCardInEmbed');
    const imgPlain = document.getElementById('unboostCardInPlain');

    if (!enabled) {
        if (wrap)     wrap.style.display     = 'none';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = 'none';
        return;
    }

    const canvas  = document.getElementById('unboostCardCanvas');
    const dataUrl = canvas ? canvas.toDataURL() : '';
    if (imgEmbed && dataUrl) imgEmbed.src = dataUrl;
    if (imgPlain && dataUrl) imgPlain.src = dataUrl;

    const isPlain = (document.getElementById('unboostMessageType')?.value || 'plain') === 'plain';
    if (isPlain) {
        if (wrap)     wrap.style.display     = 'none';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = 'block';
    } else {
        if (wrap)     wrap.style.display     = 'none';
        if (imgEmbed) imgEmbed.style.display = 'block';
        if (imgPlain) imgPlain.style.display = 'none';
    }
}

// ── Canvas card drawing ────────────────────────────────────────────────────
async function drawUnboostCard() {
    const enabled = document.getElementById('unboostCardEnabled').checked;
    if (!enabled) { _syncCardPlacement(); return; }

    const canvas = document.getElementById('unboostCardCanvas');
    const ctx    = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;

    const g = id => document.getElementById('unboostCard' + id);
    const bgType    = document.getElementById('unboostCardBgType')?.value || 'gradient';
    const bg1       = g('BgColor')?.value      || '#1e0a0a';
    const bg2       = g('BgColor2')?.value     || '#2e0a0a';
    const bgImgUrl  = (g('BgImageUrl')?.value  || '').trim();
    const overlayClr= g('OverlayColor')?.value || '#000000';
    const overlayOp = (parseInt(g('OverlayOpacity')?.value || '0')) / 100;
    const accent    = g('AccentColor')?.value  || '#ED4245';
    const titleClr  = g('TitleColor')?.value   || '#ffffff';
    const userClr   = g('UsernameColor')?.value|| accent;
    const msgClr    = g('MsgColor')?.value     || '#cccccc';
    const shape     = document.getElementById('unboostCardAvatarShape')?.value || 'circle';
    const fontSel   = g('Font')?.value         || 'poppins';
    const fontMap   = { impact:"Impact,'Arial Black',sans-serif", arial:'Arial,Helvetica,sans-serif', georgia:"Georgia,'Times New Roman',serif", courier:"'Courier New',Courier,monospace", verdana:'Verdana,Geneva,sans-serif', discord:"'GG Sans',Whitney,Inter,'Noto Sans','Helvetica Neue',Arial,sans-serif", bebasnew:"'Bebas Neue',Impact,sans-serif", montserrat:"'Montserrat',Arial,sans-serif", poppins:"'Poppins',Arial,sans-serif", oswald:"'Oswald',Arial,sans-serif", orbitron:"'Orbitron',Arial,sans-serif", russoone:"'Russo One',Impact,sans-serif", exo2:"'Exo 2',Arial,sans-serif", rajdhani:"'Rajdhani',Arial,sans-serif" };
    const fontFam   = fontMap[fontSel] || fontMap.poppins;
    const bigText   = g('WelcomeText')?.value  || 'UNBOOST';
    const sub       = (g('SubText')?.value ?? '')
                        .replace(/{server}/gi, SAMPLE.server)
                        .replace(/{boosts}/gi, SAMPLE.boosts)
                        .replace(/{level}/gi,  SAMPLE.level);

    const gradPanel = document.getElementById('unboostCardBgGradientPanel');
    const imgPanel  = document.getElementById('unboostCardBgImagePanel');
    const col2Grp   = document.getElementById('unboostCardBgColor2Group');
    const lbl       = document.getElementById('unboostCardBgColor1Label');
    const hasBgClr  = bgType !== 'image' && bgType !== 'transparent';
    if (gradPanel) gradPanel.style.display = hasBgClr ? 'grid' : 'none';
    if (imgPanel)  imgPanel.style.display  = bgType === 'image' ? 'block' : 'none';
    if (col2Grp)   col2Grp.style.display   = bgType === 'gradient' ? 'block' : 'none';
    if (lbl)       lbl.textContent         = bgType === 'gradient' ? I18N_BOOST_LEFT_BG : I18N_BOOST_BG_COLOR;

    ctx.clearRect(0, 0, W, H);
    function rr(x,y,w,h,r){ ctx.beginPath(); ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r); ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h); ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r); ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath(); }

    if (bgType === 'transparent') {
        // Biarkan canvas benar-benar transparan
    } else if (bgType === 'image' && bgImgUrl) {
        const proxyUrl = `/api/guild/${GUILD_ID}/image-proxy?url=` + encodeURIComponent(bgImgUrl);
        try {
            await new Promise((res,rej) => { const img=new Image(); img.onload=()=>{ctx.save();rr(0,0,W,H,16);ctx.clip();const sc=Math.max(W/img.width,H/img.height);ctx.drawImage(img,(W-img.width*sc)/2,(H-img.height*sc)/2,img.width*sc,img.height*sc);ctx.restore();res();};img.onerror=rej;img.src=proxyUrl;});
        } catch { rr(0,0,W,H,16);const gd=ctx.createLinearGradient(0,0,W,H);gd.addColorStop(0,bg1);gd.addColorStop(1,bg2);ctx.fillStyle=gd;ctx.fill();}
    } else if (bgType === 'solid') { rr(0,0,W,H,16); ctx.fillStyle=bg1; ctx.fill();
    } else { rr(0,0,W,H,16);const gd=ctx.createLinearGradient(0,0,W,H);gd.addColorStop(0,bg1);gd.addColorStop(1,bg2);ctx.fillStyle=gd;ctx.fill(); }

    if (overlayOp>0){ctx.save();rr(0,0,W,H,16);ctx.clip();ctx.globalAlpha=overlayOp;ctx.fillStyle=overlayClr;ctx.fillRect(0,0,W,H);ctx.globalAlpha=1;ctx.restore();}

    // ── Layout params ─────────────────────────────────────────────────────
    const _layout = document.getElementById('unboostCardLayout')?.value || 'classic';
    const isClassic = _layout !== 'left' && _layout !== 'right';
    const isRight   = _layout === 'right';
    const AS = isClassic ? Math.round(185*W/900) : Math.round(195*W/900);
    const BD = isClassic ? Math.round(8*W/900)   : Math.round(6*W/900);
    const BT = AS + BD*2;
    const avL = isClassic ? Math.round((W-BT)/2) : isRight ? W-BT-Math.round(65*W/900) : Math.round(65*W/900);
    const avT = isClassic ? 25 : Math.round((H-BT)/2);
    const isSquare = shape==='square';

    if (bgType !== 'transparent') {
        ctx.globalAlpha=0.07;ctx.fillStyle=accent;
        if (isClassic) {
            ctx.beginPath();ctx.arc(80,80,120,0,Math.PI*2);ctx.fill();
            ctx.beginPath();ctx.arc(W-80,H-80,100,0,Math.PI*2);ctx.fill();
        } else if (isRight) {
            ctx.beginPath();ctx.arc(60,40,80,0,Math.PI*2);ctx.fill();
            ctx.beginPath();ctx.arc(20,H-20,60,0,Math.PI*2);ctx.fill();
        } else {
            ctx.beginPath();ctx.arc(W-60,40,80,0,Math.PI*2);ctx.fill();
            ctx.beginPath();ctx.arc(W-20,H-20,60,0,Math.PI*2);ctx.fill();
        }
        ctx.globalAlpha=1;
    }

    ctx.fillStyle=accent;
    if(isSquare){rr(avL,avT,BT,BT,isClassic?20:14);ctx.fill();}
    else{ctx.beginPath();ctx.arc(avL+BT/2,avT+BT/2,BT/2,0,Math.PI*2);ctx.fill();}

    const avatarProxyUrl = `/api/guild/${GUILD_ID}/image-proxy?url=` + encodeURIComponent(SAMPLE.avatarUrl);
    await new Promise(res => {
        const avImg=new Image();
        avImg.onload=()=>{ctx.save();if(isSquare){rr(avL+BD,avT+BD,AS,AS,isClassic?16:10);ctx.clip();}else{ctx.beginPath();ctx.arc(avL+BD+AS/2,avT+BD+AS/2,AS/2,0,Math.PI*2);ctx.clip();}ctx.drawImage(avImg,avL+BD,avT+BD,AS,AS);ctx.restore();res();};
        avImg.onerror=()=>{ctx.fillStyle='#5a6070';if(isSquare){rr(avL+BD,avT+BD,AS,AS,isClassic?16:10);ctx.fill();}else{ctx.beginPath();ctx.arc(avL+BD+AS/2,avT+BD+AS/2,AS/2,0,Math.PI*2);ctx.fill();}const cx=avL+BD+AS/2,cy=avT+BD+AS/2;ctx.fillStyle='#8892a4';ctx.beginPath();ctx.arc(cx,cy-AS*0.14,AS*0.18,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.ellipse(cx,cy+AS*0.28,AS*0.28,AS*0.22,0,0,Math.PI*2);ctx.fill();res();};
        avImg.src=avatarProxyUrl;
    });

    if (isClassic) {
        const CX=W/2,TITLE_Y=327,USER_Y=377,SUB_Y=418,TEXT_W=W-Math.round(120*W/900);
        let titleFs=72;ctx.font=`bold ${titleFs}px ${fontFam}`;
        while(titleFs>14&&ctx.measureText(bigText).width>TEXT_W){titleFs-=2;ctx.font=`bold ${titleFs}px ${fontFam}`;}
        const titleLs=titleFs<52?0:4; if('letterSpacing' in ctx) ctx.letterSpacing=titleLs+'px';
        ctx.textAlign='center';ctx.fillStyle=titleClr;ctx.globalAlpha=0.3;
        ctx.fillText(bigText,CX,TITLE_Y,TEXT_W);ctx.globalAlpha=1;ctx.fillText(bigText,CX,TITLE_Y,TEXT_W);
        if('letterSpacing' in ctx) ctx.letterSpacing='0px';
        ctx.font=`700 32px ${fontFam}`;ctx.fillStyle='rgba(0,0,0,0.55)';
        ctx.fillText(SAMPLE.username,CX,USER_Y+2,TEXT_W);ctx.fillStyle=userClr;
        ctx.fillText(SAMPLE.username,CX,USER_Y,TEXT_W);
        ctx.font=`600 20px ${fontFam}`;ctx.fillStyle=msgClr;
        ctx.fillText(sub,CX,SUB_Y,TEXT_W);ctx.textAlign='left';
    } else if (isRight) {
        const TX=Math.round(40*W/900),availW=avL-Math.round(50*W/900)-TX;
        const TITLE_Y=207,USER_Y=258,SUB_Y=300;
        let titleFs=84;ctx.font=`bold ${titleFs}px ${fontFam}`;
        while(titleFs>14&&ctx.measureText(bigText).width>availW){titleFs-=2;ctx.font=`bold ${titleFs}px ${fontFam}`;}
        const titleLsR=titleFs<52?0:3; if('letterSpacing' in ctx) ctx.letterSpacing=titleLsR+'px';
        ctx.fillStyle=titleClr;ctx.globalAlpha=0.35;ctx.fillText(bigText,TX,TITLE_Y,availW);
        ctx.globalAlpha=1;ctx.fillText(bigText,TX,TITLE_Y,availW);
        if('letterSpacing' in ctx) ctx.letterSpacing='0px';
        ctx.font=`700 34px ${fontFam}`;ctx.fillStyle='rgba(0,0,0,0.6)';
        ctx.fillText(SAMPLE.username,TX,USER_Y+2,availW);ctx.fillStyle=userClr;
        ctx.fillText(SAMPLE.username,TX,USER_Y,availW);
        ctx.font=`600 26px ${fontFam}`;ctx.fillStyle=msgClr;
        ctx.fillText(sub,TX,SUB_Y,availW);
    } else {
        const TX=avL+BT+Math.round(50*W/900),availW=W-TX-40;
        const TITLE_Y=207,USER_Y=258,SUB_Y=300;
        let titleFs=84;ctx.font=`bold ${titleFs}px ${fontFam}`;
        while(titleFs>14&&ctx.measureText(bigText).width>availW){titleFs-=2;ctx.font=`bold ${titleFs}px ${fontFam}`;}
        const titleLsC=titleFs<52?0:3; if('letterSpacing' in ctx) ctx.letterSpacing=titleLsC+'px';
        ctx.fillStyle=titleClr;ctx.globalAlpha=0.35;ctx.fillText(bigText,TX,TITLE_Y,availW);
        ctx.globalAlpha=1;ctx.fillText(bigText,TX,TITLE_Y,availW);
        if('letterSpacing' in ctx) ctx.letterSpacing='0px';
        ctx.font=`700 34px ${fontFam}`;ctx.fillStyle='rgba(0,0,0,0.6)';
        ctx.fillText(SAMPLE.username,TX,USER_Y+2,availW);ctx.fillStyle=userClr;
        ctx.fillText(SAMPLE.username,TX,USER_Y,availW);
        ctx.font=`600 26px ${fontFam}`;ctx.fillStyle=msgClr;
        ctx.fillText(sub,TX,SUB_Y,availW);
    }
    _syncCardPlacement();
}

// ── Field sample data ──────────────────────────────────────────────────────
const UNBOOST_FIELDS = [
    { id: 'unboostShowMember',      name: I18N_BOOST_FIELD_MBR, value: () => SAMPLE.username },
    { id: 'unboostShowTotalBoost',  name: I18N_BOOST_FIELD_TOT, value: () => `${SAMPLE.boosts} boost` },
    { id: 'unboostShowLevelServer', name: I18N_BOOST_FIELD_LVL, value: () => `Level <%= guild.premiumTier %>` },
];

function renderFields(fieldDefs, containerId) {
    const el = document.getElementById(containerId);
    const active = fieldDefs.filter(f => document.getElementById(f.id)?.checked);
    if (!active.length) { el.innerHTML = ''; return; }
    el.innerHTML = active.map(f =>
        `<div><div class="dc-field-name">${f.name}</div><div class="dc-field-value">${f.value()}</div></div>`
    ).join('');
}

// ── Preview ────────────────────────────────────────────────────────────────
function updateUnboostPreview() {
    const isPlain = (document.getElementById('unboostMessageType')?.value || 'plain') === 'plain';
    const plainEl = document.getElementById('unboostPreviewPlain');
    const embedEl = document.getElementById('unboostPreviewEmbed');
    const chanId  = document.getElementById('unboostChannel').value;
    document.getElementById('unboostPrevChannel').textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : 'pilih-channel';

    if (isPlain) {
        const html = resolveEmoji(resolvePh(mdToHtml(document.getElementById('unboostPlainText').value)));
        plainEl.innerHTML     = html;
        plainEl.style.display = html.trim() ? 'block' : 'none';
        embedEl.style.display = 'none';
    } else {
        plainEl.style.display = 'none';
        const color = document.getElementById('unboostColor').value || '#ED4245';
        document.getElementById('unboostPreviewPill').style.background  = color;
        document.getElementById('unboostPreviewTitle').innerHTML = resolvePh(esc(document.getElementById('unboostTitle').value)).replace(/(https?:\/\/[^\s<>"']+)/g, u => { const c=u.replace(/[.,;:!?)\]>]+$/,''); return `<a href="${c}" target="_blank" rel="noopener noreferrer">${c}</a>`; });
        document.getElementById('unboostPreviewDesc').innerHTML  = resolveEmoji(resolvePh(mdToHtml(document.getElementById('unboostDesc').value)));
        renderFields(UNBOOST_FIELDS, 'unboostPreviewFields');
        const footer = document.getElementById('unboostFooter').value.trim();
        document.getElementById('unboostPreviewFooter').innerHTML = footer ? resolveEmoji(resolvePh(mdToHtml(footer))) : '';
        const hasTitle   = document.getElementById('unboostTitle').value.trim();
        const hasDesc    = document.getElementById('unboostDesc').value.trim();
        const hasField   = UNBOOST_FIELDS.some(f => document.getElementById(f.id)?.checked);
        const cardActive = document.getElementById('unboostCardEnabled').checked;
        embedEl.style.display = (hasTitle || hasDesc || hasField || cardActive) ? 'flex' : 'none';
        const thumbEl = document.getElementById('unboostPreviewThumb');
        if (thumbEl) thumbEl.style.display = document.getElementById('unboostShowThumbnail').checked ? 'block' : 'none';
    }
    _syncCardPlacement();
}

document.getElementById('unboostChannel').addEventListener('change', updateUnboostPreview);

// ── Color sync ─────────────────────────────────────────────────────────────
function syncHex(inputId, pickerId) { document.getElementById(inputId).value = document.getElementById(pickerId).value; }
function syncPicker(inputId, pickerId) {
    const val = document.getElementById(inputId).value;
    if (/^#[0-9A-Fa-f]{6}$/.test(val)) document.getElementById(pickerId).value = val;
}

// ── Placeholder picker ─────────────────────────────────────────────────────
const PLACEHOLDERS = [
    ['{member}',   I18N_BOOST_PH_MENTION],
    ['{username}', I18N_BOOST_PH_USERNAME],
    ['{tag}',      I18N_BOOST_PH_TAG],
    ['{server}',   I18N_BOOST_PH_SERVER],
    ['{boosts}',   I18N_BOOST_PH_BOOSTS],
    ['{level}',    I18N_BOOST_PH_LEVEL],
];

let unboostLastFocused = 'unboostTitle';
['unboostTitle','unboostDesc','unboostFooter'].forEach(id => {
    document.getElementById(id)?.addEventListener('focus', () => unboostLastFocused = id);
});

function buildEmbedPicker(pickerId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) =>
        `<button type="button" class="ph-item" onclick="insertPhDyn('${ph}')"><code>${ph}</code><span>${desc}</span></button>`
    ).join('');
}

function buildPlainPicker(pickerId, targetId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) =>
        `<button type="button" class="ph-item" onclick="insertPh('${targetId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
    ).join('');
}

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});

function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

function insertPhDyn(ph) { insertPh(unboostLastFocused, ph); }

// ── Save ───────────────────────────────────────────────────────────────────
async function saveUnboost() {
    if (!document.getElementById('unboostChannel').value)
        return showAlert(I18N_BOOST_ERR_NO_CH);
    const messageType = document.getElementById('unboostMessageType')?.value || 'plain';
    const color       = document.getElementById('unboostColor').value.trim() || '#ED4245';
    if (messageType === 'embed' && !/^#[0-9A-Fa-f]{6}$/.test(color))
        return showAlert(I18N_BOOST_ERR_CLR);

    const res = await fetch(`/api/guild/${GUILD_ID}/booster-unboost`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            enabled:         document.getElementById('unboostEnabled').checked,
            channelId:       document.getElementById('unboostChannel').value,
            messageType,
            plainText:       document.getElementById('unboostPlainText').value.trim(),
            title:           document.getElementById('unboostTitle').value.trim(),
            description:     document.getElementById('unboostDesc').value.trim(),
            footerText:      document.getElementById('unboostFooter').value.trim(),
            color,
            showMember:      document.getElementById('unboostShowMember').checked,
            showTotalBoost:  document.getElementById('unboostShowTotalBoost').checked,
            showLevelServer: document.getElementById('unboostShowLevelServer').checked,
            showThumbnail:   document.getElementById('unboostShowThumbnail').checked,
            cardEnabled:        document.getElementById('unboostCardEnabled').checked,
            cardWelcomeText:    document.getElementById('unboostCardWelcomeText').value.trim()    || 'UNBOOST',
            cardSubText:        document.getElementById('unboostCardSubText').value.trim(),
            cardBgColor:        document.getElementById('unboostCardBgColor').value.trim()        || '#1e0a0a',
            cardBgColor2:       document.getElementById('unboostCardBgColor2').value.trim()       || '#2e0a0a',
            cardAccentColor:    document.getElementById('unboostCardAccentColor').value.trim()    || '#ED4245',
            cardAvatarShape:    document.getElementById('unboostCardAvatarShape')?.value || 'circle',
            cardLayout:         document.getElementById('unboostCardLayout')?.value || 'classic',
            cardBgType:         document.getElementById('unboostCardBgType')?.value      || 'gradient',
            cardBgImageUrl:     document.getElementById('unboostCardBgImageUrl')?.value.trim()    || '',
            cardOverlayColor:   document.getElementById('unboostCardOverlayColor')?.value.trim()  || '#000000',
            cardOverlayOpacity: parseInt(document.getElementById('unboostCardOverlayOpacity')?.value || '0'),
            cardTitleColor:     document.getElementById('unboostCardTitleColor')?.value.trim()    || '#ffffff',
            cardUsernameColor:  document.getElementById('unboostCardUsernameColor')?.value.trim() || '#ED4245',
            cardMsgColor:       document.getElementById('unboostCardMsgColor')?.value.trim()      || '#cccccc',
            cardFont:           document.getElementById('unboostCardFont')?.value                 || 'poppins',
        })
    });
    const data = await res.json();
    if (data.success) showToast(data.message, 'success');
    else showAlert(data.message);
}

function _buildMentionDd(dd, getTarget) {
    function item(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => {
            const ta = typeof getTarget === 'function' ? getTarget() : getTarget;
            if (!ta) return;
            const s = ta.selectionStart ?? ta.value.length;
            const ep = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, s) + mention + ta.value.slice(ep);
            ta.selectionStart = ta.selectionEnd = s + mention.length;
            ta.focus(); ta.dispatchEvent(new Event('input', {bubbles: true}));
            document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
            document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
        });
        return b;
    }
    function hdr(t) { const h = document.createElement('div'); h.className = 'ph-group-label'; h.textContent = t; return h; }
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => { el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special'));
    dd.appendChild(item('<code>@everyone</code>', '@everyone'));
    dd.appendChild(item('<code>@here</code>', '@here'));
    const rKeys = Object.keys(ROLES);
    if (rKeys.length) {
        dd.appendChild(hdr('Roles'));
        rKeys.forEach(id => { const r = ROLES[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`)); });
    }
    const cKeys = Object.keys(CHANNELS);
    if (cKeys.length) {
        dd.appendChild(hdr('Channels'));
        cKeys.forEach(id => { const name = CHANNELS[id]; dd.appendChild(item(`<span>#${name}</span>`, `<#${id}>`)); });
    }
}

// ── Init ───────────────────────────────────────────────────────────────────
buildEmbedPicker('unboostEmbedPicker');
buildPlainPicker('unboostPlainPicker', 'unboostPlainText');
_buildMentionDd(document.getElementById('unboostEmbedMentionPicker'), () => document.getElementById(unboostLastFocused));
_buildMentionDd(document.getElementById('unboostPlainMentionPicker'), () => document.getElementById('unboostPlainText'));

if (document.getElementById('unboostCardEnabled').checked)
    document.getElementById('unboostCardPanel').style.display = 'block';

drawUnboostCard().then(() => toggleUnboostType());

function mbResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    el.style.height = el.scrollHeight + 'px';
}
function mbUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
function mbInlineCount(inputId, countId) {
    const el = document.getElementById(inputId);
    const ct = document.getElementById(countId);
    if (!el || !ct) return;
    const len = el.value.length;
    const max = parseInt(el.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'input-inline-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
document.addEventListener('DOMContentLoaded', () => {
    toggleUnboostType();
    document.querySelectorAll('.mb-auto-resize').forEach(mbResizeArea);
    mbUpdateCount('unboostPlainText',        'unboostPlainCount');
    mbInlineCount('unboostTitle',            'unboostTitleCount');
    mbUpdateCount('unboostDesc',             'unboostDescCount');
    mbInlineCount('unboostFooter',           'unboostFooterCount');
    mbInlineCount('unboostCardWelcomeText',  'unboostCardWelcomeTextCount');
    mbInlineCount('unboostCardSubText',      'unboostCardSubTextCount');
    if (window.initFontPicker) initFontPicker(document.getElementById('unboostCardFont-picker'), document.getElementById('unboostCardFont'));
});

window._floatSave = saveUnboost;
</script>

