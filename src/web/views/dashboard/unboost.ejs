<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'unboost' }) %>

    <main class="dash-main" style="max-width:100%;">
        <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1><%= t('booster.tab_unboost_title') %></h1>
            <p><%= t('booster.tab_unboost_desc') %></p>
        </div>

        <div class="booster-guide settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('booster.unboost_how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('booster.unboost_step1_title') %></div>
                    <div class="guide-desc"><%- t('booster.unboost_step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('booster.unboost_step2_title') %></div>
                    <div class="guide-desc"><%- t('booster.unboost_step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('booster.unboost_step3_title') %></div>
                    <div class="guide-desc"><%- t('booster.unboost_step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('booster.unboost_tip') %></div>
        </div>

        <div class="booster-editor-layout">

            <!-- Kolom kiri: form -->
            <div class="settings-card" style="margin-bottom:0;">

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="unboostEnabled" class="toggle-input"
                               <%= unboostData.enabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span><%= t('booster.unboost_enable') %></span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.notification_channel') %> <span style="color:#ed4245;">*</span></label>
                    <select id="unboostChannel" class="select">
                        <option value=""><%= t('common.select_channel') %></option>
                        <% (locals.channels || []).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= unboostData.channelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.message_type') %></label>
                    <select id="unboostMessageType" class="select" style="font-size:.82rem;">
                        <option value="plain" <%= (unboostData.messageType||'plain')==='plain'?'selected':'' %>><%= t('common.plain_text') %></option>
                        <option value="embed" <%= (unboostData.messageType||'plain')==='embed'?'selected':'' %>><%= t('common.embed') %></option>
                    </select>
                </div>

                <!-- Panel Teks Biasa -->
                <div id="unboostPlainPanel" class="form-group" style="display:none;">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;"><%= t('common.plain_text_message') %></label>
                        <div class="ph-btn-group">
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('unboostPlainPicker',event)"><%= t('booster.placeholder_btn') %></button>
                                <div class="ph-dropdown" id="unboostPlainPicker" style="display:none;"></div>
                            </div>
                            <div class="ph-picker-anchor mention-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('unboostPlainMentionPicker',event)">@ Mention</button>
                                <div class="ph-dropdown mention-dd" id="unboostPlainMentionPicker" style="display:none;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-count-wrap">
                        <textarea id="unboostPlainText" class="textarea mb-auto-resize" rows="4"
                                  maxlength="2000"
                                  placeholder="💔 {member} has stopped boosting **{server}**. Total boosts: **{boosts}**."
                                  oninput="mbResizeArea(this);mbUpdateCount('unboostPlainText','unboostPlainCount');updateUnboostPreview()"><%= unboostData.plainText %></textarea>
                        <div class="mb-char-count" id="unboostPlainCount">0 / 2000</div>
                    </div>
                </div>

                <!-- Panel Embed -->
                <div id="unboostEmbedPanel">

                    <div class="form-group">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('common.embed_title') %></label>
                            <div class="ph-btn-group">
                                <div class="ph-picker-anchor">
                                    <button type="button" class="ph-toggle-btn" onclick="togglePicker('unboostEmbedPicker',event)"><%= t('booster.placeholder_btn') %></button>
                                    <div class="ph-dropdown" id="unboostEmbedPicker" style="display:none;"></div>
                                </div>
                                <div class="ph-picker-anchor mention-anchor">
                                    <button type="button" class="ph-toggle-btn" onclick="togglePicker('unboostEmbedMentionPicker',event)">@ Mention</button>
                                    <div class="ph-dropdown mention-dd" id="unboostEmbedMentionPicker" style="display:none;"></div>
                                </div>
                            </div>
                        </div>
                        <div class="input-count-wrap">
                            <input type="text" id="unboostTitle" class="input"
                                   placeholder="💔 Boost Ended"
                                   maxlength="256"
                                   value="<%= unboostData.title %>"
                                   oninput="mbInlineCount('unboostTitle','unboostTitleCount');updateUnboostPreview()">
                            <span class="input-inline-count" id="unboostTitleCount">0 / 256</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label"><%= t('common.embed_description') %></label>
                        <div class="mb-count-wrap">
                            <textarea id="unboostDesc" class="textarea mb-auto-resize" rows="4"
                                      maxlength="3500"
                                      placeholder="{member} has removed their boost from the server."
                                      oninput="mbResizeArea(this);mbUpdateCount('unboostDesc','unboostDescCount');updateUnboostPreview()"><%= unboostData.description %></textarea>
                            <div class="mb-char-count" id="unboostDescCount">0 / 3500</div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label"><%= t('common.embed_color') %></label>
                        <div style="display:flex;gap:.75rem;align-items:center;">
                            <input type="color" id="unboostColorPicker" value="<%= unboostData.color || '#ED4245' %>"
                                   style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                                   oninput="syncHex('unboostColor','unboostColorPicker');updateUnboostPreview()">
                            <input type="text" id="unboostColor" class="input" style="max-width:130px;"
                                   placeholder="#ED4245" maxlength="7"
                                   value="<%= unboostData.color || '#ED4245' %>"
                                   oninput="syncPicker('unboostColor','unboostColorPicker');updateUnboostPreview()">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label"><%= t('booster.footer_label') %> <span style="font-weight:400;color:var(--text-muted)"><%= t('booster.footer_optional') %></span></label>
                        <div class="input-count-wrap">
                            <input type="text" id="unboostFooter" class="input"
                                   placeholder="<%= t('booster.footer_placeholder') %>"
                                   maxlength="2048"
                                   value="<%= unboostData.footerText || '' %>"
                                   oninput="mbInlineCount('unboostFooter','unboostFooterCount');updateUnboostPreview()">
                            <span class="input-inline-count" id="unboostFooterCount">0 / 2048</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="unboostShowThumbnail" class="toggle-input"
                                   <%= unboostData.showThumbnail !== false ? 'checked' : '' %> onchange="updateUnboostPreview()">
                            <span class="toggle-slider"></span>
                            <span><%= t('booster.show_thumbnail') %></span>
                        </label>
                    </div>

                    <div class="form-group" style="border-top:1px solid var(--border);padding-top:1rem;margin-top:.5rem;">
                        <label class="label" style="margin-bottom:.75rem;"><%= t('booster.field_info') %></label>
                        <div style="display:flex;flex-direction:column;gap:.6rem;">
                            <label class="toggle-label">
                                <input type="checkbox" id="unboostShowMember" class="toggle-input"
                                       <%= unboostData.showMember ? 'checked' : '' %> onchange="updateUnboostPreview()">
                                <span class="toggle-slider"></span><span><%= t('booster.field_member') %></span>
                            </label>
                            <label class="toggle-label">
                                <input type="checkbox" id="unboostShowTotalBoost" class="toggle-input"
                                       <%= unboostData.showTotalBoost ? 'checked' : '' %> onchange="updateUnboostPreview()">
                                <span class="toggle-slider"></span><span><%= t('booster.field_total_boost') %></span>
                            </label>
                            <label class="toggle-label">
                                <input type="checkbox" id="unboostShowLevelServer" class="toggle-input"
                                       <%= unboostData.showLevelServer ? 'checked' : '' %> onchange="updateUnboostPreview()">
                                <span class="toggle-slider"></span><span><%= t('booster.field_level_server') %></span>
                            </label>
                        </div>
                    </div>
                </div><!-- /unboostEmbedPanel -->

                <!-- ── Unboost Card ── -->
                <div class="form-group" style="margin-top:1.5rem;border-top:1px solid var(--border);padding-top:1.25rem;">
                    <label class="label" style="margin-bottom:.75rem;"><%= t('booster.unboost_card_label') %></label>
                    <label class="toggle-label">
                        <input type="checkbox" id="unboostCardEnabled" class="toggle-input"
                               <%= unboostData.cardEnabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span><%= t('booster.send_unboost_card') %></span>
                    </label>
                </div>
                <div id="unboostCardPanel" style="display:none;">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_avatar_shape') %></label>
                            <select id="unboostCardAvatarShape" class="select" style="font-size:.82rem;">
                                <option value="circle" <%= (unboostData.cardAvatarShape||'circle')==='circle'?'selected':'' %>><%= t('booster.card_avatar_circle') %></option>
                                <option value="square" <%= unboostData.cardAvatarShape==='square'?'selected':'' %>><%= t('booster.card_avatar_square') %></option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_font') %></label>
                            <div class="font-picker" id="unboostCardFont-picker">
                                <button type="button" class="font-picker-trigger">
                                    <span class="font-picker-label">Poppins</span>
                                </button>
                                <div class="font-picker-list" hidden>
                                    <% [['poppins','Poppins',"'Poppins',Arial,sans-serif"],['impact','Impact',"Impact,'Arial Black',sans-serif"],['arial','Arial','Arial,Helvetica,sans-serif'],['georgia','Georgia',"Georgia,'Times New Roman',serif"],['courier','Courier New',"'Courier New',Courier,monospace"],['verdana','Verdana','Verdana,Geneva,sans-serif'],['discord','Discord (GG Sans)',"'GG Sans',Whitney,Inter,'Noto Sans','Helvetica Neue',Arial,sans-serif"],['bebasnew','Bebas Neue',"'Bebas Neue',Impact,sans-serif"],['montserrat','Montserrat',"'Montserrat',Arial,sans-serif"],['oswald','Oswald',"'Oswald',Arial,sans-serif"],['orbitron','Orbitron',"'Orbitron',Arial,sans-serif"],['russoone','Russo One',"'Russo One',Impact,sans-serif"],['exo2','Exo 2',"'Exo 2',Arial,sans-serif"],['rajdhani','Rajdhani',"'Rajdhani',Arial,sans-serif"]].forEach(function(f){ %>
                                        <div class="fp-item" data-value="<%= f[0] %>" style="font-family:<%= f[2] %>"><%= f[1] %></div>
                                    <% }); %>
                                </div>
                            </div>
                            <input type="hidden" id="unboostCardFont" value="<%= unboostData.cardFont || 'poppins' %>">
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('card_image.card_layout') %></label>
                            <select id="unboostCardLayout" class="select" style="font-size:.82rem;">
                                <option value="classic" <%= (unboostData.cardLayout||'classic')==='classic'?'selected':'' %>><%= t('card_image.layout_classic') %></option>
                                <option value="left" <%= unboostData.cardLayout==='left'?'selected':'' %>><%= t('card_image.layout_left') %></option>
                                <option value="right" <%= unboostData.cardLayout==='right'?'selected':'' %>><%= t('card_image.layout_right') %></option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_bg_type') %></label>
                            <select id="unboostCardBgType" class="select" style="font-size:.82rem;">
                                <option value="gradient" <%= (unboostData.cardBgType||'gradient')==='gradient'?'selected':'' %>><%= t('booster.card_bg_gradient') %></option>
                                <option value="solid" <%= unboostData.cardBgType==='solid'?'selected':'' %>><%= t('booster.card_bg_solid') %></option>
                                <option value="image" <%= unboostData.cardBgType==='image'?'selected':'' %>><%= t('booster.card_bg_image_url_opt') %></option>
                                <option value="transparent" <%= unboostData.cardBgType==='transparent'?'selected':'' %>><%= t('booster.card_bg_transparent') %></option>
                            </select>
                        </div>
                    </div>
                    <div id="unboostCardBgGradientPanel" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label" id="unboostCardBgColor1Label"><%= t('booster.card_left_bg') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardBgColorPicker" value="<%= unboostData.cardBgColor||'#1e0a0a' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardBgColor','unboostCardBgColorPicker');drawUnboostCard()">
                                <input type="text" id="unboostCardBgColor" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardBgColor||'#1e0a0a' %>" oninput="bcSyncP('unboostCardBgColor','unboostCardBgColorPicker');drawUnboostCard()">
                            </div>
                        </div>
                        <div class="form-group" id="unboostCardBgColor2Group">
                            <label class="label"><%= t('booster.card_right_bg') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardBgColor2Picker" value="<%= unboostData.cardBgColor2||'#2e0a0a' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardBgColor2','unboostCardBgColor2Picker');drawUnboostCard()">
                                <input type="text" id="unboostCardBgColor2" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardBgColor2||'#2e0a0a' %>" oninput="bcSyncP('unboostCardBgColor2','unboostCardBgColor2Picker');drawUnboostCard()">
                            </div>
                        </div>
                    </div>
                    <div id="unboostCardBgImagePanel" style="display:none;" class="form-group">
                        <label class="label"><%= t('booster.card_bg_image_url') %></label>
                        <input type="text" id="unboostCardBgImageUrl" class="input" placeholder="https://..." value="<%= unboostData.cardBgImageUrl||'' %>">
                        <div class="hint" style="margin-top:.3rem;"><%= t('card_image.bg_image_hint') %></div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_overlay_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardOverlayColorPicker" value="<%= unboostData.cardOverlayColor||'#000000' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardOverlayColor','unboostCardOverlayColorPicker');drawUnboostCard()">
                                <input type="text" id="unboostCardOverlayColor" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardOverlayColor||'#000000' %>" oninput="bcSyncP('unboostCardOverlayColor','unboostCardOverlayColorPicker');drawUnboostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label" style="display:flex;justify-content:space-between;"><span><%= t('booster.card_overlay_opacity') %></span><span id="unboostCardOverlayOpacityVal" style="color:var(--text-muted);font-weight:400;"><%= unboostData.cardOverlayOpacity||'0' %>%</span></label>
                            <input type="range" id="unboostCardOverlayOpacity" min="0" max="100" value="<%= unboostData.cardOverlayOpacity||'0' %>" style="width:100%;margin-top:.45rem;accent-color:var(--accent,#5865f2);" oninput="document.getElementById('unboostCardOverlayOpacityVal').textContent=this.value+'%';drawUnboostCard()">
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_title_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardTitleColorPicker" value="<%= unboostData.cardTitleColor||'#ffffff' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardTitleColor','unboostCardTitleColorPicker');drawUnboostCard()">
                                <input type="text" id="unboostCardTitleColor" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardTitleColor||'#ffffff' %>" oninput="bcSyncP('unboostCardTitleColor','unboostCardTitleColorPicker');drawUnboostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_username_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardUsernameColorPicker" value="<%= unboostData.cardUsernameColor||'#ED4245' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardUsernameColor','unboostCardUsernameColorPicker');drawUnboostCard()">
                                <input type="text" id="unboostCardUsernameColor" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardUsernameColor||'#ED4245' %>" oninput="bcSyncP('unboostCardUsernameColor','unboostCardUsernameColorPicker');drawUnboostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_msg_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardMsgColorPicker" value="<%= unboostData.cardMsgColor||'#cccccc' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardMsgColor','unboostCardMsgColorPicker');drawUnboostCard()">
                                <input type="text" id="unboostCardMsgColor" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardMsgColor||'#cccccc' %>" oninput="bcSyncP('unboostCardMsgColor','unboostCardMsgColorPicker');drawUnboostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('booster.card_avatar_border') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="unboostCardAccentPicker" value="<%= unboostData.cardAccentColor||'#ED4245' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('unboostCardAccentColor','unboostCardAccentPicker');drawUnboostCard()">
                                <input type="text" id="unboostCardAccentColor" class="input" style="max-width:110px;" maxlength="7" value="<%= unboostData.cardAccentColor||'#ED4245' %>" oninput="bcSyncP('unboostCardAccentColor','unboostCardAccentPicker');drawUnboostCard()">
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('booster.card_large_text') %></label>
                        <div class="input-count-wrap">
                            <input type="text" id="unboostCardWelcomeText" class="input" maxlength="20" placeholder="UNBOOST" value="<%= unboostData.cardWelcomeText||'UNBOOST' %>"
                                   oninput="mbInlineCount('unboostCardWelcomeText','unboostCardWelcomeTextCount')">
                            <span class="input-inline-count" id="unboostCardWelcomeTextCount">0 / 20</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('booster.card_small_text') %></label>
                        <div class="input-count-wrap">
                            <input type="text" id="unboostCardSubText" class="input" maxlength="60" placeholder="Boost ended..." value="<%= unboostData.cardSubText ?? '' %>"
                                   oninput="mbInlineCount('unboostCardSubText','unboostCardSubTextCount')">
                            <span class="input-inline-count" id="unboostCardSubTextCount">0 / 60</span>
                        </div>
                        <div class="hint" style="margin-top:.3rem;"><code>{server}</code> · <code>{boosts}</code> · <code>{level}</code></div>
                    </div>
                </div>

                <div id="unboostMsg" class="form-message"></div>
            </div>

            <!-- Kolom kanan: preview -->
            <div class="preview-panel">
                <div class="preview-label"><%= t('common.preview') %></div>
                <div class="dc-window">
                    <div class="dc-channel-bar">
                        <span class="dc-channel-hash">#</span>
                        <span id="unboostPrevChannel">pilih-channel</span>
                    </div>
                    <div class="dc-messages">
                        <div id="unboostCardPreviewWrap" style="display:none;padding:.75rem 1rem .25rem;">
                            <canvas id="unboostCardCanvas" width="900" height="450" style="width:100%;border-radius:12px;display:block;"></canvas>
                        </div>
                        <div class="dc-message">
                            <img class="dc-avatar"
                                 src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                 alt="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="dc-msg-body">
                                <span class="dc-username" style="color:<%- botUser ? botUser.roleColor : '#ffffff' %>"><%- botUser ? botUser.username : 'Bot' %></span>
                                <span class="dc-timestamp">Today at 12:00 PM</span>
                                <div id="unboostPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                <img id="unboostCardInPlain" style="display:none;width:100%;max-width:440px;border-radius:8px;margin-top:.4rem;" alt="">
                                <div class="dc-embed" id="unboostPreviewEmbed">
                                    <div class="dc-embed-pill" id="unboostPreviewPill" style="background:#ED4245;"></div>
                                    <div class="dc-embed-body">
                                        <div class="dc-embed-main">
                                            <div class="dc-embed-content">
                                                <div class="dc-embed-title" id="unboostPreviewTitle"></div>
                                                <div class="dc-embed-desc"  id="unboostPreviewDesc"></div>
                                                <div class="dc-embed-fields" id="unboostPreviewFields"></div>
                                            </div>
                                            <div class="dc-embed-thumb" id="unboostPreviewThumb" style="display:none;">
                                                <img id="unboostPreviewThumbImg"
                                                     src="<%- loginUser ? loginUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                                     alt="thumb" style="width:100%;height:100%;object-fit:cover;display:block;"
                                                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                                            </div>
                                        </div>
                                        <img id="unboostCardInEmbed" style="display:none;width:100%;border-radius:4px;margin-top:.4rem;" alt="">
                                        <div class="dc-embed-footer" id="unboostPreviewFooter"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div><!-- /dash-content-wide -->

    <%- include('../partials/dash-footer') %>
    </main>
</div>

