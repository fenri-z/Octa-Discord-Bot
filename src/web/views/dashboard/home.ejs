}
.ov-feat-card:hover .ov-feat-icon { transform: scale(1.1); }
.ov-feat-icon svg { width: 20px; height: 20px; }
.ov-feat-body { flex: 1; min-width: 0; }
.ov-feat-title {
    font-size: .875rem; font-weight: 600;
    margin-bottom: .2rem; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ov-feat-desc {
    font-size: .75rem; color: var(--text-muted); line-height: 1.45;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
}
.ov-feat-arrow {
    width: 16px; height: 16px; flex-shrink: 0;
    color: var(--text-muted); opacity: 0;
    transition: opacity .15s, transform .15s;
}
.ov-feat-card:hover .ov-feat-arrow { opacity: 1; transform: translateX(3px); }
@media(hover:none) { .ov-feat-arrow { opacity: .4; } }

@media(max-width:600px) {
    .ov-banner { padding: 1.25rem; }
    .ov-server-icon, .ov-server-icon-placeholder { width: 48px; height: 48px; border-radius: 12px; }
    .ov-server-name { font-size: 1.2rem; }
    .ov-feat-grid { grid-template-columns: 1fr; }
    .ov-botsettings-grid { grid-template-columns: 1fr; }
}
</style>

<script>
// ── SSE: live guild stats ─────────────────────────────────────────────────────
(function () {
    const guildId = '<%= guild.id %>';
    const bar     = document.getElementById('ov-live-bar');
    const elMembers = document.getElementById('ov-stat-member-count');
    const elPing    = document.getElementById('ov-stat-ping');
    const elTickets = document.getElementById('ov-stat-tickets');

    if (!window.EventSource) return;

    const es = new EventSource(`/api/guild/${guildId}/stats/stream`);

    es.onmessage = function (e) {
        try {
            const d = JSON.parse(e.data);
            if (elMembers && d.memberCount != null) elMembers.textContent = d.memberCount.toLocaleString();
            if (elPing)    elPing.textContent    = d.ping >= 0 ? `${d.ping} ms` : '—';
            if (elTickets) elTickets.textContent = d.activeTickets ?? '—';
            if (bar) bar.style.display = 'flex';
        } catch { /* ignore */ }
    };

    es.onerror = function () {
        if (bar) bar.style.display = 'none';
    };

    window.addEventListener('beforeunload', () => es.close());
})();

const GUILD_ID = '<%= guild.id %>';

const _initNickname = document.getElementById('nicknameInput').value;
const _initPrefix   = document.getElementById('prefixInput').value;

window._floatSave = async function () {
    const nickname = document.getElementById('nicknameInput').value.trim();
    const prefix   = document.getElementById('prefixInput').value.trim() || '!';
    const msg      = document.getElementById('settingsMsg');

    const nickChanged = nickname !== _initNickname.trim();
    const prefChanged = (prefix   !== (_initPrefix.trim() || '!'));

    const tasks = [];
    if (nickChanged) tasks.push(
        fetch(`/api/guild/${GUILD_ID}/nickname`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nickname }),
        }).then(r => r.json()).then(d => ({ key: 'nick', ...d }))
    );
    if (prefChanged) tasks.push(
        fetch(`/api/guild/${GUILD_ID}/prefix`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prefix }),
        }).then(r => r.json()).then(d => ({ key: 'pref', ...d }))
    );

    if (!tasks.length) return;

    const results = await Promise.all(tasks);
    const failed  = results.find(r => !r.success);
    if (failed) {
        showMsg(msg, failed.message, 'error');
    } else {
        showMsg(msg, results[results.length - 1].message, 'success');
    }
};
</script>

