<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'home' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">

        <!-- ── Server Banner ─────────────────────────────────────── -->
        <% const _gBannerURL = guild.bannerURL({ size: 1024, dynamic: true }); %>
        <div class="ov-banner<%- _gBannerURL ? ' ov-banner-img' : '' %>"
             <%- _gBannerURL ? `style="background-image:url('${_gBannerURL}')"` : '' %>>
            <div class="ov-banner-bg"></div>
            <div class="ov-banner-content">
                <% if (guild.iconURL()) { %>
                    <img src="<%= guild.iconURL() %>" alt="<%= guild.name %>" class="ov-server-icon">
                <% } else { %>
                    <div class="ov-server-icon-placeholder"><%= guild.name.charAt(0) %></div>
                <% } %>
                <div class="ov-server-info">
                    <h1 class="ov-server-name"><%= guild.name %></h1>
                    <p class="ov-server-sub"><%= t('home.welcome_sub') %></p>
                </div>
            </div>
        </div>

        <!-- ── Stats Grid ─────────────────────────────────────────── -->
        <div class="ov-stats-grid">
            <div class="ov-stat-card" style="--accent-c:#5865F2;">
                <div class="ov-stat-icon" style="background:rgba(88,101,242,.15);color:#5865F2;">
                    <i data-lucide="users"></i>
                </div>
                <div class="ov-stat-body">
                    <div class="ov-stat-value" id="ov-stat-member-count"><%= guild.memberCount %></div>
                    <div class="ov-stat-label"><%= t('home.total_members') %></div>
                </div>
                <div class="ov-stat-bar"></div>
            </div>
            <div class="ov-stat-card" style="--accent-c:#57F287;">
                <div class="ov-stat-icon" style="background:rgba(87,242,135,.12);color:#57F287;">
                    <i data-lucide="hash"></i>
                </div>
                <div class="ov-stat-body">
                    <div class="ov-stat-value"><%= guild.channels.cache.filter(c => c.type === 0).size %></div>
                    <div class="ov-stat-label"><%= t('home.text_channels') %></div>
                </div>
                <div class="ov-stat-bar"></div>
            </div>
            <div class="ov-stat-card" style="--accent-c:#FEE75C;">
                <div class="ov-stat-icon" style="background:rgba(254,231,92,.12);color:#FEE75C;">
                    <i data-lucide="shield"></i>
                </div>
                <div class="ov-stat-body">
                    <div class="ov-stat-value"><%= guild.roles.cache.size %></div>
                    <div class="ov-stat-label"><%= t('home.roles') %></div>
                </div>
                <div class="ov-stat-bar"></div>
            </div>
        </div>

        <!-- ── Live Status Bar ───────────────────────────────────── -->
        <div class="ov-live-bar" id="ov-live-bar" style="display:none;">
            <span class="ov-live-dot"></span>
            <span class="ov-live-label">LIVE</span>
            <span class="ov-live-sep">·</span>
            <i data-lucide="activity" style="width:13px;height:13px;opacity:.7;"></i>
            <span><%= t('home.ping') %>: <strong id="ov-stat-ping">—</strong></span>
            <span class="ov-live-sep">·</span>
            <i data-lucide="ticket" style="width:13px;height:13px;opacity:.7;"></i>
            <span><%= t('home.active_tickets') %>: <strong id="ov-stat-tickets">—</strong></span>
        </div>

        <!-- ── Permission Status ──────────────────────────────────── -->
        <% if (missingPerms.length > 0) { %>
        <div class="ov-perm-warn">
            <div class="ov-perm-header">
                <i data-lucide="alert-triangle"></i>
                <span><%- t('home.perm_missing', { count: missingPerms.length }) %></span>
            </div>
            <ul class="perm-list">
                <% missingPerms.forEach(p => { %>
                <li><code class="perm-name"><%= p.name %></code><span class="perm-desc"> — <%= p.desc %></span></li>
                <% }); %>
            </ul>
            <p class="perm-hint"><%= t('home.perm_hint') %></p>
        </div>
        <% } %>

        <!-- ── Bot Settings ──────────────────────────────────────── -->
        <div class="ov-botsettings-card">
            <div class="ov-botsettings-header">
                <div class="ov-botsettings-icon"><i data-lucide="settings-2"></i></div>
                <div class="ov-botsettings-title"><%= t('home.settings_title') %></div>
            </div>
            <div class="ov-botsettings-grid">
                <div class="form-group" style="margin:0;">
                    <label class="label"><%= t('home.bot_nickname') %></label>
                    <p style="font-size:.75rem;color:var(--text-muted);margin:.1rem 0 .5rem;"><%= t('home.nickname_sub') %></p>
                    <input type="text" id="nicknameInput" class="input" value="<%= botNickname %>"
                           maxlength="32" placeholder="<%= t('home.nickname_placeholder') %>">
                </div>
                <div class="form-group" style="margin:0;">
                    <label class="label"><%= t('home.prefix_label') %></label>
                    <p style="font-size:.75rem;color:var(--text-muted);margin:.1rem 0 .5rem;"><%= t('home.prefix_sub') %></p>
                    <input type="text" id="prefixInput" class="input" value="<%= botPrefix %>"
                           maxlength="5" placeholder="<%= t('home.prefix_placeholder') %>">
                </div>
            </div>
            <div id="settingsMsg" class="form-message" style="margin-top:.75rem;"></div>
        </div>

        <!-- ══════════════════════════════════════════════════
             FITUR DASHBOARD
        ══════════════════════════════════════════════════ -->

        <!-- ── Notification ────────────────────────────────── -->
        <div class="ov-feat-section">
            <div class="ov-section-header">
                <div class="ov-section-dot" style="background:#5865F2;"></div>
                <span><%= t('home.section_notification') %></span>
                <div class="ov-section-line"></div>
            </div>
            <div class="ov-feat-grid">
                <a href="/dashboard/<%= guild.id %>/welcome" class="ov-feat-card">
                    <div class="ov-feat-icon" style="--ic:#5865F2;background:rgba(88,101,242,.15);color:#7289da;">
                        <i data-lucide="user-plus"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_welcome_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_welcome_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/goodbye" class="ov-feat-card">
                    <div class="ov-feat-icon" style="--ic:#ED4245;background:rgba(237,66,69,.12);color:#ED4245;">
                        <i data-lucide="log-out"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_goodbye_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_goodbye_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/booster?tab=boost" class="ov-feat-card">
                    <div class="ov-feat-icon" style="--ic:#FF73FA;background:rgba(255,115,250,.12);color:#FF73FA;">
                        <i data-lucide="zap"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_boost_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_boost_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/booster?tab=unboost" class="ov-feat-card">
                    <div class="ov-feat-icon" style="--ic:#ED4245;background:rgba(237,66,69,.1);color:#f27f81;">
                        <i data-lucide="zap-off"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_unboost_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_unboost_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
            </div>
        </div>

        <!-- ── Auto Role ────────────────────────────────────── -->
        <div class="ov-feat-section">
            <div class="ov-section-header">
                <div class="ov-section-dot" style="background:#57F287;"></div>
                <span><%= t('home.section_autorole') %></span>
                <div class="ov-section-line"></div>
            </div>
            <div class="ov-feat-grid">
                <a href="/dashboard/<%= guild.id %>/autorole?tab=join" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(59,165,93,.15);color:#3ba55d;">
                        <i data-lucide="users"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_autorole_join_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_autorole_join_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/autorole?tab=booster" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(255,115,250,.12);color:#FF73FA;">
                        <i data-lucide="zap"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_autorole_booster_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_autorole_booster_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/autorole?tab=button" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(240,160,50,.15);color:#f0a032;">
                        <i data-lucide="mouse-pointer-2"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_autorole_button_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_autorole_button_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/autorole?tab=reaction" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(88,101,242,.15);color:#949cf7;">
                        <i data-lucide="smile"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_autorole_reaction_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_autorole_reaction_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
            </div>
        </div>

        <!-- ── Moderation ────────────────────────────────────── -->
        <div class="ov-feat-section">
            <div class="ov-section-header">
                <div class="ov-section-dot" style="background:#ED4245;"></div>
                <span><%= t('home.section_moderation') %></span>
                <div class="ov-section-line"></div>
            </div>
            <div class="ov-feat-grid">
                <a href="/dashboard/<%= guild.id %>/automod" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(237,66,69,.12);color:#ED4245;">
                        <i data-lucide="shield-check"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_automod_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_automod_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/warnings" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(240,160,50,.12);color:#F0A032;">
                        <i data-lucide="triangle-alert"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_warnings_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_warnings_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/modlog" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(88,101,242,.12);color:#949cf7;">
                        <i data-lucide="scroll-text"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_modlog_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_modlog_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
            </div>
        </div>

        <!-- ── Utility ──────────────────────────────────────── -->
        <div class="ov-feat-section">
            <div class="ov-section-header">
                <div class="ov-section-dot" style="background:#FEE75C;"></div>
                <span><%= t('home.section_utility') %></span>
                <div class="ov-section-line"></div>
            </div>
            <div class="ov-feat-grid">
                <a href="/dashboard/<%= guild.id %>/ticket" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(254,231,92,.12);color:#FEE75C;">
                        <i data-lucide="ticket"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_ticket_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_ticket_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/giveaway" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(87,242,135,.1);color:#57F287;">
                        <i data-lucide="gift"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_giveaway_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_giveaway_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/message-builder" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(155,89,182,.15);color:#9b59b6;">
                        <i data-lucide="mail"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_message_builder_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_message_builder_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/serverstats" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(87,242,135,.12);color:#57F287;">
                        <i data-lucide="bar-chart-2"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_serverstats_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_serverstats_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/invites" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(88,101,242,.12);color:#5865F2;">
                        <i data-lucide="link"></i>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_invites_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_invites_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
            </div>
        </div>

        <!-- ── Social Media ─────────────────────────────────────── -->
        <div class="ov-feat-section">
            <div class="ov-section-header">
                <div class="ov-section-dot" style="background:#FF73FA;"></div>
                <span><%= t('home.section_social') %></span>
                <div class="ov-section-line"></div>
            </div>
            <div class="ov-feat-grid">
                <a href="/dashboard/<%= guild.id %>/youtube" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(237,66,69,.12);color:#ED4245;">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_youtube_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_youtube_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/tiktok" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(254,231,92,.1);color:#FEE75C;">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_tiktok_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_tiktok_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/twitch" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(145,70,255,.15);color:#9146FF;">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_twitch_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_twitch_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
                <a href="/dashboard/<%= guild.id %>/kick" class="ov-feat-card">
                    <div class="ov-feat-icon" style="background:rgba(83,252,24,.12);color:#53FC18;">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                    </div>
                    <div class="ov-feat-body">
                        <div class="ov-feat-title"><%= t('home.feat_kick_title') %></div>
                        <div class="ov-feat-desc"><%= t('home.feat_kick_desc') %></div>
                    </div>
                    <i data-lucide="arrow-right" class="ov-feat-arrow"></i>
                </a>
            </div>
        </div>

    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<style>
/* ── Server Banner ── */
.ov-banner {
    position: relative; overflow: hidden;
    border-radius: 14px; margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #1a1b2e 0%, #2a2b38 100%);
    background-size: cover;
    background-position: center top;
    border: 1px solid var(--border);
    padding: 1.75rem 1.75rem;
}
/* Light mode fallback */
[data-theme="light"] .ov-banner:not(.ov-banner-img) {
    background: linear-gradient(135deg, #b8bcc8 0%, #c8cbd5 100%);
}
/* Dark mode: text white over dark gradient */
.ov-banner:not(.ov-banner-img) .ov-server-name { color: #fff; }
.ov-banner:not(.ov-banner-img) .ov-server-sub  { color: rgba(255,255,255,.6); }
/* Light mode: revert to theme text colors */
[data-theme="light"] .ov-banner:not(.ov-banner-img) .ov-server-name { color: var(--text); }
[data-theme="light"] .ov-banner:not(.ov-banner-img) .ov-server-sub  { color: var(--text-muted); }
.ov-banner-bg {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(circle at 80% 50%, rgba(88,101,242,.18) 0%, transparent 60%),
                radial-gradient(circle at 10% 80%, rgba(87,242,135,.07) 0%, transparent 50%);
}
/* No extra glow overlay in light mode without banner */
[data-theme="light"] .ov-banner:not(.ov-banner-img) .ov-banner-bg { background: none; }
/* When guild has an actual banner image */
.ov-banner.ov-banner-img .ov-banner-bg {
    background: linear-gradient(to top, rgba(0,0,0,.72) 0%, rgba(0,0,0,.25) 60%, rgba(0,0,0,.1) 100%);
}
.ov-banner.ov-banner-img .ov-server-name { color: #fff; }
.ov-banner.ov-banner-img .ov-server-sub  { color: rgba(255,255,255,.75); }
.ov-banner.ov-banner-img .ov-server-icon { border-color: rgba(255,255,255,.2); }
.ov-banner.ov-banner-img .ov-server-icon-placeholder { border-color: rgba(255,255,255,.2); }
.ov-banner-content {
    position: relative; display: flex; align-items: center; gap: 1.25rem;
}
.ov-server-icon {
    width: 64px; height: 64px; border-radius: 16px;
    border: 2px solid var(--border); flex-shrink: 0;
