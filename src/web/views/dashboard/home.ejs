@media(max-width:600px) { .ov-botsettings-grid { grid-template-columns: 1fr; } }

/* ── Feature section ── */
.ov-feat-section { margin-bottom: 1.5rem; }
.ov-section-header {
    display: flex; align-items: center; gap: .6rem;
    margin-bottom: .9rem;
}
.ov-section-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
