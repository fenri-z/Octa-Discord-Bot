.ov-perm-header { display: flex; align-items: center; gap: .55rem; color: #f27f81; margin-bottom: .6rem; }
.ov-perm-header svg { width: 17px; height: 17px; flex-shrink: 0; }

/* ── Bot Settings card ── */
.ov-botsettings-card {
    background: var(--bg2); border: 1px solid var(--border);
