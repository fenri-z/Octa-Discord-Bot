<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
/* ── Layout 2 kolom ──────────────────────────────────────────────────────── */
.kk-panel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
}
@media (max-width: 860px) { .kk-panel-layout { grid-template-columns: 1fr; } }

/* ── Preview sticky ──────────────────────────────────────────────────────── */
.kk-preview-col { position: sticky; top: calc(var(--navbar-h, 56px) + 1rem); }
.preview-label  {
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: .5rem;
}

/* ── Account card ────────────────────────────────────────────────────────── */
.kk-channel-card {
    border-radius: 10px; padding: 1.1rem; margin-bottom: 1.25rem;
}
.kk-card-header {
    display: flex; align-items: center; gap: .85rem; margin-bottom: 1rem;
}
.kk-card-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    object-fit: cover; flex-shrink: 0; background: #111;
    border: 2px solid #53FC18;
}
.kk-card-avatar-placeholder {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(83,252,24,.2); display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
}
.kk-card-name { font-weight: 600; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── Search loading ──────────────────────────────────────────────────────── */
@keyframes kk-spin    { to { transform: rotate(360deg); } }
@keyframes kk-shimmer { 0% { background-position:-200% 0; } 100% { background-position:200% 0; } }
@keyframes kk-dot     { 0%,80%,100% { transform:scale(0);opacity:.3; } 40% { transform:scale(1);opacity:1; } }

.kk-spinner {
    width: 13px; height: 13px;
    border: 2px solid rgba(83,252,24,.22);
    border-top-color: #53FC18;
    border-radius: 50%;
    animation: kk-spin .65s linear infinite;
    display: inline-block; vertical-align: middle; flex-shrink: 0;
}
.kk-skeleton {
    background: linear-gradient(90deg,
        rgba(255,255,255,.04) 25%,
        rgba(255,255,255,.11) 50%,
        rgba(255,255,255,.04) 75%);
    background-size: 200% 100%;
    animation: kk-shimmer 1.4s ease-in-out infinite;
    border-radius: 5px;
}
.kk-dot-row { display:inline-flex; gap:3px; align-items:center; }
.kk-dot-row span {
    width:5px; height:5px; border-radius:50%; background:#53FC18;
    animation: kk-dot 1.2s ease-in-out infinite;
}
.kk-dot-row span:nth-child(2) { animation-delay:.2s; }
.kk-dot-row span:nth-child(3) { animation-delay:.4s; }

/* ── Stats ───────────────────────────────────────────────────────────────── */
.kk-stats-grid { grid-template-columns: repeat(3,1fr) !important; }

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 860px) {
    .kk-panel-layout { grid-template-columns: 1fr; }
    .kk-preview-col  { position: static; }
    /* Stats: 2 kolom di tablet */
    .kk-stats-grid   { grid-template-columns: 1fr 1fr !important; }
    .kk-stats-grid .stat-card { min-width: 0; }
    .kk-stats-grid .stat-info { min-width: 0; overflow: hidden; }
    .kk-stats-grid .stat-label { white-space: normal; line-height: 1.3; }
}
@media (max-width: 680px) {
    .dash-main        { padding: 1.25rem 1rem 1.5rem !important; }
    .settings-card    { padding: 1rem !important; }
    .kk-channel-card  { padding: .9rem; }
    .kk-stats-grid    { grid-template-columns: 1fr 1fr !important; }
    .kk-stats-grid .stat-card { min-width: 0; padding: .75rem; gap: .5rem; }
    .kk-stats-grid .stat-info { min-width: 0; overflow: hidden; }
    .kk-stats-grid .stat-label { white-space: normal; line-height: 1.3; }
    .kk-card-header   { gap: .6rem; }
    .kk-card-avatar,
    .kk-card-avatar-placeholder { width: 38px; height: 38px; }
    .kk-card-name     { font-size: .9rem; }
    .kk-card-header .btn-sm { padding: .25rem .4rem; }
    .kk-search-row    { flex-direction: column !important; }
    .kk-search-row .btn { width: 100%; justify-content: center; }
    .kk-action-row    { flex-direction: column !important; }
    .kk-action-row .btn { width: 100%; justify-content: center; }
}
@media (max-width: 480px) {
    .dash-main        { padding: 1rem .75rem 1.5rem !important; }
    .kk-channel-card  { padding: .75rem; }
    .kk-stats-grid .stat-card { padding: .6rem .5rem; gap: .4rem; }
    .kk-stats-grid .stat-icon { width: 30px !important; height: 30px !important; border-radius: 7px !important; flex-shrink: 0; }
    .kk-stats-grid .stat-icon svg { width: 14px !important; height: 14px !important; }
    .kk-stats-grid .stat-value { font-size: 1.1rem; }
    .kk-stats-grid .stat-label { font-size: .63rem; }
    .kk-card-header .btn-sm { padding: .3rem .45rem; }
    .label-with-picker { flex-wrap: wrap; gap: .35rem; }
}

/* ── Responsive: Mobile kecil (≤ 380px) ─────────────────────────────────── */
@media (max-width: 380px) {
    .dash-main        { padding: .85rem .6rem 1.5rem !important; }
    .kk-channel-card  { padding: .65rem; }

    /* Card header: wrap action buttons */
    .kk-card-header   { flex-wrap: wrap; gap: .35rem !important; }
    .kk-card-header > a.btn,
    .kk-card-header > button.btn { padding: .2rem .32rem !important; }

    /* Page header: stack */
    .page-header      { flex-direction: column !important; align-items: flex-start !important; }

    /* Textarea kompak */
    .form-group .textarea { min-height: 70px; }

    /* Lookup result wraps */
    .kk-lookup-result-inner { flex-wrap: wrap !important; }
    .kk-lookup-result-inner .btn { width: 100%; justify-content: center; margin-top: .3rem; }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'kick' }) %>
    <main class="dash-main" style="max-width:100%;overflow-x:hidden;">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <!-- Header -->
        <div class="page-header">
            <h1><%= t('kick.page_title') %></h1>
            <p><%= t('kick.page_desc') %></p>
        </div>

        <!-- Warning: belum dikonfigurasi -->
        <% if (!isConfigured) { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="alert-triangle"></i>
            <div>
                <strong>Kick API is not configured.</strong> Add the following variables to your <code>.env</code> file and restart the bot:
                <div style="margin-top:.5rem;font-size:.82rem;background:rgba(0,0,0,.3);padding:.5rem .75rem;border-radius:6px;font-family:monospace;line-height:1.8;">
                    KICK_CLIENT_ID=your_client_id<br>
                    KICK_CLIENT_SECRET=your_client_secret
                </div>
                <div style="margin-top:.5rem;font-size:.79rem;color:var(--text-muted);">
                    <%- t('kick.api_note') %>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Stats -->
        <div class="stats-grid kk-stats-grid" style="margin-bottom:1.5rem;">
            <div class="stat-card">
                <div class="stat-icon" style="color:#53FC18;">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                </div>
                <div class="stat-info">
                    <div class="stat-value"><%= kickAccounts.length %></div>
                    <div class="stat-label"><%= t('kick.stat_monitored') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;">
                    <i data-lucide="radio"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value"><%= kickAccounts.filter(a => a.enabled).length %></div>
                    <div class="stat-label"><%= t('kick.stat_active') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#80848e;">
                    <i data-lucide="list"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value"><%= maxAccounts - kickAccounts.length %></div>
                    <div class="stat-label"><%= t('kick.stat_slots') %></div>
                </div>
            </div>
        </div>

        <!-- Add Streamer -->
        <% if (kickAccounts.length < maxAccounts) { %>
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;">
                <i data-lucide="plus-circle" style="color:#53FC18;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('kick.add_title') %></h2>
            </div>
            <p style="font-size:.85rem;color:var(--text-muted);margin:0 0 1rem 0;">
                <%- t('kick.add_desc', { remaining: maxAccounts - kickAccounts.length, max: maxAccounts }) %>
            </p>
            <div class="form-group" style="margin-bottom:0;">
                <label class="label"><%= t('kick.search_label') %></label>
                <div class="kk-search-row" style="display:flex;gap:.6rem;">
                    <input type="text" id="kkLookupInput" class="input"
                           placeholder="username  atau  https://kick.com/username"
                           style="flex:1;min-width:0;" maxlength="200" data-flt-ignore
                           onkeydown="if(event.key==='Enter') lookupKick()">
                    <button class="btn btn-primary" onclick="lookupKick()" id="kkLookupBtn"
                            style="white-space:nowrap;flex-shrink:0;<% if (!isConfigured) { %>opacity:.5;cursor:not-allowed;<% } %>"
                            <%= !isConfigured ? 'disabled' : '' %>>
                        <i data-lucide="search" style="width:14px;height:14px;"></i> <%= t('kick.search_btn') %>
                    </button>
                </div>
            </div>

            <!-- Loading -->
            <div id="kkSearchStatus" style="display:none;margin-top:.75rem;padding:.65rem 1rem;background:rgba(83,252,24,.07);border:1px solid rgba(83,252,24,.2);border-radius:8px;align-items:center;gap:.75rem;">
                <div class="kk-spinner"></div>
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:.5rem;">
                        <span id="kkStatusText" style="font-size:.83rem;color:#53FC18;font-weight:600;"></span>
                        <span class="kk-dot-row"><span></span><span></span><span></span></span>
                    </div>
                    <div style="font-size:.74rem;color:var(--text-muted);margin-top:.15rem;"><%= t('kick.searching_wait') %></div>
                </div>
            </div>

            <!-- Skeleton -->
            <div id="kkSearchSkeleton" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border);">
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <div class="kk-skeleton" style="width:42px;height:42px;border-radius:50%;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:.45rem;">
                        <div class="kk-skeleton" style="height:13px;width:52%;"></div>
                        <div class="kk-skeleton" style="height:10px;width:35%;"></div>
                    </div>
                    <div class="kk-skeleton" style="width:70px;height:30px;border-radius:6px;flex-shrink:0;"></div>
                </div>
            </div>

            <div id="kkLookupMsg" class="form-message" style="margin-top:.5rem;"></div>

            <!-- Hasil -->
            <div id="kkLookupResult" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border);">
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <img id="kkLookupThumb" src="" alt=""
                         style="width:42px;height:42px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#111;border:2px solid #53FC18;"
                         onerror="this.style.display='none'">
                    <div style="flex:1;min-width:0;">
                        <div id="kkLookupName" style="font-weight:600;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
                        <div id="kkLookupLogin" style="font-size:.78rem;color:var(--text-muted);"></div>
                    </div>
                    <button class="btn btn-primary" onclick="addKickStreamer()" style="flex-shrink:0;">
                        <i data-lucide="plus" style="width:14px;height:14px;"></i> <%= t('kick.add_btn') %>
                    </button>
                </div>
            </div>
        </div>
        <% } else { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="info"></i>
            <span><%- t('kick.max_reached', { max: maxAccounts }) %></span>
        </div>
        <% } %>

        <!-- Daftar Streamer -->
        <div id="kkAccountList">
        <% if (kickAccounts.length === 0) { %>
            <div class="settings-card" style="text-align:center;padding:3rem 1.5rem;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:48px;height:48px;color:#53FC18;opacity:.4;display:block;margin:0 auto .75rem;"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                <p style="color:var(--text-muted);margin:0;"><%= t('kick.no_streamers') %></p>
            </div>
        <% } else { %>
        <% kickAccounts.forEach(function(acc) {
            const cardKey = acc.slug.replace(/[^a-zA-Z0-9]/g,'_');
        %>
        <div class="settings-card kk-channel-card" id="kkCard-<%= cardKey %>">

            <!-- Header -->
            <div class="kk-card-header">
                <% if (acc.thumbnail) { %>
                <img src="<%= acc.thumbnail %>" alt="" class="kk-card-avatar"
                     data-kick-thumb="<%= acc.slug %>"
                     referrerpolicy="no-referrer"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="kk-card-avatar-placeholder" style="display:none;">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#53FC18;"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                </div>
                <% } else { %>
                <div class="kk-card-avatar-placeholder">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#53FC18;"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                </div>
                <% } %>
                <div style="flex:1;min-width:0;">
                    <div class="kk-card-name" data-kick-name><%= acc.displayName || acc.slug %></div>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.1rem;">kick.com/<%= acc.slug %></div>
                </div>
                <a href="https://kick.com/<%= acc.slug %>" target="_blank" class="btn btn-sm" title="<%= t('kick.open_on_kick') %>">
                    <i data-lucide="external-link" style="width:13px;height:13px;"></i>
                </a>
                <button class="btn btn-sm btn-danger"
                        data-slug="<%= acc.slug %>"
                        data-name="<%= (acc.displayName||acc.slug).replace(/"/g,'&quot;') %>"
                        onclick="removeKickStreamer(this.dataset.slug, this.dataset.name)"
                        title="Delete streamer">
                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                </button>
            </div>

            <!-- 2-kolom: form | preview -->
            <div class="kk-panel-layout">

                <!-- Kiri: form -->
                <div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="kkEnabled-<%= cardKey %>"
                                   <%= acc.enabled ? 'checked' : '' %>
                                   onchange="updateKickPreview('<%= cardKey %>')">
                            <span class="toggle-slider"></span>
                            <span><%= t('kick.enable_live') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('common.channel') %></label>
                        <select class="select" id="kkChannel-<%= cardKey %>" onchange="updateKickPreview('<%= cardKey %>')">
                            <option value=""><%= t('common.select_channel') %></option>
                            <% (locals.channels||[]).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= acc.channelId===ch.id?'selected':'' %>>#<%= ch.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('kick.additional_msg') %></label>
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="toggleKkPicker('kkPicker-<%= cardKey %>',event)">{…} Placeholder</button>
                                <div class="ph-dropdown" id="kkPicker-<%= cardKey %>" style="display:none;"></div>
                            </div>
                        </div>
                        <textarea class="textarea" rows="3" id="kkMessage-<%= cardKey %>"
                                  style="font-size:.82rem;"
                                  oninput="updateKickPreview('<%= cardKey %>')"
                        ><%= acc.message || "Hey, **{account}** is **LIVE** on Kick right now!\nCome join and watch the stream~ 🎉" %></textarea>
                    </div>

                    <!-- Aksi -->
                    <div class="kk-action-row" style="display:flex;justify-content:flex-end;gap:.5rem;padding-top:.85rem;">
                        <button class="btn btn-secondary" onclick="testKickNotif('<%= acc.slug %>','<%= cardKey %>')">
                            <i data-lucide="send" style="width:14px;height:14px;"></i> <%= t('kick.test_notif_btn') %>
                        </button>
                    </div>
                    <div id="kkMsg-<%= cardKey %>" class="form-message" style="margin-top:.4rem;"></div>
                </div>

                <!-- Kanan: preview Discord -->
                <div class="kk-preview-col">
                    <div class="preview-label">Preview</div>
                    <div class="dc-window">
                        <div class="dc-channel-bar">
                            <span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>
                            <span id="kkPrevCh-<%= cardKey %>"><%= ((locals.channels||[]).find(c=>c.id===acc.channelId)||{}).name || 'select-channel' %></span>
                        </div>
                        <div class="dc-message">
                            <div class="dc-avatar">
                                <img src="<%= locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                     alt="bot" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            </div>
                            <div class="dc-msg-body">
                                <div class="dc-username-row">
                                    <%= locals.botNavName || 'Bot' %>
                                    <span class="dc-app-badge">
                                        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        APP
                                    </span>
                                    <span class="dc-timestamp">Today at 12:00 PM</span>
                                </div>
                                <div class="dc-embed" id="kkPrev-<%= cardKey %>">
                                    <div class="dc-embed-pill" style="background:#53FC18;"></div>
                                    <div class="dc-embed-body">
                                        <div class="dc-embed-main">
                                            <div class="dc-embed-content">
                                                <div class="dc-embed-title">🔴 <%= acc.displayName||acc.slug %> is Live Now!</div>
                                                <div class="dc-embed-desc" id="kkPrevDesc-<%= cardKey %>" style="margin-top:.15rem;margin-bottom:.35rem;"></div>
                                                <div style="margin-top:.35rem;">
                                                    <div style="margin-bottom:.3rem;">
                                                        <div class="dc-field-name">🎙️ Stream Title</div>
                                                        <div class="dc-field-value">[TEST] Example stream title</div>
                                                    </div>
                                                    <div style="margin-bottom:.3rem;">
                                                        <div class="dc-field-name">🎮 Category</div>
                                                        <div class="dc-field-value">Just Chatting</div>
                                                    </div>
                                                    <div>
                                                        <div class="dc-field-name">🔗 Link</div>
                                                        <div class="dc-field-value">Click Me ▶</div>
                                                    </div>
                                                </div>
                                            </div>
                                            <% if (acc.thumbnail) { %>
                                            <div class="dc-embed-thumb">
                                                <img src="<%= acc.thumbnail %>" referrerpolicy="no-referrer"
                                                     alt="" onerror="this.closest('.dc-embed-thumb').style.display='none'">
                                            </div>
                                            <% } %>
                                        </div>
                                        <div style="border-radius:4px;overflow:hidden;background:rgba(83,252,24,.06);aspect-ratio:16/9;max-width:100%;margin-top:.5rem;display:flex;align-items:center;justify-content:center;">
                                            <svg viewBox="0 0 24 24" fill="#53FC18" style="width:32px;height:32px;opacity:.25;"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                                        </div>
                                        <div class="dc-embed-footer">
                                            <svg viewBox="0 0 24 24" fill="#53FC18" style="width:12px;height:12px;flex-shrink:0;"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg>
                                            <span>Kick LIVE</span>
                                            <span class="dc-footer-sep"> • </span>
                                            <span>Today at 12:00 PM</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /kk-panel-layout -->
        </div><!-- /kk-channel-card -->
        <% }); %>
        <% } %>
        </div><!-- /kkAccountList -->

    </div><!-- /dash-content-wide -->
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<%- include('../partials/bottom-nav') %>

<script>
const GUILD_ID    = '<%= guild.id %>';
const KK_CHANNELS = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;
const ROLES_MAP   = <%- JSON.stringify(Object.fromEntries((locals.roles||[]).map(r=>[r.id,r]))) %>;
const CHANNELS_MAP= <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(c=>[c.id,c]))) %>;
let _kkLookupData = null;

const I18N_KK_CONFIRM_DEL = '<%= t("kick.confirm_delete") %>';
const I18N_KK_ERR_NO_CH   = '<%= t("kick.err_no_channel") %>';
const I18N_KK_SEARCH_BTN  = '<%= t("kick.search_btn") %>';
const I18N_KK_SEARCHING   = '<%= t("kick.searching") %>';
const I18N_KK_SAVING      = '<%= t("kick.saving") %>';
const I18N_KK_TIPS        = ['<%= t("kick.tip_1") %>','<%= t("kick.tip_2") %>','<%= t("kick.tip_3") %>','<%= t("kick.tip_4") %>'];
const I18N_KK_ERR_CONN    = '<%= t("kick.err_conn") %>';
const I18N_KK_ERR_CONNECT = '<%= t("kick.err_connect") %>';
const I18N_KK_SENDING_TEST= '<%= t("kick.sending_test") %>';
const I18N_KK_NO_CHANNEL  = '<%= t("kick.preview_no_channel") %>';
const I18N_KK_PH_ACCOUNT  = '<%= t("kick.ph_account") %>';
const I18N_KK_PH_SLUG     = '<%= t("kick.ph_slug") %>';
const I18N_KK_PH_URL      = '<%= t("kick.ph_url") %>';
const I18N_KK_PH_CATEGORY = '<%= t("kick.ph_category") %>';
const I18N_KK_PH_TITLE    = '<%= t("kick.ph_title") %>';
const I18N_KK_PH_VIEWERS  = '<%= t("kick.ph_viewers") %>';

// ── Lookup ────────────────────────────────────────────────────────────────────
async function lookupKick() {
    const input      = document.getElementById('kkLookupInput').value.trim();
    const btn        = document.getElementById('kkLookupBtn');
    const resEl      = document.getElementById('kkLookupResult');
    const statusEl   = document.getElementById('kkSearchStatus');
    const skeletonEl = document.getElementById('kkSearchSkeleton');
    const msgEl      = document.getElementById('kkLookupMsg');
    if (!input) return;

    resEl.style.display = 'none'; statusEl.style.display = 'none'; skeletonEl.style.display = 'none';
    if (msgEl) { msgEl.textContent = ''; msgEl.className = 'form-message'; }
    _kkLookupData = null;

    btn.disabled  = true;
    btn.innerHTML = `<span class="kk-spinner"></span> ${I18N_KK_SEARCHING}`;

    const tips = I18N_KK_TIPS;
    let tipIdx = 0;
    const statusTextEl = document.getElementById('kkStatusText');
    if (statusTextEl) statusTextEl.textContent = tips[0];
    statusEl.style.display = 'flex'; skeletonEl.style.display = 'block';
    const tipTimer = setInterval(() => { tipIdx = (tipIdx+1)%tips.length; if (statusTextEl) statusTextEl.textContent = tips[tipIdx]; }, 3000);

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/kick/lookup`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input }),
        });
        const data = await r.json();
        if (!data.success) { if (msgEl) showMsg(msgEl, data.message, 'error', true); return; }

        _kkLookupData = data.channel;
        const thumb = document.getElementById('kkLookupThumb');
        thumb.src = _kkLookupData.thumbnail || ''; thumb.style.display = _kkLookupData.thumbnail ? 'block' : 'none';
        document.getElementById('kkLookupName').textContent  = _kkLookupData.displayName;
        document.getElementById('kkLookupLogin').textContent = 'kick.com/' + _kkLookupData.slug;
        resEl.style.display = 'block';
    } catch (err) {
        if (msgEl) showMsg(msgEl, I18N_KK_ERR_CONN + err.message, 'error', true);
    } finally {
        clearInterval(tipTimer);
        statusEl.style.display = 'none'; skeletonEl.style.display = 'none';
        btn.disabled  = false;
        btn.innerHTML = `<i data-lucide="search" style="width:14px;height:14px;"></i> ${I18N_KK_SEARCH_BTN}`;
        if (window.lucide) lucide.createIcons();
    }
}

// ── Add ───────────────────────────────────────────────────────────────────────
async function addKickStreamer() {
    if (!_kkLookupData) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/kick/accounts`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(_kkLookupData),
    });
    const data = await r.json();
    if (data.success) { queueToast(data.message, 'success'); location.reload(); }
    else alert(data.message);
}

// ── Save ──────────────────────────────────────────────────────────────────────
async function saveKickStreamer(slug, key, quiet = false) {
    const msgEl     = document.getElementById(`kkMsg-${key}`);
    const btn       = document.querySelector(`#kkCard-${key} .kk-action-row .btn-primary`);
    const enabled   = document.getElementById(`kkEnabled-${key}`)?.checked  || false;
    const channelId = document.getElementById(`kkChannel-${key}`)?.value    || '';
    const message   = document.getElementById(`kkMessage-${key}`)?.value?.trim() || '';

    if (enabled && !channelId) {
        showMsg(msgEl, I18N_KK_ERR_NO_CH, 'error');
        document.getElementById(`kkChannel-${key}`)?.focus();
        return { success: false, message: I18N_KK_ERR_NO_CH };
    }

    const orig = btn?.innerHTML;
    if (btn) { btn.disabled = true; btn.innerHTML = `<span class="kk-spinner"></span> ${I18N_KK_SAVING}`; }

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/kick/accounts/${encodeURIComponent(slug)}`, {
            method: 'PUT', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ enabled, channelId, message }),
        });
        const data = await r.json();
        if (!quiet || !data.success) showMsg(msgEl, data.message, data.success ? 'success' : 'error');
        return data;
    } catch {
        showMsg(msgEl, I18N_KK_ERR_CONNECT, 'error');
        return { success: false, message: I18N_KK_ERR_CONNECT };
    } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = orig; if (window.lucide) lucide.createIcons(); }
    }
}

// ── Test ──────────────────────────────────────────────────────────────────────
async function testKickNotif(slug, key) {
    const msgEl = document.getElementById(`kkMsg-${key}`);
    showMsg(msgEl, I18N_KK_SENDING_TEST, 'info');
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/kick/accounts/${encodeURIComponent(slug)}/test`, { method: 'POST' });
        const data = await r.json();
        showMsg(msgEl, data.message, data.success ? 'success' : 'error');
    } catch {
        showMsg(msgEl, 'Gagal terhubung ke server.', 'error');
    }
}

// ── Remove ────────────────────────────────────────────────────────────────────
async function removeKickStreamer(slug, name) {
    if (!confirm(I18N_KK_CONFIRM_DEL.replace('{{name}}', name))) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/kick/accounts/${encodeURIComponent(slug)}`, { method: 'DELETE' });
    const data = await r.json();
    if (data.success) { queueToast(data.message, 'success'); location.reload(); }
    else alert(data.message);
}

// ── Discord Markdown renderer ──────────────────────────────────────────────────
function discordMd(raw) {
    if (!raw) return '';
    const _t=[]; const _T=i=>`\x00${i}\x00`;
    let _src = raw
        .replace(/<@&(\d+)>/g,  (_,id)=>{ const r=ROLES_MAP[id],c=r?.color||'#5865F2'; _t.push(`<span class="dc-mention" style="color:${c};background:${c}1a;">@${r?r.name:id}</span>`); return _T(_t.length-1); })
        .replace(/<@!?(\d+)>/g, (_,id)=>{ _t.push(`<span class="dc-mention">@${id}</span>`); return _T(_t.length-1); })
        .replace(/<#(\d+)>/g,   (_,id)=>{ const ch=CHANNELS_MAP[id]; _t.push(`<span class="dc-mention">#${ch?ch.name:id}</span>`); return _T(_t.length-1); })
        .replace(/@everyone\b/g,()=>{ _t.push('<span class="dc-mention">@everyone</span>'); return _T(_t.length-1); })
        .replace(/@here\b/g,    ()=>{ _t.push('<span class="dc-mention">@here</span>'); return _T(_t.length-1); });
    let s = _src.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    s = s.replace(/^### (.+)$/gm, '<span style="font-size:.88em;font-weight:700;line-height:1.6;display:block">$1</span>');
    s = s.replace(/^## (.+)$/gm,  '<span style="font-size:1em;font-weight:700;line-height:1.75;display:block">$1</span>');
    s = s.replace(/^# (.+)$/gm,   '<span style="font-size:1.15em;font-weight:700;line-height:2;display:block">$1</span>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>');
    s = s.replace(/\*([^*\n]+?)\*/g,    '<em>$1</em>');
    s = s.replace(/_([^_\n]+?)_/g,      '<em>$1</em>');
    s = s.replace(/__([^_\n]+?)__/g,    '<u>$1</u>');
    s = s.replace(/~~(.+?)~~/g,         '<s>$1</s>');
    s = s.replace(/`([^`]+)`/g, '<code style="background:rgba(255,255,255,.07);padding:0 4px;border-radius:3px;font-size:.83em;font-family:monospace">$1</code>');
    s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" onclick="return false;" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/^&gt; (.+)$/gm, '<span style="border-left:3px solid #4e5058;padding-left:.5em;color:#b5bac1;display:block">$1</span>');
    s = s.replace(/\n/g, '<br>');
    s = s.replace(/\x00(\d+)\x00/g, (_,i)=>_t[+i]);
    return s;
}

// ── Update preview ────────────────────────────────────────────────────────────
function updateKickPreview(key) {
    const chanId = document.getElementById(`kkChannel-${key}`)?.value || '';
    const chEl   = document.getElementById(`kkPrevCh-${key}`);
    if (chEl) chEl.textContent = chanId && KK_CHANNELS[chanId] ? KK_CHANNELS[chanId] : I18N_KK_NO_CHANNEL;

    const card    = document.getElementById(`kkCard-${key}`);
    const accName = card?.querySelector('.kk-card-name')?.textContent?.trim() || key;
    const msgRaw  = (document.getElementById(`kkMessage-${key}`)?.value || '').trim();
    const descEl  = document.getElementById(`kkPrevDesc-${key}`);
    if (descEl) {
        const ph = s => s
            .replace(/{account}/g,   accName)
            .replace(/{slug}/g,      key)
            .replace(/{url}/g,       `https://kick.com/${key}`)
            .replace(/{category}/g,  'Just Chatting')
            .replace(/{title}/g,     'Example stream title')
            .replace(/{viewers}/g,   '1234');
        const defaultDesc = `Hey, <strong>${accName}</strong> is <strong>LIVE</strong> on Kick right now!<br>Come join and watch the stream~ 🎉`;
        descEl.innerHTML = msgRaw ? discordMd(ph(msgRaw)) : defaultDesc;
    }
}

// ── Helper ────────────────────────────────────────────────────────────────────
function showMsg(el, text, type, persist) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (!persist) setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 4000);
}

// ── Placeholder picker ────────────────────────────────────────────────────────
const PH_KICK = [
    ['{account}',   I18N_KK_PH_ACCOUNT],
    ['{slug}',      I18N_KK_PH_SLUG],
    ['{url}',       I18N_KK_PH_URL],
    ['{category}',  I18N_KK_PH_CATEGORY],
    ['{title}',     I18N_KK_PH_TITLE],
    ['{viewers}',   I18N_KK_PH_VIEWERS],
];

function buildKkPickers() {
    document.querySelectorAll('[id^="kkPicker-"]').forEach(el => {
        const key = el.id.replace('kkPicker-', '');
        el.innerHTML = PH_KICK.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertKkPh('kkMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
}

function toggleKkPicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id); const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});

function insertKkPh(targetId, ph) {
    const el = document.getElementById(targetId); if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus(); el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

// Init
buildKkPickers();
document.querySelectorAll('[id^="kkMessage-"]').forEach(el => updateKickPreview(el.id.replace('kkMessage-', '')));
document.getElementById('kkLookupInput')?.addEventListener('keydown', e => { if (e.key === 'Enter') lookupKick(); });

// ── Mention picker ─────────────────────────────────────────────────────────────
document.querySelectorAll('.ph-picker-anchor:not(.mention-anchor)').forEach(anchor => {
    const ta = anchor.closest('.form-group')?.querySelector('textarea');
    if (!ta) return;
    const ma = document.createElement('div');
    ma.className = 'ph-picker-anchor mention-anchor';
    const btn = document.createElement('button');
    btn.type='button'; btn.className='ph-toggle-btn'; btn.textContent='@ Mention';
    const dd = document.createElement('div');
    dd.className='ph-dropdown mention-dd'; dd.style.display='none';
    btn.addEventListener('click', e => {
        e.stopPropagation();
        document.querySelectorAll('.ph-dropdown').forEach(d=>{ if(d!==dd) d.style.display='none'; });
        document.querySelectorAll('.ph-toggle-btn').forEach(b=>{ if(b!==btn) b.classList.remove('active'); });
        if(dd.style.display!=='none'){ dd.style.display='none'; btn.classList.remove('active'); return; }
        if(!dd.dataset.built){ dd.dataset.built='1'; _buildMentionDd(dd,ta); }
        dd.style.display='grid';
        btn.classList.add('active');
    });
    ma.appendChild(btn); ma.appendChild(dd);
    const grp = document.createElement('div');
    grp.className = 'ph-btn-group';
    anchor.parentNode.insertBefore(grp, anchor);
    grp.appendChild(anchor);
    grp.appendChild(ma);
});
function _buildMentionDd(dd, ta) {
    function item(html, mention) {
        const b=document.createElement('button'); b.type='button'; b.className='ph-item';
        b.innerHTML=html;
        b.addEventListener('click',()=>{ const s=ta.selectionStart,e=ta.selectionEnd; ta.value=ta.value.slice(0,s)+mention+ta.value.slice(e); ta.selectionStart=ta.selectionEnd=s+mention.length; ta.focus(); ta.dispatchEvent(new Event('input',{bubbles:true})); dd.style.display='none'; });
        return b;
    }
    function hdr(t){ const h=document.createElement('div'); h.className='ph-group-label'; h.textContent=t; return h; }
    const inp=document.createElement('input'); inp.type='text'; inp.className='mention-search-input'; inp.placeholder='Search...';
    inp.addEventListener('click',e=>e.stopPropagation());
    inp.addEventListener('input',()=>{ const q=inp.value.toLowerCase(); dd.querySelectorAll('.ph-item').forEach(el=>{ el.style.display=el.textContent.toLowerCase().includes(q)?'':'none'; }); });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special')); dd.appendChild(item('<code>@everyone</code>','@everyone')); dd.appendChild(item('<code>@here</code>','@here'));
    const rKeys=Object.keys(ROLES_MAP);
    if(rKeys.length){ dd.appendChild(hdr('Roles')); rKeys.forEach(id=>{ const r=ROLES_MAP[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`,`<@&${r.id}>`)); }); }
    const cKeys=Object.keys(CHANNELS_MAP);
    if(cKeys.length){ dd.appendChild(hdr('Channels')); cKeys.forEach(id=>{ const c=CHANNELS_MAP[id]; dd.appendChild(item(`<span>#${c.name}</span>`,`<#${c.id}>`)); }); }
}

const _kkAllAccounts = <%- JSON.stringify(kickAccounts.map(a => ({ slug: a.slug, key: a.slug.replace(/[^a-zA-Z0-9]/g,'_') }))) %>;
window._floatSave = async function () {
    if (_kkAllAccounts.length === 0) return;
    const results = await Promise.allSettled(_kkAllAccounts.map(a => saveKickStreamer(a.slug, a.key, true)));
    const ok = results.every(r => r.status === 'fulfilled' && r.value?.success);
    if (ok) showMsg(null, results[0].value.message, 'success');
    else throw new Error();
};
</script>

