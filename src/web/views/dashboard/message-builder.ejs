<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'message-builder' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1><%= t('message_builder.page_title') %></h1>
            <p><%= t('message_builder.page_desc') %></p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="layout-template"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statMbTotal"><%= templates.length %></div>
                    <div class="stat-label"><%= t('message_builder.total_templates') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="hash"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statMbWithChannel"><%= templates.filter(tmpl => tmpl.channelId).length %></div>
                    <div class="stat-label"><%= t('message_builder.with_channel') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div id="statMbSlotsIcon" class="stat-icon<%= templates.length >= 20 ? '' : ' stat-icon-comm' %>"<%= templates.length >= 20 ? ' style="color:#ed4245;background:rgba(237,66,69,.12);"' : '' %>><i data-lucide="layers"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statMbSlots" style="<%= templates.length >= 20 ? 'color:#ed4245;' : '' %>"><%= templates.length %>/20</div>
                    <div class="stat-label"><%= t('message_builder.slots_used') %></div>
                </div>
            </div>
        </div>

        <!-- How to Use -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('message_builder.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('message_builder.step1_title') %></div>
                    <div class="guide-desc"><%- t('message_builder.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('message_builder.step2_title') %></div>
                    <div class="guide-desc"><%- t('message_builder.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('message_builder.step3_title') %></div>
                    <div class="guide-desc"><%- t('message_builder.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('message_builder.tip') %></div>
        </div>

        <!-- Form card -->
        <div class="settings-card" id="mbFormCard">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-bottom:.9rem;">
                <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
                    <h2 id="mbFormTitle" style="margin:0;"><%= t('message_builder.modal_new_title') %></h2>
                </div>
                <button type="button" id="mbCancelEdit" class="btn btn-sm" style="display:none;" onclick="cancelEdit()">
                    <i data-lucide="x" style="width:13px;height:13px;"></i> <%= t('message_builder.cancel_edit') %>
                </button>
            </div>

            <input type="hidden" id="editOriginalName">

            <div class="mb-top-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:.75rem;">
                <div class="form-group" style="margin:0;">
                    <label class="label"><%= t('message_builder.field_name') %> <span style="color:#ed4245;">*</span></label>
                    <input type="text" id="editName" class="input" data-flt-ignore
                           placeholder="e.g. announcement" maxlength="32" oninput="onFormInput()">
                    <div class="hint"><%- t('message_builder.field_name_hint') %></div>
                </div>
                <div class="form-group" style="margin:0;">
                    <label class="label"><%= t('message_builder.field_channel') %> <span style="color:#ed4245;">*</span></label>
                    <select id="editChannelId" class="select" data-flt-ignore onchange="onFormInput()">
                        <option value="">— <%= t('message_builder.no_channel') %> —</option>
                        <% channels.forEach(ch => { %>
                            <option value="<%= ch.id %>">#<%= ch.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="cc-form-preview-row">
                <!-- Left: form inputs -->
                <div class="cc-form-inputs">

                    <!-- Text Message section -->
                    <div class="mb-section">
                        <div class="mb-section-head">
                            <span class="mb-section-title" style="display:flex;align-items:center;gap:.4rem;">
                                <i data-lucide="message-square" style="width:13px;height:13px;color:var(--accent);flex-shrink:0;"></i>
                                <%= t('common.plain_text_message') %> <span style="color:#ed4245;">*</span> <span style="font-size:.7rem;font-weight:400;color:var(--text-muted);">(<%= t('common.or_embed') %>)</span>
                            </span>
                            <div class="ph-btn-group">
                                <div class="ph-picker-anchor">
                                    <button type="button" class="ph-toggle-btn" onclick="togglePicker('mbPlainPhPicker',event)">{…} Placeholder</button>
                                    <div class="ph-dropdown" id="mbPlainPhPicker" style="display:none;"></div>
                                </div>
                                <div class="ph-picker-anchor mention-anchor">
                                    <button type="button" class="ph-toggle-btn" onclick="togglePicker('mbPlainMentionPicker',event)">@ Mention</button>
                                    <div class="ph-dropdown mention-dd" id="mbPlainMentionPicker" style="display:none;"></div>
                                </div>
                            </div>
                        </div>
                        <div class="mb-section-body">
                            <textarea id="editPlainText" class="textarea mb-auto-resize" data-flt-ignore rows="3"
                                      placeholder="<%= t('message_builder.ph_plain_text') %>" maxlength="2000"
                                      oninput="mbResizeArea(this);mbUpdateCount('editPlainText','plainTextCount');onFormInput()"></textarea>
                            <div class="mb-char-count" id="plainTextCount">0 / 2000</div>
                            <textarea id="editPlainImage" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                      placeholder="<%= t('message_builder.ph_plain_image') %>"
                                      oninput="mbResizeArea(this);mbWarnUrl(this,true);onFormInput()" onblur="mbWarnUrl(this,true,event)"></textarea>
                        </div>
                    </div>

                    <!-- Embed Builder section -->
                    <div class="mb-section">
                        <div class="mb-section-head">
                            <span class="mb-section-title" style="display:flex;align-items:center;gap:.4rem;">
                                <i data-lucide="layers" style="width:13px;height:13px;color:var(--accent);flex-shrink:0;"></i>
                                <%= t('common.embed_builder') %>
                            </span>
                            <div style="display:flex;align-items:center;gap:.45rem;">
                                <span style="font-size:.75rem;color:var(--text-muted);"><%= t('message_builder.label_accent') %></span>
                                <input type="color" id="editColorPicker" value="#5865F2" class="mb-color-pk" data-flt-ignore
                                       oninput="syncHex('editColor','editColorPicker');onFormInput()">
                                <input type="hidden" id="editColor" value="#5865F2">
                            </div>
                        </div>
                        <div class="mb-section-body" style="padding:0;">
                            <div class="ee-body" style="border:none;border-radius:0;">

                                <!-- AUTHOR -->
                                <div class="ee-section">
                                    <div class="ee-sec-label"><%= t('message_builder.label_author') %></div>
                                    <div class="form-group" style="margin-bottom:.5rem;">
                                        <input type="text" id="editAuthorName" class="input" data-flt-ignore
                                               style="display:block;width:100%;align-self:flex-start;"
                                               placeholder="<%= t('message_builder.ph_author_name') %>" maxlength="256" oninput="onFormInput()">
                                    </div>
                                    <div class="mb-url-pair" style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;">
                                        <textarea id="editAuthorUrl" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                               placeholder="<%= t('message_builder.ph_author_url') %>" oninput="mbResizeArea(this);mbWarnUrl(this,false);onFormInput()" onblur="mbWarnUrl(this,false,event)"></textarea>
                                        <textarea id="editAuthorIcon" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                               placeholder="<%= t('message_builder.ph_author_icon') %>" oninput="mbResizeArea(this);mbWarnUrl(this,true);onFormInput()" onblur="mbWarnUrl(this,true,event)"></textarea>
                                    </div>
                                </div>

                                <div class="ee-sep"></div>

                                <!-- TITLE -->
                                <div class="ee-section">
                                    <div class="ee-sec-label"><%= t('message_builder.label_title') %></div>
                                    <div class="form-group" style="margin-bottom:.5rem;">
                                        <input type="text" id="editTitle" class="input ee-title-input" data-flt-ignore
                                               placeholder="<%= t('message_builder.ph_embed_title') %>" maxlength="256" oninput="onFormInput()">
                                    </div>
                                    <textarea id="editTitleUrl" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                           placeholder="<%= t('message_builder.ph_title_url') %>" oninput="mbResizeArea(this);mbWarnUrl(this,false);onFormInput()" onblur="mbWarnUrl(this,false,event)"></textarea>
                                </div>

                                <div class="ee-sep"></div>

                                <!-- DESCRIPTION -->
                                <div class="ee-section">
                                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.3rem;margin-bottom:.45rem;">
                                        <div class="ee-sec-label" style="margin:0;"><%= t('message_builder.label_description') %></div>
                                        <div class="ph-btn-group">
                                            <div class="ph-picker-anchor">
                                                <button type="button" class="ph-toggle-btn cc-ph-dark-btn" onclick="togglePicker('mbDescPhPicker',event)">{…} Placeholder</button>
                                                <div class="ph-dropdown" id="mbDescPhPicker" style="display:none;"></div>
                                            </div>
                                            <div class="ph-picker-anchor mention-anchor">
                                                <button type="button" class="ph-toggle-btn cc-ph-dark-btn" onclick="togglePicker('mbEmbedMentionPicker',event)">@ Mention</button>
                                                <div class="ph-dropdown mention-dd" id="mbEmbedMentionPicker" style="display:none;"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <textarea id="editDescription" class="textarea mb-auto-resize" data-flt-ignore rows="4"
                                              placeholder="<%= t('message_builder.ph_description') %>" maxlength="4096"
                                              oninput="mbResizeArea(this);mbUpdateCount('editDescription','descCount');onFormInput()"></textarea>
                                    <div class="mb-char-count" id="descCount">0 / 4096</div>
                                </div>

                                <div class="ee-sep"></div>

                                <!-- MEDIA -->
                                <div class="ee-section">
                                    <div class="ee-sec-label"><%= t('message_builder.label_media') %></div>
                                    <div class="form-group" style="margin-bottom:.5rem;">
                                        <label class="label"><%= t('message_builder.label_thumbnail') %></label>
                                        <textarea id="editThumbnail" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                               placeholder="https://..." oninput="mbResizeArea(this);mbWarnUrl(this,true);onFormInput()" onblur="mbWarnUrl(this,true,event)"></textarea>
                                    </div>
                                    <div>
                                        <label class="label"><%= t('message_builder.label_image') %></label>
                                        <textarea id="editImage" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                               placeholder="https://..." oninput="mbResizeArea(this);mbWarnUrl(this,true);onFormInput()" onblur="mbWarnUrl(this,true,event)"></textarea>
                                    </div>
                                </div>

                                <div class="ee-sep"></div>

                                <!-- FIELDS -->
                                <div class="ee-section">
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem;">
                                        <div class="ee-sec-label" style="margin:0;"><%= t('message_builder.label_fields') %> <span id="mbFieldCount" style="font-weight:400;text-transform:none;letter-spacing:0;">(0 / 25)</span></div>
                                        <button type="button" class="btn btn-outline btn-sm" onclick="addMbField()">
                                            <i data-lucide="plus" style="width:13px;height:13px;"></i> <%= t('message_builder.btn_add_field') %>
                                        </button>
                                    </div>
                                    <div id="mbFieldsList"></div>
                                </div>

                                <div class="ee-sep"></div>

                                <!-- FOOTER -->
                                <div class="ee-section">
                                    <div class="ee-sec-label"><%= t('message_builder.label_footer') %></div>
                                    <div style="margin-bottom:.5rem;">
                                        <input type="text" id="editFooter" class="input input-sm" data-flt-ignore
                                               style="display:block;width:100%;"
                                               placeholder="<%= t('message_builder.ph_footer_text') %>" maxlength="2048"
                                               oninput="onFormInput()">
                                    </div>
                                    <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;">
                                        <textarea id="editFooterIcon" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                               style="flex:1;min-width:120px;"
                                               placeholder="<%= t('message_builder.ph_footer_icon') %>"
                                               oninput="mbResizeArea(this);mbWarnUrl(this,true);onFormInput()" onblur="mbWarnUrl(this,true,event)"></textarea>
                                        <label class="toggle-label" style="gap:.5rem;cursor:pointer;flex-shrink:0;">
                                            <input type="checkbox" id="editTimestamp" class="toggle-input" data-flt-ignore
                                                   onchange="onFormInput()">
                                            <span class="toggle-slider"></span>
                                            <span class="label" style="margin:0;white-space:nowrap;"><%= t('message_builder.label_timestamp') %></span>
                                        </label>
                                    </div>
                                </div>

                            </div><!-- /ee-body -->
                        </div><!-- /mb-section-body -->
                    </div><!-- /embed section -->

                </div><!-- /cc-form-inputs -->

                <!-- Right: Discord preview -->
                <div class="preview-panel">
                    <div class="preview-label" onclick="toggleMbPreview()" style="cursor:pointer;user-select:none;" title="Toggle preview">
                        <svg id="mbPreviewEyeIcon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg> PREVIEW
                    </div>
                    <div class="dc-window">
                        <div id="mbPreviewChannel" class="dc-channel-bar">
                            <span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>preview
                        </div>
                        <div class="dc-message">
                            <div class="dc-avatar">
                                <img src="<%- botUser ? botUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                     alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            </div>
                            <div class="dc-msg-body">
                                <div class="dc-username-row">
                                    <%- botUser ? botUser.username : 'Bot' %>
                                    <span class="dc-app-badge">
                                        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        APP
                                    </span>
                                    <span class="dc-timestamp">Today at 12:00</span>
                                </div>
                                <div id="mbPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                <div id="mbPreviewPlainImageWrap" class="dc-plain-image" style="display:none;">
                                    <img id="mbPreviewPlainImage" src="" alt="" onerror="this.closest('.dc-plain-image').style.display='none'">
                                </div>
                                <div id="mbPreviewEmbed" class="dc-embed" style="display:none;">
                                    <div id="mbPreviewPill" class="dc-embed-pill" style="background:#5865F2;"></div>
                                    <div class="dc-embed-body">
                                        <div class="dc-embed-main">
                                            <div class="dc-embed-content">
                                                <div id="mbPreviewAuthor" class="dc-embed-author" style="display:none;"></div>
                                                <div id="mbPreviewTitle"  class="dc-embed-title"  style="display:none;"></div>
                                                <div id="mbPreviewDesc"   class="dc-embed-desc"   style="display:none;"></div>
                                                <div id="mbPreviewFields" class="dc-embed-fields"  style="display:none;"></div>
                                            </div>
                                            <div id="mbPreviewThumb" class="dc-embed-thumb" style="display:none;">
                                                <img id="mbPreviewThumbImg" src="" alt="">
                                            </div>
                                        </div>
                                        <div id="mbPreviewImage" class="dc-embed-image" style="display:none;">
                                            <img id="mbPreviewImageImg" src="" alt="">
                                        </div>
                                        <div id="mbPreviewFooter" class="dc-embed-footer" style="display:none;"></div>
                                    </div>
                                </div>
                                <div id="mbPreviewEmpty" class="dc-embed-empty">Fill in fields above to see preview</div>
                            </div>
                        </div>
                    </div>
                </div><!-- /preview-panel -->

            </div><!-- /cc-form-preview-row -->

            <div id="mbFormMsg" class="form-message" style="margin-top:.5rem;"></div>
        </div><!-- /mbFormCard -->

        <!-- Template list -->
        <div class="settings-card">
            <div class="ar-saved-header">
                <span class="ar-saved-label"><%= t('message_builder.list_title') %></span>
                <div class="ar-saved-line"></div>
            </div>
            <div id="mbList">
                <% if (!templates.length) { %>
                <div style="text-align:center;padding:2.5rem 1rem 2rem;">
                    <i data-lucide="inbox" style="width:44px;height:44px;color:var(--text-muted);opacity:.35;display:block;margin:0 auto .85rem;"></i>
                    <div style="font-size:.9rem;font-weight:600;color:var(--text-muted);margin-bottom:.3rem;"><%= t('message_builder.no_templates') %></div>
                    <div style="font-size:.8rem;color:var(--text-muted);opacity:.7;"><%- t('message_builder.no_templates_hint') %></div>
                </div>
                <% } %>
                <% templates.forEach(function(tmpl) { %>
                <% var _effChannelId = tmpl.channelId || tmpl.sentChannelId || ''; %>
                <% var tmplChannel = _effChannelId ? channels.find(function(c){ return c.id === _effChannelId; }) : null; %>
                <div class="ar-panel-card mb-row" data-name="<%= tmpl.name %>" data-channel-id="<%= _effChannelId %>">
                    <div class="ar-panel-row-left">
                        <span class="ar-panel-name">
                            <span style="width:10px;height:10px;border-radius:50%;background:<%= tmpl.color || '#5865F2' %>;flex-shrink:0;display:inline-block;"></span>
                            <%= tmpl.name %>
                        </span>
                        <% if (tmplChannel) { %>
                        <span class="ar-panel-channel"><i data-lucide="hash" style="width:11px;height:11px;"></i><%= tmplChannel.name %></span>
                        <% } %>
                        <span class="mb-badge mb-badge-type">
                            <%= tmpl.messageType === 'plain' ? t('message_builder.badge_text') : tmpl.messageType === 'both' ? t('message_builder.badge_both') : 'Embed' %>
                        </span>
                    </div>
                    <div class="ar-panel-row-right">
                        <button class="btn btn-outline btn-sm" onclick="editTemplate('<%= tmpl.name %>')">
                            <i data-lucide="pencil" style="width:13px;height:13px;vertical-align:middle;margin-right:.25rem;"></i>Edit
                        </button>
                        <% if (tmpl.isSent) { %>
                        <a class="btn btn-outline btn-sm" href="https://discord.com/channels/<%= guild.id %>/<%= tmpl.sentChannelId %>/<%= tmpl.sentMessageId %>" target="_blank">
                            <i data-lucide="external-link" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i> View
                        </a>
                        <% } else { %>
                        <button class="btn btn-outline btn-sm" onclick="openSendModal('<%= tmpl.name %>')">
                            <i data-lucide="send" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i>Send
                        </button>
                        <% } %>
                        <button class="btn btn-sm ar-btn-delete" onclick="deleteTemplate('<%= tmpl.name %>')">
                            <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                        </button>
                    </div>
                </div>
                <% }) %>
            </div>
            <div id="mbListMsg" class="form-message" style="margin-top:.75rem;"></div>
        </div>

    </div><!-- /dash-content-wide -->
    <%- include('../partials/dash-footer') %>
    </main>
</div><!-- /dash-layout -->

<%- include('../partials/bottom-nav') %>

<!-- ══════════════════════════════════════════════
     MODAL: Send to Channel
══════════════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="sendBackdrop" onclick="closeSendModal()"></div>
<div class="mb-modal mb-modal-sm" id="sendModal" data-flt-ignore>
    <div class="mb-modal-header">
        <h2 style="display:flex;align-items:center;gap:.5rem;"><i data-lucide="send" style="width:16px;height:16px;"></i> <%= t('message_builder.send_modal_title') %></h2>
        <button class="mb-modal-close" onclick="closeSendModal()">✕</button>
    </div>
    <div class="mb-modal-body">
        <p style="color:var(--text-muted);font-size:.9rem;margin:0;">
            <%- t('message_builder.send_modal_desc').replace('{{name}}', '<span id="sendTemplateName"></span>').replace('{{channel}}', '<span id="sendChannelName"></span>') %>
        </p>
        <p style="color:var(--text-muted);font-size:.8rem;margin-top:.5rem;opacity:.7;"><%= t('message_builder.send_modal_note') %></p>
    </div>
    <div class="mb-modal-footer">
        <div id="sendMsg" class="form-message"></div>
        <div style="display:flex;gap:.75rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeSendModal()"><%= t('common.cancel') %></button>
            <button class="btn btn-primary" onclick="sendTemplate()"><%= t('message_builder.send_btn') %></button>
        </div>
    </div>
</div>

<style>
/* ── Slot badge ── */
.mb-slot-badge {
    font-size:.72rem; padding:.2rem .6rem; border-radius:999px;
    background:rgba(88,101,242,.15); color:var(--accent);
    font-weight:600; white-space:nowrap;
}

/* ── Template list row ── */
.mb-row {
    display:flex; align-items:center; justify-content:space-between;
    gap:.75rem; padding:.6rem .75rem;
    background:var(--bg3); border:1px solid var(--border);
    border-radius:8px; margin-bottom:.4rem; flex-wrap:wrap;
}
/* When using ar-panel-card layout, force single-row — no column stacking */
.ar-panel-card.mb-row { flex-wrap:nowrap; flex-direction:row; align-items:center; padding:.5rem .75rem; gap:.5rem; }
.mb-row-left  { display:flex; align-items:center; gap:.5rem; flex-wrap:wrap; min-width:0; }
.mb-row-right { display:flex; align-items:center; gap:.4rem; flex-shrink:0; }
.mb-row-pill  { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
.mb-row-name  { font-size:.875rem; }
.mb-row-preview { font-size:.8rem; color:var(--text-muted); max-width:220px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

/* ── Badges ── */
.mb-badge { font-size:.72rem; padding:.2rem .5rem; border-radius:999px; white-space:nowrap; }
.mb-badge-unik  { background:rgba(88,101,242,.2); color:var(--accent); }
.mb-badge-biasa { background:var(--bg3); color:var(--text-muted); border:1px solid var(--border); }
.mb-badge-type  { background:rgba(87,242,135,.12); color:#57f287; border:1px solid rgba(87,242,135,.25); }
[data-theme="light"] .mb-badge-type { background:rgba(45,120,60,.1); color:#1e6b2e; border-color:rgba(45,120,60,.25); }

/* ── mb-section (Text Message / Embed Builder wrappers) ── */
.mb-section {
    border:1px solid var(--border); border-radius:var(--radius);
    overflow:visible; margin-bottom:.85rem;
}
.mb-section-head {
    display:flex; align-items:center; justify-content:space-between;
    padding:.45rem .85rem; background:var(--bg3);
    border-bottom:1px solid var(--border);
    border-radius:var(--radius) var(--radius) 0 0;
}
.mb-section-title { font-size:.8rem; font-weight:600; color:var(--text); display:flex; align-items:center; gap:.4rem; }
.mb-section-body  { padding:.85rem; display:flex; flex-direction:column; gap:.7rem; }

/* ── Embed builder inner sections ── */
.ee-body     { border:1px solid var(--border); border-radius:10px; overflow:visible; }
.ee-section  { padding:.85rem 1rem; }
.ee-sep      { height:1px; background:var(--border); }
.ee-sec-label { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); margin-bottom:.5rem; }
.ee-title-input { font-weight:600 !important; }
.input-sm   { font-size:.85rem !important; padding:.35rem .65rem !important; }

/* ── Color picker ── */
.mb-color-pk { width:30px; height:30px; padding:2px; border-radius:6px; border:1px solid var(--border); background:none; cursor:pointer; }

/* ── Dark mention button ── */
.cc-ph-dark-btn { font-size:.68rem; padding:2px 8px; background:rgba(255,255,255,.05); color:rgba(255,255,255,.35); border-color:rgba(255,255,255,.1); }
.cc-ph-dark-btn:hover { background:rgba(255,255,255,.12); color:rgba(255,255,255,.75); border-color:rgba(255,255,255,.2); }
.cc-ph-dark-btn.active { background:rgba(88,101,242,.2); border-color:rgba(88,101,242,.4); color:#c0c7ff; }
[data-theme="light"] .cc-ph-dark-btn { background:rgba(0,0,0,.04); color:var(--text-muted); border-color:var(--border); }
[data-theme="light"] .cc-ph-dark-btn:hover { background:rgba(0,0,0,.08); color:var(--text); }

/* ── Spoiler ── */
.dc-spoiler {
    background:var(--text-muted); border-radius:2px; color:transparent;
    cursor:pointer; transition:color .1s,background .1s; user-select:none; padding:0 2px;
}
.dc-spoiler.shown { color:var(--text); background:rgba(0,0,0,.25); }

/* ── Inline code in preview ── */
.mb-inline-code {
    background:rgba(0,0,0,.18); color:var(--text);
    padding:1px 5px; border-radius:3px; font-size:.85em;
    font-family:'Consolas',monospace;
}
[data-theme="light"] .mb-inline-code { background:rgba(0,0,0,.07); }
.mb-code-block {
    display:block; background:var(--bg3); border-radius:4px;
    padding:.4rem .75rem; font-family:'Consolas',monospace;
    font-size:.82em; white-space:pre; overflow-x:auto;
    color:var(--text); margin:.2rem 0;
}
[data-theme="light"] .mb-code-block { background:rgba(0,0,0,.05); }

/* ── Char counter ── */
.mb-char-count {
    text-align:right; font-size:.72rem; color:var(--text-muted);
    margin-top:.18rem; transition:color .2s; user-select:none;
}
.mb-char-count.warn   { color:#f0b232; }
.mb-char-count.danger { color:#ed4245; font-weight:600; }

/* ── Embed field rows (form) ── */
.cc-field-row { display:flex; gap:.6rem; align-items:flex-start; background:var(--bg3); border:1px solid var(--border); border-radius:8px; padding:.65rem .75rem; margin-bottom:.45rem; }
.cc-field-inputs { flex:1; min-width:0; display:flex; flex-direction:column; gap:.4rem; }
.cc-field-num { font-size:.73rem; color:var(--text-muted); font-weight:600; }
.cc-field-del { flex-shrink:0; align-self:flex-start; }
.cc-field-inline-row { display:flex; align-items:center; gap:.5rem; margin-top:.15rem; }
.cc-field-inline-row label { font-size:.8rem; color:var(--text-muted); cursor:pointer; display:flex; align-items:center; gap:.3rem; }
.ee-body .cc-field-row { background:var(--bg2,rgba(255,255,255,.02)); }
.ee-body .cc-field-inline-row input[type="checkbox"] { accent-color:#5865F2; }

/* ── URL warning ── */
.mb-url-warn {
    border-color: rgba(237,66,69,.55) !important;
    background: rgba(237,66,69,.05) !important;
}

/* ── Send modal (style dari global style.css) ── */

/* ── Panel-card shared styles ── */
.ar-panel-card {
    display:flex; align-items:center; gap:.6rem;
    background:var(--bg3); border:1px solid var(--border);
    border-radius:8px; padding:.5rem .75rem;
    margin-bottom:.4rem; transition:border-color .15s;
}
.ar-panel-card:hover { border-color:var(--accent); }
.ar-panel-row-left  { display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; flex:1; min-width:0; }
.ar-panel-row-right { display:flex; align-items:center; gap:.3rem; flex-shrink:0; margin-left:auto; }
.ar-panel-name {
    font-weight:600; font-size:.875rem; display:flex; align-items:center; gap:.3rem;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0;
}
.ar-panel-channel {
    font-size:.72rem; color:#5865F2; display:inline-flex; align-items:center;
    gap:.2rem; white-space:nowrap; flex-shrink:0;
    background:rgba(88,101,242,.12); padding:2px 7px; border-radius:12px;
}
.ar-panel-row-right .btn {
    min-height:28px !important; padding:.25rem .55rem !important;
    font-size:.78rem !important; line-height:1.2;
}
.ar-btn-delete {
    background:transparent; border:1.5px solid var(--border);
    color:#ed4245; border-radius:var(--radius,8px); cursor:pointer;
    transition:all .15s; min-height:28px !important; padding:.2rem .45rem;
    display:flex; align-items:center; justify-content:center;
}
.ar-btn-delete:hover { background:rgba(237,66,69,.1); border-color:#ed4245; }
.ar-saved-header { display:flex; align-items:center; gap:.75rem; margin-bottom:.75rem; }
.ar-saved-label  { font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); white-space:nowrap; }
.ar-saved-line   { flex:1; height:1px; background:var(--border); }
@media(max-width:520px) {
    .ar-saved-header { justify-content:space-between; }
    .ar-saved-label  { white-space:normal; line-height:1.3; max-width:72px; }
    .ar-saved-line   { display:none; }
    .ar-panel-channel, .mb-badge { display:none; }
}

/* ── Responsive ── */
@media (max-width:640px) {
    .mb-top-grid  { grid-template-columns:1fr !important; }
    .mb-url-pair  { grid-template-columns:1fr !important; }
    .mb-section-head { flex-wrap:wrap; gap:.4rem; }
    .ph-btn-group { flex-wrap:wrap; }
    .mb-row-preview { max-width:160px; }
}
@media (max-width:500px) {
    .mb-row:not(.ar-panel-card) { flex-direction:column; align-items:flex-start; }
    .mb-row-right { width:100%; justify-content:flex-end; }
    .mb-row-preview { max-width:none; }
    .settings-card { padding:1rem; }
}
@media (max-width:420px) {
    .mb-section-head { padding:.4rem .65rem; }
    .mb-section-body { padding:.65rem; }
    .ee-section { padding:.65rem .75rem; }
    .ph-toggle-btn { font-size:.68rem; padding:2px 7px; }
    .mb-char-count { font-size:.68rem; }
}
</style>

<script>
const GUILD_ID = '<%= guild.id %>';
const CHANNELS = <%- JSON.stringify(Object.fromEntries(channels.map(c => [c.id, { name: c.name, type: c.type }]))) %>;
const ROLES    = <%- JSON.stringify(Object.fromEntries((locals.roles||[]).map(r=>[r.id,{name:r.name,color:r.color}]))) %>;
const MB_SAMPLE = {
    user_username:  <%- JSON.stringify(loginUser.username || 'User') %>,
    user_id:        <%- JSON.stringify(loginUser.id || '0') %>,
    user_avatar:    <%- JSON.stringify(loginUser.avatarUrl || '') %>,
    server_name:    <%- JSON.stringify(guild.name || 'Server') %>,
    server_id:      <%- JSON.stringify(guild.id) %>,
    server_members: <%- JSON.stringify(String(guild.memberCount || guild.approximateMemberCount || 0)) %>,
    server_icon:    <%- JSON.stringify((typeof guild.iconURL === 'function' ? guild.iconURL({ size: 128 }) : '') || '') %>,
};
const MB_LIMIT = 20;
let mbEmbedFields = [];

const I18N_MB_NEW_TITLE   = '<%= t("message_builder.modal_new_title") %>';
const I18N_MB_CONFIRM_DEL = <%- JSON.stringify(t("message_builder.confirm_delete")) %>;
const I18N_MB_ERR_EMPTY   = '<%= t("message_builder.err_name_empty") %>';
const I18N_MB_ERR_INVALID = '<%= t("message_builder.err_name_invalid") %>';
const I18N_MB_ERR_NO_CH       = '<%= t("message_builder.err_no_channel") %>';
const I18N_MB_ERR_NO_CH_SEND  = <%- JSON.stringify(t("message_builder.err_no_channel_send")) %>;
const I18N_MB_ERR_LIMIT       = <%- JSON.stringify(t("message_builder.err_limit")) %>;
const I18N_MB_ERR_LOAD_TMPL   = <%- JSON.stringify(t("message_builder.err_load_template")) %>;
const I18N_MB_ERR_DUPLICATE    = <%- JSON.stringify(t("message_builder.err_duplicate")) %>;
const I18N_MB_ERR_URL_INVALID  = <%- JSON.stringify(t("message_builder.err_url_invalid")) %>;
const I18N_MB_ERR_URL_IMG      = <%- JSON.stringify(t("message_builder.err_url_not_image")) %>;
const I18N_MB_NO_TEMPLATES      = '<%= t("message_builder.no_templates") %>';
const I18N_MB_NO_TEMPLATES_HINT = '<%- t("message_builder.no_templates_hint") %>';
const I18N_MB_BADGE_TEXT = '<%= t("message_builder.badge_text") %>';
const I18N_MB_BADGE_BOTH = '<%= t("message_builder.badge_both") %>';

const MB_PLACEHOLDERS = [
    { group: 'USER', items: [
        ['{user.mention}',   'Mention user'],
        ['{user.username}',  'Username'],
        ['{user.id}',        'User ID'],
        ['{user.avatar}',    'Avatar URL'],
    ]},
    { group: 'SERVER', items: [
        ['{server.name}',    'Server name'],
        ['{server.id}',      'Server ID'],
        ['{server.members}', 'Member count'],
        ['{server.icon}',    'Server icon URL'],
    ]},
];

function buildMbPhPicker(pickerId, targetId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    let html = '';
    MB_PLACEHOLDERS.forEach(({ group, items }, gi) => {
        if (gi > 0) html += `<div style="grid-column:1/-1;height:1px;background:rgba(255,255,255,.1);margin:.2rem 0;"></div>`;
        html += `<div class="ph-group-label" style="grid-column:1/-1;">${group}</div>`;
        items.forEach(([ph, desc]) => {
            html += `<button type="button" class="ph-item" onclick="insertMbPlaceholder('${targetId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`;
        });
    });
    el.innerHTML = html;
}
function insertMbPlaceholder(targetId, text) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const start = el.selectionStart ?? el.value.length;
    const end   = el.selectionEnd   ?? el.value.length;
    el.value = el.value.slice(0, start) + text + el.value.slice(end);
    el.dispatchEvent(new Event('input', { bubbles: true }));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
}

let _sendingName = '';
let _sendingChannelId = '';
let _editingName = null;
let _savedTemplateData = null;

// ── Color picker sync ─────────────────────────────────────────────────────
function syncHex(inputId, pickerId) {
    document.getElementById(inputId).value = document.getElementById(pickerId).value;
}
function syncPicker(inputId, pickerId) {
    const val = document.getElementById(inputId).value;
    if (/^#[0-9A-Fa-f]{6}$/.test(val)) document.getElementById(pickerId).value = val;
}

// ── Form input handler ────────────────────────────────────────────────────
// ── Form snapshot for accurate dirty tracking ─────────────────────────────
// All MB fields have data-flt-ignore so the float bar's native isClean()
// can't see them. We maintain our own baseline snapshot instead.
let _mbBaselineSnap = null;
function _mbFormSnap() {
    const ids = [
        'editName','editChannelId','editColor',
        'editPlainText','editPlainImage',
        'editTitle','editTitleUrl','editDescription',
        'editFooter','editFooterIcon',
        'editAuthorName','editAuthorUrl','editAuthorIcon',
        'editImage','editThumbnail',
    ];
    const parts = ids.map(id => { const el = document.getElementById(id); return el ? el.value : ''; });
    const ts = document.getElementById('editTimestamp');
    parts.push(ts ? (ts.checked ? '1' : '0') : '0');
    parts.push(mbEmbedFields.map(f => `${f.name}\x01${f.value}\x01${f.inline}`).join('\x02'));
    return parts.join('\x00');
}
function _mbCaptureBaseline() { _mbBaselineSnap = _mbFormSnap(); }

function onFormInput() {
    updatePreview();
    if (_mbBaselineSnap !== null && _mbFormSnap() === _mbBaselineSnap) {
        window._floatClean?.();
    } else {
        window._floatDirty?.();
    }
}

// ── Toggle preview (eye icon) ─────────────────────────────────────────────
function toggleMbPreview() {
    const panel = document.querySelector('.preview-panel');
    const icon  = document.getElementById('mbPreviewEyeIcon');
    panel.classList.toggle('dc-preview-hidden');
    const hidden = panel.classList.contains('dc-preview-hidden');
    if (icon) {
        icon.innerHTML = hidden
            ? '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>'
            : '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>';
    }
}

// ── URL validation ────────────────────────────────────────────────────────
function mbIsHttpUrl(url) {
    if (!url) return true;
    try { const u = new URL(url); return u.protocol === 'http:' || u.protocol === 'https:'; } catch { return false; }
}
function mbWarnUrl(el, requireImg, event) {
    const rel = event?.relatedTarget;
    if (rel && (rel.id === 'flt-reset' || rel.closest?.('#flt-bar'))) return;
    const url = el.value.trim();
    let bad = false, tip = '';
    if (url) {
        if (!mbIsHttpUrl(url))    { bad = true; tip = '⚠ URL must start with https://'; }
        else if (requireImg && !isHttpImg(url)) { bad = true; tip = '⚠ Must be a direct image link (.png .jpg .gif .webp)'; }
    }
    el.classList.toggle('mb-url-warn', bad);
    el.title = bad ? tip : '';
}
function mbClearUrlWarns() {
    document.querySelectorAll('.mb-url-warn').forEach(el => { el.classList.remove('mb-url-warn'); el.title = ''; });
}

// ── Restore form from template data object (for reliable reset) ──────────
function _restoreFromData(t) {
    if (!t) return;
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.value = v; };
    set('editPlainText',   t.plainText   || '');
    set('editPlainImage',  t.plainImage  || '');
    set('editTitle',       t.title       || '');
    set('editTitleUrl',    t.titleUrl    || '');
    set('editDescription', t.description || '');
    set('editFooter',      t.footer      || '');
    set('editFooterIcon',  t.footerIcon  || '');
    set('editAuthorName',  t.authorName  || '');
    set('editAuthorIcon',  t.authorIcon  || '');
    set('editAuthorUrl',   t.authorUrl   || '');
    set('editImage',       t.image       || '');
    set('editThumbnail',   t.thumbnail   || '');
    const color = t.color || '#5865F2';
    set('editColor', color); set('editColorPicker', color);

    // Channel select is intentionally NOT set here — editTemplate() handles it
    // synchronously after display:'' (matching the autorole pattern).

    const ts = document.getElementById('editTimestamp'); if (ts) ts.checked = !!t.timestamp;
    document.getElementById('editName').disabled = true;
    mbEmbedFields = Array.isArray(t.fields) ? t.fields.map(f => ({ name: f.name || '', value: f.value || '', inline: !!f.inline })) : [];
    renderMbFields(); mbClearUrlWarns();
    mbResizeAll();
    mbUpdateCount('editPlainText', 'plainTextCount');
    mbUpdateCount('editDescription', 'descCount');
    updatePreview();
}

// ── Clear form ────────────────────────────────────────────────────────────
function clearForm() {
    ['editOriginalName','editName','editPlainText','editPlainImage','editTitle',
     'editTitleUrl','editDescription','editFooter','editFooterIcon',
     'editAuthorName','editAuthorIcon','editAuthorUrl','editImage','editThumbnail'
    ].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    const chSel = document.getElementById('editChannelId');
    if (chSel) {
        chSel.disabled = false;
        Array.from(chSel.options).forEach(o => { if (o.dataset.fallback) o.remove(); });
        chSel.selectedIndex = 0;
        const cselW = chSel.closest('.csel');
        if (cselW) {
            const tr = cselW.querySelector('.csel-trigger');
            if (tr) tr.textContent = chSel.options[0]?.textContent || '';
            cselW.querySelectorAll('.csel-option').forEach(o => o.classList.remove('active'));
            cselW.classList.remove('disabled');
        }
    }
    document.getElementById('editColor').value = '#5865F2';
    document.getElementById('editColorPicker').value = '#5865F2';
    document.getElementById('editTimestamp').checked = false;
    document.getElementById('editName').disabled = false;
    mbEmbedFields = [];
    renderMbFields();
    mbClearUrlWarns();
    mbResizeAll();
    mbUpdateCount('editPlainText', 'plainTextCount');
    mbUpdateCount('editDescription', 'descCount');
}

// ── _applyChannel: set channel value + disabled + lock indicator ─────────────
function _applyChannel(chId, locked) {
    const chSel = document.getElementById('editChannelId');
    if (!chSel) return;

    // Remove stale fallback options
    Array.from(chSel.options).forEach(o => { if (o.dataset.fallback) o.remove(); });

    // Set value BEFORE disabled — Chromium silently ignores .value on a disabled <select>.
    if (chId) {
        chSel.value = chId;
        if (chSel.value !== chId) {
            // Option not in guild list — add fallback
            let found = false;
            for (let i = 0; i < chSel.options.length; i++) {
                if (chSel.options[i].value === chId) { chSel.selectedIndex = i; found = true; break; }
            }
            if (!found) {
                const opt = document.createElement('option');
                opt.value = chId; opt.textContent = `#${chId}`; opt.dataset.fallback = '1';
                chSel.appendChild(opt);
                chSel.value = chId;
            }
        }
    } else {
        chSel.value = '';
    }
    chSel.disabled = locked;

    // Sync the .csel custom dropdown visual. dashboard.js wraps every select.select in a
    // .csel component at DOMContentLoaded — setting .value alone does NOT fire 'change',
    // so the .csel-trigger text stays stale unless we update it here directly.
    const cselWrapper = chSel.closest('.csel');
    if (cselWrapper) {
        const trigger = cselWrapper.querySelector('.csel-trigger');
        if (trigger) {
            const selOpt = chSel.options[chSel.selectedIndex];
            trigger.textContent = selOpt ? selOpt.textContent : '';
        }
        cselWrapper.querySelectorAll('.csel-option').forEach(o => {
            o.classList.toggle('active', o.dataset.value === chSel.value);
        });
        cselWrapper.classList.toggle('disabled', locked);
    }
}

// ── Edit template (fill form) ─────────────────────────────────────────────
async function editTemplate(name, markDirty = true) {
    const res  = await fetch(`/api/guild/${GUILD_ID}/message-builder/${encodeURIComponent(name)}`);
    const data = await res.json();
    if (!data.success) return showAlert(I18N_MB_ERR_LOAD_TMPL.replace('{{msg}}', data.message));
    const t = data.template;

    _editingName = name;
    _savedTemplateData = t;
    document.getElementById('editOriginalName').value = name;
    document.getElementById('editName').value = name;

    const _chId     = String(t.isSent ? (t.sentChannelId || t.channelId || '') : (t.channelId || '')).trim();
    const _chLocked = !!t.isSent;

    _restoreFromData(t);
    _applyChannel(_chId, _chLocked);
    _mbCaptureBaseline();

    document.getElementById('mbFormTitle').textContent = `Edit: ${name}`;
    document.getElementById('mbCancelEdit').style.display = '';
    document.getElementById('mbFormMsg').textContent = '';

    if (markDirty) {
        window._floatDirty?.();
        document.getElementById('mbFormCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
        setTimeout(() => window._floatCapture?.(), 50);
    }

    // Safety net: re-apply channel after resize rAF fires.
    requestAnimationFrame(() => { _applyChannel(_chId, _chLocked); });
    if (window.lucide) lucide.createIcons();
}

// ── New template (clear form, scroll to top) ─────────────────────────────
function newTemplate() {
    cancelEdit();
    document.getElementById('editName').focus();
}

// ── Cancel edit ───────────────────────────────────────────────────────────
function cancelEdit() {
    _editingName = null;
    _savedTemplateData = null;
    clearForm();
    document.getElementById('editName').disabled = false;
    document.getElementById('mbFormTitle').textContent = I18N_MB_NEW_TITLE;
    document.getElementById('mbCancelEdit').style.display = 'none';
    document.getElementById('mbFormMsg').textContent = '';
    updatePreview();
    _mbCaptureBaseline();
    window._floatClean?.();
}

// ── Render a single template card (DOM, no reload) ────────────────────────
function _mbRenderCard(name, tmpl, isSent, sentChannelId, sentMessageId) {
    const esc     = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const effChId = isSent ? (sentChannelId || tmpl.channelId || '') : (tmpl.channelId || '');
    const ch      = effChId ? CHANNELS[effChId] : null;
    const color   = tmpl.color || '#5865F2';
    const badge   = tmpl.messageType === 'plain' ? I18N_MB_BADGE_TEXT
                  : tmpl.messageType === 'both'  ? I18N_MB_BADGE_BOTH : 'Embed';
    const sz      = 'width:13px;height:13px;vertical-align:middle;';
    const nameEsc = esc(name);
    const viewOrSend = isSent && sentChannelId && sentMessageId
        ? `<a class="btn btn-outline btn-sm" href="https://discord.com/channels/${GUILD_ID}/${sentChannelId}/${sentMessageId}" target="_blank"><i data-lucide="external-link" style="${sz}margin-right:.2rem;"></i> View</a>`
        : `<button class="btn btn-outline btn-sm" onclick="openSendModal('${nameEsc}')"><i data-lucide="send" style="${sz}margin-right:.2rem;"></i>Send</button>`;
    const div = document.createElement('div');
    div.className = 'ar-panel-card mb-row';
    div.dataset.name = name;
    div.dataset.channelId = effChId;
    div.innerHTML = `
        <div class="ar-panel-row-left">
            <span class="ar-panel-name">
                <span style="width:10px;height:10px;border-radius:50%;background:${color};flex-shrink:0;display:inline-block;"></span>
                ${esc(name)}
            </span>
            ${ch ? `<span class="ar-panel-channel"><i data-lucide="hash" style="width:11px;height:11px;"></i>${esc(ch.name)}</span>` : ''}
            <span class="mb-badge mb-badge-type">${badge}</span>
        </div>
        <div class="ar-panel-row-right">
            <button class="btn btn-outline btn-sm" onclick="editTemplate('${nameEsc}')"><i data-lucide="pencil" style="${sz}margin-right:.25rem;"></i>Edit</button>
            ${viewOrSend}
            <button class="btn btn-sm ar-btn-delete" onclick="deleteTemplate('${nameEsc}')"><i data-lucide="trash-2" style="${sz}"></i></button>
        </div>`;
    requestAnimationFrame(() => {
        const icons = div.querySelectorAll('[data-lucide]');
        if (icons.length && window.lucide) lucide.createIcons({ nodes: [...icons] });
    });
    return div;
}

// ── Save template ─────────────────────────────────────────────────────────
async function saveTemplate() {
    const originalName = document.getElementById('editOriginalName').value;
    const isEdit = !!originalName;
    const name   = isEdit ? originalName : document.getElementById('editName').value.trim();
    const msg    = document.getElementById('mbFormMsg');

    if (!isEdit) {
        const curCount = document.querySelectorAll('.mb-row').length;
        if (curCount >= MB_LIMIT) { showAlert(I18N_MB_ERR_LIMIT); throw new Error(); }
    }
    if (!name) { showAlert(I18N_MB_ERR_EMPTY); throw new Error(); }
    if (!/^[a-zA-Z0-9_-]{1,32}$/.test(name)) { showAlert(I18N_MB_ERR_INVALID); throw new Error(); }
    if (!isEdit && document.querySelector(`.mb-row[data-name="${name}"]`)) {
        showAlert(I18N_MB_ERR_DUPLICATE.replace('{{name}}', name));
        throw new Error();
    }

    const channelId = document.getElementById('editChannelId').value;
    if (!channelId) { showAlert(I18N_MB_ERR_NO_CH); throw new Error(); }

    const plainText  = document.getElementById('editPlainText').value.trim();
    const plainImage = document.getElementById('editPlainImage').value.trim();
    const title      = document.getElementById('editTitle').value.trim();
    const desc       = document.getElementById('editDescription').value.trim();
    const authorName = document.getElementById('editAuthorName').value.trim();
    const footer     = document.getElementById('editFooter').value.trim();
    const image      = document.getElementById('editImage').value.trim();
    const thumb      = document.getElementById('editThumbnail').value.trim();

    const hasPlain = !!(plainText || plainImage);
    const hasEmbed = !!(title || desc || authorName || footer || image || thumb || mbEmbedFields.some(f => f.name.trim() || f.value.trim()));
    const messageType = (hasPlain && hasEmbed) ? 'both' : hasPlain ? 'plain' : 'embed';

    // Validate URL fields before saving
    const _urlFields = [
        { id: 'editPlainImage',  label: 'Image URL (text)',      img: true  },
        { id: 'editAuthorUrl',   label: 'Author URL',            img: false },
        { id: 'editAuthorIcon',  label: 'Author icon URL',       img: true  },
        { id: 'editTitleUrl',    label: 'Title URL',             img: false },
        { id: 'editFooterIcon',  label: 'Footer icon URL',       img: true  },
        { id: 'editImage',       label: 'Embed image URL',       img: true  },
        { id: 'editThumbnail',   label: 'Thumbnail URL',         img: true  },
    ];
    for (const f of _urlFields) {
        const val = document.getElementById(f.id)?.value.trim();
        if (!val) continue;
        if (!mbIsHttpUrl(val)) {
            showAlert(I18N_MB_ERR_URL_INVALID.replace('{{label}}', f.label));
            document.getElementById(f.id)?.classList.add('mb-url-warn');
            throw new Error();
        }
        if (f.img && !isHttpImg(val)) {
            showAlert(I18N_MB_ERR_URL_IMG.replace('{{label}}', f.label));
            document.getElementById(f.id)?.classList.add('mb-url-warn');
            throw new Error();
        }
    }

    const payload = {
        name, channelId, isNew: !isEdit,
        messageType, plainText, plainImage, title,
        description: desc, footer,
        footerIcon: document.getElementById('editFooterIcon').value.trim(),
        authorName,
        authorIcon: document.getElementById('editAuthorIcon').value.trim(),
        authorUrl:  document.getElementById('editAuthorUrl').value.trim(),
        titleUrl:   document.getElementById('editTitleUrl').value.trim(),
        image, thumbnail: thumb,
        color:     document.getElementById('editColor').value.trim() || '#5865F2',
        timestamp: document.getElementById('editTimestamp').checked,
        fields:    mbEmbedFields.filter(f => f.name.trim() || f.value.trim()),
    };

    const res  = await fetch(`/api/guild/${GUILD_ID}/message-builder`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); throw new Error(data.message); }

    const list = document.getElementById('mbList');
    // Remove empty state if present
    const emptyEl = list.querySelector('div[style*="text-align:center"]');
    if (emptyEl) emptyEl.remove();

    const isSent       = !!(_savedTemplateData?.isSent);
    const sentChId     = _savedTemplateData?.sentChannelId || '';
    const sentMsgId    = _savedTemplateData?.sentMessageId || '';
    const newCard      = _mbRenderCard(name, payload, isSent, sentChId, sentMsgId);
    const existingCard = list.querySelector(`.mb-row[data-name="${name}"]`);

    if (existingCard) {
        existingCard.replaceWith(newCard);
    } else {
        list.appendChild(newCard);
    }

    if (isEdit) {
        // Stay in edit mode — update saved snapshot so Reset works correctly
        _savedTemplateData = { ..._savedTemplateData, ...payload };
        _mbCaptureBaseline();
        window._floatClean?.();
    } else {
        cancelEdit();
    }

    refreshMbStats();
    const countEl = document.getElementById('mbTmplCount');
    if (countEl) countEl.textContent = document.querySelectorAll('.mb-row').length;

    showToast(data.message, 'success');
}

function refreshMbStats() {
    const total       = document.querySelectorAll('.mb-row').length;
    const withChannel = document.querySelectorAll('.mb-row[data-channel-id]:not([data-channel-id=""])').length;
    const full        = total >= 20;
    document.getElementById('statMbTotal').textContent       = total;
    document.getElementById('statMbWithChannel').textContent = withChannel;
    document.getElementById('statMbSlots').textContent       = `${total}/20`;
    document.getElementById('statMbSlots').style.color       = full ? '#ed4245' : '';
    const icon = document.getElementById('statMbSlotsIcon');
    if (icon) {
        icon.className = full ? 'stat-icon' : 'stat-icon stat-icon-comm';
        icon.style.cssText = full ? 'color:#ed4245;background:rgba(237,66,69,.12);' : '';
    }
    const newBtn = document.getElementById('mbNewBtn');
    if (newBtn) newBtn.disabled = full;
}

// ── Delete template ───────────────────────────────────────────────────────
async function deleteTemplate(name) {
    if (!await showConfirm('Delete Template', I18N_MB_CONFIRM_DEL.replace('{{name}}', name))) return;
    const res  = await fetch(`/api/guild/${GUILD_ID}/message-builder/${encodeURIComponent(name)}`, { method: 'DELETE' });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); return; }
    const row = document.querySelector(`.mb-row[data-name="${name}"]`);
    if (row) row.remove();
    showToast(data.message, 'success');
    refreshMbStats();
    const list    = document.getElementById('mbList');
    const count   = document.querySelectorAll('.mb-row').length;
    const countEl = document.getElementById('mbTmplCount');
    if (countEl) countEl.textContent = count;
    const badge   = document.getElementById('mbSlotBadge');
    if (badge) { badge.textContent = `${count}/20 slots`; badge.style.cssText = count >= 20 ? 'background:rgba(237,66,69,.18);color:#ed4245;' : ''; }
    if (!count) {
        list.innerHTML = `<div style="text-align:center;padding:2.5rem 1rem 2rem;"><i data-lucide="inbox" style="width:44px;height:44px;color:var(--text-muted);opacity:.35;display:block;margin:0 auto .85rem;"></i><div style="font-size:.9rem;font-weight:600;color:var(--text-muted);margin-bottom:.3rem;">${I18N_MB_NO_TEMPLATES}</div><div style="font-size:.8rem;color:var(--text-muted);opacity:.7;">${I18N_MB_NO_TEMPLATES_HINT}</div></div>`;
        const inboxIcon = list.querySelector('[data-lucide="inbox"]');
        if (inboxIcon && window.lucide) lucide.createIcons({ nodes: [inboxIcon] });
    }
    if (_editingName === name) cancelEdit();
}

// ── Send modal ────────────────────────────────────────────────────────────
function openSendModal(name) {
    const row = document.querySelector(`.mb-row[data-name="${name}"]`);
    const channelId = row?.dataset.channelId || '';
    if (!channelId) {
        showAlert(I18N_MB_ERR_NO_CH_SEND);
        return;
    }
    _sendingName = name;
    _sendingChannelId = channelId;
    const channelName = CHANNELS[channelId]?.name || channelId;
    document.getElementById('sendTemplateName').textContent = `"${name}"`;
    document.getElementById('sendChannelName').textContent  = `#${channelName}`;
    document.getElementById('sendMsg').textContent = '';
    document.getElementById('sendBackdrop').classList.add('open');
    document.getElementById('sendModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    if (window.lucide) lucide.createIcons();
}
function closeSendModal() {
    document.getElementById('sendBackdrop').classList.remove('open');
    document.getElementById('sendModal').classList.remove('open');
    document.body.style.overflow = '';
}
async function sendTemplate() {
    const msg = document.getElementById('sendMsg');
    const res = await fetch(`/api/guild/${GUILD_ID}/message-builder/${encodeURIComponent(_sendingName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({})
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); return; }

    // Update card: replace Send button with View link
    const list = document.getElementById('mbList');
    const existingCard = list.querySelector(`.mb-row[data-name="${_sendingName}"]`);
    if (existingCard) {
        const tmplData = { channelId: data.channelId, color: existingCard.querySelector('[style*="border-radius:50%"]')?.style.background || '#5865F2',
            messageType: existingCard.querySelector('.mb-badge-type')?.textContent?.includes('Embed') && existingCard.querySelector('.mb-badge-type')?.textContent?.includes('Text') ? 'both'
                : existingCard.querySelector('.mb-badge-type')?.textContent === 'Embed' ? 'embed' : 'plain' };
        existingCard.replaceWith(_mbRenderCard(_sendingName, tmplData, true, data.channelId, data.messageId));
    }

    // If currently editing this template, unlock channel field
    if (_editingName === _sendingName && _savedTemplateData) {
        _savedTemplateData.isSent       = true;
        _savedTemplateData.sentChannelId = data.channelId;
        _savedTemplateData.sentMessageId = data.messageId;
        _applyChannel(data.channelId, true);
    }

    showToast(data.message, 'success');
    setTimeout(closeSendModal, 800);
}

