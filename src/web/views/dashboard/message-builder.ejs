// ── Preview: Discord markdown + placeholders + mentions ───────────────────
function mbMentionBadge(color, text, bg) {
    bg = bg || color + '26';
    return `<span style="color:${color};background:${bg};border-radius:3px;padding:0 3px;font-weight:600;">${text}</span>`;
}
function mbChannelBadge(name) {
    return `<span style="color:#7289da;background:rgba(88,101,242,.15);border-radius:3px;padding:0 3px;font-weight:600;">#${name}</span>`;
}
function mbSubtle(t) {
    return `<span style="color:#5d9ef3;font-style:italic;font-size:.85em;">${t}</span>`;
}
function mbApplyInlineMd(s) {
    const saved = [];
    s = s.replace(/`([^`\n]+)`/g, (_, c) => {
        saved.push(`<code class="mb-inline-code">${c}</code>`);
        return '\x00' + (saved.length - 1) + '\x00';
    });
    s = s.replace(/\|\|(.+?)\|\|/g, '<span class="dc-spoiler" onclick="this.classList.toggle(\'shown\')">$1</span>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/___(.+?)___/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    s = s.replace(/__(.+?)__/g, '<u>$1</u>');
    s = s.replace(/\*([^*\n]+)\*/g, '<em>$1</em>');
    s = s.replace(/(?<!\w)_([^_\n]+)_(?!\w)/g, '<em>$1</em>');
    s = s.replace(/~~(.+?)~~/g, '<s>$1</s>');
    s = s.replace(/\[([^\]]+)\]\(https?:\/\/[^)]*\)/g, '<span style="color:#00aff4;text-decoration:underline;cursor:default;">$1</span>');
    s = s.replace(/https?:\/\/[^\s<>"'\x00)]+/g, url => {
        const clean = url.replace(/[.,;:!?\]>]+$/, '');
        return `<span style="color:#00aff4;text-decoration:underline;cursor:default;">${clean}</span>`;
    });
    return s.replace(/\x00(\d+)\x00/g, (_, i) => saved[+i]);
}
function mbApplyMd(s) {
    const lines = s.split('\n'), out = [];
    let inCb = false, cbLines = [];
    for (const line of lines) {
        if (/^```/.test(line)) {
            if (!inCb) { inCb = true; cbLines = []; }
            else { out.push('<span class="mb-code-block">' + cbLines.join('\n') + '</span>'); inCb = false; }
            continue;
        }
        if (inCb) { cbLines.push(line); continue; }
        let m;
        if ((m = line.match(/^### (.*)/)))        { out.push('<strong style="font-size:1em;">'    + mbApplyInlineMd(m[1]) + '</strong>'); continue; }
        if ((m = line.match(/^## (.*)/)))         { out.push('<strong style="font-size:1.17em;">' + mbApplyInlineMd(m[1]) + '</strong>'); continue; }
        if ((m = line.match(/^# (.*)/)))          { out.push('<strong style="font-size:1.5em;">'  + mbApplyInlineMd(m[1]) + '</strong>'); continue; }
        if ((m = line.match(/^-# (.*)/)))         { out.push('<span style="font-size:.78em;color:var(--text-muted);">' + mbApplyInlineMd(m[1]) + '</span>'); continue; }
        if ((m = line.match(/^&gt;(?: (.*))?$/))) { out.push('<div style="border-left:3px solid rgba(128,128,128,.5);padding:.1rem .5rem;margin:.1rem 0;opacity:.9;display:inline-block;min-width:calc(100% - .5rem);">' + mbApplyInlineMd(m[1] || '') + '</div>'); continue; }
        out.push(mbApplyInlineMd(line));
    }
    if (inCb && cbLines.length) out.push('<span class="mb-code-block">' + cbLines.join('\n') + '</span>');
    return out.join('<br>');
}
function mbResolvePreview(text, richMentions = false) {
    if (!text) return '';
    let s = escHtml(text);
    s = s
        .replace(/\{user\.mention\}/g,   mbMentionBadge('#7289da', '@' + escHtml(MB_SAMPLE.user_username), 'rgba(88,101,242,.15)'))
        .replace(/\{user\.username\}/g,  escHtml(MB_SAMPLE.user_username))
        .replace(/\{user\.id\}/g,        escHtml(MB_SAMPLE.user_id))
        .replace(/\{user\.avatar\}/g,    mbSubtle(escHtml(MB_SAMPLE.user_avatar || '[avatar url]')))
        .replace(/\{server\.name\}/g,    escHtml(MB_SAMPLE.server_name))
        .replace(/\{server\.id\}/g,      escHtml(MB_SAMPLE.server_id))
        .replace(/\{server\.members\}/g, escHtml(MB_SAMPLE.server_members))
        .replace(/\{server\.icon\}/g,    mbSubtle(escHtml(MB_SAMPLE.server_icon || '[icon url]')));
    if (richMentions) {
        s = s
            .replace(/&lt;(a?):([^:&]+):(\d+)&gt;/g, (_, anim, name, id) => {
                const ext = anim === 'a' ? 'gif' : 'webp';
                return `<img src="https://cdn.discordapp.com/emojis/${id}.${ext}?size=32" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`;
            })
            .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => {
                const r = ROLES[id];
                if (!r) return mbMentionBadge('#99aab5', '@Unknown Role');
                const col = r.color && r.color !== '#000000' ? r.color : null;
                return col
                    ? `<span style="color:${col};background:${col}22;border-radius:3px;padding:0 3px;font-weight:600;">@${escHtml(r.name)}</span>`
                    : mbMentionBadge('#99aab5', '@' + escHtml(r.name));
            })
            .replace(/&lt;@!?(\d+)&gt;/g, () => mbMentionBadge('#7289da', '@user', 'rgba(88,101,242,.15)'))
            .replace(/&lt;#(\d+)&gt;/g, (_, id) => {
                const name = CHANNELS[id]?.name;
                return mbChannelBadge(name ? escHtml(name) : id);
            })
            .replace(/@everyone\b/g, () => mbMentionBadge('#7289da', '@everyone', 'rgba(88,101,242,.15)'))
            .replace(/@here\b/g,     () => mbMentionBadge('#7289da', '@here',     'rgba(88,101,242,.15)'));
    }
    return mbApplyMd(s);
}
function mbResolveMentions(text) {
    if (!text) return '';
    let s = escHtml(text);
    return s
        .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => {
            const r = ROLES[id];
            return '@' + (r ? escHtml(r.name) : 'Unknown Role');
        })
        .replace(/&lt;@!?(\d+)&gt;/g, () => '@user')
        .replace(/&lt;#(\d+)&gt;/g, (_, id) => {
            const name = CHANNELS[id]?.name;
            return '#' + (name ? escHtml(name) : id);
        });
}

// ── Preview ───────────────────────────────────────────────────────────────
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function isHttpImg(url) { return url && /^https?:\/\/.+\.(png|jpe?g|gif|webp|bmp|avif)(?:[?#]|$)/i.test(url); }

function mbResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    const h = el.scrollHeight;
    el.style.height = h + 'px';
}
function mbResizeAll() {
    requestAnimationFrame(() => {
        document.querySelectorAll('.mb-url-area, .mb-auto-resize').forEach(mbResizeArea);
    });
}
function mbUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}

function mbUpdatePreviewChannel() {
    const el = document.getElementById('mbPreviewChannel');
    if (!el) return;
    const sel = document.getElementById('editChannelId');
    const id  = sel?.value;
    const ch  = id ? CHANNELS[id] : null;
    el.innerHTML = `<span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>${ch ? escHtml(ch.name) : 'preview'}`;
}

function updatePreview() {
    mbUpdatePreviewChannel();
    const plainText  = document.getElementById('editPlainText').value;
    const plainImage = document.getElementById('editPlainImage').value.trim();
    const title      = document.getElementById('editTitle').value.trim();
    const titleUrl   = document.getElementById('editTitleUrl').value.trim();
    const desc       = document.getElementById('editDescription').value.trim();
    const footer     = document.getElementById('editFooter').value.trim();
    const footerIcon = document.getElementById('editFooterIcon').value.trim();
    const author     = document.getElementById('editAuthorName').value.trim();
    const authorIcon = document.getElementById('editAuthorIcon').value.trim();
    const authorUrl  = document.getElementById('editAuthorUrl').value.trim();
    const color      = document.getElementById('editColor').value || '#5865F2';
    const image      = document.getElementById('editImage').value.trim();
    const thumb      = document.getElementById('editThumbnail').value.trim();
    const ts         = document.getElementById('editTimestamp').checked;

    const activeFields = mbEmbedFields.filter(f => f.name.trim() || f.value.trim());
    const hasPlain = !!(plainText.trim() || plainImage);
    const hasEmbed = !!(title || desc || author || footer || image || thumb || activeFields.length);

    // Plain text
    const plainEl = document.getElementById('mbPreviewPlain');
    if (plainText.trim()) { plainEl.innerHTML = mbResolvePreview(plainText, true); plainEl.style.display = ''; }
    else { plainEl.style.display = 'none'; }

    // Plain image
    const plainImgWrap = document.getElementById('mbPreviewPlainImageWrap');
    const plainImgEl   = document.getElementById('mbPreviewPlainImage');
    if (isHttpImg(plainImage)) { plainImgEl.src = plainImage; plainImgWrap.style.display = ''; }
    else { plainImgWrap.style.display = 'none'; }

    // Embed
    const embedEl = document.getElementById('mbPreviewEmbed');
    if (hasEmbed) {
        document.getElementById('mbPreviewPill').style.background = color;
        embedEl.style.display = '';

        // Author
        const dpAuthor = document.getElementById('mbPreviewAuthor');
        dpAuthor.style.display = author ? '' : 'none';
        if (author) {
            const aIconOk = isHttpImg(authorIcon);
            const innerHtml = authorUrl
                ? `<span style="cursor:pointer;text-decoration:underline;text-underline-offset:2px;text-decoration-color:rgba(128,128,128,.5);">${mbResolveMentions(author)}</span>`
                : mbResolveMentions(author);
            dpAuthor.innerHTML = (aIconOk ? `<img class="dc-author-icon" src="${escHtml(authorIcon)}" onerror="this.style.display='none'" alt=""> ` : '') +
                `<span class="dc-text-wrap">${innerHtml}</span>`;
        }

        // Title
        const dpTitle = document.getElementById('mbPreviewTitle');
        dpTitle.style.display = title ? '' : 'none';
        if (title) {
            const titleHtml = mbApplyInlineMd(mbResolveMentions(title));
            dpTitle.innerHTML = titleUrl
                ? `<span style="color:#5d9ef3;text-decoration:underline;text-underline-offset:2px;cursor:pointer;">${titleHtml}</span>`
                : titleHtml;
        }

        // Description
        const dpDesc = document.getElementById('mbPreviewDesc');
        dpDesc.style.display = desc ? '' : 'none';
        if (desc) dpDesc.innerHTML = mbResolvePreview(desc, true);

        // Fields
        const dpFields = document.getElementById('mbPreviewFields');
        if (activeFields.length) {
            dpFields.style.display = '';
            dpFields.innerHTML = activeFields.map(f =>
                `<div class="dc-embed-field${f.inline ? '' : ' dc-field-block'}">
                    <div class="dc-field-name">${mbResolvePreview(f.name || '​')}</div>
                    <div class="dc-field-value">${mbResolvePreview(f.value || '​', true)}</div>
                </div>`
            ).join('');
        } else { dpFields.style.display = 'none'; }

        // Thumbnail
        const dpThumb  = document.getElementById('mbPreviewThumb');
        const thumbImg = document.getElementById('mbPreviewThumbImg');
        if (thumb && /^https?:\/\//.test(thumb)) { thumbImg.src = thumb; dpThumb.style.display = ''; }
        else { dpThumb.style.display = 'none'; }

        // Image
        const dpImage  = document.getElementById('mbPreviewImage');
        const imageImg = document.getElementById('mbPreviewImageImg');
        if (image && /^https?:\/\//.test(image)) { imageImg.src = image; dpImage.style.display = ''; }
        else { dpImage.style.display = 'none'; }

        // Footer
        const dpFooter = document.getElementById('mbPreviewFooter');
        if (footer || ts) {
            dpFooter.style.display = '';
            const _d = new Date();
            const now = 'Today at ' + _d.toLocaleString('en-US', { hour:'numeric', minute:'2-digit', hour12:true });
            const fIconOk = isHttpImg(footerIcon);
            dpFooter.innerHTML =
                (fIconOk ? `<img class="dc-footer-icon" src="${escHtml(footerIcon)}" onerror="this.style.display='none'" alt=""> ` : '') +
                (footer ? `<span class="dc-text-wrap">${mbResolveMentions(footer)}</span>` : '') +
                (footer && ts ? '<span class="dc-footer-sep" style="flex-shrink:0;"> • </span>' : '') +
                (ts ? `<span style="flex-shrink:0;">${now}</span>` : '');
        } else { dpFooter.style.display = 'none'; }

    } else { embedEl.style.display = 'none'; }

    document.getElementById('mbPreviewEmpty').style.display = (hasPlain || hasEmbed) ? 'none' : '';
}

// ── Embed fields ──────────────────────────────────────────────────────────
function addMbField() {
    if (mbEmbedFields.length >= 25) return;
    mbEmbedFields.push({ name: '', value: '', inline: false });
    renderMbFields();
    onFormInput();
}
function removeMbField(idx) {
    mbEmbedFields.splice(idx, 1);
    renderMbFields();
    onFormInput();
}
function renderMbFields() {
    const container = document.getElementById('mbFieldsList');
    const countEl   = document.getElementById('mbFieldCount');
    if (countEl) countEl.textContent = `(${mbEmbedFields.length} / 25)`;
    if (!mbEmbedFields.length) { container.innerHTML = ''; return; }
    container.innerHTML = mbEmbedFields.map((f, i) => `
        <div class="cc-field-row" data-fi="${i}">
            <div class="cc-field-inputs">
                <div class="cc-field-num">Field #${i + 1}</div>
                <input type="text" class="input" placeholder="Field name…" maxlength="256" value="${escHtml(f.name)}"
                    oninput="mbEmbedFields[${i}].name=this.value;onFormInput()">
                <textarea class="input" placeholder="Field value…" maxlength="1024" rows="2" style="resize:vertical;"
                    oninput="mbEmbedFields[${i}].value=this.value;onFormInput()">${escHtml(f.value)}</textarea>
                <div class="cc-field-inline-row">
                    <label>
                        <input type="checkbox" ${f.inline ? 'checked' : ''} onchange="mbEmbedFields[${i}].inline=this.checked;onFormInput()">
                        Inline
                    </label>
                </div>
            </div>
            <button type="button" class="btn btn-danger btn-sm cc-field-del" onclick="removeMbField(${i})">
                <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
            </button>
        </div>`).join('');
    if (window.lucide) {
        const newIcons = container.querySelectorAll('[data-lucide]');
        if (newIcons.length) lucide.createIcons({ nodes: [...newIcons] });
    }
}

// ── Mention dropdowns ─────────────────────────────────────────────────────
function _buildMentionDd(dd, getTarget) {
    function item(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => {
            const ta = typeof getTarget === 'function' ? getTarget() : getTarget;
            if (!ta) return;
            const s = ta.selectionStart ?? ta.value.length;
            const ep = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, s) + mention + ta.value.slice(ep);
            ta.selectionStart = ta.selectionEnd = s + mention.length;
            ta.focus(); ta.dispatchEvent(new Event('input', {bubbles: true}));
            document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
            document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
        });
        return b;
    }
    function hdr(t) { const h = document.createElement('div'); h.className = 'ph-group-label'; h.textContent = t; return h; }
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => { el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special'));
    dd.appendChild(item('<code>@everyone</code>', '@everyone'));
    dd.appendChild(item('<code>@here</code>', '@here'));
    const rKeys = Object.keys(ROLES);
    if (rKeys.length) {
        dd.appendChild(hdr('Roles'));
        rKeys.forEach(id => { const r = ROLES[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`)); });
    }
    const cKeys = Object.keys(CHANNELS);
    if (cKeys.length) {
        dd.appendChild(hdr('Channels'));
        cKeys.forEach(id => { const name = CHANNELS[id]?.name || id; dd.appendChild(item(`<span>#${name}</span>`, `<#${id}>`)); });
    }
}
buildMbPhPicker('mbPlainPhPicker', 'editPlainText');
buildMbPhPicker('mbDescPhPicker',  'editDescription');
_buildMentionDd(document.getElementById('mbPlainMentionPicker'),  () => document.getElementById('editPlainText'));
_buildMentionDd(document.getElementById('mbEmbedMentionPicker'),  () => document.getElementById('editDescription'));

// ── Float bar ─────────────────────────────────────────────────────────────
window._floatSave = async () => saveTemplate();
window._floatReset = () => {
    if (_editingName && _savedTemplateData) {
        const t = _savedTemplateData;
        document.getElementById('editOriginalName').value = _editingName;
        document.getElementById('editName').value = _editingName;
        _restoreFromData(t);
        const chId = String(t.isSent ? (t.sentChannelId || t.channelId || '') : (t.channelId || '')).trim();
        _applyChannel(chId, !!t.isSent);
        _mbCaptureBaseline();
        window._floatClean?.();
        setTimeout(() => window._floatCapture?.(), 50);
    } else {
        cancelEdit();
    }
};
setTimeout(() => { window._floatCapture?.(); _mbCaptureBaseline(); }, 80);

// Resize all auto-resize textareas on load and on window resize
window.addEventListener('resize', mbResizeAll);
requestAnimationFrame(mbResizeAll);
</script>

