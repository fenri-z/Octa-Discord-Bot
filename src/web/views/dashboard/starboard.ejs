<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
.sb-config-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto 120px;
    gap: 1rem;
    align-items: flex-end;
}
.sb-emoji-group { display: flex; flex-direction: column; }
.sb-emoji-bubble {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 47px;
    height: 47px;
    border-radius: 8px;
    border: 2px dashed var(--border);
    background: var(--bg-secondary, rgba(255,255,255,.04));
    font-size: 1.4rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color .15s, background .15s;
    user-select: none;
}
.sb-emoji-bubble:hover { border-color: var(--accent, #5865F2); background: rgba(88,101,242,.08); }
.sb-emoji-bubble.has-emoji { border-style: solid; border-color: var(--border); }
.sb-emoji-empty { font-size: .75rem; opacity: .4; }
@media (max-width: 600px) {
    .sb-config-row { grid-template-columns: auto 1fr; align-items: start; }
    .sb-channel-group { grid-column: 1 / -1; }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'starboard' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <div class="page-header">
            <h1><%= t('starboard.page_title') %></h1>
            <p><%= t('starboard.page_desc') %></p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="star"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statSbStatus"><%= starboardData.enabled ? t('starboard.status_active') : t('starboard.status_inactive') %></div>
                    <div class="stat-label"><%= t('starboard.status_label') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="hash"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statSbChannel">
                        <% if (starboardData.channelId) { %>
                            <% var sbCh = guild.channels.cache.get(starboardData.channelId); %>
                            <%= sbCh ? '#' + sbCh.name : t('common.channel_deleted') %>
                        <% } else { %>—<% } %>
                    </div>
                    <div class="stat-label"><%= t('starboard.channel_label') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="award"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statSbThreshold"><%= starboardData.threshold %> ⭐</div>
                    <div class="stat-label"><%= t('starboard.min_stars') %></div>
                </div>
            </div>
        </div>

        <!-- How to Use -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('starboard.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('starboard.step1_title') %></div>
                    <div class="guide-desc"><%= t('starboard.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('starboard.step2_title') %></div>
                    <div class="guide-desc"><%= t('starboard.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('starboard.step3_title') %></div>
                    <div class="guide-desc"><%= t('starboard.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%= t('starboard.tip') %></div>
        </div>

        <!-- Configuration -->
        <div class="settings-card">
            <h2><%= t('starboard.config_title') %></h2>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="sbEnabled" class="toggle-input" <%= starboardData.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('starboard.enable_label') %></span>
                </label>
            </div>

            <div class="sb-config-row">
                <div class="form-group sb-channel-group">
                    <label class="label"><%= t('starboard.channel_label') %> <span style="color:#ed4245;">*</span></label>
                    <select id="sbChannel" class="select">
                        <option value=""><%= t('starboard.select_channel') %></option>
                        <% channels.forEach(function(ch) { %>
                            <option value="<%= ch.id %>" <%= starboardData.channelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group sb-emoji-group">
                    <label class="label"><%= t('starboard.emoji_label') %> <span style="color:#ed4245;">*</span></label>
                    <input type="hidden" id="sbEmoji" value="<%= starboardData.emoji %>">
                    <div class="sb-emoji-bubble <%= starboardData.emoji ? 'has-emoji' : '' %>"
                         id="sbEmojiBubble"
                         onclick="openSbEmojiPicker(this)"
                         title="Click to pick emoji">
                        <%
                            const em = starboardData.emoji;
                            if (em && em.includes(':')) {
                                const parts = em.split(':');
                        %>
                            <img src="https://cdn.discordapp.com/emojis/<%= parts[1] %>.webp?size=64" alt=":<%= parts[0] %>:" style="width:30px;height:30px;object-fit:contain;border-radius:4px;" onerror="this.style.display='none'">
                        <% } else if (em) { %>
                            <%= em %>
                        <% } else { %>
                            <span class="sb-emoji-empty">✨</span>
                        <% } %>
                    </div>
                </div>

                <div class="form-group sb-threshold-group">
                    <label class="label"><%= t('starboard.threshold_label') %> <span style="color:#ed4245;">*</span></label>
                    <input type="number" id="sbThreshold" class="input num-only" value="<%= starboardData.threshold %>" min="1" max="50">
                </div>
            </div>

            <div id="sbMsg" class="form-message"></div>
        </div>

    </div><!-- /.dash-content-wide -->
    </main>
</div><!-- /.dash-layout -->

<script>
const GUILD_ID       = '<%= guild.id %>';
const I18N_SB_ACTIVE      = '<%- t("starboard.status_active") %>';
const I18N_SB_INACTIVE    = '<%- t("starboard.status_inactive") %>';
const I18N_SB_ERR_THRESH  = <%- JSON.stringify(t("starboard.err_threshold")) %>;

function refreshSbStats() {
    const enabled   = document.getElementById('sbEnabled')?.checked;
    const threshold = document.getElementById('sbThreshold')?.value;
    const chSel     = document.getElementById('sbChannel');
    const chText    = chSel?.value ? (chSel.options[chSel.selectedIndex]?.text || '—') : '—';
    document.getElementById('statSbStatus').textContent    = enabled ? I18N_SB_ACTIVE : I18N_SB_INACTIVE;
    document.getElementById('statSbChannel').textContent   = chText !== '—' ? `#${chText.replace(/^#/, '')}` : '—';
    document.getElementById('statSbThreshold').textContent = `${threshold} ⭐`;
}

function showMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (type === 'success') setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

async function apiFetch(path, method, body) {
    const res = await fetch(`/api/guild/${GUILD_ID}${path}`, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body:    body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}

function openSbEmojiPicker(anchorEl) {
    EmojiPicker.open(anchorEl, function(value) {
        document.getElementById('sbEmoji').value = value;
        const bubble = document.getElementById('sbEmojiBubble');
        bubble.classList.add('has-emoji');
        bubble.title = 'Click to change emoji';
        if (value.includes(':')) {
            const [name, id] = value.split(':');
            bubble.innerHTML = `<img src="https://cdn.discordapp.com/emojis/${id}.webp?size=64" alt=":${name}:" style="width:30px;height:30px;object-fit:contain;border-radius:4px;" onerror="this.style.display='none'">`;
        } else {
            bubble.textContent = value;
        }
        if (window._floatDirty) window._floatDirty();
    });
}

async function saveConfig() {
    const msg       = document.getElementById('sbMsg');
    const threshold = parseInt(document.getElementById('sbThreshold').value, 10);
    if (isNaN(threshold) || threshold < 1 || threshold > 50) {
        showAlert(I18N_SB_ERR_THRESH);
        return;
    }
    const data = await apiFetch('/starboard', 'POST', {
        enabled:   document.getElementById('sbEnabled').checked,
        channelId: document.getElementById('sbChannel').value || null,
        emoji:     document.getElementById('sbEmoji').value.trim() || '⭐',
        threshold,
    });
    if (data.success) { showToast(data.message, 'success'); refreshSbStats(); }
    else showAlert(data.message);
}

document.addEventListener('keydown', function(e) {
    if (!e.target.classList.contains('num-only')) return;
    const allowed = ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Home','End'];
    if (allowed.includes(e.key) || /^\d$/.test(e.key)) return;
    e.preventDefault();
});
document.addEventListener('paste', function(e) {
    if (!e.target.classList.contains('num-only')) return;
    e.preventDefault();
    const text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
    if (text) document.execCommand('insertText', false, text);
});

window._floatSave = () => saveConfig();

document.addEventListener('DOMContentLoaded', function() {
    const input  = document.getElementById('sbThreshold');
    const bubble = document.getElementById('sbEmojiBubble');
    if (input && bubble) {
        const h = input.offsetHeight;
        bubble.style.height = h + 'px';
        bubble.style.width  = h + 'px';
    }
});
</script>

<script src="/js/emoji-picker.js"></script>
<script>
EmojiPicker.init(<%- JSON.stringify(guildEmojis || []) %>);
</script>

<%- include('../partials/footer') %>
