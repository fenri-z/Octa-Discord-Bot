<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style nonce="<%= typeof locals.nonce !== 'undefined' ? locals.nonce : '' %>">
/* ── Override accent → TikTok black/white ───────────────────────────────── */
:root                  { --accent: #ffffff; --accent-h: #cccccc; --accent-rgb: 255,255,255; }
[data-theme="light"]   { --accent: #000000; --accent-h: #333333; --accent-rgb: 0,0,0; }

/* ── Dark mode: white accent → fix contrast on buttons & toggle ─────────── */
:root:not([data-theme="light"]) .btn-primary { color: #111111 !important; }
:root:not([data-theme="light"]) .btn-primary:hover { color: #111111 !important; }
:root:not([data-theme="light"]) .toggle-input:checked + .toggle-slider::after { background: #111111 !important; }

/* ── Float save bar: ikut TikTok accent tapi fix warna teks agar kontras ── */
.flt-btn-save { background: var(--accent) !important; }
:root:not([data-theme="light"]) .flt-btn-save { color: #111111 !important; }

/* ── Stat icon background: selalu hitam pekat (TikTok brand) ────────────── */
.stat-icon.tt-brand-icon { background: #111111 !important; color: #ffffff !important; }

/* ── Layout 2 kolom per card (sama pola YouTube) ───────────────────────── */
.tt-panel-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1.25rem;
    align-items: start;
}
@media (max-width: 860px) { .tt-panel-layout { grid-template-columns: 1fr; } }

/* ── Preview sticky ──────────────────────────────────────────────────────── */
.tt-preview-col { position: sticky; top: calc(var(--navbar-h, 56px) + 1rem); }
.preview-label  {
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: .5rem;
}

/* ── TikTok thumbnail mock ───────────────────────────────────────────────── */
.tt-thumb-mock {
    border-radius: 4px; overflow: hidden;
    background: #111; aspect-ratio: 9/16;
    max-width: 160px; /* TikTok vertikal */
    display: flex; align-items: center; justify-content: center;
    margin-top: .6rem;
}
.tt-thumb-mock-inner {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(254,44,85,.85);
    display: flex; align-items: center; justify-content: center;
}
.tt-thumb-mock-inner svg { width: 16px; height: 16px; fill: #fff; }

/* ── Tab buttons (YouTube-style) ─────────────────────────────────────────── */
.tt-tabs-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .4rem;
    margin-bottom: 1.1rem;
    border-bottom: 1px solid var(--border, rgba(255,255,255,.06));
    padding-bottom: .75rem;
}
.tt-tab-btn {
    text-align: center; padding: .38rem .4rem;
    border-radius: 20px; font-size: .82rem; font-weight: 500;
    cursor: pointer; border: none; background: transparent;
    color: var(--text-muted); transition: all .15s; white-space: nowrap;
}
.tt-tab-btn.active-video { background: rgba(1,1,1,.5);    color: #fff;    }
.tt-tab-btn.active-live  { background: rgba(254,44,85,.18); color: #FE2C55; }

/* ── Account card ────────────────────────────────────────────────────────── */
.tt-channel-card {
    border-radius: 10px; padding: 1.1rem; margin-bottom: 1.25rem;
}
.tt-card-header {
    display: flex; align-items: center; gap: .85rem; margin-bottom: 1rem;
}
.tt-card-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    object-fit: cover; flex-shrink: 0; background: #111;
}
.tt-card-avatar-placeholder {
    width: 44px; height: 44px; border-radius: 50%;
    background: #010101; display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
}
.tt-card-name { font-weight: 600; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── Responsive: Tablet (≤ 860px) ───────────────────────────────────────── */
@media (max-width: 860px) {
    .tt-panel-layout  { grid-template-columns: 1fr; }
    .tt-preview-col   { position: static; }
}

/* ── Responsive: Tablet kecil (≤ 680px) ─────────────────────────────────── */
@media (max-width: 680px) {
    .dash-main        { padding: 1.25rem 1rem 1.5rem !important; }
    .settings-card    { padding: 1rem !important; }
    .tt-channel-card  { padding: .9rem; }
    .tt-thumb-mock    { border-radius: 10px; }

    /* Card header lebih kompak */
    .tt-card-header   { gap: .6rem; }
    .tt-card-avatar,
    .tt-card-avatar-placeholder { width: 38px; height: 38px; }
    .tt-card-name     { font-size: .9rem; }

    /* Tombol aksi di header lebih kecil */
    .tt-card-header .btn-sm { padding: .25rem .4rem; }

    /* Search row stack vertikal */
    .tt-search-row    { flex-direction: column !important; }
    .tt-search-row .btn { width: 100%; justify-content: center; }

    /* Tombol simpan/test full width */
    .tt-action-row    { flex-direction: column !important; }
    .tt-action-row .btn { width: 100%; justify-content: center; }
}

/* ── Search loading states ───────────────────────────────────────────────── */
@keyframes tt-spin    { to { transform: rotate(360deg); } }
@keyframes tt-shimmer { 0% { background-position:-200% 0; } 100% { background-position:200% 0; } }
@keyframes tt-dot     { 0%,80%,100% { transform:scale(0);opacity:.3; } 40% { transform:scale(1);opacity:1; } }

.tt-spinner {
    width: 13px; height: 13px;
    border: 2px solid rgba(255,255,255,.22);
    border-top-color: #fff;
    border-radius: 50%;
    animation: tt-spin .65s linear infinite;
    display: inline-block; vertical-align: middle; flex-shrink: 0;
}
.tt-skeleton {
    background: linear-gradient(90deg,
        rgba(255,255,255,.04) 25%,
        rgba(255,255,255,.11) 50%,
        rgba(255,255,255,.04) 75%);
    background-size: 200% 100%;
    animation: tt-shimmer 1.4s ease-in-out infinite;
    border-radius: 5px;
}
.tt-dot-row { display:inline-flex; gap:3px; align-items:center; }
.tt-dot-row span {
    width:5px; height:5px; border-radius:50%; background:#FE2C55;
    animation: tt-dot 1.2s ease-in-out infinite;
}
.tt-dot-row span:nth-child(2) { animation-delay:.2s; }
.tt-dot-row span:nth-child(3) { animation-delay:.4s; }

/* ── Responsive: Mobile (≤ 480px) ───────────────────────────────────────── */
@media (max-width: 480px) {
    .dash-main        { padding: 1rem .75rem 1.5rem !important; }
    .tt-channel-card  { padding: .75rem; }

    /* Tab buttons lebih kecil */
    .tt-tab-btn       { font-size: .76rem !important; padding: .32rem .3rem !important; }

    /* Tombol header lebih kompak di mobile */
    .tt-card-header .btn-sm { padding: .3rem .45rem; }

    /* Label dengan picker: wrap */
    .label-with-picker { flex-wrap: wrap; gap: .35rem; }
}

/* ── Responsive: Mobile kecil (≤ 380px) ─────────────────────────────────── */
@media (max-width: 380px) {
    .dash-main        { padding: .85rem .6rem 1.5rem !important; }
    .tt-channel-card  { padding: .65rem; }

    /* Card header: wrap action buttons */
    .tt-card-header   { flex-wrap: wrap; gap: .35rem !important; }
    .tt-card-header > a.btn,
    .tt-card-header > button.btn { padding: .2rem .32rem !important; }

    /* Page header: stack */
    .page-header      { flex-direction: column !important; align-items: flex-start !important; }

    /* Textarea kompak */
    .tt-form-col .textarea, .form-group .textarea { min-height: 70px; }

    /* Lookup result wraps */
    .tt-lookup-result-inner { flex-wrap: wrap !important; }
    .tt-lookup-result-inner .btn { width: 100%; justify-content: center; margin-top: .3rem; }
}

/* TikTok brand icon: hitam di light mode, putih di dark mode */
.tt-brand-icon { color: #fff; }
[data-theme="light"] .tt-brand-icon { color: #000; }
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'tiktok' }) %>
    <main class="dash-main" style="max-width:100%;overflow-x:hidden;">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <!-- Header -->
        <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
            <div>
                <h1><%= t('tiktok.page_title') %></h1>
                <p><%= t('tiktok.page_desc') %></p>
            </div>
        </div>

        <!-- Live warning -->
        <% if (!liveSupported) { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="alert-triangle"></i>
            <span><strong>Live detection tidak aktif.</strong> Jalankan <code>npm install tiktok-live-connector</code> lalu restart bot.</span>
        </div>
        <% } %>

        <!-- Stats -->
        <div class="stats-grid" style="margin-bottom:1.5rem;">
            <div class="stat-card">
                <div class="stat-icon tt-brand-icon stat-icon-comm">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </div>
                <div class="stat-info">
                    <div class="stat-value" id="statAccounts"><%= ttAccounts.length %></div>
                    <div class="stat-label"><%= t('tiktok.stat_monitored') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon tt-brand-icon stat-icon-comm"><i data-lucide="video"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statVideoEnabled"><%= ttAccounts.filter(a => a.videoEnabled).length %></div>
                    <div class="stat-label"><%= t('tiktok.stat_video') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon tt-brand-icon stat-icon-comm"><i data-lucide="radio"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statLiveEnabled"><%= ttAccounts.filter(a => a.liveEnabled).length %></div>
                    <div class="stat-label"><%= t('tiktok.stat_live') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon tt-brand-icon stat-icon-comm"><i data-lucide="list"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statSlots"><%= maxAccounts - ttAccounts.length %></div>
                    <div class="stat-label"><%= t('tiktok.stat_slots') %></div>
                </div>
            </div>
        </div>

        <!-- Add Account -->
        <div id="ttAddCard" class="settings-card" style="margin-bottom:1.5rem;<%- ttAccounts.length >= maxAccounts ? 'display:none;' : '' %>">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;">
                <i data-lucide="plus-circle" class="tt-brand-icon" style="width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('tiktok.add_title') %></h2>
            </div>
            <p id="ttAddDesc" style="font-size:.85rem;color:var(--text-muted);margin:0 0 1rem 0;">
                <%- t('tiktok.add_desc', { remaining: maxAccounts - ttAccounts.length, max: maxAccounts }) %>
            </p>
            <div class="form-group" style="margin-bottom:0;">
                <label class="label"><%= t('tiktok.search_label') %></label>
                <div class="tt-search-row" style="display:flex;gap:.6rem;">
                    <input type="text" id="ttLookupInput" class="input"
                           placeholder="@username  atau  https://tiktok.com/@username"
                           style="flex:1;min-width:0;" maxlength="200" data-flt-ignore
                           onkeydown="if(event.key==='Enter') lookupTikTok()">
                    <button class="btn btn-primary" onclick="lookupTikTok()" id="ttLookupBtn" style="white-space:nowrap;flex-shrink:0;">
                        <i data-lucide="search" style="width:14px;height:14px;"></i> <%= t('tiktok.search_btn') %>
                    </button>
                </div>
            </div>

            <!-- Status bar saat sedang mencari -->
            <div id="ttSearchStatus" style="display:none;margin-top:.75rem;padding:.65rem 1rem;background:rgba(254,44,85,.07);border:1px solid rgba(254,44,85,.2);border-radius:8px;align-items:center;gap:.75rem;">
                <div class="tt-spinner" style="border-color:rgba(254,44,85,.25);border-top-color:#FE2C55;width:16px;height:16px;border-width:2.5px;"></div>
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:.5rem;">
                        <span id="ttStatusText" style="font-size:.83rem;color:#FE2C55;font-weight:600;"></span>
                        <span class="tt-dot-row"><span></span><span></span><span></span></span>
                    </div>
                    <div style="font-size:.74rem;color:var(--text-muted);margin-top:.15rem;"><%= t('tiktok.searching_wait') %></div>
                </div>
            </div>

            <!-- Skeleton placeholder hasil pencarian -->
            <div id="ttSearchSkeleton" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border,rgba(255,255,255,.06));">
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <div class="tt-skeleton" style="width:42px;height:42px;border-radius:50%;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:.45rem;">
                        <div class="tt-skeleton" style="height:13px;width:52%;"></div>
                        <div class="tt-skeleton" style="height:10px;width:35%;"></div>
                    </div>
                    <div class="tt-skeleton" style="width:70px;height:30px;border-radius:6px;flex-shrink:0;"></div>
                </div>
            </div>

            <!-- Error / pesan lookup -->
            <div id="ttLookupMsg" class="form-message" style="margin-top:.5rem;"></div>

            <div id="ttLookupResult" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border,rgba(255,255,255,.06));">
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <img id="ttLookupThumb" src="" alt=""
                         style="width:42px;height:42px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#111;"
                         onerror="this.style.display='none'">
                    <div style="flex:1;min-width:0;">
                        <div id="ttLookupName" style="font-weight:600;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
                        <div id="ttLookupUsername" style="font-size:.78rem;color:var(--text-muted);"></div>
                    </div>
                    <button class="btn btn-success" onclick="addAccount()" style="flex-shrink:0;">
                        <i data-lucide="plus" style="width:14px;height:14px;"></i> <%= t('tiktok.add_btn') %>
                    </button>
                </div>
            </div>
        </div>
        <div id="ttMaxBanner" class="perm-card perm-warn" style="margin-bottom:1.5rem;<%- ttAccounts.length < maxAccounts ? 'display:none;' : '' %>">
            <i data-lucide="info"></i>
            <span><%- t('tiktok.max_reached', { max: maxAccounts }) %></span>
        </div>

        <!-- Daftar Akun -->
        <div id="ttAccountList">
            <div id="ttEmptyState" class="settings-card" style="text-align:center;padding:3rem 1.5rem;<%- ttAccounts.length > 0 ? 'display:none;' : '' %>">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:48px;height:48px;color:var(--text-muted);opacity:.5;display:block;margin:0 auto .75rem;"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                <p style="color:var(--text-muted);margin:0;"><%= t('tiktok.no_accounts') %></p>
            </div>
        <% ttAccounts.forEach(function(acc) {
            const key = acc.username.replace('@','').replace(/\./g,'_');
            acc.name = (acc.name||acc.username).replace(/\s+on\s+TikTok\s*$/i,'').trim();
        %>
        <div class="settings-card tt-channel-card" id="ttCard-<%= key %>">

            <!-- Header akun -->
            <div class="tt-card-header">
                <% if (acc.thumbnail) { %>
                <img src="<%= acc.thumbnail %>" alt="" class="tt-card-avatar"
                     data-tt-thumb="<%= acc.username %>"
                     referrerpolicy="no-referrer"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="tt-card-avatar-placeholder" style="display:none;">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </div>
                <% } else { %>
                <div class="tt-card-avatar-placeholder">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </div>
                <% } %>
                <div style="flex:1;min-width:0;">
                    <div class="tt-card-name"><%= acc.name || acc.username %></div>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.1rem;">
                        <%= acc.username %>
                    </div>
                    <% if (acc.broken) { %>
                    <span class="server-badge badge-red" title="<%= t('tiktok.badge_broken_tooltip') %>">
                        <%= t('tiktok.badge_broken') %>
                    </span>
                    <% } %>
                </div>
                <% if (acc.broken) { %>
                <button class="btn btn-sm btn-success" id="ttReenableBtn-<%= key %>"
                        onclick="reEnableAccount('<%= acc.username %>', '<%= key %>')"
                        style="flex-shrink:0;" title="Aktifkan kembali akun ini">
                    <i data-lucide="rotate-ccw" style="width:13px;height:13px;"></i>
                </button>
                <% } %>
                <a href="https://www.tiktok.com/<%= acc.username %>" target="_blank" class="btn btn-sm" style="flex-shrink:0;" title="Buka di TikTok">
                    <i data-lucide="external-link" style="width:13px;height:13px;"></i>
                </a>
                <button class="btn btn-sm btn-danger"
                        data-username="<%= acc.username %>"
                        data-name="<%= (acc.name||acc.username).replace(/"/g,'&quot;') %>"
                        onclick="removeAccount(this.dataset.username, this.dataset.name)"
                        style="flex-shrink:0;" title="Delete account">
                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                </button>
            </div>

            <!-- Tab Video / Live -->
            <div class="tt-tabs-row">
                <button class="tt-tab-btn active-video" id="tab-video-<%= key %>"
                        onclick="switchTab('<%= key %>','video')">🎬 Video</button>
                <button class="tt-tab-btn" id="tab-live-<%= key %>"
                        onclick="switchTab('<%= key %>','live')">
                    🔴 Live<% if (!liveSupported) { %> <span style="font-size:.65rem;opacity:.5;"><%= t('tiktok.live_inactive') %></span><% } %>
                </button>
            </div>

            <!-- 2-kolom: form | preview -->
            <div class="tt-panel-layout">

                <!-- Kiri: form -->
