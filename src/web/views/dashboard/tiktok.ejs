<script nonce="<%= typeof locals.nonce !== 'undefined' ? locals.nonce : '' %>">
const GUILD_ID    = '<%= guild.id %>';
const CHANNELS    = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;
const ROLES_MAP   = <%- JSON.stringify(Object.fromEntries((locals.roles||[]).map(r=>[r.id,r]))) %>;
const CHANNELS_MAP= <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(c=>[c.id,c]))) %>;

const I18N_TT_CONFIRM_DEL  = <%- JSON.stringify(t("tiktok.confirm_delete")) %>;
const TT_MAX_ACCOUNTS      = <%= maxAccounts %>;
const TT_ADD_DESC_TPL      = <%- JSON.stringify(t("tiktok.add_desc", { remaining: '__N__', max: maxAccounts })) %>;
const I18N_TT_ERR_VIDEO_CH = '<%= t("tiktok.err_no_video_channel") %>';
const I18N_TT_ERR_LIVE_CH  = '<%= t("tiktok.err_no_live_channel") %>';
const I18N_TT_SEARCH_BTN   = '<%= t("tiktok.search_btn") %>';
const I18N_TT_SEARCHING    = '<%= t("tiktok.searching") %>';
const I18N_TT_TIP_1        = '<%= t("tiktok.tip_1") %>';
const I18N_TT_TIP_2        = '<%= t("tiktok.tip_2") %>';
const I18N_TT_TIP_3        = '<%= t("tiktok.tip_3") %>';
const I18N_TT_TIP_4        = '<%= t("tiktok.tip_4") %>';
const I18N_TT_ERR_CONN     = '<%= t("tiktok.err_conn") %>';
const I18N_TT_ERR_CONNECT  = '<%= t("tiktok.err_connect") %>';
const I18N_TT_SENDING_TEST = '<%= t("tiktok.sending_test") %>';
const I18N_TT_PREV_NO_CH   = '<%= t("common.preview_no_channel") %>';

// ── Lookup ────────────────────────────────────────────────────────────────────
let _lookupData = null;

async function lookupTikTok() {
    const input      = document.getElementById('ttLookupInput').value.trim();
    const btn        = document.getElementById('ttLookupBtn');
    const resEl      = document.getElementById('ttLookupResult');
    const statusEl   = document.getElementById('ttSearchStatus');
    const skeletonEl = document.getElementById('ttSearchSkeleton');
    const msgEl      = document.getElementById('ttLookupMsg');
    if (!input) return;

    // Reset state
    resEl.style.display      = 'none';
    statusEl.style.display   = 'none';
    skeletonEl.style.display = 'none';
    if (msgEl) { msgEl.textContent = ''; msgEl.className = 'form-message'; }
    _lookupData = null;

    // Loading state
    btn.disabled   = true;
    btn.innerHTML  = `<span class="tt-spinner"></span> ${I18N_TT_SEARCHING}`;

    // Status bar
    const tips = [I18N_TT_TIP_1, I18N_TT_TIP_2, I18N_TT_TIP_3, I18N_TT_TIP_4];
    let tipIdx = 0;
    const statusTextEl = document.getElementById('ttStatusText');
    if (statusTextEl) statusTextEl.textContent = tips[0];
    statusEl.style.display   = 'flex';
    skeletonEl.style.display = 'block';

    const tipTimer = setInterval(() => {
        tipIdx = (tipIdx + 1) % tips.length;
        if (statusTextEl) statusTextEl.textContent = tips[tipIdx];
    }, 3500);

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/lookup`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input }),
        });
        const data = await r.json();
        if (!data.success) {
            if (msgEl) showMsg(msgEl, data.message, 'error', true);
            return;
        }
        _lookupData = data.account;
        const thumb = document.getElementById('ttLookupThumb');
        thumb.src = _lookupData.thumbnail || '';
        thumb.style.display = _lookupData.thumbnail ? 'block' : 'none';
        document.getElementById('ttLookupName').textContent     = _lookupData.name;
        document.getElementById('ttLookupUsername').textContent = _lookupData.username;
        resEl.style.display = 'block';
    } catch (err) {
        if (msgEl) showMsg(msgEl, I18N_TT_ERR_CONN + err.message, 'error', true);
    } finally {
        clearInterval(tipTimer);
        statusEl.style.display   = 'none';
        skeletonEl.style.display = 'none';
        btn.disabled  = false;
        btn.innerHTML = `<i data-lucide="search" style="width:14px;height:14px;"></i> ${I18N_TT_SEARCH_BTN}`;
        if (window.lucide) lucide.createIcons();
    }
}

async function addAccount() {
    if (!_lookupData) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: _lookupData.username, name: _lookupData.name, thumbnail: _lookupData.thumbnail }),
    });
    const data = await r.json();
    if (data.success) { queueToast(data.message, 'success'); location.reload(); }
    else showAlert(data.message);
}

// ── Discord Markdown renderer ──────────────────────────────────────────────────
function discordMd(raw) {
    if (!raw) return '';
    const _t=[]; const _T=i=>`\x00${i}\x00`;
    let _src = raw
        .replace(/<a:(\w+):(\d+)>/g, (_,name,id)=>{ _t.push(`<img src="https://cdn.discordapp.com/emojis/${id}.gif" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`);  return _T(_t.length-1); })
        .replace(/<:(\w+):(\d+)>/g,  (_,name,id)=>{ _t.push(`<img src="https://cdn.discordapp.com/emojis/${id}.webp" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`); return _T(_t.length-1); })
        .replace(/<@&(\d+)>/g,  (_,id)=>{ const r=ROLES_MAP[id],c=r?.color||'#5865F2'; _t.push(`<span class="dc-mention" style="color:${c};background:${c}1a;">@${r?r.name:id}</span>`); return _T(_t.length-1); })
        .replace(/<@!?(\d+)>/g, (_,id)=>{ _t.push(`<span class="dc-mention">@${id}</span>`); return _T(_t.length-1); })
        .replace(/<#(\d+)>/g,   (_,id)=>{ const ch=CHANNELS_MAP[id]; _t.push(`<span class="dc-mention">#${ch?ch.name:id}</span>`); return _T(_t.length-1); })
        .replace(/@everyone/g,()=>{ _t.push('<span class="dc-mention">@everyone</span>'); return _T(_t.length-1); })
        .replace(/@here/g,    ()=>{ _t.push('<span class="dc-mention">@here</span>'); return _T(_t.length-1); });
    let s = _src.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    s = s.replace(/^### (.+)$/gm, '<span style="font-size:.88em;font-weight:700;line-height:1.6;display:block">$1</span>');
    s = s.replace(/^## (.+)$/gm,  '<span style="font-size:1em;font-weight:700;line-height:1.75;display:block">$1</span>');
    s = s.replace(/^# (.+)$/gm,   '<span style="font-size:1.15em;font-weight:700;line-height:2;display:block">$1</span>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>');
    s = s.replace(/\*([^*\n]+?)\*/g,    '<em>$1</em>');
    s = s.replace(/_([^_\n]+?)_/g,      '<em>$1</em>');
    s = s.replace(/__([^_\n]+?)__/g,    '<u>$1</u>');
    s = s.replace(/~~(.+?)~~/g,         '<s>$1</s>');
    s = s.replace(/`([^`]+)`/g, '<code style="background:rgba(255,255,255,.07);padding:0 4px;border-radius:3px;font-size:.83em;font-family:monospace">$1</code>');
    s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" onclick="return false;" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/(https?:\/\/[^\s<\x00]+)/g, '<a href="$1" target="_blank" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/^&gt; (.+)$/gm, '<span style="border-left:3px solid #4e5058;padding-left:.5em;color:#b5bac1;display:block">$1</span>');
    s = s.replace(/\n/g, '<br>');
    s = s.replace(/\x00(\d+)\x00/g, (_,i)=>_t[+i]);
    return s;
}

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(key, tab) {
    const isVideo = tab === 'video';
    document.getElementById(`tab-video-${key}`).className = isVideo ? 'tt-tab-btn active-video' : 'tt-tab-btn';
    document.getElementById(`tab-live-${key}`).className  = isVideo ? 'tt-tab-btn' : 'tt-tab-btn active-live';
    document.getElementById(`panel-video-${key}`).style.display = isVideo ? '' : 'none';
    document.getElementById(`panel-live-${key}`).style.display  = isVideo ? 'none' : '';
    document.getElementById(`prev-video-${key}`).style.display  = isVideo ? '' : 'none';
    document.getElementById(`prev-live-${key}`).style.display   = isVideo ? 'none' : '';
    // Update test button label
    const testBtn = document.getElementById(`testBtn-${key}`);
    if (testBtn) testBtn.dataset.tab = tab;
    updatePreview(key);
}

// ── Update preview ────────────────────────────────────────────────────────────
function updatePreview(key) {
    const chanId  = document.getElementById(`vidChannel-${key}`)?.value || '';
    document.getElementById(`prevCh-${key}`).textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : I18N_TT_PREV_NO_CH;

    const liveChanId = document.getElementById(`liveChannel-${key}`)?.value || '';
    const liveChanEl = document.getElementById(`prevChLive-${key}`);
    if (liveChanEl) liveChanEl.textContent = liveChanId && CHANNELS[liveChanId] ? CHANNELS[liveChanId] : I18N_TT_PREV_NO_CH;

    // Ambil nama akun dari header card
    const accName = document.getElementById(`ttCard-${key}`)?.querySelector('.tt-card-name')?.textContent?.trim() || key;

    const ph = s => s
        .replace(/{account}/g,  accName)
        .replace(/{username}/g, '@' + key)
        .replace(/{title}/g,    '(Video Title)')
        .replace(/{url}/g,      'https://tiktok.com/...')
        .replace(/{id}/g,       '0000000000');

    // Video plain message preview
    const vidPlainMsg = (document.getElementById(`vidPlainMessage-${key}`)?.value || '').trim();
    const vidPlainEl  = document.getElementById(`prevVideoPlain-${key}`);
    if (vidPlainEl) {
        if (vidPlainMsg) { vidPlainEl.innerHTML = discordMd(ph(vidPlainMsg)); vidPlainEl.style.display = ''; }
        else vidPlainEl.style.display = 'none';
    }

    // Live plain message preview
    const livePlainMsg = (document.getElementById(`livePlainMessage-${key}`)?.value || '').trim();
    const livePlainEl  = document.getElementById(`prevLivePlain-${key}`);
    if (livePlainEl) {
        if (livePlainMsg) { livePlainEl.innerHTML = discordMd(ph(livePlainMsg)); livePlainEl.style.display = ''; }
        else livePlainEl.style.display = 'none';
    }

    // Video desc — jika kosong tampilkan default
    const videoMsg   = (document.getElementById(`vidMessage-${key}`)?.value || '').trim();
    const videoDescEl = document.getElementById(`prevVideoDesc-${key}`);
    if (videoDescEl) {
        if (videoMsg) {
            videoDescEl.innerHTML = discordMd(ph(videoMsg));
        } else {
            videoDescEl.innerHTML = `<strong>${accName}</strong> just posted a new video on TikTok!<br>Don't miss it, watch now! 🎉`;
        }
    }

    // Live desc — jika kosong tampilkan default
    const liveMsg   = (document.getElementById(`liveMessage-${key}`)?.value || '').trim();
    const liveDescEl = document.getElementById(`prevLiveDesc-${key}`);
    if (liveDescEl) {
        if (liveMsg) {
            liveDescEl.innerHTML = discordMd(ph(liveMsg));
        } else {
            liveDescEl.innerHTML = `Hey, <strong>${accName}</strong> is <strong>LIVE</strong> on TikTok right now!<br>Come join and watch the stream~ 🎉`;
        }
    }
}

// ── Simpan ────────────────────────────────────────────────────────────────────
async function saveAccount(username, quiet = false) {
    const key   = username.replace('@','').replace(/\./g,'_');
    const msgEl = document.getElementById(`msg-${key}`);

    const videoEnabled   = document.getElementById(`vidEnabled-${key}`)?.checked  || false;
    const videoChannelId = document.getElementById(`vidChannel-${key}`)?.value    || '';
    const liveEnabled    = document.getElementById(`liveEnabled-${key}`)?.checked || false;
    const liveChannelId  = document.getElementById(`liveChannel-${key}`)?.value   || '';

    // Validasi client-side
    if (videoEnabled && !videoChannelId) {
        switchTab(key, 'video');
        showAlert(I18N_TT_ERR_VIDEO_CH);
        document.getElementById(`vidChannel-${key}`)?.focus();
        return { success: false, message: I18N_TT_ERR_VIDEO_CH };
    }
    if (liveEnabled && !liveChannelId) {
        switchTab(key, 'live');
        showAlert(I18N_TT_ERR_LIVE_CH);
        document.getElementById(`liveChannel-${key}`)?.focus();
        return { success: false, message: I18N_TT_ERR_LIVE_CH };
    }

    const payload = {
        videoEnabled,
        videoChannelId,
        videoPlainMessage: document.getElementById(`vidPlainMessage-${key}`)?.value?.trim() || '',
        videoMessage:      document.getElementById(`vidMessage-${key}`)?.value?.trim() || '',
        liveEnabled,
        liveChannelId,
        livePlainMessage:  document.getElementById(`livePlainMessage-${key}`)?.value?.trim() || '',
        liveMessage:       document.getElementById(`liveMessage-${key}`)?.value?.trim() || '',
    };
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (data.success) { if (!quiet) showToast(data.message, 'success'); refreshTtStats(); }
    else showAlert(data.message);
    return data;
}

// ── Test notif ────────────────────────────────────────────────────────────────
async function testNotif(username, key) {
    const msgEl = document.getElementById(`msg-${key}`);
    const btn   = document.getElementById(`testBtn-${key}`);
    const tab   = btn?.dataset.tab || 'video';
    showMsg(msgEl, I18N_TT_SENDING_TEST, 'info');
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}/test`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: tab }),
    });
    const data = await r.json();
    showMsg(msgEl, '', 'info');
    if (data.success) showToast(data.message, 'success');
    else showAlert(data.message);
}

// ── Hapus akun ────────────────────────────────────────────────────────────────
async function removeAccount(username, name) {
    if (!await showConfirm('Remove Account', I18N_TT_CONFIRM_DEL.replace('{{name}}', name))) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}`, { method: 'DELETE' });
    const data = await r.json();
    if (data.success) {
        const key  = username.replace('@', '').replace(/\./g, '_');
        const card = document.getElementById(`ttCard-${key}`);
        if (card) card.remove();
        const idx = _ttAllUsers.indexOf(username);
        if (idx !== -1) _ttAllUsers.splice(idx, 1);
        const newCount = document.querySelectorAll('.tt-channel-card').length;
        refreshTtStats();
        if (newCount < TT_MAX_ACCOUNTS) {
            document.getElementById('ttMaxBanner').style.display = 'none';
            document.getElementById('ttAddCard').style.display   = '';
            document.getElementById('ttAddDesc').innerHTML = TT_ADD_DESC_TPL.replace('__N__', TT_MAX_ACCOUNTS - newCount);
        }
        if (newCount === 0) document.getElementById('ttEmptyState').style.display = '';
        showToast(data.message, 'success');
    } else {
        showAlert(data.message);
    }
}

async function reEnableAccount(username, key) {
    const btn = document.getElementById(`ttReenableBtn-${key}`);
    if (btn) { btn.disabled = true; btn.innerHTML = '<i data-lucide="loader-2" style="width:13px;height:13px;animation:tt-spin .8s linear infinite;display:inline-block;"></i>'; if (window.lucide) lucide.createIcons(); }
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}/reenable`, { method: 'POST' });
        const data = await r.json();
        if (data.success) { queueToast(data.message, 'success'); location.reload(); }
        else showAlert(data.message);
    } catch {
        showAlert(I18N_TT_ERR_CONNECT);
    } finally {
        if (btn) { btn.disabled = false; if (window.lucide) lucide.createIcons(); }
    }
}

// ── Helper ────────────────────────────────────────────────────────────────────
function showMsg(el, text, type, persist) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (!persist) setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 4000);
}

function showLookupMsg(text, type) {
    const el = document.getElementById('ttLookupMsg');
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
}

// ── Placeholder picker ────────────────────────────────────────────────────────
const PH_VIDEO = [
    ['{account}',  'Nama akun'],
    ['{username}', 'Username (@)'],
    ['{title}',    'Video title'],
    ['{url}',      'Link video'],
    ['{id}',       'ID video'],
];
const PH_LIVE = [
    ['{account}',  'Nama akun'],
    ['{username}', 'Username (@)'],
    ['{url}',      'Link live'],
];

function buildPickers() {
    document.querySelectorAll('[id^="vidPlainPicker-"]').forEach(el => {
        const key    = el.id.replace('vidPlainPicker-','');
        el.innerHTML = PH_VIDEO.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('vidPlainMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
    document.querySelectorAll('[id^="vidPicker-"]').forEach(el => {
        const key    = el.id.replace('vidPicker-','');
        el.innerHTML = PH_VIDEO.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('vidMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
    document.querySelectorAll('[id^="livePlainPicker-"]').forEach(el => {
        const key    = el.id.replace('livePlainPicker-','');
        el.innerHTML = PH_LIVE.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('livePlainMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
    document.querySelectorAll('[id^="livePicker-"]').forEach(el => {
        const key    = el.id.replace('livePicker-','');
        el.innerHTML = PH_LIVE.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('liveMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
}

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el        = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});

function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

// Init
buildPickers();
document.querySelectorAll('[id^="testBtn-"]').forEach(btn => btn.dataset.tab = 'video');
document.getElementById('ttLookupInput')?.addEventListener('keydown', e => { if (e.key==='Enter') lookupTikTok(); });
// Render preview pakai pesan custom yang sudah tersimpan (termasuk mention) saat halaman pertama dimuat
document.querySelectorAll('[id^="vidMessage-"]').forEach(el => updatePreview(el.id.replace('vidMessage-', '')));

// ── Mention picker ─────────────────────────────────────────────────────────────
document.querySelectorAll('.ph-picker-anchor:not(.mention-anchor):not([data-no-mention])').forEach(anchor => {
    const ta = anchor.closest('.form-group')?.querySelector('textarea');
    if (!ta) return;
    const ma = document.createElement('div');
    ma.className = 'ph-picker-anchor mention-anchor';
    const btn = document.createElement('button');
    btn.type='button'; btn.className='ph-toggle-btn'; btn.textContent='@ Mention';
    const dd = document.createElement('div');
    dd.className='ph-dropdown mention-dd'; dd.style.display='none';
    btn.addEventListener('click', e => {
        e.stopPropagation();
        document.querySelectorAll('.ph-dropdown').forEach(d=>{ if(d!==dd) d.style.display='none'; });
        document.querySelectorAll('.ph-toggle-btn').forEach(b=>{ if(b!==btn) b.classList.remove('active'); });
        if(dd.style.display!=='none'){ dd.style.display='none'; btn.classList.remove('active'); return; }
        if(!dd.dataset.built){ dd.dataset.built='1'; _buildMentionDd(dd,ta); }
        dd.style.display='grid';
        btn.classList.add('active');
    });
    ma.appendChild(btn); ma.appendChild(dd);
    const grp = document.createElement('div');
    grp.className = 'ph-btn-group';
    anchor.parentNode.insertBefore(grp, anchor);
    grp.appendChild(anchor);
    grp.appendChild(ma);
});
function _buildMentionDd(dd, ta) {
    function item(html, mention) {
        const b=document.createElement('button'); b.type='button'; b.className='ph-item';
        b.innerHTML=html;
        b.addEventListener('click',()=>{ const s=ta.selectionStart,e=ta.selectionEnd; ta.value=ta.value.slice(0,s)+mention+ta.value.slice(e); ta.selectionStart=ta.selectionEnd=s+mention.length; ta.focus(); ta.dispatchEvent(new Event('input',{bubbles:true})); dd.style.display='none'; });
        return b;
    }
    function hdr(t){ const h=document.createElement('div'); h.className='ph-group-label'; h.textContent=t; return h; }
    const inp=document.createElement('input'); inp.type='text'; inp.className='mention-search-input'; inp.placeholder='Search...';
    inp.addEventListener('click',e=>e.stopPropagation());
    inp.addEventListener('input',()=>{ const q=inp.value.toLowerCase(); dd.querySelectorAll('.ph-item').forEach(el=>{ el.style.display=el.textContent.toLowerCase().includes(q)?'':'none'; }); });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special')); dd.appendChild(item('<code>@everyone</code>','@everyone')); dd.appendChild(item('<code>@here</code>','@here'));
    const rKeys=Object.keys(ROLES_MAP);
    if(rKeys.length){ dd.appendChild(hdr('Roles')); rKeys.forEach(id=>{ const r=ROLES_MAP[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`,`<@&${r.id}>`)); }); }
    const cKeys=Object.keys(CHANNELS_MAP);
    if(cKeys.length){ dd.appendChild(hdr('Channels')); cKeys.forEach(id=>{ const c=CHANNELS_MAP[id]; dd.appendChild(item(`<span>#${c.name}</span>`,`<#${c.id}>`)); }); }
}

function mbResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    el.style.height = el.scrollHeight + 'px';
}
function mbUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.mb-auto-resize').forEach(mbResizeArea);
    document.querySelectorAll('textarea[maxlength]').forEach(ta => {
        mbUpdateCount(ta.id, ta.id.replace('Message', 'Count'));
    });
});

async function refreshTtStats() {
    try {
        const r = await fetch(`/api/guild/${GUILD_ID}/tiktok/stats`);
        const d = await r.json();
        if (!d.success) return;
        document.getElementById('statAccounts').textContent     = d.accounts;
        document.getElementById('statVideoEnabled').textContent = d.videoEnabled;
        document.getElementById('statLiveEnabled').textContent  = d.liveEnabled;
        document.getElementById('statSlots').textContent        = d.slots;
    } catch {}
}

const _ttAllUsers = <%- JSON.stringify(ttAccounts.map(a => a.username)) %>;
window._floatSave = async function () {
    if (_ttAllUsers.length === 0) return;
    const results = await Promise.allSettled(_ttAllUsers.map(u => saveAccount(u, true)));
    const ok = results.every(r => r.status === 'fulfilled' && r.value?.success);
    if (ok) showToast(results[0].value.message, 'success');
    else throw new Error();
};
