<script>
const GUILD_ID  = '<%= guild.id %>';
const CHANNELS  = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;

const I18N_TT_CONFIRM_DEL  = '<%= t("tiktok.confirm_delete") %>';
const I18N_TT_ERR_VIDEO_CH = '<%= t("tiktok.err_no_video_channel") %>';
const I18N_TT_ERR_LIVE_CH  = '<%= t("tiktok.err_no_live_channel") %>';
const I18N_TT_SEARCH_BTN   = '<%= t("tiktok.search_btn") %>';
const I18N_TT_SEARCHING    = '<%= t("tiktok.searching") %>';
const I18N_TT_TIP_1        = '<%= t("tiktok.tip_1") %>';
const I18N_TT_TIP_2        = '<%= t("tiktok.tip_2") %>';
const I18N_TT_TIP_3        = '<%= t("tiktok.tip_3") %>';
const I18N_TT_TIP_4        = '<%= t("tiktok.tip_4") %>';
const I18N_TT_ERR_CONN     = '<%= t("tiktok.err_conn") %>';
const I18N_TT_ERR_CONNECT  = '<%= t("tiktok.err_connect") %>';
const I18N_TT_SENDING_TEST = '<%= t("tiktok.sending_test") %>';
const I18N_TT_THUMB_OK     = '<%= t("tiktok.thumbnail_updated") %>';
const I18N_TT_PREV_NO_CH   = '<%= t("common.preview_no_channel") %>';

// ── Lookup ────────────────────────────────────────────────────────────────────
let _lookupData = null;

async function lookupTikTok() {
    const input      = document.getElementById('ttLookupInput').value.trim();
    const btn        = document.getElementById('ttLookupBtn');
    const resEl      = document.getElementById('ttLookupResult');
    const statusEl   = document.getElementById('ttSearchStatus');
    const skeletonEl = document.getElementById('ttSearchSkeleton');
    const msgEl      = document.getElementById('ttLookupMsg');
    if (!input) return;

    // Reset state
    resEl.style.display      = 'none';
    statusEl.style.display   = 'none';
    skeletonEl.style.display = 'none';
    if (msgEl) { msgEl.textContent = ''; msgEl.className = 'form-message'; }
    _lookupData = null;

    // Loading state
    btn.disabled   = true;
    btn.innerHTML  = `<span class="tt-spinner"></span> ${I18N_TT_SEARCHING}`;

    // Status bar
    const tips = [I18N_TT_TIP_1, I18N_TT_TIP_2, I18N_TT_TIP_3, I18N_TT_TIP_4];
    let tipIdx = 0;
    const statusTextEl = document.getElementById('ttStatusText');
    if (statusTextEl) statusTextEl.textContent = tips[0];
    statusEl.style.display   = 'flex';
    skeletonEl.style.display = 'block';

    const tipTimer = setInterval(() => {
        tipIdx = (tipIdx + 1) % tips.length;
        if (statusTextEl) statusTextEl.textContent = tips[tipIdx];
    }, 3500);

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/lookup`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input }),
        });
        const data = await r.json();
        if (!data.success) {
            if (msgEl) showMsg(msgEl, data.message, 'error', true);
            return;
        }
        _lookupData = data.account;
        const thumb = document.getElementById('ttLookupThumb');
        thumb.src = _lookupData.thumbnail || '';
        thumb.style.display = _lookupData.thumbnail ? 'block' : 'none';
        document.getElementById('ttLookupName').textContent     = _lookupData.name;
        document.getElementById('ttLookupUsername').textContent = _lookupData.username;
        resEl.style.display = 'block';
    } catch (err) {
        if (msgEl) showMsg(msgEl, I18N_TT_ERR_CONN + err.message, 'error', true);
    } finally {
        clearInterval(tipTimer);
        statusEl.style.display   = 'none';
        skeletonEl.style.display = 'none';
        btn.disabled  = false;
        btn.innerHTML = `<i data-lucide="search" style="width:14px;height:14px;"></i> ${I18N_TT_SEARCH_BTN}`;
        if (window.lucide) lucide.createIcons();
    }
}

async function addAccount() {
    if (!_lookupData) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: _lookupData.username, name: _lookupData.name, thumbnail: _lookupData.thumbnail }),
    });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.message);
}

// ── Discord Markdown renderer ──────────────────────────────────────────────────
function discordMd(raw) {
    if (!raw) return '';
    let s = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    s = s.replace(/^### (.+)$/gm, '<span style="font-size:.88em;font-weight:700;line-height:1.6;display:block">$1</span>');
    s = s.replace(/^## (.+)$/gm,  '<span style="font-size:1em;font-weight:700;line-height:1.75;display:block">$1</span>');
    s = s.replace(/^# (.+)$/gm,   '<span style="font-size:1.15em;font-weight:700;line-height:2;display:block">$1</span>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>');
    s = s.replace(/\*([^*\n]+?)\*/g,    '<em>$1</em>');
    s = s.replace(/_([^_\n]+?)_/g,      '<em>$1</em>');
    s = s.replace(/__([^_\n]+?)__/g,    '<u>$1</u>');
    s = s.replace(/~~(.+?)~~/g,         '<s>$1</s>');
    s = s.replace(/`([^`]+)`/g, '<code style="background:rgba(255,255,255,.07);padding:0 4px;border-radius:3px;font-size:.83em;font-family:monospace">$1</code>');
    s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" onclick="return false;" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/^&gt; (.+)$/gm, '<span style="border-left:3px solid #4e5058;padding-left:.5em;color:#b5bac1;display:block">$1</span>');
    s = s.replace(/\n/g, '<br>');
    return s;
}

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(key, tab) {
    const isVideo = tab === 'video';
    document.getElementById(`tab-video-${key}`).className = isVideo ? 'tt-tab-btn active-video' : 'tt-tab-btn';
    document.getElementById(`tab-live-${key}`).className  = isVideo ? 'tt-tab-btn' : 'tt-tab-btn active-live';
    document.getElementById(`panel-video-${key}`).style.display = isVideo ? '' : 'none';
    document.getElementById(`panel-live-${key}`).style.display  = isVideo ? 'none' : '';
    document.getElementById(`prev-video-${key}`).style.display  = isVideo ? 'flex' : 'none';
    document.getElementById(`prev-live-${key}`).style.display   = isVideo ? 'none' : 'flex';
    // Update test button label
    const testBtn = document.getElementById(`testBtn-${key}`);
    if (testBtn) testBtn.dataset.tab = tab;
    updatePreview(key);
}

// ── Update preview ────────────────────────────────────────────────────────────
function updatePreview(key) {
    const chanId  = document.getElementById(`vidChannel-${key}`)?.value || '';
    document.getElementById(`prevCh-${key}`).textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : I18N_TT_PREV_NO_CH;

    // Ambil nama akun dari header card
    const accName = document.getElementById(`ttCard-${key}`)?.querySelector('.tt-card-name')?.textContent?.trim() || key;

    const ph = s => s
        .replace(/{account}/g,  accName)
        .replace(/{username}/g, '@' + key)
        .replace(/{title}/g,    '(Video Title)')
        .replace(/{url}/g,      'https://tiktok.com/...')
        .replace(/{id}/g,       '0000000000');

    // Video desc — jika kosong tampilkan default
    const videoMsg   = (document.getElementById(`vidMessage-${key}`)?.value || '').trim();
    const videoDescEl = document.getElementById(`prevVideoDesc-${key}`);
    if (videoDescEl) {
        if (videoMsg) {
            videoDescEl.innerHTML = discordMd(ph(videoMsg));
        } else {
            videoDescEl.innerHTML = `<strong>${accName}</strong> just posted a new video on TikTok!<br>Don't miss it, watch now! 🎉`;
        }
    }

    // Live desc — jika kosong tampilkan default
    const liveMsg   = (document.getElementById(`liveMessage-${key}`)?.value || '').trim();
    const liveDescEl = document.getElementById(`prevLiveDesc-${key}`);
    if (liveDescEl) {
        if (liveMsg) {
            liveDescEl.innerHTML = discordMd(ph(liveMsg));
        } else {
            liveDescEl.innerHTML = `Hey, <strong>${accName}</strong> is <strong>LIVE</strong> on TikTok right now!<br>Come join and watch the stream~ 🎉`;
        }
    }
}

// ── Simpan ────────────────────────────────────────────────────────────────────
async function saveAccount(username) {
    const key   = username.replace('@','').replace(/\./g,'_');
    const msgEl = document.getElementById(`msg-${key}`);

    const videoEnabled   = document.getElementById(`vidEnabled-${key}`)?.checked  || false;
    const videoChannelId = document.getElementById(`vidChannel-${key}`)?.value    || '';
    const liveEnabled    = document.getElementById(`liveEnabled-${key}`)?.checked || false;
    const liveChannelId  = document.getElementById(`liveChannel-${key}`)?.value   || '';

    // Validasi client-side
    if (videoEnabled && !videoChannelId) {
        switchTab(key, 'video');
        showMsg(msgEl, I18N_TT_ERR_VIDEO_CH, 'error');
        document.getElementById(`vidChannel-${key}`)?.focus();
        return;
    }
    if (liveEnabled && !liveChannelId) {
        switchTab(key, 'live');
        showMsg(msgEl, I18N_TT_ERR_LIVE_CH, 'error');
        document.getElementById(`liveChannel-${key}`)?.focus();
        return;
    }

    const payload = {
        videoEnabled,
        videoChannelId,
        videoMessage:  document.getElementById(`vidMessage-${key}`)?.value?.trim() || '',
        liveEnabled,
        liveChannelId,
        liveMessage:   document.getElementById(`liveMessage-${key}`)?.value?.trim() || '',
    };
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
    });
    const data = await r.json();
    showMsg(msgEl, data.message, data.success ? 'success' : 'error');
}

// ── Test notif ────────────────────────────────────────────────────────────────
async function testNotif(username, key) {
    const msgEl = document.getElementById(`msg-${key}`);
    const btn   = document.getElementById(`testBtn-${key}`);
    const tab   = btn?.dataset.tab || 'video';
    showMsg(msgEl, I18N_TT_SENDING_TEST, 'info');
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}/test`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: tab }),
    });
    const data = await r.json();
    showMsg(msgEl, data.message, data.success ? 'success' : 'error');
}

// ── Refresh thumbnail ─────────────────────────────────────────────────────────
async function refreshThumbnail(username, btn) {
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span style="width:11px;height:11px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:tt-spin .65s linear infinite;display:inline-block;vertical-align:middle;"></span>';

    const key   = username.replace('@','').replace(/\./g,'_');
    const msgEl = document.getElementById(`msg-${key}`);
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}/refresh-thumbnail`, { method: 'POST' });
        const data = await r.json();
        if (data.success) {
            showMsg(msgEl, I18N_TT_THUMB_OK, 'success');
            // Update semua gambar profil akun ini di halaman
            if (data.thumbnail) {
                document.querySelectorAll(`img[data-tt-thumb="${username}"]`).forEach(img => {
                    img.src = data.thumbnail;
                    img.style.display = '';
                });
            }
        } else {
            showMsg(msgEl, data.message, 'error');
        }
    } catch {
        showMsg(msgEl, I18N_TT_ERR_CONNECT, 'error');
    } finally {
        btn.disabled  = false;
        btn.innerHTML = orig;
        if (window.lucide) lucide.createIcons();
    }
}

// ── Reset last video ──────────────────────────────────────────────────────────
async function resetLastVideo(username) {
    const key   = username.replace('@','').replace(/\./g,'_');
    const msgEl = document.getElementById(`msg-${key}`);
    const r     = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}/reset`, { method: 'POST' });
    const data  = await r.json();
    showMsg(msgEl, data.message, data.success ? 'success' : 'error');
}

// ── Hapus akun ────────────────────────────────────────────────────────────────
async function removeAccount(username, name) {
    if (!confirm(I18N_TT_CONFIRM_DEL.replace('{{name}}', name))) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/accounts/${encodeURIComponent(username)}`, { method: 'DELETE' });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.message);
}

// ── Force poll ────────────────────────────────────────────────────────────────
async function forcePoll(btn) {
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i data-lucide="loader" style="width:14px;height:14px;"></i> Polling...';
    if (window.lucide) lucide.createIcons();
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/tiktok/force-poll`, { method: 'POST' });
        const data = await r.json();
        showMsg(null, data.message, data.success ? 'success' : 'error');
        if (data.success) setTimeout(() => location.reload(), 1500);
    } catch {
        showMsg(null, 'Gagal terhubung ke server.', 'error');
    } finally {
        btn.disabled  = false;
        btn.innerHTML = orig;
        if (window.lucide) lucide.createIcons();
    }
}

// ── Helper ────────────────────────────────────────────────────────────────────
function showMsg(el, text, type, persist) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (!persist) setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 4000);
}

function showLookupMsg(text, type) {
    const el = document.getElementById('ttLookupMsg');
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
}

// ── Placeholder picker ────────────────────────────────────────────────────────
const PH_VIDEO = [
    ['{account}',  'Nama akun'],
    ['{username}', 'Username (@)'],
    ['{title}',    'Video title'],
    ['{url}',      'Link video'],
    ['{id}',       'ID video'],
];
const PH_LIVE = [
    ['{account}',  'Nama akun'],
    ['{username}', 'Username (@)'],
    ['{url}',      'Link live'],
];

function buildPickers() {
    document.querySelectorAll('[id^="vidPicker-"]').forEach(el => {
        const key    = el.id.replace('vidPicker-','');
        el.innerHTML = PH_VIDEO.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('vidMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
    document.querySelectorAll('[id^="livePicker-"]').forEach(el => {
        const key    = el.id.replace('livePicker-','');
        el.innerHTML = PH_LIVE.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('liveMessage-${key}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
}

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el        = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    if (wasHidden) el.style.display = 'grid';
}
document.addEventListener('click', () =>
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none')
);

function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

// Init
buildPickers();
document.querySelectorAll('[id^="testBtn-"]').forEach(btn => btn.dataset.tab = 'video');
document.getElementById('ttLookupInput')?.addEventListener('keydown', e => { if (e.key==='Enter') lookupTikTok(); });
</script>

