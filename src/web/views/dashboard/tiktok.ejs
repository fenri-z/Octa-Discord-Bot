                                    <!-- Video preview -->
                                    <div id="prev-video-<%= key %>" class="dc-embed" style="max-width:100%;">
                                        <div style="width:4px;flex-shrink:0;background:#010101;"></div>
                                        <div class="dc-embed-inner" style="flex:1;min-width:0;">

                                            <!-- Title + right profile -->
                                            <div style="display:flex;align-items:flex-start;gap:.5rem;">
                                                <div style="flex:1;min-width:0;">
                                                    <div class="dc-embed-title">🎵 <%= acc.name||acc.username %> — New Video!</div>
                                                    <div class="dc-embed-desc" id="prevVideoDesc-<%= key %>" style="margin-top:.2rem;">
                                                        <strong><%= acc.name||acc.username %></strong> just posted a new video on TikTok!<br>Don't miss it, watch now! 🎉
                                                    </div>
                                                    <div class="dc-embed-field">
                                                        <div class="dc-field-name">🎬 Title</div>
                                                        <div class="dc-field-value" style="color:#dbdee1;">[TEST] Example Video Notification from <%= acc.name||acc.username %></div>
                                                    </div>
                                                    <div class="dc-embed-field">
                                                        <div class="dc-field-name">🔗 Link</div>
