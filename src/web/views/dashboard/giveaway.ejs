<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
/* ── Giveaway card ───────────────────────────────────────────────────────── */
.gw-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px; padding: 1rem 1.1rem;
    display: flex; align-items: flex-start; gap: 1rem;
    margin-bottom: .75rem;
}
.gw-card-icon {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
}
.gw-card-icon.active  { background: rgba(240,160,50,.15); }
.gw-card-icon.ended   { background: rgba(88,101,242,.15); }
.gw-card-icon.cancelled { background: rgba(237,66,69,.1); }
.gw-card-body { flex: 1; min-width: 0; }
.gw-prize  { font-weight: 700; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.gw-meta   { font-size: .78rem; color: var(--text-muted); margin-top: .2rem; display: flex; flex-wrap: wrap; gap: .4rem .8rem; }
.gw-badge  {
    font-size: .68rem; font-weight: 700; padding: .15rem .5rem;
    border-radius: 20px; letter-spacing: .04em; white-space: nowrap;
}
.gw-badge.active    { background: rgba(240,160,50,.18); color: #F0A032; }
.gw-badge.ended     { background: rgba(88,101,242,.18); color: #8b9cf8; }
.gw-badge.cancelled { background: rgba(237,66,69,.15);  color: #ed4245; }
.gw-actions { display: flex; gap: .4rem; flex-shrink: 0; flex-wrap: wrap; align-items: flex-start; }

/* ── Form grid ───────────────────────────────────────────────────────────── */
.gw-form-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: .85rem 1rem;
}
@media (max-width: 600px) { .gw-form-grid { grid-template-columns: 1fr; } }

/* ── Duration picker ─────────────────────────────────────────────────────── */
.gw-duration-row { display: flex; gap: .5rem; }
.gw-duration-row input[type=number] { width: 80px; flex-shrink: 0; }

/* ── Action buttons: semua seragam tingginya ─────────────────────────────── */
.gw-actions .btn.btn-sm {
    height: 30px;
    padding: 0 .65rem;
    display: inline-flex; align-items: center; justify-content: center;
    gap: .3rem;
}
.gw-actions .btn-icon {
    width: 30px;
    padding: 0;
}

/* ── Section label ───────────────────────────────────────────────────────── */
.gw-section-label {
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em;
    margin: 1.5rem 0 .6rem;
}

/* ── Responsive: Tablet (≤ 860px) ───────────────────────────────────────── */
@media (max-width: 860px) {

/* ── Responsive: Tablet kecil (≤ 680px) ─────────────────────────────────── */
@media (max-width: 680px) {
    .dash-main        { padding: 1.25rem 1rem 1.5rem !important; }
    .gw-form-grid     { grid-template-columns: 1fr !important; }

    /* Card: sembunyikan icon, actions pindah ke bawah body */
    .gw-card          { flex-wrap: wrap; gap: .65rem; padding: .85rem; }
    .gw-card-icon     { display: none; }
    .gw-card-body     { width: 100%; min-width: 0; }
    .gw-actions       { width: 100%; justify-content: flex-start; }
    .gw-actions .btn  { flex: 1; justify-content: center; font-size: .78rem; padding: .3rem .5rem; }

    /* Form action row stack */
    .gw-form-action-row { flex-direction: column !important; align-items: stretch !important; }
    .gw-form-action-row .btn { width: 100%; justify-content: center; }
    .gw-form-action-row #gwCreateMsg { text-align: center; }

    /* Duration row lebih kompak */
    .gw-duration-row input[type=number] { width: 70px; }
}

/* ── Responsive: Mobile (≤ 480px) ───────────────────────────────────────── */
@media (max-width: 480px) {
    .dash-main        { padding: 1rem .75rem 1.5rem !important; }
    .gw-prize         { font-size: .9rem; }
    .gw-meta          { font-size: .74rem; gap: .3rem .6rem; }
    .gw-section-label { font-size: .68rem; margin: 1.1rem 0 .5rem; }
    .settings-card    { padding: .9rem !important; }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'giveaway' }) %>
    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <!-- Header -->
        <div class="page-header">
            <h1><%= t('giveaway.page_title') %></h1>
            <p><%= t('giveaway.page_desc') %></p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="gift"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statGwActive"><%= giveaways.filter(g => !g.ended && !g.cancelled).length %></div>
                    <div class="stat-label"><%= t('giveaway.stat_active') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="trophy"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statGwEnded"><%= giveaways.filter(g => g.ended && !g.cancelled).length %></div>
                    <div class="stat-label"><%= t('giveaway.stat_ended') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="list"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statGwTotal"><%= giveaways.length %></div>
                    <div class="stat-label"><%= t('giveaway.stat_total') %></div>
                </div>
            </div>
        </div>

        <!-- How to Use -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('giveaway.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('giveaway.step1_title') %></div>
                    <div class="guide-desc"><%= t('giveaway.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('giveaway.step2_title') %></div>
                    <div class="guide-desc"><%= t('giveaway.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('giveaway.step3_title') %></div>
                    <div class="guide-desc"><%= t('giveaway.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('giveaway.tip') %></div>
        </div>

        <!-- Form Buat Giveaway -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1.1rem;">
                <i data-lucide="plus-circle" style="color:#F0A032;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('giveaway.create_title') %></h2>
            </div>
            <div class="gw-form-grid">
                <!-- Prize -->
                <div class="form-group" style="grid-column:1/-1;margin-bottom:0;">
                    <label class="label"><%= t('giveaway.prize_label') %> <span style="color:#ed4245;">*</span></label>
                    <input type="text" id="gwPrize" class="input" placeholder="<%= t('giveaway.prize_placeholder') %>" maxlength="200">
                </div>
                <!-- Channel -->
                <div class="form-group" style="margin-bottom:0;">
                    <label class="label">📢 Channel <span style="color:#ed4245;">*</span></label>
                    <select id="gwChannel" class="select">
                        <option value=""><%= t('common.select_channel') %></option>
                        <% (channels||[]).forEach(ch => { %>
                        <option value="<%= ch.id %>">#<%= ch.name %></option>
                        <% }) %>
                    </select>
                </div>
                <!-- Winners -->
                <div class="form-group" style="margin-bottom:0;">
                    <label class="label"><%= t('giveaway.winners_label') %> <span style="color:#ed4245;">*</span></label>
                    <input type="number" id="gwWinnerCount" class="input" value="1" min="1" max="20" placeholder="1">
                </div>
                <!-- Duration -->
                <div class="form-group" style="margin-bottom:0;">
                    <label class="label"><%= t('giveaway.duration_label') %> <span style="color:#ed4245;">*</span></label>
                    <div class="gw-duration-row">
                        <input type="number" id="gwDurValue" class="input" value="1" min="1" max="999" placeholder="1">
                        <select id="gwDurUnit" class="select" style="flex:1;">
                            <option value="60000"><%= t('giveaway.dur_minutes') %></option>
                            <option value="3600000" selected><%= t('giveaway.dur_hours') %></option>
                            <option value="86400000"><%= t('giveaway.dur_days') %></option>
                        </select>
                    </div>
                </div>
                <!-- Required Role (optional) -->
                <div class="form-group" style="margin-bottom:0;">
                    <label class="label"><%= t('giveaway.required_role') %> <span style="font-weight:400;color:var(--text-muted);"><%= t('giveaway.required_role_hint') %></span></label>
                    <select id="gwRole" class="select">
                        <option value=""><%= t('giveaway.all_members') %></option>
                        <% (roles||[]).forEach(r => { %>
                        <option value="<%= r.id %>"><%= r.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
            <div id="gwCreateMsg" class="form-message" style="margin-top:1rem;"></div>
        </div>

        <!-- Daftar Giveaway -->
        <% const activeGws  = giveaways.filter(g => !g.ended && !g.cancelled); %>
        <% const endedGws   = giveaways.filter(g => g.ended && !g.cancelled); %>
        <% const cancelGws  = giveaways.filter(g => g.cancelled); %>

        <% if (activeGws.length > 0) { %>
        <div class="gw-section-label"><%= t('giveaway.section_active') %></div>
        <% activeGws.forEach(function(gw) { %>
        <div class="gw-card" id="gwRow-<%= gw.id %>" data-state="active">
            <div class="gw-card-icon active">🎉</div>
            <div class="gw-card-body">
                <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;">
                    <div class="gw-prize"><%= gw.prize %></div>
                    <span class="gw-badge active"><%= t('giveaway.badge_active') %></span>
                </div>
                <div class="gw-meta">
                    <span>🏆 <%= gw.winnerCount %> <%= t('giveaway.meta_winners') %></span>
                    <span>⏰ <%= t('giveaway.meta_ends') %> <strong><span data-endat="<%= gw.endsAt %>"></span></strong></span>
                    <% const ch = channels.find(c => c.id === gw.channelId); %>
                    <% if (ch) { %><span>📢 #<%= ch.name %></span><% } %>
                    <% if (gw.requiredRoleId) { %><span>🔒 <%= t('giveaway.required_role_badge') %></span><% } %>
                </div>
                <div id="gwMsg-<%= gw.id %>" class="form-message" style="margin-top:.3rem;"></div>
            </div>
            <div class="gw-actions">
                <a href="https://discord.com/channels/<%= gw.guildId %>/<%= gw.channelId %>/<%= gw.messageId %>"
                   target="_blank" class="btn btn-sm btn-icon" title="<%= t('common.view_in_discord') %>">
                    <i data-lucide="external-link" style="width:12px;height:12px;"></i>
                </a>
                <button class="btn btn-sm btn-primary" onclick="endGiveaway('<%= gw.id %>')" title="<%= t('giveaway.end_btn') %>">
                    <i data-lucide="flag" style="width:12px;height:12px;"></i> <%= t('giveaway.end_btn') %>
                </button>
                <button class="btn btn-sm btn-danger btn-icon" onclick="cancelGiveaway('<%= gw.id %>')" title="<%= t('common.cancel') %>">
                    <i data-lucide="x" style="width:12px;height:12px;"></i>
                </button>
            </div>
        </div>
        <% }); %>
        <% } %>

        <% if (endedGws.length > 0) { %>
        <div class="gw-section-label"><%= t('giveaway.section_ended') %></div>
        <% endedGws.forEach(function(gw) { %>
        <div class="gw-card" id="gwRow-<%= gw.id %>" data-state="ended">
            <div class="gw-card-icon ended">🏆</div>
            <div class="gw-card-body">
                <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;">
                    <div class="gw-prize"><%= gw.prize %></div>
                    <span class="gw-badge ended"><%= t('giveaway.badge_ended') %></span>
                </div>
                <div class="gw-meta">
                    <% if (gw.winners && gw.winners.length > 0) { %>
                    <span>🏆 Winners:
                        <% gw.winners.forEach(function(id, i) { %>
                        <strong><a href="https://discord.com/users/<%= id %>" target="_blank" style="color:inherit;text-decoration:none;" title="<%= id %>">@<%= (gw.winnerNames && gw.winnerNames[i]) ? gw.winnerNames[i] : id %></a></strong><% if (i < gw.winners.length - 1) { %>, <% } %>
                        <% }); %>
                    </span>
                    <% } else { %>
                    <span style="color:#ed4245;"><%= t('giveaway.no_participants') %></span>
                    <% } %>
                    <span>⏰ <%= t('giveaway.meta_ends') %>: <%= new Date(gw.endsAt).toLocaleString('id-ID') %></span>
                </div>
                <div id="gwMsg-<%= gw.id %>" class="form-message" style="margin-top:.3rem;"></div>
            </div>
            <div class="gw-actions">
                <a href="https://discord.com/channels/<%= gw.guildId %>/<%= gw.channelId %>/<%= gw.messageId %>"
                   target="_blank" class="btn btn-sm btn-icon" title="<%= t('common.view_in_discord') %>">
                    <i data-lucide="external-link" style="width:12px;height:12px;"></i>
                </a>
                <button class="btn btn-sm btn-secondary" onclick="rerollGiveaway('<%= gw.id %>')" title="Reroll">
                    <i data-lucide="refresh-cw" style="width:12px;height:12px;"></i> Reroll
                </button>
                <button class="btn btn-sm btn-danger btn-icon" onclick="deleteGiveaway('<%= gw.id %>')" title="<%= t('common.delete') %>">
                    <i data-lucide="trash-2" style="width:12px;height:12px;"></i>
                </button>
            </div>
        </div>
        <% }); %>
        <% } %>

        <% if (cancelGws.length > 0) { %>
        <div class="gw-section-label" style="color:var(--text-muted);"><%= t('giveaway.section_cancelled') %></div>
        <% cancelGws.forEach(function(gw) { %>
        <div class="gw-card" id="gwRow-<%= gw.id %>" data-state="cancelled" style="opacity:.6;">
            <div class="gw-card-icon cancelled">🚫</div>
            <div class="gw-card-body">
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <div class="gw-prize"><%= gw.prize %></div>
                    <span class="gw-badge cancelled"><%= t('giveaway.badge_cancelled') %></span>
                </div>
                <div class="gw-meta">
                    <span>⏰ <%= new Date(gw.endsAt).toLocaleString('id-ID') %></span>
                </div>
                <div id="gwMsg-<%= gw.id %>" class="form-message" style="margin-top:.3rem;"></div>
            </div>
            <div class="gw-actions">
                <button class="btn btn-sm btn-danger btn-icon" onclick="deleteGiveaway('<%= gw.id %>')" title="<%= t('common.delete') %>">
                    <i data-lucide="trash-2" style="width:12px;height:12px;"></i>
                </button>
            </div>
        </div>
        <% }); %>
        <% } %>

        <% if (giveaways.length === 0) { %>
        <div class="settings-card" style="text-align:center;padding:3rem 1.5rem;">
            <i data-lucide="gift" style="width:48px;height:48px;color:#F0A032;opacity:.4;display:block;margin:0 auto .75rem;"></i>
            <p style="color:var(--text-muted);margin:0;"><%= t('giveaway.no_giveaways') %></p>
        </div>
        <% } %>

    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<%- include('../partials/bottom-nav') %>

<script>
const GUILD_ID         = '<%= guild.id %>';
const I18N_GW_CONFIRM_END    = '<%= t("giveaway.confirm_end") %>';
const I18N_GW_CONFIRM_REROLL = '<%= t("giveaway.confirm_reroll") %>';
const I18N_GW_CONFIRM_DEL    = '<%= t("giveaway.confirm_delete") %>';
const I18N_GW_CONFIRM_CANCEL = '<%= t("giveaway.confirm_cancel") %>';
const I18N_GW_ERR_PRIZE    = '<%= t("giveaway.err_prize") %>';
const I18N_GW_ERR_CHANNEL  = '<%= t("giveaway.err_channel") %>';
const I18N_GW_ERR_WINNERS  = '<%= t("giveaway.err_winners") %>';
const I18N_GW_ERR_DURATION = '<%= t("giveaway.err_duration") %>';
const I18N_GW_ERR_CONNECT  = '<%= t("giveaway.err_connect") %>';
const I18N_GW_SOON      = '<%= t("giveaway.countdown_soon") %>';
const I18N_GW_DHM       = '<%= t("giveaway.countdown_dhm") %>';
const I18N_GW_HM        = '<%= t("giveaway.countdown_hm") %>';
const I18N_GW_MS        = '<%= t("giveaway.countdown_ms") %>';
const I18N_GW_S         = '<%= t("giveaway.countdown_s") %>';
const I18N_GW_REROLLING = '<%= t("giveaway.rerolling") %>';
const I18N_GW_DELETING  = '<%= t("giveaway.deleting") %>';

// ── Countdown timer ───────────────────────────────────────────────────────────
function updateCountdowns() {
    document.querySelectorAll('[data-endat]').forEach(el => {
        const endsAt    = parseInt(el.dataset.endat);
        const remaining = endsAt - Date.now();
        if (remaining <= 0) { el.textContent = I18N_GW_SOON; return; }

        const d = Math.floor(remaining / 86400000);
        const h = Math.floor((remaining % 86400000) / 3600000);
        const m = Math.floor((remaining % 3600000) / 60000);
        const s = Math.floor((remaining % 60000) / 1000);

        const _fmt = (tpl, vars) => tpl.replace(/\{\{(\w+)\}\}/g, (_,k) => vars[k] ?? _);
        if (d > 0)      el.textContent = _fmt(I18N_GW_DHM, {d, h});
        else if (h > 0) el.textContent = _fmt(I18N_GW_HM,  {h, m});
        else if (m > 0) el.textContent = _fmt(I18N_GW_MS,  {m, s});
        else            el.textContent = _fmt(I18N_GW_S,   {s});
    });
}
updateCountdowns();
setInterval(updateCountdowns, 1000);

// ── Create ────────────────────────────────────────────────────────────────────
async function createGiveaway() {
    const prize       = document.getElementById('gwPrize').value.trim();
    const channelId   = document.getElementById('gwChannel').value;
    const winnerCount = parseInt(document.getElementById('gwWinnerCount').value);
    const durValue    = parseInt(document.getElementById('gwDurValue').value);
    const durUnit     = parseInt(document.getElementById('gwDurUnit').value);
    const roleId      = document.getElementById('gwRole').value;
    const msgEl       = document.getElementById('gwCreateMsg');

    if (!prize)                          { showMsg(msgEl, I18N_GW_ERR_PRIZE,    'error'); throw new Error(); }
    if (!channelId)                      { showMsg(msgEl, I18N_GW_ERR_CHANNEL,  'error'); throw new Error(); }
    if (!winnerCount || winnerCount < 1) { showMsg(msgEl, I18N_GW_ERR_WINNERS,  'error'); throw new Error(); }
    if (!durValue || durValue < 1)       { showMsg(msgEl, I18N_GW_ERR_DURATION, 'error'); throw new Error(); }

    const durationMs = durValue * durUnit;
    let r, data;
    try {
        r    = await fetch(`/api/guild/${GUILD_ID}/giveaway`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ channelId, prize, durationMs, winnerCount, requiredRoleId: roleId || null }),
        });
        data = await r.json();
    } catch (err) {
        showMsg(msgEl, I18N_GW_ERR_CONNECT, 'error');
        throw err;
    }
    if (data.success) {
        queueToast(data.message, 'success');
        location.reload();
    } else {
        showMsg(msgEl, data.message, 'error');
        throw new Error(data.message);
    }
}

window._floatSave = async () => createGiveaway();

// ── End ───────────────────────────────────────────────────────────────────────
async function endGiveaway(id) {
    if (!confirm(I18N_GW_CONFIRM_END)) return;
    const msgEl = document.getElementById(`gwMsg-${id}`);
    showMsg(msgEl, 'Mengakhiri giveaway...', 'info');
    const r    = await fetch(`/api/guild/${GUILD_ID}/giveaway/${id}/end`, { method: 'POST' });
    const data = await r.json();
    if (data.success) { queueToast(data.message, 'success'); location.reload(); }
    else showMsg(msgEl, data.message, 'error');
}

// ── Reroll ────────────────────────────────────────────────────────────────────
async function rerollGiveaway(id) {
    if (!confirm(I18N_GW_CONFIRM_REROLL)) return;
    const msgEl = document.getElementById(`gwMsg-${id}`);
    showMsg(msgEl, I18N_GW_REROLLING, 'info');
    const r    = await fetch(`/api/guild/${GUILD_ID}/giveaway/${id}/reroll`, { method: 'POST' });
    const data = await r.json();
    showMsg(msgEl, data.message, data.success ? 'success' : 'error');
}

function refreshGwStats() {
    const cards = document.querySelectorAll('.gw-card');
    document.getElementById('statGwActive').textContent = document.querySelectorAll('.gw-card[data-state="active"]').length;
    document.getElementById('statGwEnded').textContent  = document.querySelectorAll('.gw-card[data-state="ended"]').length;
    document.getElementById('statGwTotal').textContent  = cards.length;
}

// ── Delete from history ───────────────────────────────────────────────────────
async function deleteGiveaway(id) {
    if (!confirm(I18N_GW_CONFIRM_DEL)) return;
    const msgEl = document.getElementById(`gwMsg-${id}`);
    showMsg(msgEl, I18N_GW_DELETING, 'info');
    const r    = await fetch(`/api/guild/${GUILD_ID}/giveaway/${id}/remove`, { method: 'POST' });
    const data = await r.json();
    if (data.success) {
        const row = document.getElementById(`gwRow-${id}`);
        if (row) row.remove();
        refreshGwStats();
    } else {
        showMsg(msgEl, data.message, 'error');
    }
}

// ── Cancel ────────────────────────────────────────────────────────────────────
async function cancelGiveaway(id) {
    if (!confirm(I18N_GW_CONFIRM_CANCEL)) return;
    const msgEl = document.getElementById(`gwMsg-${id}`);
    const r     = await fetch(`/api/guild/${GUILD_ID}/giveaway/${id}`, { method: 'DELETE' });
    const data  = await r.json();
    if (data.success) { queueToast(data.message, 'success'); location.reload(); }
    else showMsg(msgEl, data.message, 'error');
}

// ── Helper ────────────────────────────────────────────────────────────────────
function showMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (type !== 'info') setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 4000);
}

// Inline spin keyframe
const style = document.createElement('style');
style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
document.head.appendChild(style);
</script>

