<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'ticket' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1><%= t('ticket.page_title') %></h1>
            <p><%= t('ticket.page_desc') %></p>
        </div>

        <!-- ── How to Use ──────────────────────────────────────────────────────────── -->
        <div class="settings-card" style="margin-bottom:1.5rem;--guide-accent:#5865F2;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:#5865F2;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('ticket.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('ticket.step1_title') %></div>
                    <div class="guide-desc"><%- t('ticket.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('ticket.step2_title') %></div>
                    <div class="guide-desc"><%- t('ticket.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('ticket.step3_title') %></div>
                    <div class="guide-desc"><%- t('ticket.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('ticket.tip') %></div>
        </div>

        <div class="tk-layout">

        <!-- ── Kolom kiri: konfigurasi ── -->
        <div class="tk-config-col">

        <!-- Enable/Disable -->
        <div class="settings-card" style="margin-bottom:1rem;">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
                <div>
                    <div style="font-weight:600;font-size:.95rem;"><%= t('ticket.enable_title') %></div>
                    <div style="font-size:.8rem;color:var(--text-muted);margin-top:.15rem;"><%= t('ticket.enable_desc') %></div>
                </div>
                <label class="toggle-label">
                    <input type="checkbox" id="ticketEnabled" class="toggle-input" <%= ticketData.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <!-- Channel & Category -->
        <div class="settings-card" style="margin-bottom:1rem;">
            <div style="font-size:.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.9rem;"><%= t('ticket.channel_config') %></div>

            <div class="form-group">
                <label class="label"><%= t('ticket.category_label') %> <span class="hint-inline"><%= t('giveaway.required_role_hint') %></span></label>
                <select id="ticketCategory" class="select">
                    <option value=""><%= t('ticket.category_none') %></option>
                    <% categories.forEach(c => { %>
                        <option value="<%= c.id %>" <%= ticketData.categoryId === c.id ? 'selected' : '' %>>📁 <%= c.name %></option>
                    <% }) %>
                </select>
                <div class="hint"><%= t('ticket.category_hint') %></div>
            </div>

            <div class="form-group">
                <label class="label"><%= t('ticket.log_label') %></label>
                <select id="ticketLogChannel" class="select">
                    <option value=""><%= t('ticket.log_none') %></option>
                    <% channels.forEach(c => { %>
                        <option value="<%= c.id %>" <%= ticketData.logChannelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                    <% }) %>
                </select>
                <div class="hint"><%= t('ticket.log_hint') %></div>
            </div>
        </div>

        <!-- Staff Roles -->
        <div class="settings-card" style="margin-bottom:1rem;">
            <% const validStaffRoles = ticketData.staffRoles.filter(id => roles.find(r => r.id === id)); %>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.9rem;flex-wrap:wrap;gap:.5rem;">
                <div style="font-size:.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;"><%= t('ticket.staff_roles') %></div>
                <span style="font-size:.72rem;padding:.15rem .45rem;border-radius:999px;background:var(--bg2);border:1px solid var(--border);color:var(--text-muted);" id="staffRoleCounter"><%= validStaffRoles.length %> role</span>
            </div>
            <div id="staffRoleList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:.75rem;min-height:1.5rem;">
                <% validStaffRoles.forEach(roleId => { %>
                    <% const role = roles.find(r => r.id === roleId); %>
                    <span class="am-word-chip" data-id="<%= role.id %>" style="border-color:<%= role.color || 'var(--border)' %>;">
                        <span style="font-size:.8rem;color:<%= role.color || 'inherit' %>;">@<%= role.name %></span>
                        <button class="am-chip-del" onclick="removeStaffRole('<%= role.id %>')" title="<%= t('ticket.role_remove_title') %>">×</button>
                    </span>
                <% }) %>
                <span id="staffRoleEmpty" style="color:var(--text-muted);font-size:.82rem;<%= validStaffRoles.length > 0 ? 'display:none;' : '' %>">
                    <%= t('ticket.staff_empty') %>
                </span>
            </div>
            <div style="display:flex;gap:.5rem;">
                <select id="staffRoleAdd" class="select" style="flex:1;" data-flt-ignore>
                    <option value=""><%= t('common.select_role') %></option>
                    <% roles.forEach(r => { %>
                        <option value="<%= r.id %>" style="color:<%= r.color %>">@<%= r.name %></option>
                    <% }) %>
                </select>
                <button class="btn btn-primary btn-sm" onclick="addStaffRole()"><%= t('ticket.add_btn') %></button>
            </div>
            <div id="staffRoleMsg" class="form-message" style="margin-top:.4rem;"></div>
            <div class="hint" style="margin-top:.5rem;"><%= t('ticket.staff_hint') %></div>
        </div>

        <div id="configMsg" class="form-message" style="margin-bottom:1rem;"></div>

        </div><!-- /tk-config-col -->

        <!-- ── Kolom kanan: panel embed ── -->
        <div class="tk-panel-col">

        <div class="settings-card">
            <div style="font-size:.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.9rem;"><%= t('ticket.panel_appearance') %></div>

            <div class="form-group">
                <label class="label"><%= t('ticket.embed_title_label') %></label>
                <input type="text" id="panelTitle" class="input" maxlength="256"
                       value="<%= ticketData.embedTitle %>" placeholder="<%= t('ticket.embed_title_default') %>"
                       oninput="updateTicketPreview()">
            </div>
            <div class="form-group">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.35rem;">
                    <label class="label" style="margin:0;"><%= t('ticket.description_label') %></label>
                    <div class="ph-picker-anchor mention-anchor">
                        <button type="button" class="ph-toggle-btn" onclick="togglePicker('ticketDescMentionPicker',event)">@ Mention</button>
                        <div class="ph-dropdown mention-dd" id="ticketDescMentionPicker" style="display:none;"></div>
                    </div>
                </div>
                <textarea id="panelDesc" class="textarea" rows="4" maxlength="4000"
                          placeholder="<%= t('ticket.embed_desc_default') %>"
                          oninput="updateTicketPreview()"><%= ticketData.embedDesc %></textarea>
            </div>
            <div class="form-group">
                <label class="label"><%= t('ticket.embed_color_label') %></label>
                <div style="display:flex;gap:.75rem;align-items:center;">
                    <input type="color" id="panelColorPicker" value="<%= ticketData.embedColor || '#5865F2' %>"
                           style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                           oninput="syncPicker('panelColor','panelColorPicker');updateTicketPreview()">
                    <input type="text" id="panelColor" class="input" style="max-width:130px;"
                           value="<%= ticketData.embedColor || '#5865F2' %>" maxlength="7"
                           oninput="syncHex('panelColor','panelColorPicker');updateTicketPreview()">
                </div>
            </div>
            <div class="form-group">
                <label class="label"><%= t('ticket.btn_label') %></label>
                <input type="text" id="panelBtnLabel" class="input" maxlength="80"
                       value="<%= ticketData.btnLabel %>" placeholder="<%= t('ticket.btn_label_default') %>"
                       oninput="updateTicketPreview()">
            </div>

            <!-- Preview Discord -->
            <div class="preview-label" style="margin-top:1.25rem;"><%= t('common.preview') %></div>
            <div class="dc-window">
                <div class="dc-channel-bar"><span class="dc-channel-hash">#</span><span>ticket-panel</span></div>
                <div class="dc-messages">
                    <div class="dc-message">
                        <img class="dc-avatar" src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="bot" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                        <div class="dc-msg-body">
                            <span class="dc-username" style="color:<%- locals.botNavColor||'#fff' %>"><%- locals.botNavName||'Bot' %></span>
                            <span class="dc-timestamp">Today at 12:00 PM</span>
                            <div class="dc-embed" id="tkPreviewEmbed">
                                <div class="dc-embed-pill" id="tkPreviewPill" style="background:<%= ticketData.embedColor||'#5865F2' %>;"></div>
                                <div class="dc-embed-content">
                                    <div class="dc-embed-title" id="tkPreviewTitle"><%= ticketData.embedTitle || t('ticket.embed_title_default') %></div>
                                    <div class="dc-embed-desc" id="tkPreviewDesc"><%= ticketData.embedDesc || t('ticket.embed_desc_default') %></div>
                                </div>
                            </div>
                            <!-- Preview tombol -->
                            <div style="margin-top:.4rem;">
                                <span class="tk-btn-preview" id="tkPreviewBtn"><%= ticketData.btnLabel || t('ticket.btn_label_default') %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Select send channel -->
            <div class="form-group" style="margin-top:1rem;" id="panelSendChannelGroup">
                <label class="label"><%= t('ticket.send_channel_label') %></label>
                <select id="panelSendChannel" class="select">
                    <option value=""><%= t('common.select_channel') %></option>
                    <% channels.forEach(c => { %>
                        <option value="<%= c.id %>" <%= ticketData.panelChannelId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                    <% }) %>
                </select>
                <% if (ticketData.panelSent) { %>
                <div class="hint" style="margin-top:.4rem;">
                    <%= t('ticket.panel_sent') %> <a href="https://discord.com/channels/<%= guild.id %>/<%= ticketData.panelChannelId %>/<%= ticketData.panelMsgId %>" target="_blank" style="color:var(--accent);"><%= t('ticket.panel_sent_view') %></a>.
                    <%- t('ticket.panel_sent_hint') %>
                </div>
                <% } %>
            </div>

            <div style="display:flex;gap:.75rem;margin-top:1rem;flex-wrap:wrap;">
                <button class="btn btn-primary" onclick="sendPanel()"><%= t('ticket.send_panel_btn') %></button>
            </div>
            <div id="panelMsg" class="form-message" style="margin-top:.5rem;"></div>
        </div>

        <!-- Active Tickets List -->
        <% if (openTickets.length > 0) { %>
        <div class="settings-card" style="margin-top:1rem;">
            <div style="font-size:.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.9rem;">
                <%= t('ticket.active_tickets') %>
                <span style="font-size:.72rem;padding:.15rem .45rem;border-radius:999px;background:var(--bg2);border:1px solid rgba(87,242,135,.3);color:#57F287;margin-left:.5rem;"><%= openTickets.length %> <%= t('ticket.tickets_open') %></span>
            </div>
            <div style="display:flex;flex-direction:column;gap:.45rem;">
                <% openTickets.forEach(tk => { %>
                <div class="tk-ticket-row">
                    <div class="tk-ticket-num">#<%= String(tk.ticketNumber).padStart(4,'0') %></div>
                    <div class="tk-ticket-body">
                        <div class="tk-ticket-user"><%= tk.username %></div>
                        <%
                            const _diff = Date.now() - tk.openedAt;
                            const _min  = Math.floor(_diff / 60000);
                            const _hr   = Math.floor(_diff / 3600000);
                            const _day  = Math.floor(_diff / 86400000);
                            const _remH = _hr - _day * 24;
                            const _dur  = _day >= 1
                                ? (_remH > 0 ? t('ticket.days_ago', { d: _day, h: _remH }) : t('ticket.days_only_ago', { d: _day }))
                                : _hr >= 1
                                    ? t('ticket.hours_ago', { n: _hr })
                                    : t('ticket.minutes_ago', { n: _min });
                        %>
                        <div class="tk-ticket-time"><%= t('ticket.ticket_opened') %> <span title="<%= new Date(tk.openedAt).toLocaleString('id-ID') %>"><%= _dur %></span></div>
                    </div>
                    <a href="https://discord.com/channels/<%= guild.id %>/<%= tk.channelId %>" target="_blank" class="btn btn-outline btn-sm" style="flex-shrink:0;"><%= t('ticket.view_btn') %></a>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        </div><!-- /tk-panel-col -->
        </div><!-- /tk-layout -->
    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<style>
/* ── Discord preview ── */
.dc-window { background:#36393f; border-radius:8px; overflow:hidden; margin-top:.5rem; }
.dc-channel-bar { background:#2f3136; padding:.45rem .75rem; font-size:.78rem; color:#8e9297; display:flex; align-items:center; gap:.4rem; }
.dc-channel-hash { font-weight:700; }
.dc-messages { padding:.75rem; }
.dc-message { display:flex; gap:.75rem; }
.dc-avatar { width:40px; height:40px; border-radius:50%; flex-shrink:0; object-fit:cover; }
.dc-msg-body { flex:1; min-width:0; }
.dc-username { color:#fff; font-weight:600; font-size:.875rem; margin-right:.4rem; }
.dc-timestamp { color:#72767d; font-size:.72rem; }
.dc-embed {
    margin-top:.35rem; background:#2f3136; border-radius:4px;
    display:flex; max-width:432px; overflow:hidden;
}
.dc-embed-pill { width:4px; flex-shrink:0; border-radius:4px 0 0 4px; }
.dc-embed-content { padding:.6rem .75rem; flex:1; min-width:0; }
.dc-embed-title { color:#fff; font-weight:600; font-size:.9rem; margin-bottom:.2rem; }
.dc-embed-desc { color:#dcddde; font-size:.83rem; line-height:1.4; word-break:break-word; }

/* ── Dashboard layout ── */
.tk-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
}
@media(max-width:860px) { .tk-layout { grid-template-columns: 1fr; } }

/* Role chips */
.am-word-chip {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .25rem .5rem .25rem .6rem;
    background: var(--bg-3, rgba(255,255,255,.05));
    border: 1px solid var(--border, rgba(255,255,255,.1));
    border-radius: 6px; font-size: .82rem; line-height: 1.4;
}
.am-chip-del {
    background: none; border: none; color: var(--text-muted);
    cursor: pointer; padding: 0 2px; font-size: 1rem; line-height: 1;
    border-radius: 3px; transition: color .15s, background .15s; flex-shrink: 0;
}
.am-chip-del:hover { color: #ED4245; background: rgba(237,66,69,.1); }

/* Ticket row */
.tk-ticket-row {
    display: flex; align-items: center; gap: .75rem;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: .55rem .75rem;
}
.tk-ticket-num {
    font-weight: 700; font-size: .8rem; color: var(--accent);
    min-width: 48px; font-family: monospace;
}
.tk-ticket-body { flex: 1; min-width: 0; }
.tk-ticket-user { font-size: .85rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tk-ticket-time { font-size: .72rem; color: var(--text-muted); }

/* Preview button */
.tk-btn-preview {
    display: inline-flex; align-items: center;
    background: rgba(88,101,242,.25); color: #949cf7;
    border: 1px solid rgba(88,101,242,.4);
    border-radius: 6px; padding: .3rem .85rem;
    font-size: .82rem; font-weight: 500;
    cursor: default; user-select: none;
}
</style>

<script>
const GUILD_ID              = '<%= guild.id %>';
const I18N_TK_NO_CH         = '<%= t("ticket.err_no_channel") %>';
const I18N_TK_SENT_OK       = '<%= t("ticket.panel_sent_ok") %>';
const I18N_TK_TITLE_DEF     = '<%= t("ticket.embed_title_default") %>';
const I18N_TK_DESC_DEF      = '<%= t("ticket.embed_desc_default") %>';
const I18N_TK_BTN_DEF       = '<%= t("ticket.btn_label_default") %>';
const I18N_TK_REMOVE_TITLE  = '<%= t("ticket.role_remove_title") %>';
const ROLES_MAP = <%- JSON.stringify(Object.fromEntries(roles.map(r => [r.id, { name: r.name, color: r.color }]))) %>;
const CHANNELS  = <%- JSON.stringify(Object.fromEntries(channels.map(c => [c.id, c.name]))) %>;
let _staffRoles = <%- JSON.stringify(validStaffRoles) %>;

// ── Color sync ────────────────────────────────────────────────────────────────
function syncHex(hexId, pickId) {
    const v = document.getElementById(hexId).value.trim();
    if (/^#[0-9A-Fa-f]{6}$/.test(v)) document.getElementById(pickId).value = v;
}
function syncPicker(hexId, pickId) {
    document.getElementById(hexId).value = document.getElementById(pickId).value;
}

// ── Mention preview helpers ───────────────────────────────────────────────────
function _tkEsc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function _tkBadge(color, text, bg) { return `<span style="color:${color};background:${bg||'rgba(88,101,242,.15)'};border-radius:3px;padding:0 3px;font-weight:600;">${text}</span>`; }
function _tkMdToHtml(text) {
    if (!text) return '';
    const lines = text.split('\n');
    return lines.map(l => _tkEsc(l)
        .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
        .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
        .replace(/\*(.+?)\*/g,'<em>$1</em>')
        .replace(/__(.+?)__/g,'<u>$1</u>')
        .replace(/~~(.+?)~~/g,'<s>$1</s>')
    ).join('<br>');
}
function _tkResolveMentions(html) {
    if (!html) return '';
    return html
        .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => { const r=ROLES_MAP[id]; return r ? _tkBadge(r.color,'@'+r.name) : _tkBadge('#99aab5','@unknown-role'); })
        .replace(/&lt;@!?(\d+)&gt;/g,    ()       => _tkBadge('#7289da','@User'))
        .replace(/&lt;#(\d+)&gt;/g,      (_, id)  => { const n=CHANNELS[id]; return n ? _tkBadge('#7289da','#'+n) : _tkBadge('#7289da','#unknown'); })
        .replace(/@everyone\b/g, () => _tkBadge('#7289da','@everyone'))
        .replace(/@here\b/g,     () => _tkBadge('#7289da','@here'));
}

// ── Preview ───────────────────────────────────────────────────────────────────
function updateTicketPreview() {
    const title = document.getElementById('panelTitle').value;
    const desc  = document.getElementById('panelDesc').value;
    const color = document.getElementById('panelColor').value || '#5865F2';
    const btn   = document.getElementById('panelBtnLabel').value || I18N_TK_BTN_DEF;

    document.getElementById('tkPreviewTitle').textContent = title || I18N_TK_TITLE_DEF;
    document.getElementById('tkPreviewDesc').innerHTML    = desc ? _tkResolveMentions(_tkMdToHtml(desc)) : _tkEsc(I18N_TK_DESC_DEF);
    document.getElementById('tkPreviewPill').style.background = color;
    document.getElementById('tkPreviewBtn').textContent   = btn;
}

// ── Staff roles ───────────────────────────────────────────────────────────────
async function addStaffRole() {
    const sel    = document.getElementById('staffRoleAdd');
    const roleId = sel.value;
    if (!roleId) return;
    if (_staffRoles.includes(roleId)) { sel.value = ''; return; }

    const msg = document.getElementById('staffRoleMsg');
    const res  = await fetch(`/api/guild/${GUILD_ID}/ticket/staff-roles`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ roleId }),
    });
    const data = await res.json();
    if (!data.success) { showMsg(msg, data.message, 'error'); return; }

    const r = ROLES_MAP[roleId];
    _staffRoles.push(roleId);
    sel.value = '';
    const list  = document.getElementById('staffRoleList');
    const empty = document.getElementById('staffRoleEmpty');
    if (empty) empty.style.display = 'none';
    const chip = document.createElement('span');
    chip.className  = 'am-word-chip';
    chip.dataset.id = roleId;
    if (r?.color) chip.style.borderColor = r.color;
    chip.innerHTML = `<span style="font-size:.8rem;${r?.color ? `color:${r.color};` : ''}">@${r?.name || roleId}</span><button class="am-chip-del" onclick="removeStaffRole('${roleId}')" title="${I18N_TK_REMOVE_TITLE}">×</button>`;
    list.appendChild(chip);
    document.getElementById('staffRoleCounter').textContent = `${_staffRoles.length} role`;
    showMsg(msg, data.message, 'success');
}

async function removeStaffRole(roleId) {
    const msg  = document.getElementById('staffRoleMsg');
    const res  = await fetch(`/api/guild/${GUILD_ID}/ticket/staff-roles/${roleId}`, { method: 'DELETE' });
    const data = await res.json();
    if (!data.success) { showMsg(msg, data.message, 'error'); return; }

    _staffRoles = _staffRoles.filter(id => id !== roleId);
    document.querySelector(`.am-word-chip[data-id="${roleId}"]`)?.remove();
    document.getElementById('staffRoleCounter').textContent = `${_staffRoles.length} role`;
    if (_staffRoles.length === 0) document.getElementById('staffRoleEmpty').style.display = '';
    showMsg(msg, data.message, 'success');
}

// ── showMsg helper ────────────────────────────────────────────────────────────
function showMsg(el, text, type) {
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

// ── Simpan konfigurasi ────────────────────────────────────────────────────────
async function saveConfig(quiet = false) {
    const msg = document.getElementById('configMsg');
    const payload = {
        enabled:      document.getElementById('ticketEnabled').checked,
        categoryId:   document.getElementById('ticketCategory').value,
        logChannelId: document.getElementById('ticketLogChannel').value,
    };
    const res  = await fetch(`/api/guild/${GUILD_ID}/ticket/config`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!quiet) showMsg(msg, data.message, data.success ? 'success' : 'error');
    return data;
}

// ── Simpan embed panel ────────────────────────────────────────────────────────
async function savePanelEmbed(quiet = false) {
    const msg = document.getElementById('panelMsg');
    const payload = {
        embedTitle: document.getElementById('panelTitle').value.trim(),
        embedDesc:  document.getElementById('panelDesc').value.trim(),
        embedColor: document.getElementById('panelColor').value.trim(),
        btnLabel:   document.getElementById('panelBtnLabel').value.trim(),
    };
    const res  = await fetch(`/api/guild/${GUILD_ID}/ticket/panel-embed`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!quiet) showMsg(msg, data.message, data.success ? 'success' : 'error');
    return data;
}

// ── Kirim panel ───────────────────────────────────────────────────────────────
async function sendPanel() {
    const msg       = document.getElementById('panelMsg');
    const channelId = document.getElementById('panelSendChannel').value;
    if (!channelId) return showMsg(msg, I18N_TK_NO_CH, 'error');

    // Simpan embed dulu
    await savePanelEmbed();

    const res  = await fetch(`/api/guild/${GUILD_ID}/ticket/send-panel`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId })
    });
    const data = await res.json();
    if (data.success) showMsg(msg, I18N_TK_SENT_OK, 'success');
    else              showMsg(msg, data.message, 'error');

    if (data.success) setTimeout(() => location.reload(), 1200);
}

window._floatSave = async function () {
    const [d1, d2] = await Promise.all([saveConfig(true), savePanelEmbed(true)]);
    const msg = document.getElementById('configMsg');
    const ok = d1.success && d2.success;
    showMsg(msg, ok ? d1.message : (d1.success ? d2.message : d1.message), ok ? 'success' : 'error');
    if (!ok) throw new Error();
};

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});
function _buildMentionDd(dd, getTarget) {
    function item(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => {
            const ta = typeof getTarget === 'function' ? getTarget() : getTarget;
            if (!ta) return;
            const s = ta.selectionStart ?? ta.value.length;
            const ep = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, s) + mention + ta.value.slice(ep);
            ta.selectionStart = ta.selectionEnd = s + mention.length;
            ta.focus(); ta.dispatchEvent(new Event('input', {bubbles: true}));
            document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
            document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
        });
        return b;
    }
    function hdr(t) { const h = document.createElement('div'); h.className = 'ph-group-label'; h.textContent = t; return h; }
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => { el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special'));
    dd.appendChild(item('<code>@everyone</code>', '@everyone'));
    dd.appendChild(item('<code>@here</code>', '@here'));
    const rKeys = Object.keys(ROLES_MAP);
    if (rKeys.length) {
        dd.appendChild(hdr('Roles'));
        rKeys.forEach(id => { const r = ROLES_MAP[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`)); });
    }
    const cKeys = Object.keys(CHANNELS);
    if (cKeys.length) {
        dd.appendChild(hdr('Channels'));
        cKeys.forEach(id => { const name = CHANNELS[id]; dd.appendChild(item(`<span>#${name}</span>`, `<#${id}>`)); });
    }
}
_buildMentionDd(document.getElementById('ticketDescMentionPicker'), () => document.getElementById('panelDesc'));
</script>

