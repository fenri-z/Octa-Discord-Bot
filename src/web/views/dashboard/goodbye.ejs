.dc-field-name  { font-size: .75rem; font-weight: 700; color: #dbdee1; margin-bottom: .1rem; }
.dc-field-value { font-size: .8rem; color: #b5bac1; }
.dc-embed-footer { font-size: .72rem; color: #80848e; margin-top: .5rem; border-top: 1px solid rgba(255,255,255,.06); padding-top: .4rem; }
.dc-embed-footer:empty { display: none; border: none; padding: 0; }
.dc-embed-thumb { width: 60px; height: 60px; border-radius: 4px; object-fit: cover; flex-shrink: 0; margin: .6rem .6rem .6rem 0; align-self: flex-start; }
.label-with-picker { display: flex; align-items: center; justify-content: space-between; gap: .5rem; margin-bottom: .35rem; }
.ph-picker-anchor { position: relative; }
.ph-toggle-btn { font-size: .72rem; padding: 2px 9px; border: 1px solid var(--border, #3f4147); border-radius: 4px; background: rgba(255,255,255,.05); color: var(--text-muted, #80848e); cursor: pointer; font-family: monospace; white-space: nowrap; line-height: 1.6; transition: background .15s, color .15s; }
.ph-toggle-btn:hover { background: rgba(255,255,255,.12); color: var(--text, #dbdee1); }
.ph-dropdown { position: absolute; top: calc(100% + 4px); right: 0; z-index: 200; background: #2b2d31; border: 1px solid #3f4147; border-radius: 8px; padding: .5rem; min-width: 260px; box-shadow: 0 8px 28px rgba(0,0,0,.55); display: grid; grid-template-columns: 1fr 1fr; gap: .25rem; }
.ph-item { display: flex; flex-direction: column; align-items: flex-start; padding: .32rem .5rem; border: 1px solid transparent; border-radius: 5px; background: transparent; cursor: pointer; text-align: left; width: 100%; transition: background .12s; }
.ph-item:hover { background: rgba(255,255,255,.09); border-color: #4f5660; }
.ph-item code { font-size: .76rem; color: #7289da; font-family: monospace; }
.ph-item span { font-size: .67rem; color: #80848e; margin-top: 1px; }
</style>

<script>
const SAMPLE = {
    member:      '@' + <%- JSON.stringify(loginUser.displayName) %>,
    username:    <%- JSON.stringify(loginUser.username) %>,
    displayName: <%- JSON.stringify(loginUser.displayName) %>,
    tag:         <%- JSON.stringify(loginUser.username) %> + '#0',
    avatarUrl:   <%- JSON.stringify(loginUser.avatarUrl) %>,
    server:      <%- JSON.stringify(guild.name) %>,
    count:       '<%= guild.memberCount %>',
    akun_dibuat: '3 tahun yang lalu',
};

const guildId = '<%= guild.id %>';

// ── Markdown Discord → HTML ──────────────────────────────────────────────────
function mdToHtml(text) {
    if (!text) return '';
    function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function inline(s) {
        const codeStore = [];
        s = s.replace(/`(.+?)`/g, (_, code) => {
            const i = codeStore.length;
            codeStore.push('<code style="background:#2b2d31;padding:1px 5px;border-radius:3px;font-size:.85em;font-family:\'Consolas\',monospace;">' + code + '</code>');
            return '\x01C' + i + '\x01';
        });
        s = s
            .replace(/\[([^\]]+)\]\(\s*(https?:\/\/[^\s)]+)\s*\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" style="color:#00b0f4;text-decoration:none;">$1</a>')
            .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
            .replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g,         '<em>$1</em>')
            .replace(/__(.+?)__/g,         '<u>$1</u>')
            .replace(/~~(.+?)~~/g,         '<s>$1</s>')
            .replace(/\|\|(.+?)\|\|/g,     '<span class="dc-spoiler" title="Klik untuk lihat spoiler" onclick="this.classList.toggle(\'shown\')">$1</span>')
            .replace(/(href="[^"]*")|((https?:\/\/[^\s<>"']+))/g, (match, hrefAttr, _, url) => {
                if (hrefAttr) return match;
                const clean = url.replace(/[.,;:!?)\]>]+$/, '');
                return '<a href="' + clean + '" target="_blank" rel="noopener noreferrer" style="color:#00b0f4;text-decoration:underline;">' + clean + '</a>';
            });
        return s.replace(/\x01C(\d+)\x01/g, (_, i) => codeStore[+i]);
    }
    const lines = text.split('\n');
    const out = []; let inCode = false, codeBuf = [];
    for (let i = 0; i < lines.length; i++) {
        const raw = lines[i];
        if (!inCode && /^```/.test(raw)) { inCode = true; codeBuf = []; continue; }
        if (inCode) {
            if (/^```\s*$/.test(raw.trim())) {
                inCode = false;
                out.push('<div style="display:block;background:#1e1f22;border-radius:4px;padding:.4rem .75rem;font-family:\'Consolas\',monospace;font-size:.82em;white-space:pre;color:#dbdee1;">' + esc(codeBuf.join('\n')) + '</div>');
            } else { codeBuf.push(raw); }
            continue;
        }
        let m;
        if ((m = raw.match(/^>>> (.*)$/))) { out.push('<div style="display:block;border-left:4px solid #4e5058;padding:.1em .75em;margin:.1em 0;color:#dbdee1;">' + inline(esc([m[1], ...lines.slice(i+1)].join('\n'))) + '</div>'); break; }
        if ((m = raw.match(/^> (.+)$/)))   { out.push('<div style="display:block;border-left:4px solid #4e5058;padding:.1em .75em;margin:.05em 0;color:#dbdee1;">' + inline(esc(m[1])) + '</div>'); continue; }
        if ((m = raw.match(/^### (.+)$/))) { out.push('<div style="display:block;font-size:1.05em;font-weight:700;margin:.3em 0 .1em;">' + inline(esc(m[1])) + '</div>'); continue; }
        if ((m = raw.match(/^## (.+)$/)))  { out.push('<div style="display:block;font-size:1.25em;font-weight:700;margin:.3em 0 .2em;">' + inline(esc(m[1])) + '</div>'); continue; }
        if ((m = raw.match(/^# (.+)$/)))   { out.push('<div style="display:block;font-size:1.5em;font-weight:700;line-height:1.3;margin:.3em 0 .2em;">' + inline(esc(m[1])) + '</div>'); continue; }
        if ((m = raw.match(/^-# (.+)$/)))  { out.push('<div style="display:block;font-size:.75em;color:#80848e;margin:.05em 0;">' + inline(esc(m[1])) + '</div>'); continue; }
        out.push(inline(esc(raw)));
    }
    if (inCode && codeBuf.length) out.push('<div style="display:block;background:#1e1f22;border-radius:4px;padding:.4rem .75rem;font-family:\'Consolas\',monospace;font-size:.82em;white-space:pre;color:#dbdee1;">' + esc(codeBuf.join('\n')) + '</div>');
    let result = '';
    for (let j = 0; j < out.length; j++) {
        const isBlock = out[j].startsWith('<div'), prevBlock = j > 0 && out[j-1].startsWith('<div');
        if (j > 0 && !isBlock && !prevBlock) result += '<br>';
        result += out[j];
    }
    return result;
}

// ── Mention cache ────────────────────────────────────────────────────────────
const memberCache = {}, roleCache = {}, channelCache = {};

function mentionBadge(color, text, bg) {
    bg = bg || color + '26';
    return '<span style="color:' + color + ';background:' + bg + ';border-radius:3px;padding:0 2px;font-weight:600;">' + text + '</span>';
}

async function resolveMentionId(id) {
    if (memberCache[id] !== undefined) return;
    memberCache[id] = 'fetching';
    try {
        const res  = await fetch('/api/guild/' + guildId + '/members/search?q=' + encodeURIComponent(id));
        const data = await res.json();
        memberCache[id] = (data.success && data.members && data.members.length > 0 && data.members[0].display) ? data.members[0].display : null;
    } catch(e) { memberCache[id] = null; }
    updatePreview();
}
async function resolveRoleId(id) {
    if (roleCache[id] !== undefined) return;
    roleCache[id] = 'fetching';
    try {
        const res  = await fetch('/api/guild/' + guildId + '/roles/' + id);
        const data = await res.json();
        roleCache[id] = (data.success && data.role && data.role.name) ? { name: data.role.name, color: data.role.color } : null;
    } catch(e) { roleCache[id] = null; }
    updatePreview();
}
async function resolveChannelId(id) {
    if (channelCache[id] !== undefined) return;
    channelCache[id] = 'fetching';
    try {
        const res  = await fetch('/api/guild/' + guildId + '/channels/' + id);
        const data = await res.json();
        channelCache[id] = (data.success && data.channel && data.channel.name) ? { name: data.channel.name } : null;
    } catch(e) { channelCache[id] = null; }
    updatePreview();
}

// Untuk title/footer — {member} → @displayName sebagai teks biasa (sesuai Discord)
function resolvePlaceholdersTitle(text) {
    if (!text) return '';
    return text
        .replace(/\{member\}/g,      SAMPLE.member)
        .replace(/\{username\}/g,    SAMPLE.username)
        .replace(/\{tag\}/g,         SAMPLE.tag)
        .replace(/\{server\}/g,      SAMPLE.server)
        .replace(/\{count\}/g,       SAMPLE.count)
        .replace(/\{akun\.dibuat\}/g,SAMPLE.akun_dibuat);
}

// Untuk description/plain — {member} → marker mention badge
function resolvePlaceholders(text) {
    if (!text) return '';
    return text
        .replace(/\{member\}/g,      '\x00MENTION_MEMBER\x00')
        .replace(/\{username\}/g,    SAMPLE.username)
        .replace(/\{tag\}/g,         SAMPLE.tag)
        .replace(/\{server\}/g,      SAMPLE.server)
        .replace(/\{count\}/g,       SAMPLE.count)
        .replace(/\{akun\.dibuat\}/g,SAMPLE.akun_dibuat);
}

function resolveHtmlMentions(html) {
    if (!html) return '';
    return html
        .replace(/\x00MENTION_MEMBER\x00/g, mentionBadge('#7289da', SAMPLE.member, 'rgba(88,101,242,.15)'))
        .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => {
            const st = ROLES[id];
            if (st) return mentionBadge(st.color, '@' + st.name);
            const c = roleCache[id];
            if (c === undefined) resolveRoleId(id);
            if (c && c !== 'fetching') return mentionBadge(c.color, '@' + c.name);
            return mentionBadge('#99aab5', c === null ? '@unknown-role' : '@...');
        })
        .replace(/&lt;@!?(\d+)&gt;/g, (_, id) => {
            const c = memberCache[id];
            if (c === undefined) resolveMentionId(id);
            return mentionBadge('#7289da', c && c !== 'fetching' ? '@' + c : c === null ? '@unknown-user' : '@...', 'rgba(88,101,242,.15)');
        })
        .replace(/&lt;#(\d+)&gt;/g, (_, id) => {
            if (CHANNELS[id]) return mentionBadge('#7289da', '#' + CHANNELS[id], 'rgba(88,101,242,.15)');
            const c = channelCache[id];
            if (c === undefined) resolveChannelId(id);
            if (c && c !== 'fetching') return mentionBadge('#7289da', '#' + c.name, 'rgba(88,101,242,.15)');
            return mentionBadge('#7289da', c === null ? '#unknown-channel' : '#...', 'rgba(88,101,242,.15)');
        });
}

// ── Card sync ────────────────────────────────────────────────────────────────
function _syncCardPlacement() {
    const enabled  = document.getElementById('cardEnabled').checked;
    const wrap     = document.getElementById('cardPreviewWrap');
    const imgEmbed = document.getElementById('previewCardInEmbed');
    const imgPlain = document.getElementById('previewCardInPlain');
    if (!enabled) { wrap.style.display = 'none'; if (imgEmbed) imgEmbed.style.display = 'none'; if (imgPlain) imgPlain.style.display = 'none'; return; }
    const canvas = document.getElementById('cardCanvas');
    const dataUrl = canvas ? canvas.toDataURL() : '';
    if (imgEmbed && dataUrl) imgEmbed.src = dataUrl;
    if (imgPlain && dataUrl) imgPlain.src = dataUrl;
    const isPlain = document.getElementById('typePlain').checked;
    if (isPlain) {
        const plainVal    = (document.getElementById('goodbyePlainText') || {}).value || '';
        const activeFields = FIELD_DEFS.filter(f => document.getElementById(f.id).checked);
        const hasContent  = plainVal.trim() || activeFields.length > 0;
        wrap.style.display = hasContent ? 'none'  : 'block';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = hasContent ? 'block' : 'none';
    } else {
        // Mode embed: card selalu masuk ke dalam embed, tidak pernah standalone
        wrap.style.display = 'none';
        if (imgEmbed) imgEmbed.style.display = 'block';
        if (imgPlain) imgPlain.style.display = 'none';
    }
}

// ── Card canvas preview ──────────────────────────────────────────────────────
async function drawCardPreview() {
    const enabled = document.getElementById('cardEnabled').checked;
    if (!enabled) { _syncCardPlacement(); return; }
    const canvas = document.getElementById('cardCanvas');
    const ctx    = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    const bgType   = document.querySelector('input[name="cardBgType"]:checked')?.value || 'gradient';
    const bg1      = document.getElementById('cardBgColor')?.value      || '#1a0a0a';
    const bg2      = document.getElementById('cardBgColor2')?.value     || '#2e0a0a';
    const bgImgUrl = (document.getElementById('cardBgImageUrl')?.value  || '').trim();
    const overlayClr = document.getElementById('cardOverlayColor')?.value  || '#000000';
    const overlayOp  = (parseInt(document.getElementById('cardOverlayOpacity')?.value || '0')) / 100;
    const accent   = document.getElementById('cardAccentColor')?.value  || '#ED4245';
    const titleClr = document.getElementById('cardTitleColor')?.value   || '#ffffff';
    const userClr  = document.getElementById('cardUsernameColor')?.value || accent;
    const msgClr   = document.getElementById('cardMsgColor')?.value     || '#cccccc';
    const shape    = document.querySelector('input[name="cardAvatarShape"]:checked')?.value || 'circle';
    const fontSel  = document.getElementById('cardFont')?.value         || 'impact';
    const fontMap  = { impact:"Impact,'Arial Black',sans-serif", arial:'Arial,Helvetica,sans-serif', georgia:"Georgia,'Times New Roman',serif", courier:"'Courier New',Courier,monospace", verdana:'Verdana,Geneva,sans-serif' };
    const fontFam  = fontMap[fontSel] || fontMap.impact;
    const bigText  = document.getElementById('cardWelcomeText')?.value  || 'GOODBYE';
    const sub      = (document.getElementById('cardSubText')?.value     || 'FROM {server}')
                       .replace(/{server}/gi, SAMPLE.server).replace(/{count}/gi, SAMPLE.count).replace(/{tag}/gi, SAMPLE.tag);

    const gradPanel = document.getElementById('cardBgGradientPanel');
    const imgPanel  = document.getElementById('cardBgImagePanel');
    const col2Grp   = document.getElementById('cardBgColor2Group');
    const hasBgColor = bgType !== 'image' && bgType !== 'transparent';
    if (gradPanel) gradPanel.style.display = hasBgColor ? 'grid' : 'none';
    if (imgPanel)  imgPanel.style.display  = bgType === 'image' ? 'block' : 'none';
    if (col2Grp)   col2Grp.style.display   = bgType === 'gradient' ? 'block' : 'none';
    const lbl = document.getElementById('cardBgColor1Label');
    if (lbl) lbl.textContent = bgType === 'gradient' ? 'Latar Kiri' : 'Warna Latar';

    ctx.clearRect(0, 0, W, H);
    function rr(x, y, w, h, r) {
        ctx.beginPath(); ctx.moveTo(x+r, y);
        ctx.lineTo(x+w-r, y); ctx.quadraticCurveTo(x+w, y, x+w, y+r);
        ctx.lineTo(x+w, y+h-r); ctx.quadraticCurveTo(x+w, y+h, x+w-r, y+h);
        ctx.lineTo(x+r, y+h); ctx.quadraticCurveTo(x, y+h, x, y+h-r);
        ctx.lineTo(x, y+r); ctx.quadraticCurveTo(x, y, x+r, y); ctx.closePath();
    }

    if (bgType === 'transparent') {
        const sz = 12;
        ctx.save(); rr(0, 0, W, H, 16); ctx.clip();
        for (let y = 0; y < H; y += sz) for (let x = 0; x < W; x += sz) {
            ctx.fillStyle = (Math.floor(x/sz) + Math.floor(y/sz)) % 2 === 0 ? '#c0c0c0' : '#909090';
            ctx.fillRect(x, y, sz, sz);
        }
        ctx.restore();
    } else if (bgType === 'image' && bgImgUrl) {
        const proxyUrl = '/api/guild/<%= guild.id %>/image-proxy?url=' + encodeURIComponent(bgImgUrl);
        try {
            await new Promise((res, rej) => {
                const img = new Image();
                img.onload = () => { ctx.save(); rr(0,0,W,H,16); ctx.clip(); const sc=Math.max(W/img.width,H/img.height); ctx.drawImage(img,(W-img.width*sc)/2,(H-img.height*sc)/2,img.width*sc,img.height*sc); ctx.restore(); res(); };
                img.onerror = rej; img.src = proxyUrl;
            });
        } catch { rr(0,0,W,H,16); const gd=ctx.createLinearGradient(0,0,W,H); gd.addColorStop(0,bg1); gd.addColorStop(1,bg2); ctx.fillStyle=gd; ctx.fill(); }
    } else if (bgType === 'solid') {
        rr(0,0,W,H,16); ctx.fillStyle=bg1; ctx.fill();
    } else {
        rr(0,0,W,H,16); const gd=ctx.createLinearGradient(0,0,W,H); gd.addColorStop(0,bg1); gd.addColorStop(1,bg2); ctx.fillStyle=gd; ctx.fill();
    }

    if (overlayOp > 0) { ctx.save(); rr(0,0,W,H,16); ctx.clip(); ctx.globalAlpha=overlayOp; ctx.fillStyle=overlayClr; ctx.fillRect(0,0,W,H); ctx.globalAlpha=1; ctx.restore(); }

    ctx.globalAlpha=0.07; ctx.fillStyle=accent;
    ctx.beginPath(); ctx.arc(W-60,40,80,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(W-20,H-20,60,0,Math.PI*2); ctx.fill();
    ctx.globalAlpha=1;

    const AS=120,BD=5,avL=50,avT=(H-AS-BD*2)/2,TX=avL+AS+BD*2+40;
    const isSquare = shape==='square';
    ctx.fillStyle=accent;
    if (isSquare) { rr(avL,avT,AS+BD*2,AS+BD*2,20); ctx.fill(); }
    else { ctx.beginPath(); ctx.arc(avL+(AS+BD*2)/2,avT+(AS+BD*2)/2,(AS+BD*2)/2,0,Math.PI*2); ctx.fill(); }

    const avatarProxyUrl = '/api/guild/<%= guild.id %>/image-proxy?url=' + encodeURIComponent(SAMPLE.avatarUrl);
    await new Promise(resAvatar => {
        const avImg = new Image();
        avImg.onload = () => {
            ctx.save();
            if (isSquare) { rr(avL+BD,avT+BD,AS,AS,14); ctx.clip(); }
            else { ctx.beginPath(); ctx.arc(avL+BD+AS/2,avT+BD+AS/2,AS/2,0,Math.PI*2); ctx.clip(); }
            ctx.drawImage(avImg,avL+BD,avT+BD,AS,AS); ctx.restore(); resAvatar();
        };
        avImg.onerror = () => {
            ctx.fillStyle='#5a6070';
            if (isSquare) { rr(avL+BD,avT+BD,AS,AS,14); ctx.fill(); }
            else { ctx.beginPath(); ctx.arc(avL+BD+AS/2,avT+BD+AS/2,AS/2,0,Math.PI*2); ctx.fill(); }
            const cx=avL+BD+AS/2,cy=avT+BD+AS/2; ctx.fillStyle='#8892a4';
            ctx.beginPath(); ctx.arc(cx,cy-20,22,0,Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(cx,cy+40,35,28,0,0,Math.PI*2); ctx.fill(); resAvatar();
        };
        avImg.src = avatarProxyUrl;
    });

    ctx.shadowColor=titleClr; ctx.shadowBlur=8; ctx.font=`900 54px ${fontFam}`; ctx.fillStyle=titleClr; ctx.fillText(bigText,TX,115); ctx.shadowBlur=0;
    ctx.shadowColor='rgba(0,0,0,0.5)'; ctx.shadowBlur=4; ctx.font=`700 24px ${fontFam}`; ctx.fillStyle=userClr; ctx.fillText(SAMPLE.username,TX,157); ctx.shadowBlur=0;
    ctx.font=`600 16px ${fontFam}`; ctx.fillStyle=msgClr; ctx.fillText(sub,TX,192);

    _syncCardPlacement();
}

// ── Panel toggles ────────────────────────────────────────────────────────────
function toggleMessageTypePanel() {
    const isPlain = document.getElementById('typePlain').checked;
    document.getElementById('plainTextPanel').style.display = isPlain ? 'block' : 'none';
    document.getElementById('embedPanel').style.display     = isPlain ? 'none'  : 'block';
    document.getElementById('fieldsPanel').style.display    = 'block';
    updatePreview();
}
document.querySelectorAll('input[name="goodbyeMessageType"]').forEach(el => el.addEventListener('change', toggleMessageTypePanel));

function toggleCardPanel() {
    const en = document.getElementById('cardEnabled').checked;
    document.getElementById('cardPanel').style.display = en ? 'block' : 'none';
    drawCardPreview();
}
document.getElementById('cardEnabled').addEventListener('change', toggleCardPanel);

['cardWelcomeText','cardSubText','cardBgColor','cardBgColor2','cardAccentColor','cardTitleColor',
 'cardUsernameColor','cardMsgColor','cardBgImageUrl','cardFont'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input',  () => drawCardPreview());
    if (el) el.addEventListener('change', () => drawCardPreview());
});
document.querySelectorAll('input[name="cardAvatarShape"], input[name="cardBgType"]').forEach(el => el.addEventListener('change', () => drawCardPreview()));

// ── Sync hex & picker ─────────────────────────────────────────────────────────
function syncHex(inputId, pickerId) {
    document.getElementById(inputId).value = document.getElementById(pickerId).value;
    updatePreview();
    if (inputId.startsWith('card')) drawCardPreview();
}
function syncPicker(inputId, pickerId) {
    const val = document.getElementById(inputId).value;
    if (/^#[0-9A-Fa-f]{6}$/.test(val)) document.getElementById(pickerId).value = val;
    updatePreview();
    if (inputId.startsWith('card')) drawCardPreview();
}

// ── Placeholder picker ────────────────────────────────────────────────────────
const PLACEHOLDERS = [
    ['{member}',      'Mention member'],
    ['{username}',    'Nama pengguna'],
    ['{tag}',         'Username#tag'],
    ['{server}',      'Nama server'],
    ['{count}',       'Total member'],
    ['{akun.dibuat}', 'Tanggal buat akun'],
];

let _lastFocusedEmbed = 'goodbyeDescription';
document.getElementById('goodbyeTitle')?.addEventListener('focus',       () => _lastFocusedEmbed = 'goodbyeTitle');
document.getElementById('goodbyeDescription')?.addEventListener('focus', () => _lastFocusedEmbed = 'goodbyeDescription');

function buildPicker(pickerId, mode) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) => {
        const tgt = mode === 'embed' ? '_lastFocusedEmbed' : "'goodbyePlainText'";
        return '<button type="button" class="ph-item" onclick="insertPh(' + tgt + ',\'' + ph + '\')">' +
               '<code>' + ph + '</code><span>' + desc + '</span></button>';
    }).join('');
}
function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    if (wasHidden) el.style.display = 'grid';
}
document.addEventListener('click', () => document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none'));
function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus(); el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

// ── Field defs ────────────────────────────────────────────────────────────────
const FIELD_DEFS = [
    { id: 'field_member',       name: '👤 Member',       value: SAMPLE.username        },
    { id: 'field_bergabung',    name: '📅 Bergabung',    value: '2 tahun yang lalu'    },
    { id: 'field_akun_dibuat',  name: '📅 Akun Dibuat',  value: SAMPLE.akun_dibuat     },
    { id: 'field_total_member', name: '👥 Total Member', value: SAMPLE.count           },
];

const CHANNELS = <%- JSON.stringify(Object.fromEntries((locals.channels || []).map(ch => [ch.id, ch.name]))) %>;
const ROLES    = <%- JSON.stringify(Object.fromEntries((locals.roles    || []).map(r  => [r.id,  { name: r.name, color: r.color }]))) %>;

// ── Update preview ────────────────────────────────────────────────────────────
function updatePreview() {
    const color  = document.getElementById('goodbyeColor').value || '#ED4245';
    const thumb  = document.getElementById('goodbyeThumbnail').checked;
    const chanId = document.getElementById('goodbyeChannel').value;
    const isPlain = document.getElementById('typePlain').checked;

    document.getElementById('previewPlainMsg').style.display = isPlain ? 'block' : 'none';
    document.getElementById('previewEmbed').style.display    = isPlain ? 'none'  : 'flex';

    if (isPlain) {
        const plainVal = (document.getElementById('goodbyePlainText') || {}).value || '';
        let plainHtml = resolveHtmlMentions(mdToHtml(resolvePlaceholders(plainVal)));
        const activeFields = FIELD_DEFS.filter(f => document.getElementById(f.id).checked);
        if (activeFields.length > 0) { if (plainHtml) plainHtml += '\n'; plainHtml += activeFields.map(f => `<strong>${f.name}:</strong> ${f.value}`).join('\n'); }
        const msgsEl = document.querySelector('.dc-messages');
        if (plainHtml.trim()) {
            document.getElementById('previewPlainMsg').innerHTML = plainHtml;
            document.getElementById('previewPlainMsg').style.display = 'block';
            if (msgsEl) msgsEl.style.display = 'block';
        } else {
            document.getElementById('previewPlainMsg').style.display = 'none';
            if (msgsEl) msgsEl.style.display = 'none';
        }
        document.getElementById('prevChannelName').textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : 'pilih-channel';
        _syncCardPlacement(); return;
    }

    const _titleVal = document.getElementById('goodbyeTitle').value.trim();
    const _descVal  = document.getElementById('goodbyeDescription').value.trim();
    const _hasActiveFields = FIELD_DEFS.some(f => document.getElementById(f.id).checked);
    const _msgsEl = document.querySelector('.dc-messages');
    if (!_titleVal && !_descVal && !_hasActiveFields) {
        // Bersihkan semua elemen embed agar konten lama tidak tertinggal
        document.getElementById('previewTitle').innerHTML  = '';
        document.getElementById('previewDesc').innerHTML   = '';
        document.getElementById('previewFields').innerHTML = '';
        document.getElementById('previewFooter').innerHTML = '';
        document.getElementById('previewThumb').style.display = 'none';
        const _cardActive = document.getElementById('cardEnabled').checked;
        if (_cardActive) {
            // Card aktif tapi tidak ada teks — embed tetap tampil, card akan muncul sebagai gambar embed
            if (_msgsEl) _msgsEl.style.display = 'block';
            document.getElementById('previewEmbed').style.display = 'flex';
        } else {
            if (_msgsEl) _msgsEl.style.display = 'none';
            document.getElementById('previewEmbed').style.display = 'none';
        }
        document.getElementById('prevChannelName').textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : 'pilih-channel';
        _syncCardPlacement(); return;
    }
    if (_msgsEl) _msgsEl.style.display = 'block';

    document.getElementById('previewPill').style.background = color;
    document.getElementById('previewTitle').innerHTML = mdToHtml(resolvePlaceholdersTitle(document.getElementById('goodbyeTitle').value));
    document.getElementById('previewDesc').innerHTML  = resolveHtmlMentions(mdToHtml(resolvePlaceholders(document.getElementById('goodbyeDescription').value)));

    const footer = document.getElementById('goodbyeFooter').value.trim();
    document.getElementById('previewFooter').innerHTML = (footer && footer !== '-') ? resolveHtmlMentions(mdToHtml(resolvePlaceholders(footer))) : '';

    const thumbEl = document.getElementById('previewThumb');
    thumbEl.style.display = thumb ? 'block' : 'none';

    const fieldsEl = document.getElementById('previewFields');
    fieldsEl.innerHTML = '';
    FIELD_DEFS.forEach(f => {
        if (document.getElementById(f.id).checked) {
            const div = document.createElement('div');
            div.innerHTML = `<div class="dc-field-name">${f.name}</div><div class="dc-field-value">${f.value}</div>`;
            fieldsEl.appendChild(div);
        }
    });

    document.getElementById('prevChannelName').textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : 'pilih-channel';
    const hashEl = document.querySelector('.dc-channel-hash');
    if (hashEl) hashEl.style.color = chanId ? '#dbdee1' : '#80848e';
    _syncCardPlacement();
}

['goodbyeTitle','goodbyeDescription','goodbyeFooter','goodbyeColor',
 'goodbyeEnabled','goodbyeThumbnail','goodbyeChannel','goodbyePlainText']
    .forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', updatePreview);
        if (el) el.addEventListener('change', updatePreview);
    });
document.querySelectorAll('.field-toggle').forEach(el => el.addEventListener('change', updatePreview));

// Render awal
toggleCardPanel();
toggleMessageTypePanel();
buildPicker('embedPicker', 'embed');
buildPicker('plainPicker', 'plain');

// ── Save ──────────────────────────────────────────────────────────────────────
async function saveGoodbye(guildId) {
    const msg = document.getElementById('goodbyeMsg');
    const payload = {
        enabled:       document.getElementById('goodbyeEnabled').checked,
        channelId:     document.getElementById('goodbyeChannel').value,
        messageType:   document.querySelector('input[name="goodbyeMessageType"]:checked')?.value || 'embed',
        plainText:     (document.getElementById('goodbyePlainText') || {}).value?.trim() || '',
        title:         document.getElementById('goodbyeTitle').value.trim(),
        description:   document.getElementById('goodbyeDescription').value.trim(),
        color:         document.getElementById('goodbyeColor').value.trim() || '#ED4245',
        footerText:    document.getElementById('goodbyeFooter').value.trim(),
        thumbnail:     document.getElementById('goodbyeThumbnail').checked,
        cardEnabled:        document.getElementById('cardEnabled').checked,
        cardWelcomeText:    document.getElementById('cardWelcomeText').value.trim()    || 'GOODBYE',
        cardSubText:        document.getElementById('cardSubText').value.trim()         || 'FROM {server}',
        cardBgColor:        document.getElementById('cardBgColor').value.trim()         || '#1a0a0a',
        cardBgColor2:       document.getElementById('cardBgColor2').value.trim()        || '#2e0a0a',
        cardAccentColor:    document.getElementById('cardAccentColor').value.trim()     || '#ED4245',
        cardTextColor:      document.getElementById('cardTitleColor')?.value.trim()     || '#ffffff',
        cardAvatarShape:    document.querySelector('input[name="cardAvatarShape"]:checked')?.value || 'circle',
        cardBgType:         document.querySelector('input[name="cardBgType"]:checked')?.value      || 'gradient',
        cardBgImageUrl:     document.getElementById('cardBgImageUrl')?.value.trim()     || '',
        cardOverlayColor:   document.getElementById('cardOverlayColor')?.value.trim()   || '#000000',
        cardOverlayOpacity: parseInt(document.getElementById('cardOverlayOpacity')?.value || '0'),
        cardTitleColor:     document.getElementById('cardTitleColor')?.value.trim()     || '#ffffff',
        cardUsernameColor:  document.getElementById('cardUsernameColor')?.value.trim()  || '#ED4245',
        cardMsgColor:       document.getElementById('cardMsgColor')?.value.trim()       || '#cccccc',
        cardFont:           document.getElementById('cardFont')?.value                  || 'impact',
        showMember:      document.getElementById('field_member').checked,
        showBergabung:   document.getElementById('field_bergabung').checked,
        showAkunDibuat:  document.getElementById('field_akun_dibuat').checked,
        showTotalMember: document.getElementById('field_total_member').checked,
    };
    const res  = await fetch(`/api/guild/${guildId}/goodbye`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

function showMsg(el, text, type) {
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3000);
}
</script>

