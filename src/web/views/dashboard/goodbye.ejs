<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <aside class="sidebar">
        <div class="sidebar-bot-brand">
            <img style="width:30px;height:30px;border-radius:50%;object-fit:cover;flex-shrink:0;"
                 src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                 alt="Bot" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
            <span style="font-size:.95rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;background:linear-gradient(135deg,#e3e5e8,#8b8fbd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
                <%- locals.botNavName || 'OCTA BOT' %>
            </span>
            <button class="sidebar-bot-close" onclick="closeSidebar()" title="Tutup"><i data-lucide="x"></i></button>
        </div>
        <div class="sidebar-guild">
            <button class="sidebar-server-btn" onclick="toggleServerSelector()">
                <% if (guild.iconURL()) { %><img src="<%= guild.iconURL() %>" alt="<%= guild.name %>" class="sidebar-guild-icon">
                <% } else { %><div class="sidebar-guild-icon-placeholder"><%= guild.name.charAt(0) %></div><% } %>
                <span class="sidebar-guild-name"><%= guild.name %></span>
                <span class="sidebar-server-chevron"><i data-lucide="chevron-down"></i></span>
            </button>
            <div class="sidebar-server-dd" id="sidebarServerDD">
                <div class="sidebar-server-dd-item active">
                    <% if (guild.iconURL()) { %><img src="<%= guild.iconURL() %>" alt="" class="sidebar-guild-icon">
                    <% } else { %><div class="sidebar-guild-icon-placeholder"><%= guild.name.charAt(0) %></div><% } %>
                    <%= guild.name %>
                </div>
                <div class="sidebar-server-dd-divider"></div>
                <a href="/dashboard" class="sidebar-server-dd-item sidebar-server-dd-change">
                    <i data-lucide="arrow-left-right"></i> Ganti Server
                </a>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a href="/dashboard/<%= guild.id %>"                  class="sidebar-link"><i data-lucide="layout-dashboard"></i> Overview</a>
            <span class="sidebar-group-label">Notification</span>
            <a href="/dashboard/<%= guild.id %>/welcome"              class="sidebar-sublink"><i data-lucide="user-plus"></i> Welcome Notification</a>
            <a href="/dashboard/<%= guild.id %>/goodbye"              class="sidebar-sublink active"><i data-lucide="log-out"></i> Goodbye Notification</a>
            <a href="/dashboard/<%= guild.id %>/booster?tab=boost"    class="sidebar-sublink"><i data-lucide="zap"></i> Boost Notification</a>
            <a href="/dashboard/<%= guild.id %>/booster?tab=unboost"  class="sidebar-sublink"><i data-lucide="zap-off"></i> Unboost Notification</a>
            <span class="sidebar-group-label">Auto Role</span>
            <a href="/dashboard/<%= guild.id %>/autorole?tab=join"    class="sidebar-sublink"><i data-lucide="users"></i> Autorole Join</a>
            <a href="/dashboard/<%= guild.id %>/autorole?tab=booster" class="sidebar-sublink"><i data-lucide="zap"></i> Autorole Booster</a>
            <a href="/dashboard/<%= guild.id %>/autorole?tab=button"  class="sidebar-sublink"><i data-lucide="mouse-pointer-2"></i> Autorole Button</a>
            <span class="sidebar-group-label">Others</span>
            <a href="/dashboard/<%= guild.id %>/message-builder"      class="sidebar-sublink"><i data-lucide="mail"></i> Message Builder</a>
            <a href="/dashboard/<%= guild.id %>/serverstats"          class="sidebar-sublink"><i data-lucide="bar-chart-2"></i> Server Stats</a>
            <a href="/dashboard/<%= guild.id %>/invites"              class="sidebar-sublink"><i data-lucide="link"></i> Invite Links</a>
        </nav>
    </aside>

    <main class="dash-main" style="max-width:100%;">
        <div class="page-header">
            <h1>Goodbye Notification</h1>
            <p>Notifikasi yang dikirim saat member meninggalkan server.</p>
        </div>

        <div class="goodbye-editor-layout">
            <!-- ── Kolom kiri: form settings ── -->
            <div class="settings-card" style="margin-bottom:0;">

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="goodbyeEnabled" class="toggle-input"
                               <%= goodbyeData.enabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span>Aktifkan Goodbye Notification</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="label">Channel</label>
                    <select id="goodbyeChannel" class="select">
                        <option value="">— Pilih channel —</option>
                        <% (locals.channels || []).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= goodbyeData.channelId === ch.id ? 'selected' : '' %>>
                                #<%= ch.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Tipe Pesan</label>
                    <div style="display:flex;gap:.75rem;">
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="goodbyeMessageType" id="typeEmbed" value="embed"
                                   <%= (goodbyeData.messageType || 'embed') === 'embed' ? 'checked' : '' %>>
                            <span>Embed</span>
                        </label>
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="goodbyeMessageType" id="typePlain" value="plain"
                                   <%= goodbyeData.messageType === 'plain' ? 'checked' : '' %>>
                            <span>Teks Biasa</span>
                        </label>
                    </div>
                </div>

                <!-- ── Panel Teks Biasa ── -->
                <div id="plainTextPanel" class="form-group" style="display:none;">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;">Isi Pesan Teks Biasa</label>
                        <div class="ph-picker-anchor">
                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('plainPicker',event)">{…} Placeholder</button>
                            <div class="ph-dropdown" id="plainPicker" style="display:none;"></div>
                        </div>
                    </div>
                    <textarea id="goodbyePlainText" class="textarea" rows="3"
                              placeholder="Sampai jumpa, {member}! Terima kasih sudah bersama kami di **{server}**."><%= goodbyeData.plainText %></textarea>
                </div>

                <!-- ── Panel Embed ── -->
                <div id="embedPanel">

                <div class="form-group">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;">Judul Embed</label>
                        <div class="ph-picker-anchor">
                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('embedPicker',event)">{…} Placeholder</button>
                            <div class="ph-dropdown" id="embedPicker" style="display:none;"></div>
                        </div>
                    </div>
                    <input type="text" id="goodbyeTitle" class="input"
                           placeholder="👋 Selamat Tinggal!"
                           value="<%= goodbyeData.title || '' %>">
                </div>

                <div class="form-group">
                    <label class="label">Deskripsi Embed</label>
                    <textarea id="goodbyeDescription" class="textarea" rows="3"
                              placeholder="{member} telah meninggalkan server."><%= goodbyeData.description || '' %></textarea>
                </div>

                <div class="form-group">
                    <label class="label">Warna Embed</label>
                    <div style="display:flex;gap:.75rem;align-items:center;">
                        <input type="color" id="goodbyeColorPicker" value="<%= goodbyeData.color || '#ED4245' %>"
                               style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                               oninput="syncHex('goodbyeColor','goodbyeColorPicker')">
                        <input type="text" id="goodbyeColor" class="input" style="max-width:130px;"
                               placeholder="#ED4245" maxlength="7"
                               value="<%= goodbyeData.color || '#ED4245' %>"
                               oninput="syncPicker('goodbyeColor','goodbyeColorPicker')">
                    </div>
                </div>

                <div class="form-group">
                    <label class="label">Footer <span style="font-weight:400;color:var(--text-muted)">(opsional)</span></label>
                    <input type="text" id="goodbyeFooter" class="input"
                           placeholder='Kosongkan untuk menghapus'
                           value="<%= goodbyeData.footerText || '' %>">
                </div>

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="goodbyeThumbnail" class="toggle-input"
                               <%= goodbyeData.thumbnail ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span>Tampilkan foto profil member (thumbnail)</span>
                    </label>
                </div>

                </div><!-- /embedPanel -->

                <div id="fieldsPanel" class="form-group">
                    <label class="label" style="margin-bottom:.75rem;">Field Info</label>
                    <div style="display:flex;flex-direction:column;gap:.6rem;">
                        <label class="toggle-label">
                            <input type="checkbox" id="field_member" class="toggle-input field-toggle"
                                   <%= goodbyeData.showMember ? 'checked' : '' %>>
                            <span class="toggle-slider"></span><span>Member</span>
                        </label>
                        <label class="toggle-label">
                            <input type="checkbox" id="field_bergabung" class="toggle-input field-toggle"
                                   <%= goodbyeData.showBergabung ? 'checked' : '' %>>
                            <span class="toggle-slider"></span><span>Bergabung Sejak</span>
                        </label>
                        <label class="toggle-label">
                            <input type="checkbox" id="field_akun_dibuat" class="toggle-input field-toggle"
                                   <%= goodbyeData.showAkunDibuat ? 'checked' : '' %>>
                            <span class="toggle-slider"></span><span>Akun Dibuat</span>
                        </label>
                        <label class="toggle-label">
                            <input type="checkbox" id="field_total_member" class="toggle-input field-toggle"
                                   <%= goodbyeData.showTotalMember ? 'checked' : '' %>>
                            <span class="toggle-slider"></span><span>Total Member</span>
                        </label>
                    </div>
                </div>

                <div class="form-group" style="margin-top:1.5rem;border-top:1px solid var(--border);padding-top:1.25rem;">
                    <label class="label" style="margin-bottom:.75rem;">Goodbye Card</label>
                    <label class="toggle-label">
                        <input type="checkbox" id="cardEnabled" class="toggle-input"
                               <%= goodbyeData.cardEnabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span>Kirim gambar perpisahan (goodbye card)</span>
                    </label>
                </div>

                <div id="cardPanel" style="display:none;">

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label">Bentuk Avatar</label>
                            <div style="display:flex;gap:.6rem;margin-top:.2rem;">
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                    <input type="radio" name="cardAvatarShape" value="circle" <%= (goodbyeData.cardAvatarShape||'circle')==='circle'?'checked':'' %>>
                                    <span>Lingkaran</span>
                                </label>
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                    <input type="radio" name="cardAvatarShape" value="square" <%= goodbyeData.cardAvatarShape==='square'?'checked':'' %>>
                                    <span>Kotak</span>
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Font</label>
                            <select id="cardFont" class="select" style="font-size:.82rem;">
                                <% [['impact','Impact'],['arial','Arial'],['georgia','Georgia'],['courier','Courier New'],['verdana','Verdana']].forEach(function(f){ %>
                                    <option value="<%= f[0] %>" <%= (goodbyeData.cardFont||'impact')===f[0]?'selected':'' %>><%= f[1] %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label">Tipe Background</label>
                        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.2rem;">
                            <% [['gradient','Gradien'],['solid','Solid'],['image','Gambar URL'],['transparent','Transparan']].forEach(function(bt){ %>
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                <input type="radio" name="cardBgType" value="<%= bt[0] %>" <%= (goodbyeData.cardBgType||'gradient')===bt[0]?'checked':'' %>>
                                <span><%= bt[1] %></span>
                            </label>
                            <% }) %>
                        </div>
                    </div>

                    <div id="cardBgGradientPanel" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label" id="cardBgColor1Label">Latar Kiri</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardBgColorPicker" value="<%= goodbyeData.cardBgColor||'#1a0a0a' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardBgColor','cardBgColorPicker')" onchange="syncHex('cardBgColor','cardBgColorPicker')">
                                <input type="text" id="cardBgColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardBgColor||'#1a0a0a' %>" oninput="syncPicker('cardBgColor','cardBgColorPicker')">
                            </div>
                        </div>
                        <div class="form-group" id="cardBgColor2Group">
                            <label class="label">Latar Kanan</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardBgColor2Picker" value="<%= goodbyeData.cardBgColor2||'#2e0a0a' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardBgColor2','cardBgColor2Picker')" onchange="syncHex('cardBgColor2','cardBgColor2Picker')">
                                <input type="text" id="cardBgColor2" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardBgColor2||'#2e0a0a' %>" oninput="syncPicker('cardBgColor2','cardBgColor2Picker')">
                            </div>
                        </div>
                    </div>

                    <div id="cardBgImagePanel" style="display:none;" class="form-group">
                        <label class="label">URL Gambar Latar</label>
                        <input type="text" id="cardBgImageUrl" class="input"
                               placeholder="https://example.com/background.jpg"
                               value="<%= goodbyeData.cardBgImageUrl||'' %>">
                        <div class="hint" style="margin-top:.3rem;">URL gambar JPEG/PNG · Akan di-resize otomatis ke ukuran card</div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label">Warna Overlay</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardOverlayColorPicker" value="<%= goodbyeData.cardOverlayColor||'#000000' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardOverlayColor','cardOverlayColorPicker')" onchange="syncHex('cardOverlayColor','cardOverlayColorPicker')">
                                <input type="text" id="cardOverlayColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardOverlayColor||'#000000' %>" oninput="syncPicker('cardOverlayColor','cardOverlayColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label" style="display:flex;justify-content:space-between;">
                                <span>Opasitas Overlay</span>
                                <span id="cardOverlayOpacityVal" style="color:var(--text-muted);font-weight:400;"><%= goodbyeData.cardOverlayOpacity||'0' %>%</span>
                            </label>
                            <input type="range" id="cardOverlayOpacity" min="0" max="100"
                                   value="<%= goodbyeData.cardOverlayOpacity||'0' %>"
                                   style="width:100%;margin-top:.45rem;accent-color:var(--accent,#5865f2);"
                                   oninput="document.getElementById('cardOverlayOpacityVal').textContent=this.value+'%';drawCardPreview()">
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label">Warna Judul (GOODBYE)</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardTitleColorPicker" value="<%= goodbyeData.cardTitleColor||'#ffffff' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardTitleColor','cardTitleColorPicker')" onchange="syncHex('cardTitleColor','cardTitleColorPicker')">
                                <input type="text" id="cardTitleColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardTitleColor||'#ffffff' %>" oninput="syncPicker('cardTitleColor','cardTitleColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Warna Nama Pengguna</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardUsernameColorPicker" value="<%= goodbyeData.cardUsernameColor||goodbyeData.cardAccentColor||'#ED4245' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardUsernameColor','cardUsernameColorPicker')" onchange="syncHex('cardUsernameColor','cardUsernameColorPicker')">
                                <input type="text" id="cardUsernameColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardUsernameColor||goodbyeData.cardAccentColor||'#ED4245' %>" oninput="syncPicker('cardUsernameColor','cardUsernameColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Warna Pesan (sub teks)</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardMsgColorPicker" value="<%= goodbyeData.cardMsgColor||'#cccccc' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardMsgColor','cardMsgColorPicker')" onchange="syncHex('cardMsgColor','cardMsgColorPicker')">
                                <input type="text" id="cardMsgColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardMsgColor||'#cccccc' %>" oninput="syncPicker('cardMsgColor','cardMsgColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Warna Border Avatar</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardAccentPicker" value="<%= goodbyeData.cardAccentColor||'#ED4245' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardAccentColor','cardAccentPicker')" onchange="syncHex('cardAccentColor','cardAccentPicker')">
                                <input type="text" id="cardAccentColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= goodbyeData.cardAccentColor||'#ED4245' %>" oninput="syncPicker('cardAccentColor','cardAccentPicker')">
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label">Teks Besar (GOODBYE)</label>
                        <input type="text" id="cardWelcomeText" class="input" maxlength="20"
                               placeholder="GOODBYE" value="<%= goodbyeData.cardWelcomeText||'GOODBYE' %>">
                    </div>
                    <div class="form-group">
                        <label class="label">Teks Kecil Bawah</label>
                        <input type="text" id="cardSubText" class="input" maxlength="60"
                               placeholder="FROM {server}" value="<%= goodbyeData.cardSubText||'FROM {server}' %>">
                        <div class="hint" style="margin-top:.3rem;"><code>{server}</code> · <code>{count}</code> · <code>{tag}</code></div>
                    </div>

                </div><!-- /cardPanel -->

                <div class="form-actions">
                    <button class="btn btn-primary" onclick="saveGoodbye('<%= guild.id %>')">Simpan</button>
                </div>
                <div id="goodbyeMsg" class="form-message"></div>
            </div>

            <!-- ── Kolom kanan: Discord preview ── -->
            <div class="preview-panel">
                <div class="preview-label">Preview</div>

                <div class="dc-window">
                    <div class="dc-channel-bar">
                        <span class="dc-channel-hash">#</span>
                        <span id="prevChannelName">pilih-channel</span>
                    </div>
                    <!-- Card preview -->
                    <div id="cardPreviewWrap" style="display:none;padding:.75rem 1rem .25rem;">
                        <canvas id="cardCanvas" width="760" height="247"
                                style="width:100%;border-radius:12px;display:block;"></canvas>
                        <div style="font-size:.7rem;color:#80848e;margin-top:.3rem;text-align:right;">Goodbye Card Preview</div>
                    </div>

                    <div class="dc-messages">
                        <div class="dc-message">
                            <img class="dc-avatar" src="<%- loginUser && botUser ? botUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="bot avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="dc-msg-body">
                                <span class="dc-username" style="color:<%- botUser ? botUser.roleColor : '#ffffff' %>"><%= botUser ? botUser.username : 'Bot' %></span>
                                <span class="dc-timestamp">Hari ini pukul 12:00</span>
                                <div id="previewPlainMsg" class="dc-plain-msg" style="display:none;"></div>
                                <img id="previewCardInPlain" style="display:none;width:100%;max-width:440px;border-radius:8px;margin-top:.4rem;" alt="">
                                <div class="dc-embed" id="previewEmbed">
                                    <div class="dc-embed-pill" id="previewPill"></div>
                                    <div class="dc-embed-content">
                                        <div class="dc-embed-title" id="previewTitle"></div>
                                        <div class="dc-embed-desc" id="previewDesc"></div>
                                        <div class="dc-embed-fields" id="previewFields"></div>
                                        <img id="previewCardInEmbed" style="display:none;width:100%;border-radius:4px;margin-top:.4rem;" alt="">
                                        <div class="dc-embed-footer" id="previewFooter"></div>
                                    </div>
                                    <img class="dc-embed-thumb" id="previewThumb"
                                         src="<%- loginUser ? loginUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="thumb">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/bottom-nav') %>

<style>
.goodbye-editor-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 900px) {
    .goodbye-editor-layout { grid-template-columns: 1fr; }
}
.preview-panel { position: sticky; top: calc(var(--navbar-h) + 1.5rem); }
.preview-label {
    font-size: .78rem; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: .6rem;
}
.dc-window {
    background: #313338; border-radius: 10px; overflow: hidden;
    font-family: 'gg sans', 'Noto Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 14px; color: #dbdee1; box-shadow: 0 4px 24px rgba(0,0,0,.5);
}
.dc-channel-bar {
    background: #2b2d31; padding: .55rem 1rem; border-bottom: 1px solid #1e1f22;
    display: flex; align-items: center; gap: .4rem;
    font-size: .85rem; font-weight: 600; color: #dbdee1;
}
.dc-channel-hash { color: #80848e; font-size: 1.1rem; line-height: 1; }
.dc-messages { padding: 1rem; }
.dc-message  { display: flex; gap: .75rem; }
.dc-avatar   { width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0; object-fit: cover; }
.dc-msg-body { flex: 1; min-width: 0; }
.dc-username { font-weight: 600; color: #fff; font-size: .9rem; }
.dc-timestamp{ font-size: .7rem; color: #80848e; margin-left: .5rem; }
