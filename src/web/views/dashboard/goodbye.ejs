.dc-plain-msg {
    margin-top: .35rem; font-size: .85rem; color: #dbdee1;
    line-height: 1.5; word-break: break-word; max-width: 440px;
}
.dc-embed {
    display: flex; background: #2b2d31; border-radius: 4px;
    margin-top: .35rem; overflow: hidden; max-width: 440px;
}
.dc-embed-pill { width: 4px; flex-shrink: 0; background: #ed4245; border-radius: 4px 0 0 4px; }
.dc-embed-content { flex: 1; padding: .6rem .75rem; min-width: 0; }
.dc-embed-title { font-size: .9rem; font-weight: 700; color: #fff; margin-bottom: .25rem; word-break: break-word; }
.dc-embed-title:empty { display: none; }
.dc-embed-desc { font-size: .82rem; color: #dbdee1; line-height: 1.5; word-break: break-word; }
