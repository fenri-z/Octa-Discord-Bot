<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'level' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <div class="page-header">
            <h1><%= t('level.page_title') %></h1>
            <p><%= t('level.page_desc') %></p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="star"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statLvStatus"><%= levelData.enabled ? t('level.status_active') : t('level.status_inactive') %></div>
                    <div class="stat-label"><%= t('level.status_label') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="users"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= leaderboard.length %></div>
                    <div class="stat-label"><%= t('level.members_registered') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="award"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statLvRewards"><%= levelData.roleRewards.length %></div>
                    <div class="stat-label"><%= t('level.role_rewards') %></div>
                </div>
            </div>
        </div>

        <!-- How to Use -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('level.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('level.step1_title') %></div>
                    <div class="guide-desc"><%= t('level.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('level.step2_title') %></div>
                    <div class="guide-desc"><%= t('level.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('level.step3_title') %></div>
                    <div class="guide-desc"><%= t('level.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%= t('level.tip') %></div>
        </div>

        <!-- Configuration -->
        <div class="settings-card">
            <h2><%= t('level.config_title') %></h2>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="levelEnabled" class="toggle-input" <%= levelData.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('level.enable_label') %></span>
                </label>
            </div>

            <div class="form-group">
                <label class="label"><%= t('level.channel_label') %></label>
                <select id="levelChannel" class="select">
                    <option value=""><%= t('level.channel_none') %></option>
                    <% channels.forEach(function(ch) { %>
                        <option value="<%= ch.id %>" <%= levelData.channelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="form-group">
                <label class="label"><%= t('level.message_label') %> <span style="color:#ed4245;">*</span></label>
                <input type="text" id="levelMessage" class="input" value="<%= levelData.message %>" placeholder="<%= t('level.message_placeholder') %>">
                <p class="section-desc" style="margin-top:.35rem;"><%- t('level.message_hint') %></p>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label class="label"><%= t('level.xp_min') %> <span style="color:#ed4245;">*</span></label>
                    <input type="number" id="levelXpMin" class="input num-only" value="<%= levelData.xpMin %>" min="1" max="100">
                </div>
                <div class="form-group">
                    <label class="label"><%= t('level.xp_max') %> <span style="color:#ed4245;">*</span></label>
                    <input type="number" id="levelXpMax" class="input num-only" value="<%= levelData.xpMax %>" min="1" max="100">
                </div>
                <div class="form-group">
                    <label class="label"><%= t('level.cooldown') %> <span style="color:#ed4245;">*</span></label>
                    <input type="number" id="levelCooldown" class="input num-only" value="<%= levelData.cooldown %>" min="1" max="3600">
                </div>
            </div>

            <div id="levelCfgMsg" class="form-message"></div>
        </div>

        <!-- Role Rewards -->
        <div class="settings-card">
            <h2><%= t('level.role_rewards_title') %></h2>
            <p class="section-desc" style="margin-bottom:1rem;"><%= t('level.role_rewards_desc') %></p>

            <input type="hidden" id="rrChangeMarker" value="0">

            <div id="roleRewardsList">
                <% levelData.roleRewards.forEach(function(rr, i) { %>
                <div class="rr-row" data-idx="<%= i %>">
                    <div class="rr-level-wrap">
                        <span class="rr-label"><%= t('level.level_col') %></span>
                        <input type="number" class="input rr-level num-only" value="<%= rr.level %>" min="1" max="999">
                    </div>
                    <div class="rr-arrow"><i data-lucide="arrow-right" style="width:16px;height:16px;"></i></div>
                    <div class="rr-role-wrap">
                        <span class="rr-label">Role</span>
                        <select class="select rr-role">
                            <option value=""><%= t('level.select_role') %></option>
                            <% roles.forEach(function(r) { %>
                                <option value="<%= r.id %>" <%= rr.roleId === r.id ? 'selected' : '' %> style="color:<%= r.color %>">@<%= r.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <button class="btn btn-icon rr-del" onclick="removeReward(this)" title="Remove"><i data-lucide="trash-2" style="width:15px;height:15px;"></i></button>
                </div>
                <% }); %>
            </div>

            <button class="btn btn-secondary" style="margin-top:.75rem;" onclick="addReward()">
                <i data-lucide="plus" style="width:14px;height:14px;"></i> <%= t('level.add_reward') %>
            </button>

            <div id="roleRewardMsg" class="form-message" style="margin-top:.75rem;"></div>
        </div>

        <!-- Leaderboard Preview -->
        <% if (leaderboard.length) { %>
        <div class="settings-card">
            <h2><%= t('level.leaderboard_title') %></h2>
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:.875rem;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border);">
                            <th style="padding:.5rem .75rem;text-align:left;color:var(--text-muted);"><%= t('level.lb_rank') %></th>
                            <th style="padding:.5rem .75rem;text-align:left;color:var(--text-muted);"><%= t('level.lb_user') %></th>
                            <th style="padding:.5rem .75rem;text-align:center;color:var(--text-muted);"><%= t('level.lb_level') %></th>
                            <th style="padding:.5rem .75rem;text-align:center;color:var(--text-muted);"><%= t('level.lb_xp') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% leaderboard.forEach(function(entry, i) { %>
                        <tr style="border-bottom:1px solid rgba(255,255,255,.04);">
                            <td style="padding:.5rem .75rem;color:<%= i===0?'#FEE75C':i===1?'#C0C0C0':i===2?'#CD7F32':'var(--text-muted)' %>;font-weight:600;">
                                <%= i===0?'🥇':i===1?'🥈':i===2?'🥉':(i+1) %>
                            </td>
                            <td style="padding:.5rem .75rem;font-family:monospace;color:var(--text-secondary);"><%= entry.userId %></td>
                            <td style="padding:.5rem .75rem;text-align:center;font-weight:600;color:#FEE75C;">Lv.<%= entry.level %></td>
                            <td style="padding:.5rem .75rem;text-align:center;color:var(--text-muted);"><%= entry.xp.toLocaleString() %> XP</td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

    </div><!-- /.dash-content-wide -->
    </main>
</div><!-- /.dash-layout -->

<style>
.rr-row {
    display: grid;
    grid-template-columns: auto 28px 1fr 36px;
    align-items: center;
    gap: .625rem;
    padding: .6rem .875rem;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: .5rem;
}
.rr-level-wrap {
    display: flex;
    align-items: center;
    gap: .5rem;
    flex-shrink: 0;
}
.rr-level-wrap .rr-level {
    width: 72px;
    flex-shrink: 0;
}
.rr-role-wrap {
    display: flex;
    align-items: center;
    gap: .5rem;
    min-width: 0;
    flex: 1;
}
.rr-role-wrap .rr-role {
    flex: 1;
    min-width: 0;
}
.rr-label {
    color: var(--text-muted);
    font-size: .8125rem;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 38px;
}
.rr-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    flex-shrink: 0;
}
.btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border-radius: 6px;
    background: rgba(237,66,69,.12);
    color: #ED4245;
    border: 1px solid rgba(237,66,69,.25);
    cursor: pointer;
    transition: background .15s, border-color .15s;
    flex-shrink: 0;
}
.btn-icon:hover {
    background: rgba(237,66,69,.22);
    border-color: rgba(237,66,69,.45);
}
@media (max-width: 640px) {
    [style*="grid-template-columns:1fr 1fr 1fr"] { grid-template-columns: 1fr !important; }

    .rr-row {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        padding: .75rem .875rem;
        padding-right: 3rem;
    }
    .rr-arrow { display: none; }
    .rr-level-wrap { width: 100%; }
    .rr-level-wrap .rr-level { flex: 1; width: auto; }
    .rr-role-wrap  { width: 100%; }
    .rr-role-wrap .rr-role { flex: 1; }
    .rr-del {
        position: absolute;
        top: 50%;
        right: .625rem;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
    }
}
</style>

<script>
const GUILD_ID       = '<%= guild.id %>';
const I18N_LV_ACTIVE   = '<%- t("level.status_active") %>';
const I18N_LV_INACTIVE = '<%- t("level.status_inactive") %>';
const I18N_LV_CONFIRM_RM_TITLE = '<%- t("level.confirm_remove_reward_title") %>';
const I18N_LV_CONFIRM_RM_MSG   = '<%- t("level.confirm_remove_reward_msg") %>';
const I18N_LV_ERR_EMPTY_ROLE   = <%- JSON.stringify(t("level.err_empty_role")) %>;
const I18N_LV_ERR_LEVEL_MIN    = <%- JSON.stringify(t("level.err_level_min")) %>;
const I18N_LV_ERR_XP_MIN       = <%- JSON.stringify(t("level.err_xp_min")) %>;
const I18N_LV_ERR_XP_MAX       = <%- JSON.stringify(t("level.err_xp_max")) %>;
const I18N_LV_ERR_XP_ORDER     = <%- JSON.stringify(t("level.err_xp_order")) %>;
const I18N_LV_ERR_COOLDOWN     = <%- JSON.stringify(t("level.err_cooldown")) %>;

function refreshLvStats() {
    const enabled = document.getElementById('levelEnabled')?.checked;
    const rewards = getRewards().length;
    document.getElementById('statLvStatus').textContent  = enabled ? I18N_LV_ACTIVE : I18N_LV_INACTIVE;
    document.getElementById('statLvRewards').textContent = rewards;
}

function showMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (type === 'success') setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

async function apiFetch(path, method, body) {
    const res = await fetch(`/api/guild/${GUILD_ID}${path}`, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body:    body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}

const ROLES = <%- JSON.stringify(roles) %>;

document.addEventListener('keydown', function(e) {
    if (!e.target.classList.contains('num-only')) return;
    const allowed = ['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Home','End'];
    if (allowed.includes(e.key)) return;
    if (/^\d$/.test(e.key)) return;
    e.preventDefault();
});
document.addEventListener('paste', function(e) {
    if (!e.target.classList.contains('num-only')) return;
    e.preventDefault();
    const text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
    if (text) document.execCommand('insertText', false, text);
});

function markRrDirty() {
    document.getElementById('rrChangeMarker').value = Date.now();
    if (window._floatDirty) window._floatDirty();
}

function addReward() {
    const list = document.getElementById('roleRewardsList');
    const div  = document.createElement('div');
    div.className = 'rr-row';
    div.innerHTML = `
        <div class="rr-level-wrap">
            <span class="rr-label">Level</span>
            <input type="number" class="input rr-level num-only" value="1" min="1" max="999">
        </div>
        <div class="rr-arrow"><i data-lucide="arrow-right" style="width:16px;height:16px;"></i></div>
        <div class="rr-role-wrap">
            <span class="rr-label">Role</span>
            <select class="select rr-role">
                <option value="">— Select Role —</option>
                ${ROLES.map(r => `<option value="${r.id}" style="color:${r.color}">@${r.name}</option>`).join('')}
            </select>
        </div>
        <button class="btn btn-icon rr-del" onclick="removeReward(this)" title="Remove"><i data-lucide="trash-2" style="width:15px;height:15px;"></i></button>`;
    list.appendChild(div);
    if (window.lucide) lucide.createIcons();
    markRrDirty();
}

async function removeReward(btn) {
    const row      = btn.closest('.rr-row');
    const level    = row.querySelector('.rr-level')?.value || '?';
    const roleEl   = row.querySelector('.rr-role');
    const roleName = roleEl?.options[roleEl.selectedIndex]?.text || 'this role';
    const _rmMsg = I18N_LV_CONFIRM_RM_MSG.replace('{{role}}', roleName).replace('{{level}}', level);
    if (!await showConfirm(I18N_LV_CONFIRM_RM_TITLE, _rmMsg)) return;
    row.remove();
    const rrMsg = document.getElementById('roleRewardMsg');
    const rewards = getRewards().filter(r => r.roleId);
    const data = await apiFetch('/level', 'POST', {
        enabled:     document.getElementById('levelEnabled').checked,
        channelId:   document.getElementById('levelChannel').value || null,
        message:     document.getElementById('levelMessage').value.trim(),
        xpMin:       parseInt(document.getElementById('levelXpMin').value, 10)    || 15,
        xpMax:       parseInt(document.getElementById('levelXpMax').value, 10)    || 25,
        cooldown:    parseInt(document.getElementById('levelCooldown').value, 10) || 60,
        roleRewards: rewards,
    });
    if (data.success) showToast(data.message, 'success');
    else showAlert(data.message);
}

function getRewards() {
    return [...document.querySelectorAll('#roleRewardsList .rr-row')].map(row => ({
        level:  parseInt(row.querySelector('.rr-level').value, 10),
        roleId: row.querySelector('.rr-role').value,
    }));
}

async function saveConfig() {
    const rrMsg = document.getElementById('roleRewardMsg');
    const rewards = getRewards();
    const emptyRole = rewards.find(r => !r.roleId);
    if (emptyRole) { showAlert(I18N_LV_ERR_EMPTY_ROLE); return; }
    const invalidLevel = rewards.find(r => isNaN(r.level) || r.level < 1);
    if (invalidLevel) { showAlert(I18N_LV_ERR_LEVEL_MIN); return; }

    const xpMin   = parseInt(document.getElementById('levelXpMin').value, 10);
    const xpMax   = parseInt(document.getElementById('levelXpMax').value, 10);
    const cooldown= parseInt(document.getElementById('levelCooldown').value, 10);

    if (isNaN(xpMin) || xpMin < 1 || xpMin > 100) { showAlert(I18N_LV_ERR_XP_MIN); return; }
    if (isNaN(xpMax) || xpMax < 1 || xpMax > 100) { showAlert(I18N_LV_ERR_XP_MAX); return; }
    if (xpMin > xpMax) { showAlert(I18N_LV_ERR_XP_ORDER); return; }
    if (isNaN(cooldown) || cooldown < 1 || cooldown > 3600) { showAlert(I18N_LV_ERR_COOLDOWN); return; }

    const data = await apiFetch('/level', 'POST', {
        enabled:   document.getElementById('levelEnabled').checked,
        channelId: document.getElementById('levelChannel').value || null,
        message:   document.getElementById('levelMessage').value.trim(),
        xpMin, xpMax, cooldown,
        roleRewards: rewards,
    });
    if (data.success) { showToast(data.message, 'success'); refreshLvStats(); }
    else showAlert(data.message);
}

window._floatSave = () => saveConfig();
</script>

<%- include('../partials/footer') %>
