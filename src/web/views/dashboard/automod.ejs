<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<style>
/* ── Chip / Tag ─────────────────────────────────────────────────────────── */
.am-word-chip {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .25rem .5rem .25rem .6rem;
    background: var(--bg-3, rgba(255,255,255,.05));
    border: 1px solid var(--border, rgba(255,255,255,.1));
    border-radius: 6px;
    font-size: .82rem;
    line-height: 1.4;
    max-width: 100%;
    word-break: break-all;
}
.am-chip-del {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0 2px;
    font-size: 1rem;
    line-height: 1;
    border-radius: 3px;
    transition: color .15s, background .15s;
    flex-shrink: 0;
}
.am-chip-del:hover {
    color: #ED4245;
    background: rgba(237,66,69,.1);
}

/* ── General Configuration ──────────────────────────────────────────────── */
.am-cfg-group {
    flex: 1;
    min-width: 200px;
}

/* ── Spam / Raid number inputs ──────────────────────────────────────────── */
.am-num-row {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: .75rem;
}
.am-num-group {
    flex: 1;
    min-width: 160px;
}
.am-num-input {
    max-width: 120px;
    width: 100%;
}

/* ── Kata Terlarang input row ───────────────────────────────────────────── */
.am-words-add-row {
    display: flex;
    gap: .75rem;
    align-items: center;
    flex-wrap: wrap;
}
.am-words-input {
    flex: 1;
    min-width: 160px;
    max-width: 260px;
}

/* ── Whitelist ──────────────────────────────────────────────────────────── */
.am-wl-row {
    display: flex;
    flex-wrap: wrap;
}
.am-wl-col {
    flex: 1;
    min-width: 220px;
}
.am-wl-add-row {
    display: flex;
    gap: .6rem;
    align-items: center;
    flex-wrap: wrap;
}
.am-wl-select {
    flex: 1;
    min-width: 140px;
}

/* ── Tablet (≤ 900px) ───────────────────────────────────────────────────── */
@media (max-width: 900px) {
    .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
    .am-cfg-row {
        flex-direction: column !important;
        gap: 1rem !important;
    }
    .am-cfg-group {
        flex: none !important;
        width: 100% !important;
        min-width: unset !important;
    }
    .am-cfg-group .select,
    .am-cfg-group .csel {
        width: 100% !important;
        max-width: 100% !important;
    }
}

/* ── Mobile (≤ 600px) ───────────────────────────────────────────────────── */
@media (max-width: 600px) {
    .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
        gap: .6rem !important;
    }

    /* Spam / Raid / Mention number inputs: stack vertikal */
    .am-num-row {
        flex-direction: column !important;
        gap: .75rem !important;
    }
    .am-num-group {
        min-width: unset !important;
        width: 100% !important;
    }
    .am-num-input {
        max-width: 100% !important;
        width: 100% !important;
    }

    /* Kata terlarang: input full-width, button full-width */
    .am-words-add-row {
        flex-direction: column !important;
        align-items: stretch !important;
        gap: .6rem !important;
    }
    .am-words-input {
        max-width: 100% !important;
        width: 100% !important;
        min-width: unset !important;
    }
    .am-words-btn {
        width: 100% !important;
        justify-content: center !important;
    }

    /* Whitelist: stack channel & role kolom */
    .am-wl-row {
        flex-direction: column !important;
        gap: 1.5rem !important;
    }
    .am-wl-col {
        flex: none !important;
        width: 100% !important;
        min-width: unset !important;
    }
    .am-wl-add-row {
        flex-direction: column !important;
        align-items: stretch !important;
        gap: .5rem !important;
    }
    .am-wl-select {
        width: 100% !important;
        max-width: 100% !important;
        min-width: unset !important;
    }
    .am-wl-add-row .btn {
        width: 100% !important;
        justify-content: center !important;
    }

    /* Settings card padding sedikit dikurangi */
    .settings-card {
        padding: 1rem !important;
    }
    .settings-card h2 {
        font-size: 1rem !important;
    }

    /* Page header: deskripsi jangan overflow */
    .page-header p {
        word-break: break-word;
    }
}

/* ── Small mobile (≤ 420px): stats jadi 1 kolom ────────────────────────── */
@media (max-width: 420px) {
    .stats-grid {
        grid-template-columns: 1fr !important;
        gap: .5rem !important;
    }
    .stat-card {
        padding: .85rem .9rem !important;
    }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'automod' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <div class="page-header">
            <h1>🛡️ <%= t('automod.page_title') %></h1>
            <p><%= t('automod.page_desc') %></p>
        </div>

        <!-- ── Stats Overview ──────────────────────────────────────────────────── -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="color:#5865F2;"><i data-lucide="shield-check"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= activeCount %></div>
                    <div class="stat-label"><%= t('automod.active_protection') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#ED4245;"><i data-lucide="ban"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= automodData.words.length %></div>
                    <div class="stat-label"><%= t('automod.banned_words') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#FEE75C;"><i data-lucide="hash"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= automodData.wlChannels.length %></div>
                    <div class="stat-label"><%= t('automod.channel_whitelist') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;"><i data-lucide="users"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= automodData.wlRoles.length %></div>
                    <div class="stat-label"><%= t('automod.role_whitelist') %></div>
                </div>
            </div>
        </div>

        <!-- ── How to Use ──────────────────────────────────────────────────────────── -->
        <div class="settings-card" style="margin-bottom:1.5rem;--guide-accent:#5865F2;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:#5865F2;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('automod.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('automod.step1_title') %></div>
                    <div class="guide-desc"><%- t('automod.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('automod.step2_title') %></div>
                    <div class="guide-desc"><%- t('automod.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('automod.step3_title') %></div>
                    <div class="guide-desc"><%- t('automod.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('automod.tip') %></div>
        </div>

        <!-- ── General Configuration ───────────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.general_config') %></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;"><%= t('automod.general_config_desc') %></p>

            <div class="form-row am-cfg-row" style="gap:1.5rem;flex-wrap:wrap;align-items:flex-start;">

                <div class="form-group am-cfg-group">
                    <label class="label"><%= t('automod.violation_action') %></label>
                    <select id="automodAction" class="select">
                        <option value="delete" <%= automodData.action === 'delete' ? 'selected' : '' %>>🗑️ <%= t('automod.action_delete') %></option>
                        <option value="warn"   <%= automodData.action === 'warn'   ? 'selected' : '' %>>⚠️ <%= t('automod.action_warn') %></option>
                        <option value="mute"   <%= automodData.action === 'mute'   ? 'selected' : '' %>>🔇 <%= t('automod.action_mute') %></option>
                        <option value="kick"   <%= automodData.action === 'kick'   ? 'selected' : '' %>>👢 <%= t('automod.action_kick') %></option>
                        <option value="ban"    <%= automodData.action === 'ban'    ? 'selected' : '' %>>🔨 <%= t('automod.action_ban') %></option>
                    </select>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.35rem;">
                        <%= t('automod.action_choose_hint') %>
                    </div>
                </div>

                <div class="form-group am-cfg-group">
                    <label class="label"><%= t('automod.timeout_duration') %> <span style="font-weight:400;color:var(--text-muted);">(<%= t('automod.timeout_for_mute') %>)</span></label>
                    <select id="automodMuteDuration" class="select">
                        <option value="60000"    <%= automodData.muteDuration === '60000'    ? 'selected' : '' %>>⏱️ <%= t('automod.dur_1min') %></option>
                        <option value="300000"   <%= automodData.muteDuration === '300000'   ? 'selected' : '' %>>⏱️ <%= t('automod.dur_5min') %></option>
                        <option value="600000"   <%= automodData.muteDuration === '600000'   || !automodData.muteDuration ? 'selected' : '' %>>⏱️ <%= t('automod.dur_10min') %></option>
                        <option value="1800000"  <%= automodData.muteDuration === '1800000'  ? 'selected' : '' %>>⏱️ <%= t('automod.dur_30min') %></option>
                        <option value="3600000"  <%= automodData.muteDuration === '3600000'  ? 'selected' : '' %>>⏱️ <%= t('automod.dur_1hour') %></option>
                        <option value="86400000" <%= automodData.muteDuration === '86400000' ? 'selected' : '' %>>⏱️ <%= t('automod.dur_1day') %></option>
                    </select>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.35rem;">
                        <%- t('automod.timeout_uses_discord') %>
                    </div>
                </div>

                <div class="form-group am-cfg-group">
                    <label class="label"><%= t('automod.audit_log_channel') %> <span style="font-weight:400;color:var(--text-muted);"><%= t('common.footer_optional') %></span></label>
                    <select id="automodAuditLog" class="select">
                        <option value=""><%= t('automod.audit_log_none') %></option>
                        <% textChannels.forEach(function(c) { %>
                            <option value="<%= c.id %>" <%= automodData.auditLogId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                        <% }); %>
                    </select>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.35rem;">
                        <%= t('automod.audit_log_hint') %>
                    </div>
                </div>

            </div>

            <div id="generalMsg" class="form-message"></div>
        </div>

        <!-- ── Link & Attachment Protection ────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.link_title') %></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;"><%= t('automod.link_desc') %></p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="toggleAntilink" class="toggle-input" data-flt-ignore <%= automodData.antilink ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('automod.antilink_label') %></span>
                </label>
            </div>
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="toggleAntiinvite" class="toggle-input" data-flt-ignore <%= automodData.antiinvite ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('automod.antiinvite_label') %></span>
                </label>
            </div>
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="toggleAttachments" class="toggle-input" data-flt-ignore <%= automodData.attachments ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('automod.antiattach_label') %></span>
                </label>
            </div>
            <div id="toggleMsg" class="form-message"></div>
        </div>

        <!-- ── Anti-Spam ───────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.spam_title') %></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;"><%= t('automod.spam_desc') %></p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="spamEnabled" class="toggle-input" <%= automodData.spam.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('automod.spam_enable') %></span>
                </label>
            </div>

            <div id="spamConfig" class="am-num-row" style="display:<%= automodData.spam.enabled ? 'flex' : 'none' %>;">
                <div class="form-group am-num-group">
                    <label class="label"><%= t('automod.msg_limit') %></label>
                    <input type="number" id="spamLimit" class="input am-num-input" min="2" max="20"
                           value="<%= automodData.spam.limit %>" placeholder="5">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;"><%= t('automod.msg_limit_hint') %></div>
                </div>
                <div class="form-group am-num-group">
                    <label class="label"><%= t('automod.interval_label') %></label>
                    <input type="number" id="spamInterval" class="input am-num-input" min="1" max="30"
                           value="<%= automodData.spam.interval %>" placeholder="5">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;"><%= t('automod.spam_interval_hint') %></div>
                </div>
            </div>

            <div id="spamMsg" class="form-message"></div>
        </div>

        <!-- ── Anti Mass-Mention ───────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.mention_title') %></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;"><%= t('automod.mention_desc') %></p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="mentionEnabled" class="toggle-input" <%= automodData.massmention.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('automod.mention_enable') %></span>
                </label>
            </div>

            <div id="mentionConfig" style="display:<%= automodData.massmention.enabled ? 'block' : 'none' %>;margin-top:.75rem;">
                <div class="form-group am-num-group">
                    <label class="label"><%= t('automod.mention_limit') %></label>
                    <input type="number" id="mentionLimit" class="input am-num-input" min="2" max="20"
                           value="<%= automodData.massmention.limit %>" placeholder="5">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;"><%= t('automod.mention_limit_hint') %></div>
                </div>
            </div>

            <div id="mentionMsg" class="form-message"></div>
        </div>

        <!-- ── Anti-Raid ───────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.raid_title') %></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;"><%= t('automod.raid_desc') %></p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="raidEnabled" class="toggle-input" <%= automodData.antiraid.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><%= t('automod.raid_enable') %></span>
                </label>
            </div>

            <div id="raidConfig" class="am-num-row" style="display:<%= automodData.antiraid.enabled ? 'flex' : 'none' %>;">
                <div class="form-group am-num-group">
                    <label class="label"><%= t('automod.join_limit') %></label>
                    <input type="number" id="raidJoinLimit" class="input am-num-input" min="2" max="50"
                           value="<%= automodData.antiraid.joinLimit %>" placeholder="10">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;"><%= t('automod.join_limit_hint') %></div>
                </div>
                <div class="form-group am-num-group">
                    <label class="label"><%= t('automod.interval_label') %></label>
                    <input type="number" id="raidInterval" class="input am-num-input" min="5" max="60"
                           value="<%= automodData.antiraid.interval %>" placeholder="10">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;"><%= t('automod.raid_interval_hint') %></div>
                </div>
            </div>

            <div id="raidMsg" class="form-message"></div>
        </div>

        <!-- ── Banned Words ────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.words_title') %> <span id="wordCountBadge" style="font-size:.8rem;font-weight:500;color:var(--text-muted);margin-left:.4rem;"><%= automodData.words.length %> / 100</span></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;"><%= t('automod.words_desc') %></p>

            <div id="wordsList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.25rem;min-height:2rem;">
                <% if (automodData.words.length === 0) { %>
                    <span id="wordsEmpty" style="color:var(--text-muted);font-size:.875rem;"><%= t('automod.words_empty') %></span>
                <% } %>
                <% automodData.words.forEach(function(w) { %>
                    <span class="am-word-chip" data-word="<%= w %>">
                        <code style="font-size:.8rem;"><%= w %></code>
                        <button class="am-chip-del" onclick="deleteWord('<%= w %>')" title="Delete">×</button>
                    </span>
                <% }); %>
            </div>

            <div class="form-row am-words-add-row">
                <input type="text" id="newWord" class="input am-words-input" placeholder="<%= t('automod.words_placeholder') %>"
                       maxlength="50" data-flt-ignore
                       onkeydown="if(event.key==='Enter')addWord()">
                <button class="btn btn-primary am-words-btn" onclick="addWord()">
                    <i data-lucide="plus"></i> <%= t('automod.words_add') %>
                </button>
            </div>
            <div id="wordsMsg" class="form-message"></div>
        </div>

        <!-- ── Whitelist ───────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2><%= t('automod.whitelist_title') %></h2>
            <p class="section-desc" style="margin-bottom:1.5rem;"><%- t('automod.whitelist_desc') %></p>

            <div class="form-row am-wl-row" style="gap:2rem;flex-wrap:wrap;align-items:flex-start;">

                <!-- Channel whitelist -->
                <div class="am-wl-col">
                    <h3 style="font-size:.9rem;font-weight:600;margin:0 0 .75rem;color:var(--text-secondary);">📌 Channel</h3>
                    <div id="wlChannelList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:.9rem;min-height:1.5rem;">
                        <% if (automodData.wlChannels.length === 0) { %>
                            <span id="wlChEmpty" style="color:var(--text-muted);font-size:.875rem;"><%= t('automod.whitelist_none') %></span>
                        <% } %>
                        <% automodData.wlChannels.forEach(function(id) {
                            var ch = textChannels.find(function(c){ return c.id === id; });
                            if (!ch) return;
                        %>
                            <span class="am-word-chip" data-id="<%= id %>">
                                <span style="font-size:.8rem;">#<%= ch.name %></span>
                                <button class="am-chip-del" onclick="removeWhitelist('channel','<%= id %>')" title="Delete">×</button>
                            </span>
                        <% }); %>
                    </div>
                    <div class="am-wl-add-row">
                        <select id="wlAddChannel" class="select am-wl-select" data-flt-ignore>
                            <option value=""><%= t('automod.whitelist_select_channel') %></option>
                            <% textChannels.forEach(function(c) { %>
                                <option value="<%= c.id %>">#<%= c.name %></option>
                            <% }); %>
                        </select>
                        <button class="btn btn-primary" onclick="addWhitelistChannel()">
                            <i data-lucide="plus"></i> <%= t('automod.words_add') %>
                        </button>
                    </div>
                    <div id="wlChMsg" class="form-message"></div>
                </div>

                <!-- Role whitelist -->
                <div class="am-wl-col">
                    <h3 style="font-size:.9rem;font-weight:600;margin:0 0 .75rem;color:var(--text-secondary);">🎭 Role</h3>
                    <div id="wlRoleList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:.9rem;min-height:1.5rem;">
                        <% if (automodData.wlRoles.length === 0) { %>
                            <span id="wlRlEmpty" style="color:var(--text-muted);font-size:.875rem;"><%= t('automod.whitelist_none') %></span>
                        <% } %>
                        <% automodData.wlRoles.forEach(function(id) {
                            var r = roles.find(function(x){ return x.id === id; });
                            if (!r) return;
                        %>
                            <span class="am-word-chip" data-id="<%= id %>" style="border-color:<%= r.color || 'var(--border)' %>;">
                                <span style="font-size:.8rem;color:<%= r.color || 'inherit' %>;">@<%= r.name %></span>
                                <button class="am-chip-del" onclick="removeWhitelist('role','<%= id %>')" title="Delete">×</button>
                            </span>
                        <% }); %>
                    </div>
                    <div class="am-wl-add-row">
                        <select id="wlAddRole" class="select am-wl-select" data-flt-ignore>
                            <option value=""><%= t('automod.whitelist_select_role') %></option>
                            <% roles.forEach(function(r) { %>
                                <option value="<%= r.id %>" style="color:<%= r.color || 'inherit' %>;">@<%= r.name %></option>
                            <% }); %>
                        </select>
                        <button class="btn btn-primary" onclick="addWhitelistRole()">
                            <i data-lucide="plus"></i> <%= t('automod.words_add') %>
                        </button>
                    </div>
                    <div id="wlRlMsg" class="form-message"></div>
                </div>

            </div>
        </div>

    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<script>
const GUILD_ID = '<%= guild.id %>';
const I18N_WORDS_EMPTY = '<%= t("automod.words_empty") %>';
const I18N_WL_NONE     = '<%= t("automod.whitelist_none") %>';
const I18N_AM_ERR_CH   = '<%= t("automod.err_select_channel") %>';
const I18N_AM_ERR_ROLE = '<%= t("automod.err_select_role") %>';

// ── Util ──────────────────────────────────────────────────────────────────────
function showMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (type === 'success') setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

async function apiFetch(path, method, body) {
    const res  = await fetch(`/api/guild/${GUILD_ID}${path}`, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body:    body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}

// ── Konfigurasi Umum ──────────────────────────────────────────────────────────
async function saveGeneral(quiet = false) {
    const msg = document.getElementById('generalMsg');
    const data = await apiFetch('/automod/general', 'POST', {
        action:       document.getElementById('automodAction').value,
        muteDuration: document.getElementById('automodMuteDuration').value,
        auditLogId:   document.getElementById('automodAuditLog').value || null,
    });
    if (!quiet || !data.success) showMsg(msg, data.message, data.success ? 'success' : 'error');
    return data;
}

// ── Toggle handlers (simpan langsung saat diubah) ─────────────────────────────
document.getElementById('toggleAntilink')?.addEventListener('change', async function () {
    const msg  = document.getElementById('toggleMsg');
    const data = await apiFetch('/automod/antilink', 'POST', { enabled: this.checked });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) this.checked = !this.checked;
});

document.getElementById('toggleAntiinvite')?.addEventListener('change', async function () {
