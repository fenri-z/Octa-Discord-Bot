<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'automod' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <div class="page-header">
            <h1>🛡️ Automod</h1>
            <p>Automatic moderation system to protect the server from spam, harmful links, profanity, and other violations.</p>
        </div>

        <!-- ── Stats Overview ──────────────────────────────────────────────────── -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="color:#5865F2;"><i data-lucide="shield-check"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= activeCount %></div>
                    <div class="stat-label">Active Protection</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#ED4245;"><i data-lucide="ban"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= automodData.words.length %></div>
                    <div class="stat-label">Kata Terlarang</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#FEE75C;"><i data-lucide="hash"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= automodData.wlChannels.length %></div>
                    <div class="stat-label">Channel Whitelist</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;"><i data-lucide="users"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= automodData.wlRoles.length %></div>
                    <div class="stat-label">Role Whitelist</div>
                </div>
            </div>
        </div>

        <!-- ── General Configuration ───────────────────────────────────────────── -->
        <div class="settings-card">
            <h2>General Configuration</h2>
            <p class="section-desc" style="margin-bottom:1.25rem;">Configure bot actions when a violation is detected, mute role, and audit log channel.</p>

            <div class="form-row am-cfg-row" style="gap:1.5rem;flex-wrap:wrap;align-items:flex-start;">

                <div class="form-group am-cfg-group">
                    <label class="label">Violation Action</label>
                    <select id="automodAction" class="select">
                        <option value="delete" <%= automodData.action === 'delete' ? 'selected' : '' %>>🗑️ Delete — Delete message only</option>
                        <option value="warn"   <%= automodData.action === 'warn'   ? 'selected' : '' %>>⚠️ Warn — Delete + warn via DM</option>
                        <option value="mute"   <%= automodData.action === 'mute'   ? 'selected' : '' %>>🔇 Mute — Delete + mute 10 minutes</option>
                        <option value="kick"   <%= automodData.action === 'kick'   ? 'selected' : '' %>>👢 Kick — Delete + kick member</option>
                        <option value="ban"    <%= automodData.action === 'ban'    ? 'selected' : '' %>>🔨 Ban — Delete + ban member</option>
                    </select>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.35rem;">
                        Choose what the bot does when a violation is detected.
                    </div>
                </div>

                <div class="form-group am-cfg-group">
                    <label class="label">Timeout Duration <span style="font-weight:400;color:var(--text-muted);">(for Mute action)</span></label>
                    <select id="automodMuteDuration" class="select">
                        <option value="60000"    <%= automodData.muteDuration === '60000'    ? 'selected' : '' %>>⏱️ 1 minute</option>
                        <option value="300000"   <%= automodData.muteDuration === '300000'   ? 'selected' : '' %>>⏱️ 5 minutes</option>
                        <option value="600000"   <%= automodData.muteDuration === '600000'   || !automodData.muteDuration ? 'selected' : '' %>>⏱️ 10 minutes (default)</option>
                        <option value="1800000"  <%= automodData.muteDuration === '1800000'  ? 'selected' : '' %>>⏱️ 30 minutes</option>
                        <option value="3600000"  <%= automodData.muteDuration === '3600000'  ? 'selected' : '' %>>⏱️ 1 hour</option>
                        <option value="86400000" <%= automodData.muteDuration === '86400000' ? 'selected' : '' %>>⏱️ 1 day</option>
                    </select>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.35rem;">
                        Uses Discord's built-in timeout. Bot requires the <strong>Moderate Members</strong> permission.
                    </div>
                </div>

                <div class="form-group am-cfg-group">
                    <label class="label">Audit Log Channel <span style="font-weight:400;color:var(--text-muted);">(optional)</span></label>
                    <select id="automodAuditLog" class="select">
                        <option value="">— None —</option>
                        <% textChannels.forEach(function(c) { %>
                            <option value="<%= c.id %>" <%= automodData.auditLogId === c.id ? 'selected' : '' %>>#<%= c.name %></option>
                        <% }); %>
                    </select>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.35rem;">
                        All automod activity will be logged here.
                    </div>
                </div>

            </div>

            <div class="form-row" style="margin-top:.5rem;">
                <button class="btn btn-primary" onclick="saveGeneral()">
                    <i data-lucide="save"></i> Save Configuration
                </button>
            </div>
            <div id="generalMsg" class="form-message"></div>
        </div>

        <!-- ── Link & Attachment Protection ────────────────────────────────────── -->
        <div class="settings-card">
            <h2>Link &amp; Attachment Protection</h2>
            <p class="section-desc" style="margin-bottom:1.25rem;">Automatically block messages containing URLs, Discord invites, or file attachments. Changes are saved immediately.</p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="toggleAntilink" class="toggle-input" <%= automodData.antilink ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><strong>Anti-Link</strong> — Block all URLs (http, https, www)</span>
                </label>
            </div>
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="toggleAntiinvite" class="toggle-input" <%= automodData.antiinvite ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><strong>Anti-Invite</strong> — Block Discord invite links (discord.gg/...)</span>
                </label>
            </div>
            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="toggleAttachments" class="toggle-input" <%= automodData.attachments ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span><strong>Anti-Attachment</strong> — Block messages containing files or images</span>
                </label>
            </div>
            <div id="toggleMsg" class="form-message"></div>
        </div>

        <!-- ── Anti-Spam ───────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2>Anti-Spam</h2>
            <p class="section-desc" style="margin-bottom:1.25rem;">Take action against members who send messages too quickly in a short time.</p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="spamEnabled" class="toggle-input" <%= automodData.spam.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span>Enable Anti-Spam</span>
                </label>
            </div>

            <div id="spamConfig" class="am-num-row" style="display:<%= automodData.spam.enabled ? 'flex' : 'none' %>;">
                <div class="form-group am-num-group">
                    <label class="label">Message Limit</label>
                    <input type="number" id="spamLimit" class="input am-num-input" min="2" max="20"
                           value="<%= automodData.spam.limit %>" placeholder="5">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;">Max. messages per interval (2–20)</div>
                </div>
                <div class="form-group am-num-group">
                    <label class="label">Interval (seconds)</label>
                    <input type="number" id="spamInterval" class="input am-num-input" min="1" max="30"
                           value="<%= automodData.spam.interval %>" placeholder="5">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;">Check time window (1–30 seconds)</div>
                </div>
            </div>

            <div class="form-row" style="margin-top:.75rem;">
                <button class="btn btn-primary" onclick="saveSpam()">
                    <i data-lucide="save"></i> Save
                </button>
            </div>
            <div id="spamMsg" class="form-message"></div>
        </div>

        <!-- ── Anti Mass-Mention ───────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2>Anti Mass-Mention</h2>
            <p class="section-desc" style="margin-bottom:1.25rem;">Take action against members who mention many people or roles in a single message.</p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="mentionEnabled" class="toggle-input" <%= automodData.massmention.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span>Enable Anti Mass-Mention</span>
                </label>
            </div>

            <div id="mentionConfig" style="display:<%= automodData.massmention.enabled ? 'block' : 'none' %>;margin-top:.75rem;">
                <div class="form-group am-num-group">
                    <label class="label">Mention Limit per Message</label>
                    <input type="number" id="mentionLimit" class="input am-num-input" min="2" max="20"
                           value="<%= automodData.massmention.limit %>" placeholder="5">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;">Max. mention count (@user + @role) per message (2–20)</div>
                </div>
            </div>

            <div class="form-row" style="margin-top:.75rem;">
                <button class="btn btn-primary" onclick="saveMassMention()">
                    <i data-lucide="save"></i> Save
                </button>
            </div>
            <div id="mentionMsg" class="form-message"></div>
        </div>

        <!-- ── Anti-Raid ───────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2>Anti-Raid</h2>
            <p class="section-desc" style="margin-bottom:1.25rem;">Detect mass joins in a short time. Bot will automatically raise the server verification level.</p>

            <div class="form-group">
                <label class="toggle-label">
                    <input type="checkbox" id="raidEnabled" class="toggle-input" <%= automodData.antiraid.enabled ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                    <span>Enable Anti-Raid</span>
                </label>
            </div>

            <div id="raidConfig" class="am-num-row" style="display:<%= automodData.antiraid.enabled ? 'flex' : 'none' %>;">
                <div class="form-group am-num-group">
                    <label class="label">Join Limit</label>
                    <input type="number" id="raidJoinLimit" class="input am-num-input" min="2" max="50"
                           value="<%= automodData.antiraid.joinLimit %>" placeholder="10">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;">Joins considered a raid within 1 interval (2–50)</div>
                </div>
                <div class="form-group am-num-group">
                    <label class="label">Interval (seconds)</label>
                    <input type="number" id="raidInterval" class="input am-num-input" min="5" max="60"
                           value="<%= automodData.antiraid.interval %>" placeholder="10">
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.3rem;">Monitoring time window (5–60 seconds)</div>
                </div>
            </div>

            <div class="form-row" style="margin-top:.75rem;">
                <button class="btn btn-primary" onclick="saveAntiRaid()">
                    <i data-lucide="save"></i> Save
                </button>
            </div>
            <div id="raidMsg" class="form-message"></div>
        </div>

        <!-- ── Banned Words ────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2>Kata Terlarang <span id="wordCountBadge" style="font-size:.8rem;font-weight:500;color:var(--text-muted);margin-left:.4rem;"><%= automodData.words.length %> / 100</span></h2>
            <p class="section-desc" style="margin-bottom:1.25rem;">Messages containing the following words will be automatically deleted (case-insensitive).</p>

            <div id="wordsList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.25rem;min-height:2rem;">
                <% if (automodData.words.length === 0) { %>
                    <span id="wordsEmpty" style="color:var(--text-muted);font-size:.875rem;">No banned words yet.</span>
                <% } %>
                <% automodData.words.forEach(function(w) { %>
                    <span class="am-word-chip" data-word="<%= w %>">
                        <code style="font-size:.8rem;"><%= w %></code>
                        <button class="am-chip-del" onclick="deleteWord('<%= w %>')" title="Delete">×</button>
                    </span>
                <% }); %>
            </div>

            <div class="form-row am-words-add-row">
                <input type="text" id="newWord" class="input am-words-input" placeholder="Ketik kata terlarang…"
                       maxlength="50"
                       onkeydown="if(event.key==='Enter')addWord()">
                <button class="btn btn-primary am-words-btn" onclick="addWord()">
                    <i data-lucide="plus"></i> Add
                </button>
            </div>
            <div id="wordsMsg" class="form-message"></div>
        </div>

        <!-- ── Whitelist ───────────────────────────────────────────────────────── -->
        <div class="settings-card">
            <h2>Whitelist</h2>
            <p class="section-desc" style="margin-bottom:1.5rem;">The following channels and roles will be <strong>excluded</strong> from all Automod checks.</p>

            <div class="form-row am-wl-row" style="gap:2rem;flex-wrap:wrap;align-items:flex-start;">

                <!-- Channel whitelist -->
                <div class="am-wl-col">
                    <h3 style="font-size:.9rem;font-weight:600;margin:0 0 .75rem;color:var(--text-secondary);">📌 Channel</h3>
                    <div id="wlChannelList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:.9rem;min-height:1.5rem;">
                        <% if (automodData.wlChannels.length === 0) { %>
                            <span id="wlChEmpty" style="color:var(--text-muted);font-size:.875rem;">None.</span>
                        <% } %>
                        <% automodData.wlChannels.forEach(function(id) {
                            var ch = textChannels.find(function(c){ return c.id === id; });
                            if (!ch) return;
                        %>
                            <span class="am-word-chip" data-id="<%= id %>">
                                <span style="font-size:.8rem;">#<%= ch.name %></span>
                                <button class="am-chip-del" onclick="removeWhitelist('channel','<%= id %>')" title="Delete">×</button>
                            </span>
                        <% }); %>
                    </div>
                    <div class="am-wl-add-row">
                        <select id="wlAddChannel" class="select am-wl-select">
                            <option value="">— Select channel —</option>
                            <% textChannels.forEach(function(c) { %>
                                <option value="<%= c.id %>">#<%= c.name %></option>
                            <% }); %>
                        </select>
                        <button class="btn btn-primary" onclick="addWhitelistChannel()">
                            <i data-lucide="plus"></i> Add
                        </button>
                    </div>
                    <div id="wlChMsg" class="form-message"></div>
                </div>

                <!-- Role whitelist -->
                <div class="am-wl-col">
                    <h3 style="font-size:.9rem;font-weight:600;margin:0 0 .75rem;color:var(--text-secondary);">🎭 Role</h3>
                    <div id="wlRoleList" style="display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:.9rem;min-height:1.5rem;">
                        <% if (automodData.wlRoles.length === 0) { %>
                            <span id="wlRlEmpty" style="color:var(--text-muted);font-size:.875rem;">None.</span>
                        <% } %>
                        <% automodData.wlRoles.forEach(function(id) {
                            var r = roles.find(function(x){ return x.id === id; });
                            if (!r) return;
                        %>
                            <span class="am-word-chip" data-id="<%= id %>" style="border-color:<%= r.color || 'var(--border)' %>;">
                                <span style="font-size:.8rem;color:<%= r.color || 'inherit' %>;">@<%= r.name %></span>
                                <button class="am-chip-del" onclick="removeWhitelist('role','<%= id %>')" title="Delete">×</button>
                            </span>
                        <% }); %>
                    </div>
                    <div class="am-wl-add-row">
                        <select id="wlAddRole" class="select am-wl-select">
                            <option value="">— Select role —</option>
                            <% roles.forEach(function(r) { %>
                                <option value="<%= r.id %>" style="color:<%= r.color || 'inherit' %>;">@<%= r.name %></option>
                            <% }); %>
                        </select>
                        <button class="btn btn-primary" onclick="addWhitelistRole()">
                            <i data-lucide="plus"></i> Add
                        </button>
                    </div>
                    <div id="wlRlMsg" class="form-message"></div>
                </div>

            </div>
        </div>

    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<style>
/* ── Chip / Tag ─────────────────────────────────────────────────────────── */
.am-word-chip {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .25rem .5rem .25rem .6rem;
    background: var(--bg-3, rgba(255,255,255,.05));
    border: 1px solid var(--border, rgba(255,255,255,.1));
    border-radius: 6px;
    font-size: .82rem;
    line-height: 1.4;
    max-width: 100%;
    word-break: break-all;
}
.am-chip-del {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0 2px;
    font-size: 1rem;
    line-height: 1;
    border-radius: 3px;
    transition: color .15s, background .15s;
    flex-shrink: 0;
}
.am-chip-del:hover {
    color: #ED4245;
    background: rgba(237,66,69,.1);
}

/* ── General Configuration ──────────────────────────────────────────────── */
.am-cfg-group {
    flex: 1;
    min-width: 200px;
}

/* ── Spam / Raid number inputs ──────────────────────────────────────────── */
.am-num-row {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: .75rem;
}
.am-num-group {
    flex: 1;
    min-width: 160px;
}
.am-num-input {
    max-width: 120px;
    width: 100%;
}

/* ── Kata Terlarang input row ───────────────────────────────────────────── */
.am-words-add-row {
    display: flex;
    gap: .75rem;
    align-items: center;
    flex-wrap: wrap;
}
.am-words-input {
    flex: 1;
    min-width: 160px;
    max-width: 260px;
}

/* ── Whitelist ──────────────────────────────────────────────────────────── */
.am-wl-row {
    display: flex;
    flex-wrap: wrap;
}
.am-wl-col {
    flex: 1;
    min-width: 220px;
}
.am-wl-add-row {
    display: flex;
    gap: .6rem;
    align-items: center;
    flex-wrap: wrap;
}
.am-wl-select {
    flex: 1;
    min-width: 140px;
}

/* ── Tablet (≤ 900px) ───────────────────────────────────────────────────── */
@media (max-width: 900px) {
    .stats-grid {
        grid-template-columns: repeat(2, 1fr) !important;
    }
    .am-cfg-row {
        flex-direction: column !important;
        gap: 1rem !important;
    }
    .am-cfg-group {
        flex: none !important;
        width: 100% !important;
        min-width: unset !important;
    }
    .am-cfg-group .select {
        width: 100% !important;
        max-width: 100% !important;
    }
}

/* ── Mobile (≤ 600px) ───────────────────────────────────────────────────── */
@media (max-width: 600px) {
    .stats-grid {
        grid-template-columns: repeat(2, 1fr) !important;
        gap: .6rem !important;
    }

    /* Spam / Raid / Mention number inputs: stack vertikal */
    .am-num-row {
        flex-direction: column !important;
        gap: .75rem !important;
    }
    .am-num-group {
        min-width: unset !important;
        width: 100% !important;
    }
    .am-num-input {
        max-width: 100% !important;
        width: 100% !important;
    }

    /* Kata terlarang: input full-width, button full-width */
    .am-words-add-row {
        flex-direction: column !important;
        align-items: stretch !important;
        gap: .6rem !important;
    }
    .am-words-input {
        max-width: 100% !important;
        width: 100% !important;
        min-width: unset !important;
    }
    .am-words-btn {
        width: 100% !important;
        justify-content: center !important;
    }

    /* Whitelist: stack channel & role kolom */
    .am-wl-row {
        flex-direction: column !important;
        gap: 1.5rem !important;
    }
    .am-wl-col {
        flex: none !important;
        width: 100% !important;
        min-width: unset !important;
    }
    .am-wl-add-row {
        flex-direction: column !important;
        align-items: stretch !important;
        gap: .5rem !important;
    }
    .am-wl-select {
        width: 100% !important;
        max-width: 100% !important;
    }
    .am-wl-add-row .btn {
        width: 100% !important;
        justify-content: center !important;
    }

    /* Settings card padding sedikit dikurangi */
    .settings-card {
        padding: 1rem !important;
    }
    .settings-card h2 {
        font-size: 1rem !important;
    }
}
</style>

<script>
const GUILD_ID = '<%= guild.id %>';

// ── Util ──────────────────────────────────────────────────────────────────────
function showMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (type === 'success') setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

async function apiFetch(path, method, body) {
    const res  = await fetch(`/api/guild/${GUILD_ID}${path}`, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body:    body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}

// ── Konfigurasi Umum ──────────────────────────────────────────────────────────
async function saveGeneral() {
    const msg = document.getElementById('generalMsg');
    const data = await apiFetch('/automod/general', 'POST', {
        action:       document.getElementById('automodAction').value,
        muteDuration: document.getElementById('automodMuteDuration').value,
        auditLogId:   document.getElementById('automodAuditLog').value || null,
    });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

// ── Toggle handlers (simpan langsung saat diubah) ─────────────────────────────
document.getElementById('toggleAntilink')?.addEventListener('change', async function () {
    const msg  = document.getElementById('toggleMsg');
    const data = await apiFetch('/automod/antilink', 'POST', { enabled: this.checked });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) this.checked = !this.checked;
});

document.getElementById('toggleAntiinvite')?.addEventListener('change', async function () {
    const msg  = document.getElementById('toggleMsg');
    const data = await apiFetch('/automod/antiinvite', 'POST', { enabled: this.checked });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) this.checked = !this.checked;
});

document.getElementById('toggleAttachments')?.addEventListener('change', async function () {
    const msg  = document.getElementById('toggleMsg');
    const data = await apiFetch('/automod/attachments', 'POST', { enabled: this.checked });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) this.checked = !this.checked;
});

// ── Anti-Spam ─────────────────────────────────────────────────────────────────
document.getElementById('spamEnabled')?.addEventListener('change', function () {
    document.getElementById('spamConfig').style.display = this.checked ? 'flex' : 'none';
});

async function saveSpam() {
    const msg = document.getElementById('spamMsg');
    const data = await apiFetch('/automod/spam', 'POST', {
        enabled:  document.getElementById('spamEnabled').checked,
        limit:    parseInt(document.getElementById('spamLimit')?.value)    || 5,
        interval: parseInt(document.getElementById('spamInterval')?.value) || 5,
    });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

// ── Anti Mass-Mention ─────────────────────────────────────────────────────────
document.getElementById('mentionEnabled')?.addEventListener('change', function () {
    document.getElementById('mentionConfig').style.display = this.checked ? 'block' : 'none';
});

async function saveMassMention() {
    const msg = document.getElementById('mentionMsg');
    const data = await apiFetch('/automod/massmention', 'POST', {
        enabled: document.getElementById('mentionEnabled').checked,
        limit:   parseInt(document.getElementById('mentionLimit')?.value) || 5,
    });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

// ── Anti-Raid ─────────────────────────────────────────────────────────────────
document.getElementById('raidEnabled')?.addEventListener('change', function () {
    document.getElementById('raidConfig').style.display = this.checked ? 'flex' : 'none';
});

async function saveAntiRaid() {
    const msg = document.getElementById('raidMsg');
    const data = await apiFetch('/automod/antiraid', 'POST', {
        enabled:   document.getElementById('raidEnabled').checked,
        joinLimit: parseInt(document.getElementById('raidJoinLimit')?.value) || 10,
        interval:  parseInt(document.getElementById('raidInterval')?.value)  || 10,
    });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

// ── Kata Terlarang ────────────────────────────────────────────────────────────
function renderWordChip(word) {
    const span = document.createElement('span');
    span.className    = 'am-word-chip';
    span.dataset.word = word;
    span.innerHTML    = `<code style="font-size:.8rem;">${escHtml(word)}</code>
        <button class="am-chip-del" onclick="deleteWord('${escHtml(word)}')" title="Delete">×</button>`;
    return span;
}

function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function updateWordCount(total) {
    const badge = document.getElementById('wordCountBadge');
    if (badge) badge.textContent = `${total} / 100`;
}

async function addWord() {
    const input = document.getElementById('newWord');
    const msg   = document.getElementById('wordsMsg');
    const word  = input.value.trim().toLowerCase();
    if (!word) return;

    const data = await apiFetch('/automod/words', 'POST', { word });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) return;

    input.value = '';
    const list  = document.getElementById('wordsList');
    const empty = document.getElementById('wordsEmpty');
    if (empty) empty.remove();
    list.appendChild(renderWordChip(data.word));
    updateWordCount(data.total);
}

async function deleteWord(word) {
    const msg  = document.getElementById('wordsMsg');
    const data = await apiFetch(`/automod/words/${encodeURIComponent(word)}`, 'DELETE');
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) return;

    const chip = document.querySelector(`.am-word-chip[data-word="${CSS.escape(word)}"]`);
    if (chip) chip.remove();
    updateWordCount(data.total);
    if (data.total === 0) {
        const list  = document.getElementById('wordsList');
        const empty = document.createElement('span');
        empty.id        = 'wordsEmpty';
        empty.style.cssText = 'color:var(--text-muted);font-size:.875rem;';
        empty.textContent   = 'No banned words yet.';
        list.appendChild(empty);
    }
}

// ── Whitelist ─────────────────────────────────────────────────────────────────
function renderWlChannelChip(id, name) {
    const span = document.createElement('span');
    span.className  = 'am-word-chip';
    span.dataset.id = id;
    span.innerHTML  = `<span style="font-size:.8rem;">#${escHtml(name)}</span>
        <button class="am-chip-del" onclick="removeWhitelist('channel','${id}')" title="Delete">×</button>`;
    return span;
}

function renderWlRoleChip(id, name, color) {
    const span = document.createElement('span');
    span.className  = 'am-word-chip';
    span.dataset.id = id;
    if (color) span.style.borderColor = color;
    span.innerHTML  = `<span style="font-size:.8rem;${color ? `color:${color};` : ''}"">@${escHtml(name)}</span>
        <button class="am-chip-del" onclick="removeWhitelist('role','${id}')" title="Delete">×</button>`;
    return span;
}

async function addWhitelistChannel() {
    const sel  = document.getElementById('wlAddChannel');
    const msg  = document.getElementById('wlChMsg');
    const id   = sel.value;
    if (!id) { showMsg(msg, 'Please select a channel first.', 'error'); return; }

    const data = await apiFetch('/automod/whitelist', 'POST', { type: 'channel', id });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) return;

    const list  = document.getElementById('wlChannelList');
    const empty = document.getElementById('wlChEmpty');
    if (empty) empty.remove();
    list.appendChild(renderWlChannelChip(data.id, data.name));
    sel.value = '';
}

async function addWhitelistRole() {
    const sel  = document.getElementById('wlAddRole');
    const msg  = document.getElementById('wlRlMsg');
    const id   = sel.value;
    if (!id) { showMsg(msg, 'Please select a role first.', 'error'); return; }

    const data = await apiFetch('/automod/whitelist', 'POST', { type: 'role', id });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) return;

    const list  = document.getElementById('wlRoleList');
    const empty = document.getElementById('wlRlEmpty');
    if (empty) empty.remove();
    list.appendChild(renderWlRoleChip(data.id, data.name, data.color));
    sel.value = '';
}

async function removeWhitelist(type, id) {
    const msgId = type === 'channel' ? 'wlChMsg' : 'wlRlMsg';
    const listId = type === 'channel' ? 'wlChannelList' : 'wlRoleList';
    const emptyId = type === 'channel' ? 'wlChEmpty' : 'wlRlEmpty';
    const msg  = document.getElementById(msgId);

    const data = await apiFetch(`/automod/whitelist/${type}/${id}`, 'DELETE');
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (!data.success) return;

    const chip = document.querySelector(`#${listId} .am-word-chip[data-id="${id}"]`);
    if (chip) chip.remove();

    const remaining = document.querySelectorAll(`#${listId} .am-word-chip`).length;
    if (remaining === 0) {
        const list  = document.getElementById(listId);
        const empty = document.createElement('span');
        empty.id        = emptyId;
        empty.style.cssText = 'color:var(--text-muted);font-size:.875rem;';
        empty.textContent   = 'None.';
        list.appendChild(empty);
    }
}
</script>

