<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
/* ── YouTube Notifications — Preview ────────────────────────────────────── */

/* 2-kolom: form kiri | preview kanan */
.yt-panel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
}
@media (max-width: 860px) {
    .yt-panel-layout { grid-template-columns: 1fr; }
    .yt-preview-col  { position: static; }
    /* Stats: 2 kolom di tablet */
    .yt-stats-grid   { grid-template-columns: 1fr 1fr !important; }
    .yt-stats-grid .stat-card { min-width: 0; }
    .yt-stats-grid .stat-info { min-width: 0; overflow: hidden; }
    .yt-stats-grid .stat-label { white-space: normal; line-height: 1.3; }
}

.yt-preview-col { position: sticky; top: calc(var(--navbar-h, 56px) + 1rem); }
.preview-label  {
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: .5rem;
}

/* YouTube thumbnail placeholder */
.yt-thumb-mock {
    border-radius: 4px; overflow: hidden;
    background: rgba(0,0,0,.32); aspect-ratio: 16/9; max-width: 100%;
    display: flex; align-items: center; justify-content: center;
    position: relative;
}
.yt-thumb-mock-inner {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,0,0,.9);
    display: flex; align-items: center; justify-content: center; z-index: 1;
    box-shadow: 0 2px 8px rgba(0,0,0,.4);
}
.yt-thumb-mock-inner svg { width: 20px; height: 20px; fill: #fff; margin-left: 3px; }

/* ── YouTube Notifications — Responsive ─────────────────────────────────── */

/* Tab buttons: selalu 3 kolom rata */
.yt-tabs-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: .4rem;
}
.yt-tabs-row .yt-tab-btn {
    text-align: center;
    padding: .38rem .4rem !important;
    white-space: nowrap;
}

/* ── Tablet (≤ 680px) ─────────────────────────────────────────────────── */
@media (max-width: 680px) {
    /* Kurangi padding halaman */
    .dash-main {
        padding: 1.25rem 1rem 1.5rem !important;
    }
    .settings-card { padding: 1rem !important; }

    /* Stats: 2 kolom, cegah overflow dengan min-width: 0 */
    .yt-stats-grid {
        grid-template-columns: 1fr 1fr !important;
        gap: .5rem !important;
    }
    /* Kritis: flex children butuh min-width:0 agar bisa menyusut */
    .yt-stats-grid .stat-card {
        min-width: 0;
        padding: .85rem .75rem;
        gap: .55rem;
    }
    .yt-stats-grid .stat-info {
        min-width: 0;
        overflow: hidden;
    }
    .yt-stats-grid .stat-label {
        white-space: normal;
        line-height: 1.3;
        word-break: break-word;
    }
}

/* ── Mobile kecil (≤ 480px) ──────────────────────────────────────────── */
@media (max-width: 480px) {
    .dash-main {
        padding: 1rem .75rem 1.5rem !important;
    }

    /* Stats card lebih kompak */
    .yt-stats-grid .stat-card {
        padding: .7rem .6rem;
        gap: .45rem;
    }
    .yt-stats-grid .stat-icon {
        width: 32px !important;
        height: 32px !important;
        border-radius: 8px !important;
        flex-shrink: 0;
    }
    .yt-stats-grid .stat-icon svg {
        width: 14px !important;
        height: 14px !important;
    }
    .yt-stats-grid .stat-value {
        font-size: 1.1rem;
    }
    .yt-stats-grid .stat-label {
        font-size: .63rem;
    }

    /* Channel card header */
    .yt-card-header {
        gap: .55rem !important;
    }
    .yt-card-avatar {
        width: 36px !important;
        height: 36px !important;
        min-width: 36px;
    }
    .yt-card-name {
        font-size: .88rem !important;
    }

    /* Tab button teks lebih kecil */
    .yt-tabs-row .yt-tab-btn {
        font-size: .76rem !important;
        padding: .35rem .3rem !important;
    }
}

/* ── Tombol Test Notif & Simpan responsif ────────────────────────────── */
@media (max-width: 680px) {
    .yt-search-row {
        flex-direction: column !important;
    }
    .yt-search-row .btn {
        width: 100%;
        justify-content: center;
    }
    .yt-action-row {
        flex-direction: column !important;
        justify-content: stretch !important;
    }
    .yt-action-row .btn {
        width: 100%;
        justify-content: center;
    }
}

/* ── Lookup result: Add button wraps on very narrow screens ─────────── */
@media (max-width: 380px) {
    .yt-lookup-result-inner {
        flex-wrap: wrap !important;
    }
    .yt-lookup-result-inner .btn {
        width: 100%;
        justify-content: center;
        margin-top: .3rem;
    }
    .dash-main {
        padding: .85rem .6rem 1.5rem !important;
    }

    /* Card header: wrap action buttons below name */
    .yt-card-header {
        flex-wrap: wrap;
        gap: .4rem !important;
    }
    .yt-card-header > div[style] {
        flex: 1 1 0;
        min-width: 0;
    }
    /* Button group wraps to right side */
    .yt-card-header > a.btn,
    .yt-card-header > button.btn {
        padding: .22rem .35rem !important;
    }

    /* Page header: stack vertically */
    .page-header[style] {
        flex-direction: column !important;
        align-items: flex-start !important;
    }

    /* Textarea lebih pendek di mobile kecil */
    .yt-form-col .textarea { min-height: 70px; }

    /* Preview: lebih kompak di mobile kecil */
    .cc-discord-preview { font-size: 12px; }
    .cc-dp-msg { padding: .6rem; }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'youtube' }) %>

    <main class="dash-main" style="max-width:100%;overflow-x:hidden;">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
            <div>
                <h1><%= t('youtube.page_title') %></h1>
                <p><%= t('youtube.page_desc') %></p>
            </div>
        </div>


        <!-- ── Stats ─────────────────────────────────────────────────────── -->
        <div class="stats-grid yt-stats-grid" style="margin-bottom:1.5rem;">
            <div class="stat-card">
                <div class="stat-icon" style="color:#FF0000;"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></div>
                <div class="stat-info">
                    <div class="stat-value" id="statChannels"><%= ytChannels.length %></div>
                    <div class="stat-label"><%= t('youtube.stat_monitored') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;"><i data-lucide="video"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= ytChannels.filter(c => c.videoEnabled).length %></div>
                    <div class="stat-label"><%= t('youtube.stat_video_enabled') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#FF6B35;"><i data-lucide="film"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= ytChannels.filter(c => c.shortEnabled).length %></div>
                    <div class="stat-label"><%= t('youtube.stat_short_enabled') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#ED4245;"><i data-lucide="radio"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= ytChannels.filter(c => c.liveEnabled).length %></div>
                    <div class="stat-label"><%= t('youtube.stat_live_enabled') %></div>
                </div>
            </div>
        </div>

        <!-- ── Add Channel ─────────────────────────────────────────────────── -->
        <% if (ytChannels.length < maxChannels) { %>
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;">
                <i data-lucide="plus-circle" style="color:#FF0000;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('youtube.add_title') %></h2>
            </div>
            <p style="font-size:.85rem;color:var(--text-muted);margin:0 0 1rem 0;">
                <%- t('youtube.add_desc', { remaining: maxChannels - ytChannels.length, max: maxChannels }) %>
            </p>
            <div class="form-group" style="margin-bottom:0;">
                <label class="label"><%= t('youtube.search_label') %></label>
                <div class="yt-search-row" style="display:flex;gap:.6rem;">
                    <input type="text" id="ytLookupInput" class="input"
                           placeholder="<%= t('youtube.input_placeholder') %>"
                           style="flex:1;min-width:0;" maxlength="200" data-flt-ignore>
                    <button class="btn btn-primary" onclick="lookupYtChannel()" style="white-space:nowrap;flex-shrink:0;">
                        <i data-lucide="search" style="width:14px;height:14px;"></i> <%= t('youtube.search_btn') %>
                    </button>
                </div>
            </div>
            <!-- Hasil lookup -->
            <div id="ytLookupResult" style="display:none;margin-top:1rem;padding:.85rem;background:var(--bg3);border-radius:10px;border:1px solid var(--border);">
                <div class="yt-lookup-result-inner" style="display:flex;align-items:center;gap:.75rem;">
                    <img id="ytLookupThumb" src="" alt="" referrerpolicy="no-referrer"
                         style="width:42px;height:42px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#333;"
                         onerror="this.style.display='none'">
                    <div style="flex:1;min-width:0;">
                        <div id="ytLookupName" style="font-weight:600;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
                        <div id="ytLookupId" style="display:none;"></div>
                    </div>
                    <button class="btn btn-success" onclick="addYtChannel()" style="flex-shrink:0;">
                        <i data-lucide="plus" style="width:14px;height:14px;"></i> <%= t('youtube.add_btn') %>
                    </button>
                </div>
            </div>
        </div>
        <% } else { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="info"></i>
            <span><%- t('youtube.max_reached', { max: maxChannels }) %></span>
        </div>
        <% } %>


        <!-- ── Daftar Channel ─────────────────────────────────────────────── -->
        <div id="ytChannelList">
        <% if (ytChannels.length === 0) { %>
            <div class="settings-card" style="text-align:center;padding:3rem 1.5rem;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:48px;height:48px;color:#FF0000;opacity:.4;display:block;margin:0 auto .75rem;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                <p style="color:var(--text-muted);margin:0;"><%= t('youtube.no_channels') %></p>
            </div>
        <% } else { %>
        <% ytChannels.forEach(function(ytCh) { %>
        <div class="settings-card yt-channel-card" id="ytCard-<%= ytCh.id %>" style="margin-bottom:1.25rem;">

            <!-- Header channel -->
            <div class="yt-card-header" style="display:flex;align-items:center;gap:.85rem;margin-bottom:1rem;">
            <%
                const _sub = websubMeta[ytCh.id] || {};
                const _subStatus = _sub.status;
                const _defVideoMsg = "Hey, **{channel}** just uploaded a new video on YouTube!\nDon't miss it, watch now! 🎉";
                const _defShortMsg = "**{channel}** just posted a new Short!\nCheck out their quick video, don't miss out! ⚡";
                const _defLiveMsg  = "Hey, **{channel}** is **LIVE** on YouTube right now!\nCome join and watch the stream~ 🎉";
                const _ytMockUrl   = 'https://youtube.com/watch?v=dQw4w9WgXcQ';
                const _md = s => (s || '')
                    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                    .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
                    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
                    .replace(/\n/g,'<br>');
                const _ytChName = id => {
                    if (!id) return 'select-channel';
                    const ch = (channels || []).find(c => c.id === id);
                    return ch ? ch.name : 'select-channel';
                };
            %>
                <% if (ytCh.thumbnail) { %>
                <img src="<%= ytCh.thumbnail %>" alt="" class="yt-card-avatar" referrerpolicy="no-referrer"
                     style="width:44px;height:44px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#333;"
                     onerror="this.style.display='none';this.nextElementSibling&&(this.nextElementSibling.style.display='flex')">
                <% } else { %>
                <div class="yt-card-avatar" style="width:44px;height:44px;border-radius:50%;background:#FF0000;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </div>
                <% } %>
                <div style="flex:1;min-width:0;">
                    <div class="yt-card-name" style="font-weight:600;font-size:.98rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= ytCh.name %></div>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.1rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        <%= ytCh.handle || ytCh.id %>
                    </div>
                </div>
                <a href="https://www.youtube.com/channel/<%= ytCh.id %>" target="_blank" class="btn btn-sm" style="flex-shrink:0;" title="<%= t('youtube.btn_open_youtube') %>">
                    <i data-lucide="external-link" style="width:13px;height:13px;"></i>
                </a>
                <button class="btn btn-sm btn-danger" data-id="<%= ytCh.id %>" data-name="<%= ytCh.name.replace(/"/g, '&quot;') %>" onclick="deleteYtChannel(this.dataset.id, this.dataset.name)" style="flex-shrink:0;" title="<%= t('youtube.btn_delete_channel') %>">
                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                </button>
            </div>

            <!-- Tab: Video / Short / Live -->
            <div class="yt-tabs-row" style="margin-bottom:1.1rem;border-bottom:1px solid var(--border);padding-bottom:.75rem;">
                <button class="yt-tab-btn active" onclick="switchYtTab(this,'<%= ytCh.id %>','video')"
                        style="border-radius:20px;font-size:.82rem;font-weight:500;cursor:pointer;border:none;background:rgba(255,0,0,.18);color:#FF0000;transition:all .15s;">
                    <%= t('youtube.tab_video') %>
                </button>
                <button class="yt-tab-btn" onclick="switchYtTab(this,'<%= ytCh.id %>','short')"
                        style="border-radius:20px;font-size:.82rem;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text-muted);transition:all .15s;">
                    <%= t('youtube.tab_short') %>
                </button>
                <button class="yt-tab-btn" onclick="switchYtTab(this,'<%= ytCh.id %>','live')"
                        style="border-radius:20px;font-size:.82rem;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text-muted);transition:all .15s;">
                    <%= t('youtube.tab_live') %>
                </button>
            </div>

            <!-- ── Panel Video ─────────────────────────────────────────────── -->
            <div class="yt-panel" id="ytPanel-<%= ytCh.id %>-video">
            <div class="yt-panel-layout">
                <!-- Form -->
                <div class="yt-form-col">
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="videoEnabled-<%= ytCh.id %>"
                                   <%= ytCh.videoEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('youtube.enable_video') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('common.channel') %></label>
                        <select class="select" id="videoChannel-<%= ytCh.id %>"
                                onchange="updateYtPreview('<%= ytCh.id %>','video')">
                            <option value=""><%= t('common.select_channel') %></option>
                            <% channels.forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= ytCh.videoChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('youtube.additional_msg') %></label>
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('ytVideoPicker-<%= ytCh.id %>',event)"><%= t('youtube.placeholder_btn') %></button>
                                <div class="ph-dropdown" id="ytVideoPicker-<%= ytCh.id %>" style="display:none;"></div>
                            </div>
                        </div>
                        <textarea class="textarea" id="videoMessage-<%= ytCh.id %>" rows="3"
                                  placeholder="<%- t('youtube.msg_ph_video') %>"
                                  oninput="updateYtPreview('<%= ytCh.id %>','video')"><%= ytCh.videoMessage || _defVideoMsg %></textarea>
                    </div>
                    <div class="yt-action-row" style="display:flex;justify-content:flex-end;gap:.5rem;padding-top:.25rem;">
                        <button class="btn btn-secondary" onclick="testYtNotif(this,'<%= ytCh.id %>')">
                            <i data-lucide="send" style="width:14px;height:14px;"></i> <%= t('youtube.test_notif_btn') %>
                        </button>
                    </div>
                </div>
                <!-- Preview -->
                <div class="yt-preview-col">
                    <div class="preview-label"><%= t('common.preview') %></div>
                    <div class="cc-discord-preview" id="ytPrev-<%= ytCh.id %>-video">
                        <div class="cc-dp-channel">
                            <span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>
                            <span class="yt-prev-ch-name"><%= _ytChName(ytCh.videoChannelId) %></span>
                        </div>
                        <div class="cc-dp-msg">
                            <div class="cc-dp-ava">
                                <img src="<%= locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            </div>
                            <div class="cc-dp-right">
                                <div class="cc-dp-name">
                                    <%= locals.botNavName || 'Bot' %>
                                    <span class="cc-dp-app-badge">
                                        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        APP
                                    </span>
                                    <span class="cc-dp-time">Today at 12:00 PM</span>
                                </div>
                                <div class="cc-dp-embed">
                                    <div class="cc-dp-embed-bar yt-prev-pill" style="background:#FF0000;"></div>
                                    <div class="cc-dp-embed-body">
                                        <div class="cc-dp-embed-main">
                                            <div class="cc-dp-embed-content">
                                                <div class="cc-dp-embed-title">
                                                    <a href="<%= _ytMockUrl %>" onclick="return false;" style="color:#00b0f4;text-decoration:none;">📹 <%= ytCh.name %> — New Video!</a>
                                                </div>
                                                <div class="yt-prev-msg yt-prev-desc cc-dp-embed-desc">
                                                    <%- _md(`Hey, **${ytCh.name}** just uploaded a new video on YouTube!\nDon't miss it, watch now! 🎉`) %>
                                                </div>
                                                <div class="yt-prev-msg cc-dp-embed-desc" style="display:none;"></div>
                                                <div style="margin-top:.35rem;">
                                                    <div style="margin-bottom:.3rem;">
                                                        <div class="cc-dp-field-name">🎬 Video Title</div>
                                                        <div class="cc-dp-field-val"><a href="<%= _ytMockUrl %>" onclick="return false;" style="color:#00b0f4;text-decoration:none;">Example Video Title That Will Appear</a></div>
                                                    </div>
                                                    <div>
                                                        <div class="cc-dp-field-name">🔗 Link</div>
                                                        <div class="cc-dp-field-val"><a href="<%= _ytMockUrl %>" onclick="return false;" style="color:#00b0f4;text-decoration:none;">Click Me ▶</a></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <% if (ytCh.thumbnail) { %>
                                            <div class="cc-dp-embed-thumb">
                                                <img src="<%= ytCh.thumbnail %>" referrerpolicy="no-referrer" alt="" onerror="this.closest('.cc-dp-embed-thumb').style.display='none'">
                                            </div>
                                            <% } %>
                                        </div>
                                        <div class="yt-thumb-mock" style="margin-top:.5rem;">
                                            <div class="yt-thumb-mock-inner">
                                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z"/></svg>
                                            </div>
                                        </div>
                                        <div class="cc-dp-embed-footer">
                                            <span>📹 YouTube Video</span>
                                            <span class="cc-dp-footer-sep"> • </span>
                                            <span>Today at 12:00 PM</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            </div>

            <!-- ── Panel Short ─────────────────────────────────────────────── -->
            <div class="yt-panel" id="ytPanel-<%= ytCh.id %>-short" style="display:none;">
            <div class="yt-panel-layout">
                <div class="yt-form-col">
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="shortEnabled-<%= ytCh.id %>"
