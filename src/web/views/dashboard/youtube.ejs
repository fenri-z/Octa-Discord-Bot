<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
/* ── YouTube Notifications — Preview ────────────────────────────────────── */

/* 2-kolom: form kiri | preview kanan */
.yt-panel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
}
@media (max-width: 860px) {
    .yt-panel-layout { grid-template-columns: 1fr; }
    .yt-preview-col  { position: static; }
    /* Stats: 2 kolom di tablet */
    .yt-stats-grid   { grid-template-columns: 1fr 1fr !important; }
    .yt-stats-grid .stat-card { min-width: 0; }
    .yt-stats-grid .stat-info { min-width: 0; overflow: hidden; }
    .yt-stats-grid .stat-label { white-space: normal; line-height: 1.3; }
}

.yt-preview-col { position: sticky; top: calc(var(--navbar-h, 56px) + 1rem); }
.preview-label  {
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: .5rem;
}

/* Discord window mock */
.dc-window {
    background: #313338; border-radius: 8px; overflow: hidden;
    font-family: 'gg sans','Noto Sans','Helvetica Neue',Arial,sans-serif;
    font-size: 14px; color: #dbdee1;
    box-shadow: 0 4px 20px rgba(0,0,0,.5);
}
.dc-channel-bar {
    background: #2b2d31; padding: .45rem .85rem;
    border-bottom: 1px solid #1e1f22;
    display: flex; align-items: center; gap: .35rem;
    font-size: .82rem; font-weight: 600; color: #dbdee1;
}
.dc-channel-hash { color: #80848e; font-size: 1rem; }
.dc-messages    { padding: .85rem; }
.dc-message     { display: flex; gap: .65rem; }
.dc-avatar      { width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0; object-fit: cover; }
.dc-msg-body    { flex: 1; min-width: 0; }
.dc-username    { font-weight: 600; color: #fff; font-size: .85rem; }
.dc-timestamp   { font-size: .66rem; color: #80848e; margin-left: .45rem; }
.dc-plain-msg   {
    margin-top: .3rem; font-size: .82rem; color: #dbdee1;
    line-height: 1.45; word-break: break-word; white-space: pre-wrap; max-width: 420px;
}
.dc-embed {
    display: flex; background: #2b2d31; border-radius: 4px;
    margin-top: .3rem; overflow: hidden; max-width: 420px;
}
.dc-embed-pill   { width: 4px; flex-shrink: 0; background: #5865f2; }
.dc-embed-inner  { padding: .55rem .7rem; flex: 1; min-width: 0; }
.dc-embed-author {
    font-size: .75rem; color: #dbdee1; font-weight: 600;
    margin-bottom: .25rem; display: flex; align-items: center; gap: .3rem;
}
.dc-embed-title  { font-size: .88rem; font-weight: 700; color: #00b0f4; word-break: break-word; }
.dc-embed-title:empty { display: none; }

/* YouTube thumbnail placeholder */
.yt-thumb-mock {
    margin-top: .5rem; border-radius: 4px; overflow: hidden;
    background: #1a1a1a; aspect-ratio: 16/9; max-width: 100%;
    display: flex; align-items: center; justify-content: center;
    position: relative;
}
.yt-thumb-mock-inner {
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,0,0,.85);
    display: flex; align-items: center; justify-content: center; z-index: 1;
}
.yt-thumb-mock-inner svg { width: 16px; height: 16px; fill: #fff; margin-left: 2px; }

/* ── YouTube Notifications — Responsive ─────────────────────────────────── */

/* Tab buttons: selalu 3 kolom rata */
.yt-tabs-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: .4rem;
}
.yt-tabs-row .yt-tab-btn {
    text-align: center;
    padding: .38rem .4rem !important;
    white-space: nowrap;
}

/* ── Tablet (≤ 680px) ─────────────────────────────────────────────────── */
@media (max-width: 680px) {
    /* Kurangi padding halaman */
    .dash-main {
        padding: 1.25rem 1rem 1.5rem !important;
    }
    .settings-card { padding: 1rem !important; }

    /* Stats: 2 kolom, cegah overflow dengan min-width: 0 */
    .yt-stats-grid {
        grid-template-columns: 1fr 1fr !important;
        gap: .5rem !important;
    }
    /* Kritis: flex children butuh min-width:0 agar bisa menyusut */
    .yt-stats-grid .stat-card {
        min-width: 0;
        padding: .85rem .75rem;
        gap: .55rem;
    }
    .yt-stats-grid .stat-info {
        min-width: 0;
        overflow: hidden;
    }
    .yt-stats-grid .stat-label {
        white-space: normal;
        line-height: 1.3;
        word-break: break-word;
    }
}

/* ── Mobile kecil (≤ 480px) ──────────────────────────────────────────── */
@media (max-width: 480px) {
    .dash-main {
        padding: 1rem .75rem 1.5rem !important;
    }

    /* Stats card lebih kompak */
    .yt-stats-grid .stat-card {
        padding: .7rem .6rem;
        gap: .45rem;
    }
    .yt-stats-grid .stat-icon {
        width: 32px !important;
        height: 32px !important;
        border-radius: 8px !important;
        flex-shrink: 0;
    }
    .yt-stats-grid .stat-icon svg {
        width: 14px !important;
        height: 14px !important;
    }
    .yt-stats-grid .stat-value {
        font-size: 1.1rem;
    }
    .yt-stats-grid .stat-label {
        font-size: .63rem;
    }

    /* Channel card header */
    .yt-card-header {
        gap: .55rem !important;
    }
    .yt-card-avatar {
        width: 36px !important;
        height: 36px !important;
        min-width: 36px;
    }
    .yt-card-name {
        font-size: .88rem !important;
    }

    /* Tab button teks lebih kecil */
    .yt-tabs-row .yt-tab-btn {
        font-size: .76rem !important;
        padding: .35rem .3rem !important;
    }
}

/* ── Tombol Test Notif & Simpan responsif ────────────────────────────── */
@media (max-width: 680px) {
    .yt-search-row {
        flex-direction: column !important;
    }
    .yt-search-row .btn {
        width: 100%;
        justify-content: center;
    }
    .yt-action-row {
        flex-direction: column !important;
        justify-content: stretch !important;
    }
    .yt-action-row .btn {
        width: 100%;
        justify-content: center;
    }
}

/* ── Lookup result: Add button wraps on very narrow screens ─────────── */
@media (max-width: 380px) {
    .yt-lookup-result-inner {
        flex-wrap: wrap !important;
    }
    .yt-lookup-result-inner .btn {
        width: 100%;
        justify-content: center;
        margin-top: .3rem;
    }
    .dash-main {
        padding: .85rem .6rem 1.5rem !important;
    }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'youtube' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
            <div>
                <h1><%= t('youtube.page_title') %></h1>
                <p><%= t('youtube.page_desc') %></p>
            </div>
            <% if (ytChannels.length > 0) { %>
            <button class="btn btn-secondary" onclick="forcePoll(this)" style="flex-shrink:0;margin-top:.25rem;">
                <i data-lucide="refresh-cw" style="width:14px;height:14px;"></i> <%= t('youtube.poll_now') %>
            </button>
            <% } %>
        </div>


        <!-- ── Stats ─────────────────────────────────────────────────────── -->
        <div class="stats-grid yt-stats-grid" style="margin-bottom:1.5rem;">
            <div class="stat-card">
                <div class="stat-icon" style="color:#FF0000;"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></div>
                <div class="stat-info">
                    <div class="stat-value" id="statChannels"><%= ytChannels.length %></div>
                    <div class="stat-label"><%= t('youtube.stat_monitored') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;"><i data-lucide="video"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= ytChannels.filter(c => c.videoEnabled).length %></div>
                    <div class="stat-label"><%= t('youtube.stat_video_enabled') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#FF6B35;"><i data-lucide="film"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= ytChannels.filter(c => c.shortEnabled).length %></div>
                    <div class="stat-label"><%= t('youtube.stat_short_enabled') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#ED4245;"><i data-lucide="radio"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= ytChannels.filter(c => c.liveEnabled).length %></div>
                    <div class="stat-label"><%= t('youtube.stat_live_enabled') %></div>
                </div>
            </div>
        </div>

        <!-- ── Add Channel ─────────────────────────────────────────────────── -->
        <% if (ytChannels.length < maxChannels) { %>
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;">
                <i data-lucide="plus-circle" style="color:#FF0000;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('youtube.add_title') %></h2>
            </div>
            <p style="font-size:.85rem;color:var(--text-muted);margin:0 0 1rem 0;">
                <%- t('youtube.add_desc', { remaining: maxChannels - ytChannels.length, max: maxChannels }) %>
            </p>
            <div class="form-group" style="margin-bottom:0;">
                <label class="label"><%= t('youtube.search_label') %></label>
                <div class="yt-search-row" style="display:flex;gap:.6rem;">
                    <input type="text" id="ytLookupInput" class="input"
                           placeholder="<%= t('youtube.input_placeholder') %>"
                           style="flex:1;min-width:0;" maxlength="200">
                    <button class="btn btn-primary" onclick="lookupYtChannel()" style="white-space:nowrap;flex-shrink:0;">
                        <i data-lucide="search" style="width:14px;height:14px;"></i> <%= t('youtube.search_btn') %>
                    </button>
                </div>
            </div>
            <!-- Hasil lookup -->
            <div id="ytLookupResult" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border,rgba(255,255,255,.06));">
                <div class="yt-lookup-result-inner" style="display:flex;align-items:center;gap:.75rem;">
                    <img id="ytLookupThumb" src="" alt="" referrerpolicy="no-referrer"
                         style="width:42px;height:42px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#333;"
                         onerror="this.style.display='none'">
                    <div style="flex:1;min-width:0;">
                        <div id="ytLookupName" style="font-weight:600;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
                        <div id="ytLookupId" style="display:none;"></div>
                    </div>
                    <button class="btn btn-success" onclick="addYtChannel()" style="flex-shrink:0;">
                        <i data-lucide="plus" style="width:14px;height:14px;"></i> <%= t('youtube.add_btn') %>
                    </button>
                </div>
            </div>
        </div>
        <% } else { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="info"></i>
            <span><%- t('youtube.max_reached', { max: maxChannels }) %></span>
        </div>
        <% } %>


        <!-- ── Daftar Channel ─────────────────────────────────────────────── -->
        <div id="ytChannelList">
        <% if (ytChannels.length === 0) { %>
            <div class="settings-card" style="text-align:center;padding:3rem 1.5rem;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:48px;height:48px;color:#FF0000;opacity:.4;display:block;margin:0 auto .75rem;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                <p style="color:var(--text-muted);margin:0;"><%= t('youtube.no_channels') %></p>
            </div>
        <% } else { %>
        <% ytChannels.forEach(function(ytCh) { %>
        <div class="settings-card yt-channel-card" id="ytCard-<%= ytCh.id %>" style="margin-bottom:1.25rem;">

            <!-- Header channel -->
            <div class="yt-card-header" style="display:flex;align-items:center;gap:.85rem;margin-bottom:1rem;">
            <%
                const _sub = websubMeta[ytCh.id] || {};
                const _subStatus = _sub.status;
            %>
                <% if (ytCh.thumbnail) { %>
                <img src="<%= ytCh.thumbnail %>" alt="" class="yt-card-avatar" referrerpolicy="no-referrer"
                     style="width:44px;height:44px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#333;"
                     onerror="this.style.display='none';this.nextElementSibling&&(this.nextElementSibling.style.display='flex')">
                <% } else { %>
                <div class="yt-card-avatar" style="width:44px;height:44px;border-radius:50%;background:#FF0000;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </div>
                <% } %>
                <div style="flex:1;min-width:0;">
                    <div class="yt-card-name" style="font-weight:600;font-size:.98rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= ytCh.name %></div>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.1rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        <%= ytCh.handle || ytCh.id %>
                    </div>
                </div>
                <a href="https://www.youtube.com/channel/<%= ytCh.id %>" target="_blank" class="btn btn-sm" style="flex-shrink:0;" title="<%= t('youtube.btn_open_youtube') %>">
                    <i data-lucide="external-link" style="width:13px;height:13px;"></i>
                </a>
                <button class="btn btn-sm" onclick="resetLastVideo('<%= ytCh.id %>')" style="flex-shrink:0;" title="<%= t('youtube.btn_reset_position') %>">
                    <i data-lucide="rotate-ccw" style="width:13px;height:13px;"></i>
                </button>
                <button class="btn btn-sm btn-danger" data-id="<%= ytCh.id %>" data-name="<%= ytCh.name.replace(/"/g, '&quot;') %>" onclick="deleteYtChannel(this.dataset.id, this.dataset.name)" style="flex-shrink:0;" title="<%= t('youtube.btn_delete_channel') %>">
                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                </button>
            </div>

            <!-- Tab: Video / Short / Live -->
            <div class="yt-tabs-row" style="margin-bottom:1.1rem;border-bottom:1px solid var(--border,rgba(255,255,255,.06));padding-bottom:.75rem;">
                <button class="yt-tab-btn active" onclick="switchYtTab(this,'<%= ytCh.id %>','video')"
                        style="border-radius:20px;font-size:.82rem;font-weight:500;cursor:pointer;border:none;background:rgba(255,0,0,.18);color:#FF0000;transition:all .15s;">
                    <%= t('youtube.tab_video') %>
                </button>
                <button class="yt-tab-btn" onclick="switchYtTab(this,'<%= ytCh.id %>','short')"
                        style="border-radius:20px;font-size:.82rem;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text-muted);transition:all .15s;">
                    <%= t('youtube.tab_short') %>
                </button>
                <button class="yt-tab-btn" onclick="switchYtTab(this,'<%= ytCh.id %>','live')"
                        style="border-radius:20px;font-size:.82rem;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--text-muted);transition:all .15s;">
                    <%= t('youtube.tab_live') %>
                </button>
            </div>

            <!-- ── Panel Video ─────────────────────────────────────────────── -->
            <div class="yt-panel" id="ytPanel-<%= ytCh.id %>-video">
            <div class="yt-panel-layout">
                <!-- Form -->
                <div class="yt-form-col">
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="videoEnabled-<%= ytCh.id %>"
                                   <%= ytCh.videoEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('youtube.enable_video') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('common.channel') %></label>
                        <select class="select" id="videoChannel-<%= ytCh.id %>"
                                onchange="updateYtPreview('<%= ytCh.id %>','video')">
                            <option value=""><%= t('common.select_channel') %></option>
                            <% channels.forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= ytCh.videoChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('youtube.additional_msg') %> <span style="font-weight:400;color:var(--text-muted);">(<%= t('giveaway.required_role_hint') %>)</span></label>
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('ytVideoPicker-<%= ytCh.id %>',event)"><%= t('youtube.placeholder_btn') %></button>
                                <div class="ph-dropdown" id="ytVideoPicker-<%= ytCh.id %>" style="display:none;"></div>
                            </div>
                        </div>
                        <textarea class="textarea" id="videoMessage-<%= ytCh.id %>" rows="3"
                                  placeholder="<%- t('youtube.msg_ph_video') %>"
                                  oninput="updateYtPreview('<%= ytCh.id %>','video')"><%= ytCh.videoMessage %></textarea>
                    </div>
                    <div class="yt-action-row" style="display:flex;justify-content:flex-end;gap:.5rem;padding-top:.25rem;">
                        <button class="btn btn-secondary" onclick="testYtNotif(this,'<%= ytCh.id %>')">
                            <i data-lucide="send" style="width:14px;height:14px;"></i> <%= t('youtube.test_notif_btn') %>
                        </button>
                        <button class="btn btn-primary" onclick="saveYtSettings('<%= ytCh.id %>')">
                            <i data-lucide="save" style="width:14px;height:14px;"></i> <%= t('common.save') %>
                        </button>
                    </div>
                </div>
                <!-- Preview -->
                <div class="yt-preview-col">
                    <div class="preview-label"><%= t('common.preview') %></div>
                    <%- include('../partials/yt-preview-mock', { ytCh, type: 'video', botNavAvatar: locals.botNavAvatar, botNavName: locals.botNavName }) %>
                </div>
            </div>
            </div>

            <!-- ── Panel Short ─────────────────────────────────────────────── -->
            <div class="yt-panel" id="ytPanel-<%= ytCh.id %>-short" style="display:none;">
            <div class="yt-panel-layout">
                <div class="yt-form-col">
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="shortEnabled-<%= ytCh.id %>"
                                   <%= ytCh.shortEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('youtube.enable_short') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('common.channel') %></label>
                        <select class="select" id="shortChannel-<%= ytCh.id %>"
                                onchange="updateYtPreview('<%= ytCh.id %>','short')">
                            <option value=""><%= t('common.select_channel') %></option>
                            <% channels.forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= ytCh.shortChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('youtube.additional_msg') %> <span style="font-weight:400;color:var(--text-muted);">(<%= t('giveaway.required_role_hint') %>)</span></label>
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('ytShortPicker-<%= ytCh.id %>',event)"><%= t('youtube.placeholder_btn') %></button>
                                <div class="ph-dropdown" id="ytShortPicker-<%= ytCh.id %>" style="display:none;"></div>
                            </div>
                        </div>
                        <textarea class="textarea" id="shortMessage-<%= ytCh.id %>" rows="3"
                                  placeholder="<%- t('youtube.msg_ph_short') %>"
                                  oninput="updateYtPreview('<%= ytCh.id %>','short')"><%= ytCh.shortMessage %></textarea>
                    </div>
                    <div class="yt-action-row" style="display:flex;justify-content:flex-end;gap:.5rem;padding-top:.25rem;">
                        <button class="btn btn-secondary" onclick="testYtNotif(this,'<%= ytCh.id %>')">
                            <i data-lucide="send" style="width:14px;height:14px;"></i> <%= t('youtube.test_notif_btn') %>
                        </button>
                        <button class="btn btn-primary" onclick="saveYtSettings('<%= ytCh.id %>')">
                            <i data-lucide="save" style="width:14px;height:14px;"></i> <%= t('common.save') %>
                        </button>
                    </div>
                </div>
                <div class="yt-preview-col">
                    <div class="preview-label"><%= t('common.preview') %></div>
                    <%- include('../partials/yt-preview-mock', { ytCh, type: 'short', botNavAvatar: locals.botNavAvatar, botNavName: locals.botNavName }) %>
                </div>
            </div>
            </div>

            <!-- ── Panel Live ──────────────────────────────────────────────── -->
            <div class="yt-panel" id="ytPanel-<%= ytCh.id %>-live" style="display:none;">
            <div class="yt-panel-layout">
                <div class="yt-form-col">
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="liveEnabled-<%= ytCh.id %>"
                                   <%= ytCh.liveEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('youtube.enable_live') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('common.channel') %></label>
                        <select class="select" id="liveChannel-<%= ytCh.id %>"
                                onchange="updateYtPreview('<%= ytCh.id %>','live')">
                            <option value=""><%= t('common.select_channel') %></option>
                            <% channels.forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= ytCh.liveChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('youtube.additional_msg') %> <span style="font-weight:400;color:var(--text-muted);">(<%= t('giveaway.required_role_hint') %>)</span></label>
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('ytLivePicker-<%= ytCh.id %>',event)"><%= t('youtube.placeholder_btn') %></button>
                                <div class="ph-dropdown" id="ytLivePicker-<%= ytCh.id %>" style="display:none;"></div>
                            </div>
                        </div>
                        <textarea class="textarea" id="liveMessage-<%= ytCh.id %>" rows="3"
                                  placeholder="<%- t('youtube.msg_ph_live') %>"
                                  oninput="updateYtPreview('<%= ytCh.id %>','live')"><%= ytCh.liveMessage %></textarea>
                    </div>
                    <div class="yt-action-row" style="display:flex;justify-content:flex-end;gap:.5rem;padding-top:.25rem;">
                        <button class="btn btn-secondary" onclick="testYtNotif(this,'<%= ytCh.id %>')">
                            <i data-lucide="send" style="width:14px;height:14px;"></i> <%= t('youtube.test_notif_btn') %>
                        </button>
                        <button class="btn btn-primary" onclick="saveYtSettings('<%= ytCh.id %>')">
                            <i data-lucide="save" style="width:14px;height:14px;"></i> <%= t('common.save') %>
                        </button>
                    </div>
                </div>
                <div class="yt-preview-col">
                    <div class="preview-label"><%= t('common.preview') %></div>
                    <%- include('../partials/yt-preview-mock', { ytCh, type: 'live', botNavAvatar: locals.botNavAvatar, botNavName: locals.botNavName }) %>
                </div>
            </div>
            </div>

        </div><!-- /yt-channel-card -->
        <% }) %>
        <% } %>
        </div><!-- /ytChannelList -->

    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<%- include('../partials/footer') %>

<script>
const GUILD_ID               = '<%- guild.id %>';
const I18N_YT_CONFIRM_DELETE = <%- JSON.stringify(t("youtube.confirm_delete")) %>;
const I18N_YT_CONFIRM_RESET  = <%- JSON.stringify(t("youtube.confirm_reset")) %>;
const I18N_YT_ERR_INPUT      = <%- JSON.stringify(t("youtube.err_enter_input")) %>;
const I18N_YT_ERR_CONN       = <%- JSON.stringify(t("youtube.err_connection")) %>;
const I18N_YT_SENDING        = <%- JSON.stringify(t("youtube.sending")) %>;
const I18N_YT_POLLING        = <%- JSON.stringify(t("youtube.polling")) %>;
const I18N_YT_DEF_VIDEO      = <%- JSON.stringify(t("youtube.default_video_desc")) %>;
const I18N_YT_DEF_SHORT      = <%- JSON.stringify(t("youtube.default_short_desc")) %>;
const I18N_YT_DEF_LIVE       = <%- JSON.stringify(t("youtube.default_live_desc")) %>;
const I18N_YT_PH_CHANNEL     = <%- JSON.stringify(t("youtube.ph_channel_desc")) %>;
const I18N_YT_PH_TITLE       = <%- JSON.stringify(t("youtube.ph_title_desc")) %>;
const I18N_YT_PH_URL         = <%- JSON.stringify(t("youtube.ph_url_desc")) %>;
const I18N_YT_PH_ID          = <%- JSON.stringify(t("youtube.ph_id_desc")) %>;

// ── Lookup & Tambah Channel ────────────────────────────────────────────────────
let _lookupData = null;

async function lookupYtChannel() {
    const input = document.getElementById('ytLookupInput').value.trim();
    if (!input) return showMsg(null, I18N_YT_ERR_INPUT, 'error');

    const resultEl = document.getElementById('ytLookupResult');
    resultEl.style.display = 'none';
    _lookupData = null;

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/lookup`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input }),
        });
        const data = await r.json();
        if (!data.success) return showMsg(null, data.message, 'error');

        _lookupData = data.channel;
        document.getElementById('ytLookupName').textContent = data.channel.name;
        document.getElementById('ytLookupId').textContent   = data.channel.id;
        const thumb = document.getElementById('ytLookupThumb');
        thumb.src = data.channel.thumbnail || '';
        thumb.style.display = data.channel.thumbnail ? '' : 'none';
        resultEl.style.display = '';
        if (window.lucide) lucide.createIcons();
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    }
}

async function addYtChannel() {
    if (!_lookupData) return;
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/channels`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(_lookupData),
        });
        const data = await r.json();
        if (data.success) {
            showMsg(null, data.message, 'success');
            setTimeout(() => location.reload(), 900);
        } else {
            showMsg(null, data.message, 'error');
        }
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    }
}

// ── Tab switch ─────────────────────────────────────────────────────────────────
function switchYtTab(btn, chId, tab) {
    const card = document.getElementById(`ytCard-${chId}`);
    card.querySelectorAll('.yt-panel').forEach(p => p.style.display = 'none');
    card.querySelectorAll('.yt-tab-btn').forEach(b => {
        b.style.background = 'transparent';
        b.style.color      = 'var(--text-muted)';
    });
    document.getElementById(`ytPanel-${chId}-${tab}`).style.display = '';
    btn.style.background = tab === 'video' ? 'rgba(255,0,0,.18)' :
                           tab === 'short' ? 'rgba(255,107,53,.18)' : 'rgba(204,0,0,.18)';
    btn.style.color      = tab === 'video' ? '#FF0000' :
                           tab === 'short' ? '#FF6B35' : '#CC0000';
    updateYtPreview(chId, tab);
}

// ── Discord Markdown renderer ──────────────────────────────────────────────────
function discordMd(raw) {
    if (!raw) return '';
    let s = raw
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    // Block headers (harus sebelum bold/italic)
    s = s.replace(/^### (.+)$/gm, '<span style="font-size:.88em;font-weight:700;line-height:1.6;display:block">$1</span>');
    s = s.replace(/^## (.+)$/gm,  '<span style="font-size:1em;font-weight:700;line-height:1.75;display:block">$1</span>');
    s = s.replace(/^# (.+)$/gm,   '<span style="font-size:1.15em;font-weight:700;line-height:2;display:block">$1</span>');

    // Bold + italic
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    // Bold
    s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    // Italic
    s = s.replace(/\*([^*\n]+?)\*/g, '<em>$1</em>');
    s = s.replace(/_([^_\n]+?)_/g,   '<em>$1</em>');
    // Underline
    s = s.replace(/__([^_\n]+?)__/g, '<u>$1</u>');
    // Strikethrough
    s = s.replace(/~~(.+?)~~/g, '<s>$1</s>');
    // Inline code
    s = s.replace(/`([^`]+)`/g, '<code style="background:rgba(255,255,255,.07);padding:0 4px;border-radius:3px;font-size:.83em;font-family:monospace">$1</code>');
    // URLs sebagai link
    s = s.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color:#00b0f4;text-decoration:none">$1</a>');
    // Blockquote
    s = s.replace(/^&gt; (.+)$/gm, '<span style="border-left:3px solid #4e5058;padding-left:.5em;color:#b5bac1;display:block">$1</span>');
    // Line breaks
    s = s.replace(/\n/g, '<br>');

    return s;
}

// ── Preview update ─────────────────────────────────────────────────────────────
function updateYtPreview(chId, type) {
    const prevEl = document.getElementById(`ytPrev-${chId}-${type}`);
    if (!prevEl) return;

    // Channel Discord name
    const chSelect = document.getElementById(`${type}Channel-${chId}`);
    const chName   = chSelect?.selectedIndex > 0
        ? (chSelect.options[chSelect.selectedIndex].textContent || 'pilih-channel')
        : 'pilih-channel';
    prevEl.querySelector('.yt-prev-ch-name').textContent = chName;

    // Custom message dengan Discord markdown
    const ytChName  = document.querySelector(`#ytCard-${chId} .yt-card-name`)?.textContent?.trim() || 'Channel';
    const msgArea   = document.getElementById(`${type}Message-${chId}`);
    const customEl  = prevEl.querySelector('.yt-prev-msg:not(.yt-prev-desc)');
    const defaultEl = prevEl.querySelector('.yt-prev-desc');
    const rawMsg    = msgArea?.value?.trim() || '';

    const defaultDescs = {
        video: I18N_YT_DEF_VIDEO.replace('{ytChName}', ytChName),
        short: I18N_YT_DEF_SHORT.replace('{ytChName}', ytChName),
        live:  I18N_YT_DEF_LIVE.replace('{ytChName}', ytChName),
    };

    if (rawMsg) {
        const filled = rawMsg
            .replace(/{channel}/g, ytChName)
            .replace(/{title}/g,   'Example Video Title')
            .replace(/{url}/g,     'https://youtube.com/watch?v=dQw4w9WgXcQ')
            .replace(/{id}/g,      'dQw4w9WgXcQ');
        if (customEl)  { customEl.innerHTML = discordMd(filled); customEl.style.display = ''; }
        if (defaultEl) defaultEl.style.display = 'none';
    } else {
        if (customEl)  customEl.style.display = 'none';
        if (defaultEl) { defaultEl.innerHTML = defaultDescs[type] || ''; defaultEl.style.display = ''; }
    }

    // Update warna pill sesuai tipe
    const pillColors = { video: '#FF0000', short: '#FF6B35', live: '#CC0000' };
    const pill = prevEl.querySelector('.yt-prev-pill');
    if (pill) pill.style.background = pillColors[type] || '#5865F2';
}

// ── Test Notifikasi ────────────────────────────────────────────────────────────
async function testYtNotif(btn, chId) {
    // Tentukan tipe dari panel yang sedang aktif
    const card = document.getElementById(`ytCard-${chId}`);
    let type   = 'video';
    card.querySelectorAll('.yt-panel').forEach(p => {
        if (p.style.display !== 'none') {
            if (p.id.endsWith('-short')) type = 'short';
            else if (p.id.endsWith('-live')) type = 'live';
            else type = 'video';
        }
    });

    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `<i data-lucide="loader" style="width:13px;height:13px;"></i> ${I18N_YT_SENDING}`;
    if (window.lucide) lucide.createIcons();

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/channels/${chId}/test`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ type }),
        });
        const data = await r.json();
        showMsg(null, data.message, data.success ? 'success' : 'error');
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    } finally {
        btn.disabled  = false;
        btn.innerHTML = orig;
        if (window.lucide) lucide.createIcons();
    }
}

// Init preview untuk semua channel card yang sudah ada saat halaman load
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.yt-channel-card').forEach(card => {
        const chId = card.id.replace('ytCard-', '');
        updateYtPreview(chId, 'video');
    });
});

// ── Save settings ──────────────────────────────────────────────────────────────
async function saveYtSettings(chId) {
    const body = {
        videoEnabled:   document.getElementById(`videoEnabled-${chId}`)?.checked  ?? false,
        videoChannelId: document.getElementById(`videoChannel-${chId}`)?.value    ?? '',
        videoMessage:   document.getElementById(`videoMessage-${chId}`)?.value    ?? '',
        shortEnabled:   document.getElementById(`shortEnabled-${chId}`)?.checked  ?? false,
        shortChannelId: document.getElementById(`shortChannel-${chId}`)?.value    ?? '',
        shortMessage:   document.getElementById(`shortMessage-${chId}`)?.value    ?? '',
        liveEnabled:    document.getElementById(`liveEnabled-${chId}`)?.checked   ?? false,
        liveChannelId:  document.getElementById(`liveChannel-${chId}`)?.value     ?? '',
        liveMessage:    document.getElementById(`liveMessage-${chId}`)?.value     ?? '',
    };

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/channels/${chId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
        });
        const data = await r.json();
        showMsg(null, data.message, data.success ? 'success' : 'error');
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    }
}

// ── Delete channel ─────────────────────────────────────────────────────────────
async function deleteYtChannel(chId, chName) {
    if (!confirm(I18N_YT_CONFIRM_DELETE.replace('{{name}}', chName))) return;
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/channels/${chId}`, { method: 'DELETE' });
        const data = await r.json();
        if (data.success) {
            showMsg(null, data.message, 'success');
            const card = document.getElementById(`ytCard-${chId}`);
            if (card) card.remove();
            const stat = document.getElementById('statChannels');
            if (stat) stat.textContent = Math.max(0, parseInt(stat.textContent) - 1);
            if (!document.querySelector('.yt-channel-card')) setTimeout(() => location.reload(), 900);
        } else {
            showMsg(null, data.message, 'error');
        }
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    }
}

// ── Placeholder picker ─────────────────────────────────────────────────────────
const YT_PLACEHOLDERS = [
    { key: '{channel}', desc: I18N_YT_PH_CHANNEL },
    { key: '{title}',   desc: I18N_YT_PH_TITLE },
    { key: '{url}',     desc: I18N_YT_PH_URL },
    { key: '{id}',      desc: I18N_YT_PH_ID },
];
document.querySelectorAll('.ph-dropdown[id^="ytVideo"], .ph-dropdown[id^="ytShort"], .ph-dropdown[id^="ytLive"]').forEach(dd => {
    // Tentukan tipe dari prefix ID: ytVideoPicker-* | ytShortPicker-* | ytLivePicker-*
    let type;
    if (dd.id.startsWith('ytVideoPicker')) type = 'video';
    else if (dd.id.startsWith('ytShortPicker')) type = 'short';
    else if (dd.id.startsWith('ytLivePicker'))  type = 'live';
    else return;
    const chId = dd.id.replace(/^yt(Video|Short|Live)Picker-/, '');

    YT_PLACEHOLDERS.forEach(ph => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ph-item';
        btn.innerHTML = `<code>${ph.key}</code><span>${ph.desc}</span>`;
        btn.onclick = () => {
            const textarea = document.getElementById(`${type}Message-${chId}`);
            if (textarea) {
                const s = textarea.selectionStart, e = textarea.selectionEnd;
                textarea.value = textarea.value.slice(0, s) + ph.key + textarea.value.slice(e);
                textarea.selectionStart = textarea.selectionEnd = s + ph.key.length;
                textarea.focus();
            }
            dd.style.display = 'none';
        };
        dd.appendChild(btn);
    });
});

// ── Force Poll ────────────────────────────────────────────────────────────────
async function forcePoll(btn) {
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `<i data-lucide="loader" style="width:13px;height:13px;"></i> ${I18N_YT_POLLING}`;
    if (window.lucide) lucide.createIcons();
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/force-poll`, { method: 'POST' });
        const data = await r.json();
        showMsg(null, data.message, data.success ? 'success' : 'error');
        if (data.success) setTimeout(() => location.reload(), 1500);
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    } finally {
        btn.disabled  = false;
        btn.innerHTML = orig;
        if (window.lucide) lucide.createIcons();
    }
}

// ── Reset Last Video ───────────────────────────────────────────────────────────
async function resetLastVideo(chId) {
    if (!confirm(I18N_YT_CONFIRM_RESET)) return;
    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/youtube/channels/${chId}/reset`, { method: 'POST' });
        const data = await r.json();
        showMsg(null, data.message, data.success ? 'success' : 'error');
    } catch {
        showMsg(null, I18N_YT_ERR_CONN, 'error');
    }
}

// ── Placeholder picker toggle ──────────────────────────────────────────────────
function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    if (wasHidden) el.style.display = 'grid';
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
});

// Enter di input lookup
document.getElementById('ytLookupInput')?.addEventListener('keydown', e => {
    if (e.key === 'Enter') lookupYtChannel();
});
</script>
