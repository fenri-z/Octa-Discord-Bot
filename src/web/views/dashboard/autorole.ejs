async function openEditReactPanel(name) {
    document.getElementById('reactPanelModalTitle').textContent = `Edit Panel: ${name}`;
    document.getElementById('reactPanelOriginalName').value     = name;
    document.getElementById('reactPanelName').value             = name;
    document.getElementById('reactPanelName').disabled          = true;
    document.getElementById('reactPanelMsg').textContent        = '';
    document.getElementById('reactPanelInlineReactions').style.display = '';
    document.getElementById('reactPanelChannelGroup').style.display    = 'none';

    try {
        const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}`);
