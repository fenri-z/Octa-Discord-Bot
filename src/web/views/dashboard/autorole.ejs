                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(2)">2 buttons</button>
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(3)">3 buttons</button>
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(4)">4 buttons</button>
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(5)">5 buttons</button>
            </div>
        </div>
        <div class="form-group">
            <label class="label">Or enter a custom number</label>
