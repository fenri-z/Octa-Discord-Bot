// AUTOROLE JOIN
// ══════════════════════════════════════════════════════════════════════════════
async function saveJoin() {
    const msg           = document.getElementById('joinMsg');
    const allEnabled    = document.getElementById('joinAllEnabled').checked;
    const allRoleId     = document.getElementById('joinAllRole').value;
    const memberEnabled = document.getElementById('joinMemberEnabled').checked;
    const memberRoleId  = document.getElementById('joinMemberRole').value;
    const botEnabled    = document.getElementById('joinBotEnabled').checked;
    const botRoleId     = document.getElementById('joinBotRole').value;
    if (allEnabled    && !allRoleId)    { showAlert('<%- t("autorole.error_join_all_role") %>');    throw new Error(); }
    if (memberEnabled && !memberRoleId) { showAlert('<%- t("autorole.error_join_member_role") %>'); throw new Error(); }
    if (botEnabled    && !botRoleId)    { showAlert('<%- t("autorole.error_join_bot_role") %>');    throw new Error(); }
    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-join`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ allEnabled, allRoleId, memberEnabled, memberRoleId, botEnabled, botRoleId })
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); throw new Error(data.message); }
    showToast(data.message, 'success');
}

