                <button class="btn btn-primary btn-sm" onclick="confirmMultiAddCustom()">Add</button>
            </div>
        </div>
    </div>
    <div class="mb-modal-footer">
        <button class="btn btn-outline" onclick="closeMultiModal()"><%= t('common.cancel') %></button>
    </div>
</div>

<!-- ══════════════════════════════════════
