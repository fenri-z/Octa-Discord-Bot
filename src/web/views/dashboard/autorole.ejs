// AUTOROLE BOOSTER
// ══════════════════════════════════════════════════════════════════════════════
async function saveBooster() {
    const msg             = document.getElementById('boosterMsg');
    const autoroleEnabled = document.getElementById('boosterAutoroleEnabled').checked;
    const autoroleRoleId  = document.getElementById('boosterAutoroleRole').value;
    const autoremoveEnabled = document.getElementById('boosterAutoremoveEnabled').checked;
    if (autoroleEnabled && !autoroleRoleId) { showAlert('<%- t("autorole.error_booster_role") %>'); throw new Error(); }
    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-booster`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ autoroleEnabled, autoroleRoleId, autoremoveEnabled })
    });
    const data = await res.json();
