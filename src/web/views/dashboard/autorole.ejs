<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'autorole' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1>Autorole Join</h1>
            <p>Role automatically assigned when a member or bot joins the server.</p>
        </div>


        <!-- ══════════════════════════════════════
             TAB: AUTOROLE JOIN
        ══════════════════════════════════════ -->
        <div id="tab-join" class="ar-tab-content">
            <div class="settings-card">
                <p class="section-desc">Role automatically assigned when a <strong>member</strong> or <strong>bot</strong> joins the server.</p>

                <!-- Member -->
                <div class="ar-section">
                    <div class="ar-section-title">Member</div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="joinMemberEnabled" class="toggle-input"
                                   <%= joinData.memberEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span>Enable for Members</span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label">Role untuk Member</label>
                        <select id="joinMemberRole" class="select">
                            <option value="">— Select role —</option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= joinData.memberRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="ar-divider"></div>

                <!-- Bot -->
                <div class="ar-section">
                    <div class="ar-section-title">Bot</div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="joinBotEnabled" class="toggle-input"
                                   <%= joinData.botEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span>Enable for Bots</span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label">Role untuk Bot</label>
                        <select id="joinBotRole" class="select">
                            <option value="">— Select role —</option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= joinData.botRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                        <div class="hint">Only roles that can be assigned by the bot are shown.</div>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" onclick="saveJoin()">Save</button>
                </div>
                <div id="joinMsg" class="form-message"></div>
            </div>
        </div>

        <!-- ══════════════════════════════════════
             TAB: AUTOROLE BOOSTER
        ══════════════════════════════════════ -->
        <div id="tab-booster" class="ar-tab-content" style="display:none;">
            <div class="settings-card">
                <p class="section-desc">Role automatically assigned when a member <strong>boosts</strong> the server, and removed wheat mereka <strong>unboost</strong>.</p>

                <div class="ar-section">
                    <div class="ar-section-title">Autorole Booster</div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="boosterAutoroleEnabled" class="toggle-input"
                                   <%= boosterData.autoroleEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span>Enable Autorole Booster</span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label">Role untuk Booster</label>
                        <select id="boosterAutoroleRole" class="select">
                            <option value="">— Select role —</option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= boosterData.autoroleRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="ar-divider"></div>

                <div class="ar-section">
                    <div class="ar-section-title">Autoremove on Unboost</div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="boosterAutoremoveEnabled" class="toggle-input"
                                   <%= boosterData.autoremoveEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span>Automatically remove role when member stops boosting</span>
                        </label>
                        <div class="hint" style="margin-top:.5rem;">If enabled, the booster role will be immediately removed when a member removes their boost.</div>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" onclick="saveBooster()">Save</button>
                </div>
                <div id="boosterMsg" class="form-message"></div>
            </div>
        </div>

        <!-- ══════════════════════════════════════
             TAB: AUTOROLE BUTTON
        ══════════════════════════════════════ -->
        <div id="tab-button" class="ar-tab-content" style="display:none;">

            <!-- Toolbar -->
            <div class="mb-toolbar">
                <button class="btn btn-primary" onclick="openCreatePanel()">＋ New Panel</button>
                <input type="text" class="input mb-search" placeholder="🔍 Cari panel..." oninput="filterPanels(this.value)">
            </div>

            <!-- Layout 2 kolom: list kiri + preview kanan -->
            <div class="ap-page-layout">
            <div class="ap-list-col">

            <!-- Grid panel -->
            <div id="panelGrid">
                <% if (panels.length === 0) { %>
                    <div class="empty-state" id="emptyPanels">
                        <p style="font-size:2rem;margin-bottom:.5rem">🔘</p>
                        <p>No panels yet. Click <strong>＋ New Panel</strong> to create an autorole button panel.</p>
                        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.5rem">
                            Panel juga bisa dibuat lewat Discord dengan perintah
                            <code>/autorole-button create</code>.
                        </p>
                    </div>
                <% } else { %>
                    <% panels.forEach(p => { %>
                    <div class="ar-panel-card" data-name="<%= p.name %>">
                        <div class="ar-panel-header">
                            <span class="ar-panel-name">🔘 <%= p.name %></span>
                            <span class="ar-panel-mode <%= p.mode === 'single' ? 'mode-single' : 'mode-multi' %>">
                                <%= p.mode === 'single' ? '🔘 Single' : '☑️ Multi' %>
                            </span>
                            <% const sentP = sentPanels[p.name]; %>
                            <span class="ar-panel-status <%= sentP ? 'status-sent' : 'status-unsent' %>">
                                <%= sentP ? '📤 Terkirim' : '⏳ Belum dikirim' %>
                            </span>
                        </div>

                        <%
                          const isPlainPanel = p.messageType === 'plain';
                          const embedColor   = p.embedColor || '#5865F2';
                          let previewText = '';
                          if (isPlainPanel) {
                              previewText = p.plainText
                                  ? p.plainText.slice(0, 80) + (p.plainText.length > 80 ? '…' : '')
                                  : '(teks kosong)';
                          } else {
                              previewText = p.embedTitle || (p.embedDescription
                                  ? p.embedDescription.slice(0, 60) + (p.embedDescription.length > 60 ? '…' : '')
                                  : '');
                          }
                        %>
                        <% if (previewText) { %>
                        <div class="ar-panel-embed-preview" style="border-left:3px solid <%= isPlainPanel ? '#8e9297' : embedColor %>;">
                            <span class="ar-panel-embed-text" style="<%= isPlainPanel ? 'color:var(--text-muted);font-style:italic;' : '' %>"><%= previewText %></span>
                            <% if (isPlainPanel) { %><span style="font-size:.7rem;color:var(--text-muted);margin-left:.4rem;"> — Teks Biasa</span><% } %>
                        </div>
                        <% } %>

                        <div class="ar-panel-buttons-preview">
                            <% if (p.buttons && p.buttons.length > 0) { %>
                                <% p.buttons.forEach(btn => { %>
                                    <span class="ar-btn-chip ar-btn-<%= btn.styleKey || '1' %>">
                                        <%= btn.label %>
                                        <span class="ar-btn-role">@<%= roles.find(r => r.id === btn.roleId)?.name || btn.roleId %></span>
                                    </span>
                                <% }) %>
                            <% } else { %>
                                <span style="color:var(--text-muted);font-size:.8rem">No buttons yet</span>
                            <% } %>
                        </div>
                        <div class="ar-panel-actions">
                            <button class="btn btn-outline btn-sm" onclick="openEditPanel('<%= p.name %>')">✏️ Edit Panel</button>
                            <% if (sentP) { %>
                                <a class="btn btn-outline btn-sm"
                                   href="https://discord.com/channels/<%= guild.id %>/<%= sentP.channelId %>/<%= sentP.messageId %>"
                                   target="_blank">🔗 View</a>
                            <% } else { %>
                                <button class="btn btn-outline btn-sm" onclick="openSendPanel('<%= p.name %>')">📨 Send</button>
                            <% } %>
                            <button class="btn btn-sm ar-btn-delete" onclick="deletePanel('<%= p.name %>')"><i data-lucide="trash-2"></i></button>
                        </div>
                    </div>
                    <% }) %>
                <% } %>
            </div><!-- /panelGrid -->
            </div><!-- /ap-list-col -->

            <!-- Preview panel kanan -->
            <div class="ap-preview-panel" id="apPreviewPanel">
                <div class="ap-preview-header">
                    <span class="ap-preview-title" id="apPreviewTitle">Preview</span>
                    <button class="ap-preview-close" onclick="closePreviewPanel()">✕</button>
                </div>
                <div class="ap-preview-body">
                    <div id="apPreviewPlaceholder" class="ap-preview-placeholder">
                        <div style="font-size:1.75rem">👆</div>
                        <div>Click a panel to see preview</div>
                    </div>
                    <div id="apPreviewContent" style="display:none;">
                        <div class="dc-window">
                            <div class="dc-channel-bar">
                                <span class="dc-channel-hash">#</span>
                                <span>preview-channel</span>
                            </div>
                            <div class="dc-messages">
                                <div class="dc-message">
                                    <img class="dc-avatar"
                                         src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                         alt="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                                    <div class="dc-msg-body">
                                        <span class="dc-username"><%- locals.botNavName || 'Bot' %></span>
                                        <span class="dc-timestamp">Today at 12:00 PM</span>
                                        <div id="apPanelPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                        <div class="dc-embed" id="apPanelPreviewEmbed" style="display:none;">
                                            <div class="dc-embed-pill" id="apPanelPreviewPill"></div>
                                            <div class="dc-embed-content">
                                                <div class="dc-embed-title"  id="apPanelPreviewTitle"></div>
                                                <div class="dc-embed-desc"   id="apPanelPreviewDesc"></div>
                                                <img id="apPanelPreviewImage" src="" alt="" style="display:none;max-width:100%;border-radius:4px;margin-top:.5rem;">
                                                <div class="dc-embed-footer" id="apPanelPreviewFooter"></div>
                                            </div>
                                            <img class="dc-embed-thumb" id="apPanelPreviewThumb" src="" alt="" style="display:none;">
                                        </div>
                                        <div id="apPanelPreviewBtns" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.5rem;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            </div><!-- /ap-page-layout -->
        </div><!-- /tab-button -->

        <!-- ══════════════════════════════════════
             TAB: AUTOROLE REACTION
        ══════════════════════════════════════ -->
        <div id="tab-reaction" class="ar-tab-content" style="display:none;">

            <!-- Toolbar -->
            <div class="mb-toolbar">
                <button class="btn btn-primary" onclick="openCreateReactPanel()">＋ New Panel</button>
                <input type="text" class="input mb-search" placeholder="🔍 Cari panel..." oninput="filterReactPanels(this.value)">
            </div>

            <!-- Layout 2 kolom: list kiri + preview kanan -->
            <div class="ap-page-layout">
            <div class="ap-list-col">

            <!-- Grid panel reaction -->
            <div id="reactPanelGrid">
                <% if (reactPanels.length === 0) { %>
                    <div class="empty-state" id="emptyReactPanels">
                        <p style="font-size:2rem;margin-bottom:.5rem">✨</p>
                        <p>No panels yet. Click <strong>＋ New Panel</strong> to create an autorole reaction panel.</p>
                        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.5rem">
                            Panel juga bisa dibuat lewat Discord dengan perintah
                            <code>/autorole-reaction create</code>.
                        </p>
                    </div>
                <% } else { %>
                    <% reactPanels.forEach(p => { %>
                    <div class="ar-panel-card" data-name="<%= p.name %>" data-type="reaction">
                        <div class="ar-panel-header">
                            <span class="ar-panel-name">✨ <%= p.name %></span>
                            <span class="ar-panel-mode <%= p.mode === 'single' ? 'mode-single' : 'mode-multi' %>">
                                <%= p.mode === 'single' ? '🔘 Single' : '☑️ Multi' %>
                            </span>
                            <% const sentRP = sentReactPanels[p.name]; %>
                            <span class="ar-panel-status <%= sentRP ? 'status-sent' : 'status-unsent' %>">
                                <%= sentRP ? '📤 Terkirim' : '⏳ Belum dikirim' %>
                            </span>
                        </div>

                        <%
                          const isPlainRP = p.messageType === 'plain';
                          const embedColorRP = p.embedColor || '#5865F2';
                          let previewTextRP = '';
                          if (isPlainRP) {
                              previewTextRP = p.plainText
                                  ? p.plainText.slice(0, 80) + (p.plainText.length > 80 ? '…' : '')
                                  : '(teks kosong)';
                          } else {
                              previewTextRP = p.embedTitle || (p.embedDescription
                                  ? p.embedDescription.slice(0, 60) + (p.embedDescription.length > 60 ? '…' : '')
                                  : '');
                          }
                        %>
                        <% if (previewTextRP) { %>
                        <div class="ar-panel-embed-preview" style="border-left:3px solid <%= isPlainRP ? '#8e9297' : embedColorRP %>;">
                            <span class="ar-panel-embed-text" style="<%= isPlainRP ? 'color:var(--text-muted);font-style:italic;' : '' %>"><%= previewTextRP %></span>
                            <% if (isPlainRP) { %><span style="font-size:.7rem;color:var(--text-muted);margin-left:.4rem;"> — Teks Biasa</span><% } %>
                        </div>
                        <% } %>

                        <!-- Reaction emoji chips -->
                        <div class="ar-panel-buttons-preview">
                            <% if (p.reactions && p.reactions.length > 0) { %>
                                <% p.reactions.forEach(react => { %>
                                    <span class="ar-react-chip">
                                        <%= react.emoji.includes(':') ? '' : react.emoji %>
                                        <% if (react.emoji.includes(':')) { %><span class="ar-react-custom">:<%= react.emoji.split(':')[0] %>:</span><% } %>
                                        <span class="ar-btn-role">@<%= roles.find(r => r.id === react.roleId)?.name || react.roleId %></span>
                                    </span>
                                <% }) %>
                            <% } else { %>
                                <span style="color:var(--text-muted);font-size:.8rem">No reactions yet</span>
                            <% } %>
                        </div>
                        <div class="ar-panel-actions">
                            <button class="btn btn-outline btn-sm" onclick="openEditReactPanel('<%= p.name %>')">✏️ Edit Panel</button>
                            <% if (sentRP) { %>
                                <a class="btn btn-outline btn-sm"
                                   href="https://discord.com/channels/<%= guild.id %>/<%= sentRP.channelId %>/<%= sentRP.messageId %>"
                                   target="_blank">🔗 Lihat</a>
                            <% } else { %>
                                <button class="btn btn-outline btn-sm" onclick="openSendReactPanel('<%= p.name %>')">📨 Send</button>
                            <% } %>
                            <button class="btn btn-sm ar-btn-delete" onclick="deleteReactPanel('<%= p.name %>')"><i data-lucide="trash-2"></i></button>
                        </div>
                    </div>
                    <% }) %>
                <% } %>
            </div><!-- /reactPanelGrid -->
            </div><!-- /ap-list-col -->

            <!-- Preview panel kanan -->
            <div class="ap-preview-panel" id="apReactPreviewPanel">
                <div class="ap-preview-header">
                    <span class="ap-preview-title" id="apReactPreviewTitle">Preview</span>
                    <button class="ap-preview-close" onclick="closeReactPreviewPanel()">✕</button>
                </div>
                <div class="ap-preview-body">
                    <div id="apReactPreviewPlaceholder" class="ap-preview-placeholder">
                        <div style="font-size:1.75rem">✨</div>
                        <div>Click a panel to see preview</div>
                    </div>
                    <div id="apReactPreviewContent" style="display:none;">
                        <div class="dc-window">
                            <div class="dc-channel-bar">
                                <span class="dc-channel-hash">#</span>
                                <span>preview-channel</span>
                            </div>
                            <div class="dc-messages">
                                <div class="dc-message">
                                    <img class="dc-avatar"
                                         src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                         alt="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                                    <div class="dc-msg-body">
                                        <span class="dc-username"><%- locals.botNavName || 'Bot' %></span>
                                        <span class="dc-timestamp">Today at 12:00 PM</span>
                                        <div id="apReactPanelPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                        <div class="dc-embed" id="apReactPanelPreviewEmbed" style="display:none;">
                                            <div class="dc-embed-pill" id="apReactPanelPreviewPill"></div>
                                            <div class="dc-embed-content">
                                                <div class="dc-embed-title"  id="apReactPanelPreviewTitle"></div>
                                                <div class="dc-embed-desc"   id="apReactPanelPreviewDesc"></div>
                                                <img id="apReactPanelPreviewImage" src="" alt="" style="display:none;max-width:100%;border-radius:4px;margin-top:.5rem;">
                                                <div class="dc-embed-footer" id="apReactPanelPreviewFooter"></div>
                                            </div>
                                            <img class="dc-embed-thumb" id="apReactPanelPreviewThumb" src="" alt="" style="display:none;">
                                        </div>
                                        <!-- Preview reactions -->
                                        <div id="apReactPanelPreviewReacts" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.5rem;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            </div><!-- /ap-page-layout -->
        </div><!-- /tab-reaction -->
    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<!-- Backdrop mobile preview panel (button) -->
<div class="ap-preview-backdrop" id="apPreviewBackdrop" onclick="closePreviewPanel()"></div>
<!-- Backdrop mobile preview panel (reaction) -->
<div class="ap-preview-backdrop" id="apReactPreviewBackdrop" onclick="closeReactPreviewPanel()"></div>

<%- include('../partials/bottom-nav') %>

<!-- ══════════════════════════════════════
     MODAL: Buat / Edit Panel
     (Sinkron dengan modal Discord: title, description, footer + color picker)
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="panelBackdrop" onclick="closePanelModal()"></div>
<div class="mb-modal mb-modal-full" id="panelModal">
    <div class="mb-modal-header">
        <h2 id="panelModalTitle">New Panel</h2>
        <button class="mb-modal-close" onclick="closePanelModal()">✕</button>
    </div>
    <div class="mb-modal-body">
        <input type="hidden" id="panelOriginalName">
        <input type="hidden" id="panelIsSent" value="0">

        <div class="mb-editor-layout">
            <!-- ── Form kiri ── -->
            <div class="mb-editor-form">

                <div class="form-group">
                    <label class="label">Panel Name</label>
                    <input type="text" id="panelName" class="input" placeholder="e.g.: choose-role" maxlength="32">
                    <div class="hint">Hanya huruf, angka, <code>-</code>, <code>_</code> (maks 32 karakter).</div>
                </div>

                <div class="form-group" id="panelChannelGroup">
                    <label class="label">Send to Channel</label>
                    <select id="panelSendChannelInline" class="select">
                        <option value="">— Select channel —</option>
                        <% channels.forEach(c => { %>
                            <option value="<%= c.id %>">#<%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Mode</label>
                    <select id="panelMode" class="select">
                        <option value="multi">☑️ Multi — can select multiple roles</option>
                        <option value="single">🔘 Single — only 1 active role (radio)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Message Type</label>
                    <div style="display:flex;gap:.75rem;">
                        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="panelMessageType" id="panelTypeEmbed" value="embed" checked>
                            <span>Embed</span>
                        </label>
                        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="panelMessageType" id="panelTypePlain" value="plain">
                            <span>Teks Biasa</span>
                        </label>
                    </div>
                </div>

                <!-- Plain text panel -->
                <div id="panelPlainPanel" style="display:none;">
                    <div class="form-group">
                        <label class="label">Plain Text Message</label>
                        <textarea id="panelPlainText" class="textarea" rows="5"
                                  placeholder="Write your message here..."
                                  oninput="updatePanelPreview()"></textarea>
                    </div>
                </div>

                <!-- Embed panel -->
                <div id="panelEmbedPanel">
                <div class="ar-divider"></div>
                <div style="font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.75rem;">Tampilan Embed</div>

                <div class="form-group">
                    <label class="label">Title</label>
                    <input type="text" id="panelEmbedTitle" class="input" placeholder="Example: Choose Your Role"
                           maxlength="256" oninput="updatePanelPreview()">
                </div>

                <div class="form-group">
                    <label class="label">Description</label>
                    <textarea id="panelEmbedDescription" class="textarea" rows="4"
                              placeholder="Describe the buttons here..." maxlength="4000"
                              oninput="updatePanelPreview()"></textarea>
                </div>

                <div class="form-group">
                    <label class="label">Footer</label>
                    <input type="text" id="panelEmbedFooter" class="input" placeholder="Teks di bagian bawah embed..."
                           maxlength="2048" oninput="updatePanelPreview()">
                </div>

                <div class="form-group">
                    <label class="label">Image URL <span class="hint-inline">(below embed, optional)</span></label>
                    <input type="text" id="panelEmbedImage" class="input" placeholder="https://... (type - to remove)"
                           oninput="updatePanelPreview()">
                </div>

                <div class="form-group">
                    <label class="label">Thumbnail URL <span class="hint-inline">(top right, optional)</span></label>
                    <input type="text" id="panelEmbedThumbnail" class="input" placeholder="https://... (type - to remove)"
                           oninput="updatePanelPreview()">
                </div>

                <div class="form-group">
                    <label class="label">Embed Color</label>
                    <div style="display:flex;gap:.75rem;align-items:center;">
                        <input type="color" id="panelColorPicker" value="#5865F2"
                               style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                               oninput="syncPicker('panelEmbedColor','panelColorPicker');updatePanelPreview()">
                        <input type="text" id="panelEmbedColor" class="input" style="max-width:130px;"
                               placeholder="#5865F2" maxlength="7" value="#5865F2"
                               oninput="syncHex('panelEmbedColor','panelColorPicker');updatePanelPreview()">
                    </div>
                </div>

                </div><!-- /panelEmbedPanel -->

            </div>

            <!-- ── Preview kanan ── -->
            <div class="mb-editor-preview">
                <div class="preview-label">Preview</div>
                <div class="dc-window">
                    <div class="dc-channel-bar">
                        <span class="dc-channel-hash">#</span>
                        <span>preview-channel</span>
                    </div>
                    <div class="dc-messages">
                        <div class="dc-message">
                            <img class="dc-avatar" src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="dc-msg-body">
                                <span class="dc-username" style="color:<%- locals.botNavColor || '#ffffff' %>"><%- locals.botNavName || 'Bot' %></span>
                                <span class="dc-timestamp">Today at 12:00 PM</span>
                                <!-- Plain text preview -->
                                <div id="panelPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                <div class="dc-embed" id="panelPreviewEmbed">
                                    <div class="dc-embed-pill" id="panelPreviewPill"></div>
                                    <div class="dc-embed-content">
                                        <div class="dc-embed-title"  id="panelPreviewTitle"></div>
                                        <div class="dc-embed-desc"   id="panelPreviewDesc"></div>
                                        <img class="dc-embed-image"  id="panelPreviewImage" src="" alt=""
                                             style="display:none;max-width:100%;border-radius:4px;margin-top:.5rem;">
                                        <div class="dc-embed-footer" id="panelPreviewFooter"></div>
                                    </div>
                                    <img class="dc-embed-thumb" id="panelPreviewThumb" src="" alt="" style="display:none;">
                                </div>
                                <!-- Preview tombol dummy -->
                                <div id="panelPreviewBtns" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.5rem;"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="panelPreviewHint" style="margin-top:.75rem;font-size:.78rem;color:var(--text-muted);">
                    💡 Button changes below will be saved together with the embed when you click <strong>Save</strong>.
                </div>
            </div>
        </div>

        <!-- ── Section Tombol (hanya tampil saat buat panel baru) ── -->
        <div id="panelInlineButtons" style="display:none;margin-top:1.25rem;">
            <div class="ar-divider"></div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem;">
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <span style="font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.04em;">🔘 Role Buttons</span>
                    <span id="inlineBtnCounter" style="font-size:.72rem;padding:.15rem .45rem;border-radius:999px;background:var(--bg2);border:1px solid var(--border);color:var(--text-muted);">0/25</span>
                </div>
                <button type="button" class="btn btn-primary btn-sm" onclick="addInlineBtnRow()" style="gap:.3rem;">
                    <span style="font-size:1rem;line-height:1;">＋</span> Add Button
                </button>
            </div>
            <div id="inlineBtnTable"></div>
            <p id="inlineBtnEmpty" style="color:var(--text-muted);font-size:.85rem;padding:.4rem 0;">
                No buttons yet. Click <strong>＋ Add Button</strong> to add one, or skip and add later.
            </p>
        </div>

        <div id="panelMsg" class="form-message" style="margin-top:.75rem;"></div>
    </div>
    <div class="mb-modal-footer">
        <!-- State 1: Form aktif -->
        <div id="panelFooterForm" style="display:flex;gap:.75rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closePanelModal()">Batal</button>
            <button class="btn btn-primary" id="panelSaveBtn" onclick="savePanel()">Save</button>
        </div>
        <!-- State 2: Setelah simpan berhasil, panel belum terkirim -->
        <div id="panelFooterSend" style="display:none;">
            <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;justify-content:space-between;">
                <div style="display:flex;gap:.6rem;align-items:center;flex:1;min-width:200px;">
                    <span style="font-size:.85rem;white-space:nowrap;">📨 Send to:</span>
                    <select id="panelSendChannel" class="select" style="flex:1;">
                        <option value="">— Select channel —</option>
                        <% channels.forEach(c => { %>
                            <option value="<%= c.id %>">#<%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div style="display:flex;gap:.6rem;">
                    <button class="btn btn-outline" onclick="closePanelModal()">Skip</button>
                    <button class="btn btn-primary" onclick="sendAfterSave()">📨 Send</button>
                </div>
            </div>
            <div id="panelSendMsg" class="form-message" style="margin-top:.5rem;"></div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     MODAL: Kelola Tombol (Bulk Editor)
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="btnBackdrop" onclick="closeBtnModal()"></div>
<div class="mb-modal mb-modal-wide" id="btnModal">
    <div class="mb-modal-header">
        <h2>🔘 Manage Buttons — <span id="btnModalPanelName"></span></h2>
        <button class="mb-modal-close" onclick="closeBtnModal()">✕</button>
    </div>
    <div class="mb-modal-body">

        <!-- Tombol aksi atas -->
        <div style="display:flex;gap:.6rem;margin-bottom:1rem;flex-wrap:wrap;align-items:center;">
            <button class="btn btn-primary btn-sm" onclick="addButtonRow()">＋ Add Button</button>
            <button class="btn btn-outline btn-sm" onclick="addMultipleRows()">＋＋ Add Multiple</button>
            <span style="flex:1"></span>
            <span style="font-size:.8rem;color:var(--text-muted)" id="btnCounter"></span>
        </div>

        <!-- Tabel editor tombol (bulk) -->
        <div id="btnEditorTable">
            <!-- Diisi oleh JS -->
        </div>

        <div id="btnMsg" class="form-message" style="margin-top:.75rem;"></div>
    </div>
    <div class="mb-modal-footer">
        <div style="display:flex;gap:.75rem;justify-content:space-between;align-items:center;flex-wrap:wrap;">
            <span style="font-size:.8rem;color:var(--text-muted)">Click "Save All" to save changes.</span>
            <div style="display:flex;gap:.75rem;">
                <button class="btn btn-outline" onclick="closeBtnModal()">Batal</button>
                <button class="btn btn-primary" onclick="saveAllButtons()">💾 Save All</button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     MODAL: Add Multiple Buttons
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="multiBackdrop" onclick="closeMultiModal()"></div>
<div class="mb-modal mb-modal-sm" id="multiModal">
    <div class="mb-modal-header">
        <h2>＋＋ Add Multiple Buttons</h2>
        <button class="mb-modal-close" onclick="closeMultiModal()">✕</button>
    </div>
    <div class="mb-modal-body">
        <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1rem;">
            Select how many buttons to add at once.
        </p>
        <div class="form-group">
            <label class="label">Number of Buttons</label>
            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(2)">2 buttons</button>
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(3)">3 buttons</button>
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(4)">4 buttons</button>
                <button class="btn btn-outline btn-sm multi-count-btn" onclick="confirmMultiAdd(5)">5 buttons</button>
            </div>
        </div>
        <div class="form-group">
            <label class="label">Or enter a custom number</label>
            <div style="display:flex;gap:.5rem;align-items:center;">
                <input type="number" id="multiCustomCount" class="input" min="1" max="25" placeholder="1-25" style="max-width:100px;">
                <button class="btn btn-primary btn-sm" onclick="confirmMultiAddCustom()">Add</button>
            </div>
        </div>
    </div>
    <div class="mb-modal-footer">
        <button class="btn btn-outline" onclick="closeMultiModal()">Batal</button>
    </div>
</div>

<!-- ══════════════════════════════════════
     MODAL: Kirim Panel
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="sendPanelBackdrop" onclick="closeSendPanel()"></div>
<div class="mb-modal mb-modal-sm" id="sendPanelModal">
    <div class="mb-modal-header">
        <h2>📨 Send Panel</h2>
        <button class="mb-modal-close" onclick="closeSendPanel()">✕</button>
    </div>
    <div class="mb-modal-body">
        <p style="margin-bottom:1rem;color:var(--text-muted);font-size:.9rem;">
            Send panel <strong id="sendPanelName"></strong> to channel:
        </p>
        <select id="sendPanelChannel" class="select">
            <option value="">— Select channel —</option>
            <% channels.forEach(c => { %>
                <option value="<%= c.id %>">#<%= c.name %></option>
            <% }) %>
        </select>
        <div class="hint" style="margin-top:.5rem;">
            ⚠️ Panel can only be sent <strong>once</strong>. After sending, use
            <strong>Edit Panel</strong> to update the embed or buttons.
        </div>
        <div id="sendPanelMsg" class="form-message" style="margin-top:.75rem;"></div>
    </div>
    <div class="mb-modal-footer">
        <div style="display:flex;gap:.75rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeSendPanel()">Batal</button>
            <button class="btn btn-primary" onclick="doSendPanel()">Send</button>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     MODAL: Buat / Edit Panel Reaction
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="reactPanelBackdrop" onclick="closeReactPanelModal()"></div>
<div class="mb-modal mb-modal-full" id="reactPanelModal">
    <div class="mb-modal-header">
        <h2 id="reactPanelModalTitle">New Reaction Panel</h2>
        <button class="mb-modal-close" onclick="closeReactPanelModal()">✕</button>
    </div>
    <div class="mb-modal-body">
        <input type="hidden" id="reactPanelOriginalName">

        <div class="mb-editor-layout">
            <!-- ── Form kiri ── -->
            <div class="mb-editor-form">

                <div class="form-group">
                    <label class="label">Panel Name</label>
                    <input type="text" id="reactPanelName" class="input" placeholder="e.g.: choose-role" maxlength="32">
                    <div class="hint">Letters, numbers, <code>-</code>, <code>_</code> only (max 32 chars).</div>
                </div>

                <div class="form-group" id="reactPanelChannelGroup">
                    <label class="label">Send to Channel</label>
                    <select id="reactPanelSendChannelInline" class="select">
                        <option value="">— Select channel —</option>
                        <% channels.forEach(c => { %>
                            <option value="<%= c.id %>">#<%= c.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Mode</label>
                    <select id="reactPanelMode" class="select">
                        <option value="multi">☑️ Multi — can select multiple roles</option>
                        <option value="single">🔘 Single — only 1 active role (radio)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Message Type</label>
                    <div style="display:flex;gap:.75rem;">
                        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="reactPanelMessageType" id="reactPanelTypeEmbed" value="embed" checked>
                            <span>Embed</span>
                        </label>
                        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="reactPanelMessageType" id="reactPanelTypePlain" value="plain">
                            <span>Teks Biasa</span>
                        </label>
                    </div>
                </div>

                <div id="reactPanelPlainPanel" style="display:none;">
                    <div class="form-group">
                        <label class="label">Plain Text Message</label>
                        <textarea id="reactPanelPlainText" class="textarea" rows="5"
                                  placeholder="Write your message here..."
                                  oninput="updateReactPanelPreview()"></textarea>
                    </div>
                </div>

                <div id="reactPanelEmbedPanel">
                <div class="ar-divider"></div>
                <div style="font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.75rem;">Tampilan Embed</div>

                <div class="form-group">
                    <label class="label">Judul</label>
                    <input type="text" id="reactPanelEmbedTitle" class="input" placeholder="Example: Choose Your Role"
                           maxlength="256" oninput="updateReactPanelPreview()">
                </div>
                <div class="form-group">
                    <label class="label">Deskripsi</label>
                    <textarea id="reactPanelEmbedDescription" class="textarea" rows="4"
                              placeholder="Jelaskan cara menggunakan reaction di sini..." maxlength="4000"
                              oninput="updateReactPanelPreview()"></textarea>
                </div>
                <div class="form-group">
                    <label class="label">Footer</label>
                    <input type="text" id="reactPanelEmbedFooter" class="input" placeholder="Teks di bagian bawah embed..."
                           maxlength="2048" oninput="updateReactPanelPreview()">
                </div>
                <div class="form-group">
                    <label class="label">URL Gambar <span class="hint-inline">(bawah embed, opsional)</span></label>
                    <input type="text" id="reactPanelEmbedImage" class="input" placeholder="https://... (type - to remove)"
                           oninput="updateReactPanelPreview()">
                </div>
                <div class="form-group">
                    <label class="label">URL Thumbnail <span class="hint-inline">(pojok kanan, opsional)</span></label>
                    <input type="text" id="reactPanelEmbedThumbnail" class="input" placeholder="https://... (type - to remove)"
                           oninput="updateReactPanelPreview()">
                </div>
                <div class="form-group">
                    <label class="label">Embed Color</label>
                    <div style="display:flex;gap:.75rem;align-items:center;">
                        <input type="color" id="reactPanelColorPicker" value="#5865F2"
                               style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                               oninput="syncPicker('reactPanelEmbedColor','reactPanelColorPicker');updateReactPanelPreview()">
                        <input type="text" id="reactPanelEmbedColor" class="input" style="max-width:130px;"
                               placeholder="#5865F2" maxlength="7" value="#5865F2"
                               oninput="syncHex('reactPanelEmbedColor','reactPanelColorPicker');updateReactPanelPreview()">
                    </div>
                </div>
                </div><!-- /reactPanelEmbedPanel -->

            </div>

            <!-- ── Preview kanan ── -->
            <div class="mb-editor-preview">
                <div class="preview-label">Preview</div>
                <div class="dc-window">
                    <div class="dc-channel-bar">
                        <span class="dc-channel-hash">#</span>
                        <span>preview-channel</span>
                    </div>
                    <div class="dc-messages">
                        <div class="dc-message">
                            <img class="dc-avatar" src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="dc-msg-body">
                                <span class="dc-username" style="color:<%- locals.botNavColor || '#ffffff' %>"><%- locals.botNavName || 'Bot' %></span>
                                <span class="dc-timestamp">Today at 12:00 PM</span>
                                <div id="reactPanelPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                <div class="dc-embed" id="reactPanelPreviewEmbed">
                                    <div class="dc-embed-pill" id="reactPanelPreviewPill"></div>
                                    <div class="dc-embed-content">
                                        <div class="dc-embed-title"  id="reactPanelPreviewTitle"></div>
                                        <div class="dc-embed-desc"   id="reactPanelPreviewDesc"></div>
                                        <img class="dc-embed-image"  id="reactPanelPreviewImage" src="" alt=""
                                             style="display:none;max-width:100%;border-radius:4px;margin-top:.5rem;">
                                        <div class="dc-embed-footer" id="reactPanelPreviewFooter"></div>
                                    </div>
                                    <img class="dc-embed-thumb" id="reactPanelPreviewThumb" src="" alt="" style="display:none;">
                                </div>
                                <!-- Preview reactions dummy -->
                                <div id="reactPanelPreviewReacts" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.5rem;"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="margin-top:.75rem;font-size:.78rem;color:var(--text-muted);">
                    💡 Reaction changes below will be saved together with the embed when you click <strong>Save</strong>.
                </div>
            </div>
        </div>

        <!-- ── Section Reactions ── -->
        <div id="reactPanelInlineReactions" style="display:none;margin-top:1.25rem;">
            <div class="ar-divider"></div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem;">
                <div style="display:flex;align-items:center;gap:.5rem;">
                    <span style="font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.04em;">✨ Emoji Reactions</span>
                    <span id="inlineReactCounter" style="font-size:.72rem;padding:.15rem .45rem;border-radius:999px;background:var(--bg2);border:1px solid var(--border);color:var(--text-muted);">0/20</span>
                </div>
                <button type="button" class="btn btn-primary btn-sm" onclick="addInlineReactRow()" style="gap:.3rem;">
                    <span style="font-size:1rem;line-height:1;">＋</span> Add Reaction
                </button>
            </div>
            <div id="inlineReactTable"></div>
            <div id="inlineReactEmpty" style="text-align:center;padding:1.5rem 1rem;color:var(--text-muted);border:2px dashed var(--border);border-radius:10px;margin:.5rem 0;">
                <div style="font-size:2rem;margin-bottom:.4rem;">✨</div>
                <div style="font-size:.85rem;">No reactions yet. Click <strong style="color:var(--text);">＋ Add Reaction</strong> to addtuk menambahkan.</div>
            </div>
            <div style="margin-top:.75rem;padding:.6rem .75rem;background:rgba(88,101,242,.08);border-radius:8px;border:1px solid rgba(88,101,242,.2);font-size:.78rem;color:var(--text-muted);line-height:1.6;">
                💡 <strong style="color:var(--text);">Tips:</strong>
                Gunakan emoji unicode seperti <span style="font-size:1rem;">👍 🎮 ⭐ 🎭</span> atau emoji kustom server dengan format <code style="background:var(--bg3);padding:1px 4px;border-radius:3px;">&lt;:nama:id&gt;</code>.
                Maks <strong style="color:var(--text);">20 reaction</strong> per panel.
            </div>
        </div>

        <div id="reactPanelMsg" class="form-message" style="margin-top:.75rem;"></div>
    </div>
    <div class="mb-modal-footer">
        <div id="reactPanelFooterForm" style="display:flex;gap:.75rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeReactPanelModal()">Batal</button>
            <button class="btn btn-primary" id="reactPanelSaveBtn" onclick="saveReactPanel()">Save</button>
        </div>
        <div id="reactPanelFooterSend" style="display:none;">
            <div style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;justify-content:space-between;">
                <div style="display:flex;gap:.6rem;align-items:center;flex:1;min-width:200px;">
                    <span style="font-size:.85rem;white-space:nowrap;">📨 Send to:</span>
                    <select id="reactPanelSendChannel" class="select" style="flex:1;">
                        <option value="">— Select channel —</option>
                        <% channels.forEach(c => { %>
                            <option value="<%= c.id %>">#<%= c.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div style="display:flex;gap:.6rem;">
                    <button class="btn btn-outline" onclick="closeReactPanelModal()">Skip</button>
                    <button class="btn btn-primary" onclick="sendReactAfterSave()">📨 Send</button>
                </div>
            </div>
            <div id="reactPanelSendMsg" class="form-message" style="margin-top:.5rem;"></div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════
     MODAL: Kirim Panel Reaction
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="sendReactPanelBackdrop" onclick="closeSendReactPanel()"></div>
<div class="mb-modal mb-modal-sm" id="sendReactPanelModal">
    <div class="mb-modal-header">
        <h2>📨 Send Reaction Panel</h2>
        <button class="mb-modal-close" onclick="closeSendReactPanel()">✕</button>
    </div>
    <div class="mb-modal-body">
        <p style="margin-bottom:1rem;color:var(--text-muted);font-size:.9rem;">
            Kirim panel <strong id="sendReactPanelName"></strong> ke channel:
        </p>
        <select id="sendReactPanelChannel" class="select">
            <option value="">— Select channel —</option>
            <% channels.forEach(c => { %>
                <option value="<%= c.id %>">#<%= c.name %></option>
            <% }) %>
        </select>
        <div class="hint" style="margin-top:.5rem;">
            ⚠️ Panel hanya bisa dikirim <strong>1 kali</strong>. Setelah terkirim, gunakan
            <strong>Edit Panel</strong> untuk memperbarui embed atau reaction.
        </div>
        <div id="sendReactPanelMsg" class="form-message" style="margin-top:.75rem;"></div>
    </div>
    <div class="mb-modal-footer">
        <div style="display:flex;gap:.75rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeSendReactPanel()">Batal</button>
            <button class="btn btn-primary" onclick="doSendReactPanel()">Send</button>
        </div>
    </div>
</div>

<style>
/* ── Tabs ── */
.ar-tabs { display:flex; gap:.5rem; margin-bottom:1.25rem; flex-wrap:wrap; }
.ar-tab {
    padding:.5rem 1.25rem; border-radius:var(--radius);
    background:var(--bg2); border:1px solid var(--border);
    color:var(--text-muted); cursor:pointer; font-size:.9rem;
    transition:all .15s;
}
.ar-tab:hover { border-color:var(--accent); color:var(--text); }
.ar-tab.active { background:var(--accent); border-color:var(--accent); color:#fff; font-weight:600; }

/* ── Section divider ── */
.ar-section { margin-bottom:.5rem; }
.ar-section-title { font-weight:600; font-size:.9rem; color:var(--text-muted); margin-bottom:.75rem; text-transform:uppercase; letter-spacing:.04em; }
.ar-divider { border:none; border-top:1px solid var(--border); margin:1.25rem 0; }
.section-desc { color:var(--text-muted); font-size:.875rem; margin-bottom:1.25rem; }
.hint-inline { font-size:.78rem; color:var(--text-muted); font-weight:400; }

/* ── Panel card ── */
.ar-panel-card {
    background:var(--bg2); border:1px solid var(--border);
    border-radius:var(--radius); padding:1rem 1.1rem;
    margin-bottom:.75rem; transition:border-color .15s;
}
.ar-panel-card:hover { border-color:var(--accent); }
.ar-panel-header { display:flex; align-items:center; gap:.6rem; flex-wrap:wrap; margin-bottom:.5rem; }
.ar-panel-name { font-weight:600; font-size:.95rem; }
.ar-panel-mode, .ar-panel-status {
    font-size:.72rem; padding:.2rem .5rem; border-radius:999px; white-space:nowrap;
}
.mode-single { background:rgba(254,231,92,.15); color:#FEE75C; }
.mode-multi  { background:rgba(87,242,135,.15); color:#57F287; }
.status-sent   { background:rgba(87,242,135,.15); color:#57F287; }
.status-unsent { background:var(--bg3); color:var(--text-muted); }

/* Embed preview strip on card */
.ar-panel-embed-preview {
    padding:.35rem .6rem; margin-bottom:.6rem;
    background:var(--bg3); border-radius:4px;
}
.ar-panel-embed-text { font-size:.82rem; color:var(--text); }

.ar-panel-buttons-preview { display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:.75rem; min-height:1.5rem; }
.ar-btn-chip {
    font-size:.75rem; padding:.2rem .55rem; border-radius:6px;
    display:flex; align-items:center; gap:.35rem;
}
