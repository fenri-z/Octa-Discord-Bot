// AUTOROLE REACTION — PANEL MODAL (Buat / Edit)
// ══════════════════════════════════════════════════════════════════════════════

function updateReactPanelPreview() {
    const plainEl  = document.getElementById('rpModalPreviewPlain');
    const embedEl  = document.getElementById('rpModalPreviewEmbed');
    const emptyEl  = document.getElementById('rpModalPreviewEmpty');

    // Plain text block — always update independently
    const rawText   = document.getElementById('reactPanelPlainText').value;
    const plainHtml = rawText.trim() ? resolveHtmlMentions(mdToHtml(rawText)) : '';
    plainEl.innerHTML     = plainHtml;
    plainEl.style.display = plainHtml ? 'block' : 'none';

    // Embed block — always update independently
    const title      = document.getElementById('reactPanelEmbedTitle').value;
    const desc       = document.getElementById('reactPanelEmbedDescription').value;
    const footer     = document.getElementById('reactPanelEmbedFooter').value;
    const footerIcon = document.getElementById('reactPanelEmbedFooterIcon')?.value.trim() || '';
    const image      = document.getElementById('reactPanelEmbedImage').value.trim();
    const thumb      = document.getElementById('reactPanelEmbedThumbnail').value.trim();
    const color      = document.getElementById('reactPanelEmbedColor').value || '#5865F2';
    const authorName = document.getElementById('reactPanelEmbedAuthorName')?.value.trim() || '';
    const authorUrl  = document.getElementById('reactPanelEmbedAuthorUrl')?.value.trim()  || '';
    const authorIcon = document.getElementById('reactPanelEmbedAuthorIcon')?.value.trim() || '';
    const titleUrl   = document.getElementById('reactPanelEmbedTitleUrl')?.value.trim()   || '';
    const timestamp  = document.getElementById('reactPanelEmbedTimestamp')?.checked        || false;

    const validUrl = v => v && v !== '-' && /^https?:\/\/.+\..+/.test(v);
    const hasEmbedContent = !!(title || desc || footer || validUrl(image) || validUrl(thumb) || authorName || rpEmbedFields.length || timestamp);

    embedEl.style.display = hasEmbedContent ? 'flex' : 'none';

    if (hasEmbedContent) {
        document.getElementById('rpModalPreviewPill').style.background = color;

        // Author
        const authorEl = document.getElementById('rpModalPreviewAuthor');
        if (authorEl) {
            if (authorName) {
                const iconHtml = validUrl(authorIcon) ? `<img src="${authorIcon}" style="width:16px;height:16px;border-radius:50%;margin-right:.3rem;vertical-align:middle;" onerror="this.style.display='none'">` : '';
                const link = validUrl(authorUrl) ? `<a href="${authorUrl}" target="_blank" style="color:inherit;">${escHtml(authorName)}</a>` : escHtml(authorName);
                authorEl.innerHTML = iconHtml + link;
                authorEl.style.display = '';
            } else { authorEl.style.display = 'none'; }
        }

        // Title — Discord embed titles do not support emoji or mentions, render as plain markdown only
        const titleEl = document.getElementById('rpModalPreviewTitle');
        if (titleEl) {
            if (title) {
                titleEl.innerHTML = validUrl(titleUrl)
                    ? `<a href="${titleUrl}" target="_blank" style="color:#00b0f4;">${mdToHtml(title)}</a>`
                    : mdToHtml(title);
                titleEl.style.display = '';
            } else { titleEl.style.display = 'none'; }
        }

        // Description
        const descEl = document.getElementById('rpModalPreviewDesc');
        if (descEl) {
            if (desc) { descEl.innerHTML = resolveHtmlMentions(mdToHtml(desc)); descEl.style.display = ''; }
            else { descEl.style.display = 'none'; }
        }

        // Fields
        const fieldsEl = document.getElementById('rpModalPreviewFields');
        if (fieldsEl) {
            if (rpEmbedFields.length) {
                fieldsEl.innerHTML = rpEmbedFields.filter(f => f.name || f.value).map(f =>
                    `<div class="dc-embed-field${f.inline ? ' inline' : ''}">
                        <div class="dc-embed-field-name">${escHtml(f.name)}</div>
                        <div class="dc-embed-field-value">${resolveHtmlMentions(mdToHtml(f.value))}</div>
                    </div>`
                ).join('');
                fieldsEl.style.display = '';
            } else { fieldsEl.style.display = 'none'; }
        }

        // Thumbnail
        const thumbWrap = document.getElementById('rpModalPreviewThumb');
        const thumbImg  = document.getElementById('rpModalPreviewThumbImg');
        if (thumbWrap && thumbImg) {
            if (validUrl(thumb)) { thumbImg.src = thumb; thumbWrap.style.display = ''; }
            else { thumbImg.src = ''; thumbWrap.style.display = 'none'; }
        }

        // Image
        const imgWrap = document.getElementById('rpModalPreviewImage');
        const imgImg  = document.getElementById('rpModalPreviewImageImg');
        if (imgWrap && imgImg) {
            if (validUrl(image)) { imgImg.src = image; imgWrap.style.display = ''; }
            else { imgImg.src = ''; imgWrap.style.display = 'none'; }
        }

        // Footer
        const footerEl = document.getElementById('rpModalPreviewFooter');
        if (footerEl) {
            if (footer || timestamp) {
                const iconHtml = validUrl(footerIcon) ? `<img src="${footerIcon}" style="width:16px;height:16px;border-radius:50%;margin-right:.3rem;vertical-align:middle;" onerror="this.style.display='none'">` : '';
                const ts = timestamp ? new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
                const sep = footer && ts ? ' · ' : '';
                footerEl.innerHTML = iconHtml + escHtml(footer) + sep + ts;
                footerEl.style.display = '';
            } else { footerEl.style.display = 'none'; }
        }
    }

    if (emptyEl) emptyEl.style.display = (plainHtml || hasEmbedContent) ? 'none' : '';
    updateReactPanelPreviewReacts();
}

function _fillReactPanelForm(panel) {
    const el = id => document.getElementById(id);
    el('reactPanelEmbedTitle').value       = panel.embedTitle       || '';
    el('reactPanelEmbedDescription').value = panel.embedDescription || '';
    el('reactPanelEmbedFooter').value      = panel.embedFooter      || '';
    el('reactPanelEmbedImage').value       = panel.embedImage       || '';
    el('reactPanelEmbedThumbnail').value   = panel.embedThumbnail   || '';
    if (el('reactPanelEmbedAuthorName'))  el('reactPanelEmbedAuthorName').value  = panel.embedAuthorName  || '';
    if (el('reactPanelEmbedAuthorUrl'))   el('reactPanelEmbedAuthorUrl').value   = panel.embedAuthorUrl   || '';
    if (el('reactPanelEmbedAuthorIcon'))  el('reactPanelEmbedAuthorIcon').value  = panel.embedAuthorIcon  || '';
    if (el('reactPanelEmbedTitleUrl'))    el('reactPanelEmbedTitleUrl').value    = panel.embedTitleUrl    || '';
    if (el('reactPanelEmbedFooterIcon'))  el('reactPanelEmbedFooterIcon').value  = panel.embedFooterIcon  || '';
    if (el('reactPanelEmbedTimestamp'))   el('reactPanelEmbedTimestamp').checked = !!panel.embedTimestamp;
    rpEmbedFields = Array.isArray(panel.embedFields) ? panel.embedFields.map(f => ({...f})) : [];
    renderRpFields();
    const color = panel.embedColor && /^#[0-9A-Fa-f]{6}$/.test(panel.embedColor) ? panel.embedColor : '#5865F2';
    el('reactPanelEmbedColor').value  = color;
    el('reactPanelColorPicker').value = color;
    const reactModeEl = el('reactPanelMode');
    reactModeEl.value = panel.mode || 'multi';
    reactModeEl.dispatchEvent(new Event('change'));
    el('reactPanelPlainText').value = panel.plainText || '';
    apUpdateCount('reactPanelEmbedAuthorName',  'reactAuthorNameCount');
    apUpdateCount('reactPanelEmbedTitle',       'reactTitleCount');
    apUpdateCount('reactPanelEmbedDescription', 'reactDescCount');
    apUpdateCount('reactPanelEmbedFooter',      'reactFooterCount');
    apUpdateCount('reactPanelPlainText',        'reactPlainCount');
    updateReactPanelPreview();
    apResizeAll();
}

function _resetReactPanelForm() {
    const el = id => document.getElementById(id);
    // Enable selects first so value changes are reflected visually
    setCselDisabled(el('reactPanelMode'), false);
    setCselDisabled(el('reactSendPreviewChannel'), false);
    el('reactPanelName').value             = '';
    el('reactPanelEmbedTitle').value       = '';
    el('reactPanelEmbedDescription').value = '';
    el('reactPanelEmbedFooter').value      = '';
    el('reactPanelEmbedImage').value       = '';
    el('reactPanelEmbedThumbnail').value   = '';
    el('reactPanelEmbedColor').value       = '#5865F2';
    el('reactPanelColorPicker').value      = '#5865F2';
    el('reactPanelMode').value             = 'multi';
    el('reactPanelMode').dispatchEvent(new Event('change'));
    el('reactSendPreviewChannel').value    = '';
    el('reactSendPreviewChannel').dispatchEvent(new Event('change'));
    el('reactPanelMsg').textContent        = '';
    el('reactPanelPlainText').value        = '';
    if (el('reactPanelEmbedAuthorName'))  el('reactPanelEmbedAuthorName').value  = '';
    if (el('reactPanelEmbedAuthorUrl'))   el('reactPanelEmbedAuthorUrl').value   = '';
    if (el('reactPanelEmbedAuthorIcon'))  el('reactPanelEmbedAuthorIcon').value  = '';
    if (el('reactPanelEmbedTitleUrl'))    el('reactPanelEmbedTitleUrl').value    = '';
    if (el('reactPanelEmbedFooterIcon'))  el('reactPanelEmbedFooterIcon').value  = '';
    if (el('reactPanelEmbedTimestamp'))   el('reactPanelEmbedTimestamp').checked = false;
    rpEmbedFields = [];
    renderRpFields();
    apUpdateCount('reactPanelEmbedAuthorName',  'reactAuthorNameCount');
    apUpdateCount('reactPanelEmbedTitle',       'reactTitleCount');
    apUpdateCount('reactPanelEmbedDescription', 'reactDescCount');
    apUpdateCount('reactPanelEmbedFooter',      'reactFooterCount');
    apUpdateCount('reactPanelPlainText',        'reactPlainCount');
    _inlineReacts = [];
    renderInlineReactTable();
    updateReactPanelPreview();
}

function _showReactPanelFooter(state) {
    document.getElementById('reactPanelFooterForm').style.display = 'flex';
}

function openCreateReactPanel() {
    _editingReactPanelName   = '';
    _editingReactPanelIsSent = false;
    _editingReactPanelSentChannelId = '';
    _editingReactPanelSentMsgId = '';
    document.getElementById('reactPanelModalTitle').textContent        = '<%= t("autorole.new_react_panel_title") %>';
    document.getElementById('reactPanelCancelEdit').style.display      = 'none';
    document.getElementById('reactPanelOriginalName').value            = '';
    document.getElementById('reactPanelName').disabled                 = false;
    _resetReactPanelForm();
    document.getElementById('reactPanelInlineReactions').style.display = '';
    document.getElementById('reactPanelChannelGroup').style.display    = '';
    document.getElementById('reactSendPreviewChannel').value           = '';
    document.getElementById('reactSendPreviewChannel').disabled        = false;
    document.getElementById('reactPanelBtnSend').style.display         = '';
    document.getElementById('reactPanelBtnReset').style.display        = 'none';
    updateReactPanelPreviewChannel();
    _showReactPanelFooter('form');
}

async function openEditReactPanel(name, isSent = false) {
    _editingReactPanelName   = name;
    _editingReactPanelIsSent = isSent;
    document.getElementById('reactPanelModalTitle').textContent        = '<%= t("autorole.edit_panel_title") %>: ' + name;
    document.getElementById('reactPanelCancelEdit').style.display      = '';
    document.getElementById('reactPanelOriginalName').value            = name;
    document.getElementById('reactPanelName').value                    = name;
    document.getElementById('reactPanelName').disabled                 = true;
    document.getElementById('reactPanelMsg').textContent               = '';
    document.getElementById('reactPanelInlineReactions').style.display = '';
    document.getElementById('reactPanelChannelGroup').style.display    = '';
    document.getElementById('reactPanelBtnSend').style.display         = isSent ? 'none' : '';
    document.getElementById('reactPanelBtnReset').style.display        = '';
    document.getElementById('reactSendPreviewChannel').value           = '';
    try {
        const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}`);
        const data = await res.json();
        if (data.success && data.panel) {
            _fillReactPanelForm(data.panel);
            _inlineReacts = (data.panel.reactions || []).map(r => ({ emoji: r.emoji, roleId: r.roleId }));
            renderInlineReactTable();
            const chSelReact   = document.getElementById('reactSendPreviewChannel');
            const modeSelReact = document.getElementById('reactPanelMode');
            const isSentNowR   = !!data.panel.sentChannelId;
            if (isSentNowR) {
                chSelReact.value = data.panel.sentChannelId;
                setCselDisabled(chSelReact, true);
                setCselDisabled(modeSelReact, true);
                document.getElementById('reactPanelBtnSend').style.display = 'none';
                _editingReactPanelSentChannelId = data.panel.sentChannelId || '';
                _editingReactPanelSentMsgId     = data.panel.sentMessageId  || '';
            } else {
                chSelReact.value = data.panel.channelId || '';
                setCselDisabled(chSelReact, false);
                setCselDisabled(modeSelReact, false);
                document.getElementById('reactPanelBtnSend').style.display = '';
                _editingReactPanelSentChannelId = '';
                _editingReactPanelSentMsgId     = '';
            }
            chSelReact.dispatchEvent(new Event('change'));
            updateReactPanelPreviewChannel();
        }
    } catch(e) { console.error(e); }

    _showReactPanelFooter('form');
    document.getElementById('reactPanelFormCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function closeReactPanelModal() {
    openCreateReactPanel();
}

let _savingReactPanel = false;
async function saveReactPanel() {
    if (_savingReactPanel) return;
    _savingReactPanel = true;
    const _reactSaveBtns = [document.getElementById('reactPanelBtnSend'), ...document.querySelectorAll('#reactPanelFooterForm .btn')];
    _reactSaveBtns.forEach(b => b && (b.disabled = true));
    try {
    const msg          = document.getElementById('reactPanelMsg');
    const originalName = document.getElementById('reactPanelOriginalName').value;
    const name         = originalName || document.getElementById('reactPanelName').value.trim().toLowerCase();

    if (!name || !/^[a-zA-Z0-9_-]{1,32}$/.test(name)) {
        showAlert(I18N_AR_ERR_INVALID_NAME); throw new Error();
    }

    if (!originalName) {
        const exists = document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${name}"]`);
        if (exists) { showAlert(I18N_AR_ERR_NAME_EXISTS.replace('{{name}}', name)); throw new Error(); }
    }

    const panelPlainText   = document.getElementById('reactPanelPlainText').value.trim();
    const embedTitle       = document.getElementById('reactPanelEmbedTitle').value.trim();
    const embedDescription = document.getElementById('reactPanelEmbedDescription').value.trim();
    const embedFooter      = document.getElementById('reactPanelEmbedFooter').value.trim();
    const rawImage         = document.getElementById('reactPanelEmbedImage').value.trim();
    const rawThumb         = document.getElementById('reactPanelEmbedThumbnail').value.trim();
    const embedColor       = document.getElementById('reactPanelEmbedColor').value.trim() || '#5865F2';
    const mode             = document.getElementById('reactPanelMode').value;
    const isPlainType      = !!panelPlainText;
    const hasEmbedContent  = !!(embedTitle || embedDescription);

    const urlOk = v => !v || v === '-' || /^https?:\/\/.+\..+/.test(v);
    if (!urlOk(rawImage)) { showAlert(I18N_AR_ERR_IMG_URL); throw new Error(); }
    if (!urlOk(rawThumb)) { showAlert(I18N_AR_ERR_THUMB_URL); throw new Error(); }
    if (!/^#[0-9A-Fa-f]{6}$/.test(embedColor)) { showAlert(I18N_AR_ERR_COLOR); throw new Error(); }

    const reactChannelId = document.getElementById('reactSendPreviewChannel').value;
    if (!reactChannelId) { showAlert(I18N_AR_ERR_NO_CH); throw new Error(); }

    if (!panelPlainText && !embedTitle && !embedDescription) {
        showAlert(I18N_AR_ERR_NO_CONTENT); throw new Error();
    }

    const validReacts = _inlineReacts.filter(r => r.emoji && r.roleId);
    if (validReacts.length === 0) { showAlert(I18N_AR_ERR_NO_REACTIONS); throw new Error(); }

    if (!originalName) {
        if (_reactPanelCount >= 20) { showAlert(I18N_AR_ERR_PANEL_LIMIT); throw new Error(); }
    }

    const rEl = id => document.getElementById(id);

    const _rpEmbedTotal = [
        rEl('reactPanelEmbedAuthorName')?.value.trim(), embedTitle, embedDescription, embedFooter,
        ...rpEmbedFields.filter(f => f.name && f.value).flatMap(f => [f.name, f.value])
    ].reduce((s, v) => s + (v || '').length, 0);
    if (_rpEmbedTotal > 6000) { showAlert(I18N_ERR_EMBED_TOTAL); throw new Error(); }

    const payload = {
        name, mode,
        messageType: isPlainType && hasEmbedContent ? 'both' : isPlainType ? 'plain' : 'embed',
        plainText: panelPlainText,
        channelId: reactChannelId,
        embedTitle, embedDescription, embedFooter, embedColor,
        embedImage:     rawImage === '-' ? '' : rawImage,
        embedThumbnail: rawThumb === '-' ? '' : rawThumb,
        embedAuthorName: rEl('reactPanelEmbedAuthorName')?.value.trim() || '',
        embedAuthorUrl:  rEl('reactPanelEmbedAuthorUrl')?.value.trim()  || '',
        embedAuthorIcon: rEl('reactPanelEmbedAuthorIcon')?.value.trim() || '',
        embedTitleUrl:   rEl('reactPanelEmbedTitleUrl')?.value.trim()   || '',
        embedFooterIcon: rEl('reactPanelEmbedFooterIcon')?.value.trim() || '',
        embedTimestamp:  rEl('reactPanelEmbedTimestamp')?.checked        || false,
        embedFields:     rpEmbedFields.filter(f => f.name && f.value),
    };

    const url = originalName
        ? `/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(originalName)}`
        : `/api/guild/${GUILD_ID}/autorole-reaction`;

    const res  = await fetch(url, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); throw new Error(data.message); }

    // Simpan reactions inline
    const reacts = _inlineReacts.filter(r => r.emoji && r.roleId);
    try {
        await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}/reactions`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reactions: reacts })
        });
    } catch(e) { console.error('Gagal simpan reactions inline:', e); }

    const pendingCh = _pendingReactSendChannel;
    _pendingReactSendChannel = '';
    let sentChId = '', sentMsgId = '';
    if (pendingCh) {
        try {
            const sendRes  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}/send`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ channelId: pendingCh }) });
            const sendData = await sendRes.json();
            if (sendData.success) {
                sentChId  = sendData.channelId || pendingCh;
                sentMsgId = sendData.messageId || '';
                showToast(data.message + ' ✅', 'success');
            } else {
                showAlert(`Send failed: ${sendData.message}`);
                showToast(data.message, 'success');
            }
        } catch { showToast(data.message, 'success'); }
    } else {
        showToast(data.message, 'success');
    }

    // Update or add card in the list
    const rList = document.getElementById('reactPanelGrid');
    const rEmptyEl = document.getElementById('emptyReactPanels');
    const rEffSentChId  = sentChId  || (originalName ? _editingReactPanelSentChannelId : '');
    const rEffSentMsgId = sentMsgId || (originalName ? _editingReactPanelSentMsgId : '');
    const rEffChId = rEffSentChId || payload.channelId;
    const rMode = document.getElementById('reactPanelMode')?.value || 'multi';
    const newReactCard = _arRenderReactCard(name, rEffChId, rMode, rEffSentChId, rEffSentMsgId);
    const rExisting = rList.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${name}"]`);
    if (rExisting) {
        rExisting.replaceWith(newReactCard);
    } else {
        if (rEmptyEl) rEmptyEl.style.display = 'none';
        rList.appendChild(newReactCard);
        _reactPanelCount++;
    }
    if (window.lucide) lucide.createIcons();
    _arRefreshReactStats();

    openCreateReactPanel();
    } catch(e) { /* validation/network errors already shown via showAlert */ }
    finally { _savingReactPanel = false; _reactSaveBtns.forEach(b => b && (b.disabled = false)); }
}

let _editingReactPanelName   = '';
let _editingReactPanelIsSent = false;
let _editingReactPanelSentChannelId = '';
let _editingReactPanelSentMsgId = '';
let _pendingReactSendChannel = '';

async function saveAndSendReactPanel() {
    const channelId = document.getElementById('reactSendPreviewChannel').value;
    if (!channelId) { showAlert(I18N_AR_ERR_NO_CH_FIRST); return; }
    _pendingReactSendChannel = channelId;
    await saveReactPanel();
}

function resetReactPanelToOriginal() {
    if (_editingReactPanelName) openEditReactPanel(_editingReactPanelName, _editingReactPanelIsSent);
}

// ══════════════════════════════════════════════════════════════════════════════
// INLINE REACTION EDITOR
// ══════════════════════════════════════════════════════════════════════════════
let _inlineReacts = [];

function renderInlineReactTable() {
    const table   = document.getElementById('inlineReactTable');
    const empty   = document.getElementById('inlineReactEmpty');
    const counter = document.getElementById('inlineReactCounter');
    if (!table) return;
    counter.textContent = `${_inlineReacts.length}/20`;
    if (_inlineReacts.length === 0) {
        table.innerHTML = '';
        empty.style.display = '';
        return;
    }
    empty.style.display = 'none';
    const header = `
        <div class="react-col-header">
            <span></span><span></span>
            <span>🎭 Role</span>
            <span></span>
        </div>`;
    const rows = _inlineReacts.map((r, i) => {
        const emojiDisplay = _emojiDisplayFromStored(r.emoji);
        const hasEmoji     = !!r.emoji;
        return `
        <div class="react-editor-card" id="inreact-${i}">
            <span class="react-num-badge">${i + 1}</span>
            <div class="react-emoji-bubble ${hasEmoji ? 'has-emoji' : ''}" id="inreact-bubble-${i}"
                 title="${hasEmoji ? 'Click to change emoji' : 'Click to pick emoji'}"
                 onclick="openEmojiPickerForReact(${i}, this)">
                ${hasEmoji ? emojiDisplay : '<span class="react-empty-icon">✨</span>'}
            </div>
            <div class="react-fields">
                <select class="react-select" id="inreact-role-${i}" onchange="updateInlineReact(${i})">
                    <option value="">— Select Role —</option>
                    ${ALL_ROLES.map(role => `<option value="${role.id}" style="color:${role.color}" ${role.id === r.roleId ? 'selected' : ''}>@${role.name}</option>`).join('')}
                </select>
            </div>
            <button class="ar-btn-delete" onclick="removeInlineReact(${i})" title="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            </button>
        </div>`;
    }).join('');
    table.innerHTML = header + rows;
    updateReactPanelPreviewReacts();
}

// Buka emoji picker untuk reaction row ke-i
function openEmojiPickerForReact(i, anchorEl) {
    EmojiPicker.open(anchorEl, function(value, isCustom) {
        _inlineReacts[i].emoji = value;
        const bubble = document.getElementById(`inreact-bubble-${i}`);
        if (bubble) {
            bubble.innerHTML = _emojiDisplayFromStored(value);
            bubble.classList.add('has-emoji');
            bubble.title = 'Click to change emoji';
        }
        updateReactPanelPreviewReacts();
    });
}

// Konversi stored emoji (name:id atau unicode) ke HTML di dalam bubble
function _emojiDisplayFromStored(stored) {
    if (!stored) return '';
    if (stored.includes(':')) {
        const [name, id] = stored.split(':');
        return `<img src="https://cdn.discordapp.com/emojis/${id}.webp?size=64" alt=":${name}:" style="width:30px;height:30px;object-fit:contain;border-radius:4px;" onerror="this.style.display='none'">`;
    }
    const isEmoji = /\p{Emoji}/u.test(stored) && !/^[a-zA-Z0-9\s]+$/.test(stored);
    if (!isEmoji) return `<span style="font-size:1rem;opacity:.4;">?</span>`;
    return stored;
}

function updateInlineReact(i) {
    _inlineReacts[i] = {
        roleId: document.getElementById(`inreact-role-${i}`)?.value || '',
        emoji:  _inlineReacts[i]?.emoji || '',
    };
    document.getElementById('inlineReactCounter').textContent = `${_inlineReacts.length}/20`;
    updateReactPanelPreviewReacts();
}

function addInlineReactRow() {
    if (_inlineReacts.length >= 20) return showAlert(I18N_AR_ERR_MAX_REACTS);
    _inlineReacts.push({ emoji: '', roleId: '' });
    renderInlineReactTable();
    setTimeout(() => { document.getElementById('reactPanelFormCard').scrollIntoView({ behavior: 'smooth', block: 'end' }); }, 50);
}

function removeInlineReact(i) {
    _inlineReacts.splice(i, 1);
    renderInlineReactTable();
}

function updateReactPanelPreviewReacts() {
    const container = document.getElementById('reactPanelPreviewReacts');
    if (!container) return;
    container.innerHTML = _inlineReacts
        .filter(r => r.emoji)
        .map(r => {
            const isCustom = r.emoji.includes(':');
            let display;
            if (isCustom) {
                const [name, id] = r.emoji.split(':');
                display = `<img src="https://cdn.discordapp.com/emojis/${id}.webp?size=32" alt=":${name}:" style="width:18px;height:18px;object-fit:contain;vertical-align:middle;" onerror="this.style.display='none'">`;
            } else {
                display = r.emoji;
            }
            return `<span class="ar-react-chip">${display}</span>`;
        }).join('');
}

async function deleteReactPanel(name) {
    const card   = document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${name}"]`);
    const isSent = card?.dataset.sent === 'true';
    openDeleteConfirm(name, isSent, async () => {
        const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
            if (card) card.remove();
            _reactPanelCount--;
            const full = _reactPanelCount >= 20;
            document.getElementById('arReactLimitBanner').style.display    = 'none';
            document.getElementById('arReactStatTotal').textContent        = _reactPanelCount;
            document.getElementById('arReactStatSlots').textContent        = `${_reactPanelCount}/20`;
            document.getElementById('arReactStatSlots').style.color        = full ? '#ed4245' : '';
            document.getElementById('arReactStatSlotsIcon').className      = `stat-icon${full ? '' : ' stat-icon-comm'}`;
            document.getElementById('arReactStatSlotsIcon').style.cssText  = full ? 'color:#ed4245;background:rgba(237,66,69,.12);' : '';
            if (_reactPanelCount === 0) document.getElementById('emptyReactPanels').style.display = '';
            if (_editingReactPanelName === name) openCreateReactPanel();
            showToast(data.message, 'success');
        } else {
            showAlert(data.message);
        }
    });
}

let _sendReactPanelName = '';
let _sendReactPanelChannelId = '';
function openSendReactPanel(name) {
    const card = document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${name}"]`);
    const channelId = card?.dataset.channelId || '';
    if (!channelId) {
        openEditReactPanel(name, false);
        return;
    }
    _sendReactPanelName      = name;
    _sendReactPanelChannelId = channelId;
    const channelName        = CHANNELS[channelId] || channelId;
    document.getElementById('sendReactPanelName').textContent        = `"${name}"`;
    document.getElementById('sendReactPanelChannelName').textContent = `#${channelName}`;
    document.getElementById('sendReactPanelMsg').textContent         = '';
    openModal('sendReactPanelBackdrop', 'sendReactPanelModal');
}
function closeSendReactPanel() { closeModal('sendReactPanelBackdrop', 'sendReactPanelModal'); }

async function doSendReactPanel() {
    const res = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(_sendReactPanelName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId: _sendReactPanelChannelId })
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); return; }

    const sentChId  = data.channelId || _sendReactPanelChannelId;
    const sentMsgId = data.messageId || '';
    const rList = document.getElementById('reactPanelGrid');
    const rMode = rList.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${_sendReactPanelName}"]`)?.querySelector('.ar-panel-mode')?.textContent?.toLowerCase() || 'multi';
    const newCard = _arRenderReactCard(_sendReactPanelName, sentChId, rMode, sentChId, sentMsgId);
    const rExisting = rList.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${_sendReactPanelName}"]`);
    if (rExisting) { rExisting.replaceWith(newCard); if (window.lucide) lucide.createIcons(); }

    if (_editingReactPanelName === _sendReactPanelName) {
        _editingReactPanelSentChannelId = sentChId;
        _editingReactPanelSentMsgId     = sentMsgId;
        document.getElementById('reactPanelBtnSend').style.display = 'none';
        const chSel = document.getElementById('reactSendPreviewChannel');
        chSel.value = sentChId;
        setCselDisabled(chSel, true);
        setCselDisabled(document.getElementById('reactPanelMode'), true);
    }

    closeSendReactPanel();
    showToast(data.message, 'success');
}

async function saveAllButtons() {
    const msg     = document.getElementById('btnMsg');
    const buttons = collectButtonsFromEditor();

    // Validasi wajib
    for (let i = 0; i < buttons.length; i++) {
        if (!buttons[i].roleId) return showAlert(I18N_AR_BTN_ERR_NO_ROLE.replace('{{n}}', i+1));
        if (!buttons[i].label)  return showAlert(I18N_AR_BTN_ERR_NO_LABEL.replace('{{n}}', i+1));
        if (buttons[i].label.length > 80) return showAlert(I18N_AR_BTN_ERR_LABEL_LNG.replace('{{n}}', i+1));
    }

    // Validasi duplikat
    const seen = {};
    for (let i = 0; i < buttons.length; i++) {
        if (seen[buttons[i].roleId] !== undefined) {
            return showAlert(I18N_AR_BTN_ERR_DUP_ROLE.replace('{{n1}}', seen[buttons[i].roleId]+1).replace('{{n2}}', i+1));
        }
        seen[buttons[i].roleId] = i;
    }

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_btnPanelName)}/buttons`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ buttons })
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); return; }
    _btnData = buttons;
    closeBtnModal();
    showToast(data.message, 'success');
}

async function _arDefaultFloatSave() {
    const tabMap = { join: saveJoin, booster: saveBooster };
    for (const [id, fn] of Object.entries(tabMap)) {
        if (document.getElementById('tab-' + id)?.style.display !== 'none') { await fn(); break; }
    }
}
window._floatSave = _arDefaultFloatSave;

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});
function _buildMentionDd(dd, getTarget) {
    function item(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => {
            const ta = typeof getTarget === 'function' ? getTarget() : getTarget;
            if (!ta) return;
            const s = ta.selectionStart ?? ta.value.length;
            const ep = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, s) + mention + ta.value.slice(ep);
            ta.selectionStart = ta.selectionEnd = s + mention.length;
            ta.focus(); ta.dispatchEvent(new Event('input', {bubbles: true}));
            document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
            document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
        });
        return b;
    }
    function hdr(t) { const h = document.createElement('div'); h.className = 'ph-group-label'; h.textContent = t; return h; }
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => { el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special'));
    dd.appendChild(item('<code>@everyone</code>', '@everyone'));
    dd.appendChild(item('<code>@here</code>', '@here'));
    const rKeys = Object.keys(ROLES_MAP);
    if (rKeys.length) {
        dd.appendChild(hdr('Roles'));
        rKeys.forEach(id => { const r = ROLES_MAP[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`)); });
    }
    const cKeys = Object.keys(CHANNELS);
    if (cKeys.length) {
        dd.appendChild(hdr('Channels'));
        cKeys.forEach(id => { const name = CHANNELS[id]; dd.appendChild(item(`<span>#${name}</span>`, `<#${id}>`)); });
    }
}
_buildMentionDd(document.getElementById('panelPlainMentionPicker'),  () => document.getElementById('panelPlainText'));
_buildMentionDd(document.getElementById('panelEmbedMentionPicker'),  () => document.getElementById('panelEmbedDescription'));
_buildMentionDd(document.getElementById('reactPlainMentionPicker'),  () => document.getElementById('reactPanelPlainText'));
_buildMentionDd(document.getElementById('reactEmbedMentionPicker'),  () => document.getElementById('reactPanelEmbedDescription'));

buildApPhPicker('panelPlainPhPicker',  'panelPlainText');
buildApPhPicker('panelDescPhPicker',   'panelEmbedDescription');
buildApPhPicker('reactPlainPhPicker',  'reactPanelPlainText');
buildApPhPicker('reactDescPhPicker',   'reactPanelEmbedDescription');

