// ══════════════════════════════════════════════════════════════════════════════
// KELOLA TOMBOL — BULK EDITOR
// (style disimpan sebagai integer 1-4, sama dengan ButtonStyle di discord.js)
// ══════════════════════════════════════════════════════════════════════════════
let _btnPanelName = '';
let _btnData      = [];

// Map: value di select → ButtonStyle integer (Primary=1, Secondary=2, Success=3, Danger=4)
const STYLE_OPTIONS = [
    { v: '1', l: '🔵 Biru (Primary)'    },
    { v: '3', l: '🟢 Hijau (Success)'   },
    { v: '4', l: '🔴 Merah (Danger)'    },
    { v: '2', l: '⚪ Abu-abu (Secondary)'},
];

function buildRoleOptions(selectedId = '') {
    return ALL_ROLES.map(r =>
        `<option value="${r.id}" style="color:${r.color}" ${r.id === selectedId ? 'selected' : ''}>@${r.name}</option>`
    ).join('');
}

function buildStyleOptions(selectedVal = '1') {
    return STYLE_OPTIONS.map(o =>
        `<option value="${o.v}" ${String(selectedVal) === o.v ? 'selected' : ''}>${o.l}</option>`
    ).join('');
}

function renderBtnEditorTable() {
    const table   = document.getElementById('btnEditorTable');
    const counter = document.getElementById('btnCounter');
    counter.textContent = `${_btnData.length}/25 buttons`;

    const trashSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`;

    if (_btnData.length === 0) {
        table.innerHTML = `
            <div style="text-align:center;padding:1.5rem 1rem;color:var(--text-muted);border:2px dashed var(--border);border-radius:10px;margin:.5rem 0;">
                <div style="font-size:2rem;margin-bottom:.4rem;">🔘</div>
                <div style="font-size:.85rem;">No buttons yet. Click <strong style="color:var(--text);">＋ Add Button</strong> to addn.</div>
            </div>`;
        return;
    }

    table.innerHTML = _btnData.map((btn, i) => {
        const style    = btn.style || 1;
        const label    = btn.label || '';
        const chipCls  = label ? `style-${style}` : 'style-empty';
        const chipText = label || 'Button label...';
        return `
        <div class="btn-card" id="btnrow-${i}">
            <div class="btn-card-top">
                <span class="btn-num-badge">${i + 1}</span>
                <span class="btn-preview-chip ${chipCls}" id="brow-preview-${i}">${chipText}</span>
                <span style="flex:1;"></span>
                <button class="ar-btn-delete" onclick="removeButtonRow(${i})" title="Delete">${trashSvg}</button>
            </div>
            <div class="btn-card-fields">
                <select class="react-select" id="brow-role-${i}" onchange="checkDuplicateRoles();updateBulkPreview(${i})">
                    <option value="">— Select Role —</option>
                    ${buildRoleOptions(btn.roleId)}
                </select>
                <input type="text" class="react-input" id="brow-label-${i}"
                       value="${label.replace(/"/g, '&quot;')}"
                       placeholder="Button label..." maxlength="80"
                       oninput="updateBulkPreview(${i})">
                <select class="react-select" id="brow-style-${i}" onchange="updateBulkPreview(${i})">
                    ${buildStyleOptions(String(style))}
                </select>
            </div>
        </div>`;
    }).join('');
    setTimeout(checkDuplicateRoles, 0);
}

async function openManageButtons(name) {
    _btnPanelName = name;
    document.getElementById('btnModalPanelName').textContent = name;
    document.getElementById('btnMsg').textContent            = '';
    await refreshBtnData();
    renderBtnEditorTable();
    openModal('btnBackdrop', 'btnModal');
}
function closeBtnModal() { closeModal('btnBackdrop', 'btnModal'); }

async function refreshBtnData() {
    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_btnPanelName)}`);
    const data = await res.json();
    if (!data.success) return;
    _btnData = data.panel.buttons || [];
}

function addButtonRow() {
    if (_btnData.length >= 25) return alert('Panel is full (max 25 buttons).');
    _btnData.push({ roleId: '', label: '', style: 1 });
    renderBtnEditorTable();
    const body = document.getElementById('btnModal').querySelector('.mb-modal-body');
    setTimeout(() => { body.scrollTop = body.scrollHeight; }, 50);
}

function addMultipleRows() { openModal('multiBackdrop', 'multiModal'); }
function closeMultiModal() { closeModal('multiBackdrop', 'multiModal'); }

function confirmMultiAdd(count) {
    closeMultiModal();
    const toAdd = Math.min(count, 25 - _btnData.length);
    for (let i = 0; i < toAdd; i++) _btnData.push({ roleId: '', label: '', style: 1 });
    renderBtnEditorTable();
    const body = document.getElementById('btnModal').querySelector('.mb-modal-body');
    setTimeout(() => { body.scrollTop = body.scrollHeight; }, 50);
}
function confirmMultiAddCustom() {
    const val = parseInt(document.getElementById('multiCustomCount').value);
    if (!val || val < 1 || val > 25) return;
    confirmMultiAdd(val);
}

function removeButtonRow(i) {
    _btnData.splice(i, 1);
    renderBtnEditorTable();
}

function collectButtonsFromEditor() {
    return _btnData.map((_, i) => ({
        roleId: document.getElementById(`brow-role-${i}`)?.value  || '',
        label:  (document.getElementById(`brow-label-${i}`)?.value || '').trim(),
        // style disimpan sebagai integer — sinkron dengan ButtonStyle di discord.js
        style:  parseInt(document.getElementById(`brow-style-${i}`)?.value || '1'),
    }));
}

function updateBulkPreview(i) {
    const label = (document.getElementById(`brow-label-${i}`)?.value || '').trim();
    const style = parseInt(document.getElementById(`brow-style-${i}`)?.value || '1');
    const chip  = document.getElementById(`brow-preview-${i}`);
    if (chip) {
        chip.textContent = label || 'Button label...';
        chip.className   = `btn-preview-chip ${label ? `style-${style}` : 'style-empty'}`;
    }
}

function checkDuplicateRoles() {
    const buttons   = collectButtonsFromEditor();
    const roleCount = {};
    buttons.forEach(b => { if (b.roleId) roleCount[b.roleId] = (roleCount[b.roleId] || 0) + 1; });

    buttons.forEach((b, i) => {
        const card = document.getElementById(`btnrow-${i}`);
        const sel  = document.getElementById(`brow-role-${i}`);
        if (!card || !sel) return;
        const isDup = b.roleId && roleCount[b.roleId] > 1;
        card.classList.toggle('has-duplicate', isDup);
        sel.style.borderColor = isDup ? 'var(--red)' : '';
        sel.title = isDup ? '⚠️ This role is already used by another button' : '';
    });

    const dupCount = Object.values(roleCount).filter(c => c > 1).length;
    const counter  = document.getElementById('btnCounter');
    if (counter) {
        counter.textContent = `${buttons.length}/25 buttons` + (dupCount ? ` · ⚠️ ${dupCount} duplicate(s)` : '');
        counter.style.color = dupCount ? 'var(--red)' : '';
    }
}

