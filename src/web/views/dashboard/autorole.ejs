    showToast(data.message, 'success');
}

// ══════════════════════════════════════════════════════════════════════════════
// AUTOROLE BUTTON — PANEL MODAL
// (Field sinkron: name, mode, embedTitle, embedDescription, embedFooter,
//  embedColor, embedImage, embedThumbnail — sama persis dengan command JS)
// ══════════════════════════════════════════════════════════════════════════════

function updatePanelPreview() {
    const plainEl  = document.getElementById('apModalPreviewPlain');
    const embedEl  = document.getElementById('apModalPreviewEmbed');
    const emptyEl  = document.getElementById('apModalPreviewEmpty');

    // Plain text block — always update independently
    const rawText   = document.getElementById('panelPlainText').value;
    const plainHtml = rawText.trim() ? resolveHtmlMentions(mdToHtml(rawText)) : '';
    plainEl.innerHTML     = plainHtml;
    plainEl.style.display = plainHtml ? 'block' : 'none';

    // Embed block — always update independently
    const title      = document.getElementById('panelEmbedTitle').value;
    const desc       = document.getElementById('panelEmbedDescription').value;
    const footer     = document.getElementById('panelEmbedFooter').value;
    const footerIcon = document.getElementById('panelEmbedFooterIcon')?.value.trim() || '';
    const image      = document.getElementById('panelEmbedImage').value.trim();
    const thumb      = document.getElementById('panelEmbedThumbnail').value.trim();
    const color      = document.getElementById('panelEmbedColor').value || '#5865F2';
    const authorName = document.getElementById('panelEmbedAuthorName')?.value.trim() || '';
    const authorUrl  = document.getElementById('panelEmbedAuthorUrl')?.value.trim() || '';
    const authorIcon = document.getElementById('panelEmbedAuthorIcon')?.value.trim() || '';
    const titleUrl   = document.getElementById('panelEmbedTitleUrl')?.value.trim() || '';
    const timestamp  = document.getElementById('panelEmbedTimestamp')?.checked || false;

    const validUrl = v => v && v !== '-' && /^https?:\/\/.+\..+/.test(v);
    const hasEmbedContent = !!(title || desc || footer || validUrl(image) || validUrl(thumb) || authorName || apEmbedFields.length || timestamp);

    embedEl.style.display = hasEmbedContent ? 'flex' : 'none';

    if (hasEmbedContent) {
        document.getElementById('apModalPreviewPill').style.background = color;

        // Author
        const authorEl = document.getElementById('apModalPreviewAuthor');
        if (authorEl) {
            if (authorName) {
                const iconHtml = validUrl(authorIcon) ? `<img src="${authorIcon}" style="width:16px;height:16px;border-radius:50%;margin-right:.3rem;vertical-align:middle;" onerror="this.style.display='none'">` : '';
                const link = validUrl(authorUrl) ? `<a href="${authorUrl}" target="_blank" style="color:inherit;">${escHtml(authorName)}</a>` : escHtml(authorName);
                authorEl.innerHTML = iconHtml + link;
                authorEl.style.display = '';
            } else { authorEl.style.display = 'none'; }
        }

        // Title — Discord embed titles do not support emoji or mentions, render as plain markdown only
        const titleEl = document.getElementById('apModalPreviewTitle');
        if (titleEl) {
            if (title) {
                titleEl.innerHTML = validUrl(titleUrl)
                    ? `<a href="${titleUrl}" target="_blank" style="color:#00b0f4;">${mdToHtml(title)}</a>`
                    : mdToHtml(title);
                titleEl.style.display = '';
            } else { titleEl.style.display = 'none'; }
        }

        // Description
        const descEl = document.getElementById('apModalPreviewDesc');
        if (descEl) {
            if (desc) { descEl.innerHTML = resolveHtmlMentions(mdToHtml(desc)); descEl.style.display = ''; }
            else { descEl.style.display = 'none'; }
        }

        // Fields
        const fieldsEl = document.getElementById('apModalPreviewFields');
        if (fieldsEl) {
            if (apEmbedFields.length) {
                fieldsEl.innerHTML = apEmbedFields.filter(f => f.name || f.value).map(f =>
                    `<div class="dc-embed-field${f.inline ? ' inline' : ''}">
                        <div class="dc-embed-field-name">${escHtml(f.name)}</div>
                        <div class="dc-embed-field-value">${resolveHtmlMentions(mdToHtml(f.value))}</div>
                    </div>`
                ).join('');
                fieldsEl.style.display = '';
            } else { fieldsEl.style.display = 'none'; }
        }

        // Thumbnail
        const thumbWrap = document.getElementById('apModalPreviewThumb');
        const thumbImg  = document.getElementById('apModalPreviewThumbImg');
        if (thumbWrap && thumbImg) {
            if (validUrl(thumb)) { thumbImg.src = thumb; thumbWrap.style.display = ''; }
            else { thumbImg.src = ''; thumbWrap.style.display = 'none'; }
        }

        // Image
        const imgWrap = document.getElementById('apModalPreviewImage');
        const imgImg  = document.getElementById('apModalPreviewImageImg');
        if (imgWrap && imgImg) {
            if (validUrl(image)) { imgImg.src = image; imgWrap.style.display = ''; }
            else { imgImg.src = ''; imgWrap.style.display = 'none'; }
        }

        // Footer
        const footerEl = document.getElementById('apModalPreviewFooter');
        if (footerEl) {
            if (footer || timestamp) {
                const iconHtml = validUrl(footerIcon) ? `<img src="${footerIcon}" style="width:16px;height:16px;border-radius:50%;margin-right:.3rem;vertical-align:middle;" onerror="this.style.display='none'">` : '';
                const ts = timestamp ? new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';
                const sep = footer && ts ? ' · ' : '';
                footerEl.innerHTML = iconHtml + escHtml(footer) + sep + ts;
                footerEl.style.display = '';
            } else { footerEl.style.display = 'none'; }
        }
    }

    if (emptyEl) emptyEl.style.display = (plainHtml || hasEmbedContent) ? 'none' : '';
    updatePanelPreviewBtns();
}

function _fillPanelForm(panel) {
    document.getElementById('panelEmbedTitle').value       = panel.embedTitle       || '';
    document.getElementById('panelEmbedDescription').value = panel.embedDescription || '';
    document.getElementById('panelEmbedFooter').value      = panel.embedFooter      || '';
    document.getElementById('panelEmbedImage').value       = panel.embedImage       || '';
    document.getElementById('panelEmbedThumbnail').value   = panel.embedThumbnail   || '';

    const el = id => document.getElementById(id);
    if (el('panelEmbedAuthorName'))  el('panelEmbedAuthorName').value  = panel.embedAuthorName  || '';
    if (el('panelEmbedAuthorUrl'))   el('panelEmbedAuthorUrl').value   = panel.embedAuthorUrl   || '';
    if (el('panelEmbedAuthorIcon'))  el('panelEmbedAuthorIcon').value  = panel.embedAuthorIcon  || '';
    if (el('panelEmbedTitleUrl'))    el('panelEmbedTitleUrl').value    = panel.embedTitleUrl    || '';
    if (el('panelEmbedFooterIcon'))  el('panelEmbedFooterIcon').value  = panel.embedFooterIcon  || '';
    if (el('panelEmbedTimestamp'))   el('panelEmbedTimestamp').checked = !!panel.embedTimestamp;

    apEmbedFields = Array.isArray(panel.embedFields) ? panel.embedFields.map(f => ({...f})) : [];
    renderApFields();

    const color = panel.embedColor && /^#[0-9A-Fa-f]{6}$/.test(panel.embedColor)
        ? panel.embedColor : '#5865F2';
    document.getElementById('panelEmbedColor').value  = color;
    document.getElementById('panelColorPicker').value = color;
    const modeEl = document.getElementById('panelMode');
    modeEl.value = panel.mode || 'multi';
    modeEl.dispatchEvent(new Event('change'));
    document.getElementById('panelPlainText').value = panel.plainText || '';
    apUpdateCount('panelEmbedAuthorName', 'panelAuthorNameCount');
    apUpdateCount('panelEmbedTitle',      'panelTitleCount');
    apUpdateCount('panelEmbedDescription','panelDescCount');
    apUpdateCount('panelEmbedFooter',     'panelFooterCount');
    apUpdateCount('panelPlainText',       'panelPlainCount');
    updatePanelPreview();
    apResizeAll();
}

function _resetPanelForm() {
    const el = id => document.getElementById(id);
    // Enable selects first so value changes are reflected visually
    setCselDisabled(el('panelMode'), false);
    setCselDisabled(el('panelSendPreviewChannel'), false);
    el('panelName').value             = '';
    el('panelEmbedTitle').value       = '';
    el('panelEmbedDescription').value = '';
    el('panelEmbedFooter').value      = '';
    el('panelEmbedImage').value       = '';
    el('panelEmbedThumbnail').value   = '';
    el('panelEmbedColor').value       = '#5865F2';
    el('panelColorPicker').value      = '#5865F2';
    el('panelMode').value             = 'multi';
    el('panelMode').dispatchEvent(new Event('change'));
    el('panelSendPreviewChannel').value = '';
    el('panelSendPreviewChannel').dispatchEvent(new Event('change'));
    el('panelMsg').textContent        = '';
    el('panelPlainText').value        = '';
    if (el('panelEmbedAuthorName'))  el('panelEmbedAuthorName').value  = '';
    if (el('panelEmbedAuthorUrl'))   el('panelEmbedAuthorUrl').value   = '';
    if (el('panelEmbedAuthorIcon'))  el('panelEmbedAuthorIcon').value  = '';
    if (el('panelEmbedTitleUrl'))    el('panelEmbedTitleUrl').value    = '';
    if (el('panelEmbedFooterIcon'))  el('panelEmbedFooterIcon').value  = '';
    if (el('panelEmbedTimestamp'))   el('panelEmbedTimestamp').checked = false;
    apEmbedFields = [];
    renderApFields();
    apUpdateCount('panelEmbedAuthorName', 'panelAuthorNameCount');
    apUpdateCount('panelEmbedTitle',      'panelTitleCount');
    apUpdateCount('panelEmbedDescription','panelDescCount');
    apUpdateCount('panelEmbedFooter',     'panelFooterCount');
    apUpdateCount('panelPlainText',       'panelPlainCount');
    _inlineBtns = [];
    renderInlineBtnTable();
    updatePanelPreview();
}

function openCreatePanel() {
    _editingPanelName  = '';
    _editingPanelIsSent = false;
    _editingPanelSentChannelId = '';
    _editingPanelSentMsgId = '';
    document.getElementById('panelModalTitle').textContent = '<%= t("autorole.new_panel_title") %>';
    document.getElementById('panelCancelEdit').style.display               = 'none';
    document.getElementById('panelOriginalName').value                     = '';
    document.getElementById('panelIsSent').value                           = '0';
    document.getElementById('panelName').disabled                          = false;
    _resetPanelForm();
    document.getElementById('panelInlineButtons').style.display            = '';
    document.getElementById('panelPreviewHint').style.display              = 'none';
    document.getElementById('panelChannelGroup').style.display             = '';
    document.getElementById('panelSendPreviewChannel').value               = '';
    document.getElementById('panelSendPreviewChannel').disabled            = false;
    document.getElementById('panelBtnSend').style.display                  = '';
    document.getElementById('panelBtnReset').style.display                 = 'none';
    updatePanelPreviewChannel();
    _showPanelFooter('form');
}

async function openEditPanel(name, isSent = false) {
    _editingPanelName   = name;
    _editingPanelIsSent = isSent;
    document.getElementById('panelModalTitle').textContent   = '<%= t("autorole.edit_panel_title") %>: ' + name;
    document.getElementById('panelCancelEdit').style.display = '';
    document.getElementById('panelOriginalName').value       = name;
    document.getElementById('panelName').value               = name;
    document.getElementById('panelName').disabled            = true;
    document.getElementById('panelMsg').textContent          = '';
    document.getElementById('panelInlineButtons').style.display  = '';
    document.getElementById('panelPreviewHint').style.display    = 'none';
    document.getElementById('panelChannelGroup').style.display   = '';
    document.getElementById('panelBtnSend').style.display        = isSent ? 'none' : '';
    document.getElementById('panelBtnReset').style.display       = '';
    document.getElementById('panelSendPreviewChannel').value     = '';

    try {
        const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}`);
        const data = await res.json();
        if (data.success && data.panel) {
            _fillPanelForm(data.panel);
            _inlineBtns = (data.panel.buttons || []).map(b => ({
                roleId: b.roleId, label: b.label, style: b.style || 1,
            }));
            renderInlineBtnTable();
            const chSelBtn  = document.getElementById('panelSendPreviewChannel');
            const modeSelBtn = document.getElementById('panelMode');
            const isSentNow  = !!data.panel.sentChannelId;
            if (isSentNow) {
                chSelBtn.value = data.panel.sentChannelId;
                setCselDisabled(chSelBtn, true);
                setCselDisabled(modeSelBtn, true);
                document.getElementById('panelBtnSend').style.display = 'none';
                _editingPanelSentChannelId = data.panel.sentChannelId || '';
                _editingPanelSentMsgId     = data.panel.sentMessageId  || '';
            } else {
                chSelBtn.value = data.panel.channelId || '';
                setCselDisabled(chSelBtn, false);
                setCselDisabled(modeSelBtn, false);
                document.getElementById('panelBtnSend').style.display = '';
                _editingPanelSentChannelId = '';
                _editingPanelSentMsgId     = '';
            }
            chSelBtn.dispatchEvent(new Event('change'));
            updatePanelPreviewChannel();
        }
    } catch(e) { console.error(e); }

    _showPanelFooter('form');
    document.getElementById('panelFormCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function closePanelModal() {
    openCreatePanel();
}

function _showPanelFooter(state) {
    document.getElementById('panelFooterForm').style.display = 'flex';
}

let _savingPanel = false;
async function savePanel() {
    if (_savingPanel) return;
    _savingPanel = true;
    const _saveBtns = [document.getElementById('panelBtnSend'), ...document.querySelectorAll('#panelFooterForm .btn')];
    _saveBtns.forEach(b => b && (b.disabled = true));
    try {
    const msg          = document.getElementById('panelMsg');
    const originalName = document.getElementById('panelOriginalName').value;
    const name         = originalName || document.getElementById('panelName').value.trim().toLowerCase();

    if (!name || !/^[a-zA-Z0-9_-]{1,32}$/.test(name)) {
        showAlert(I18N_AR_ERR_INVALID_NAME); throw new Error();
    }

    if (!originalName) {
        const exists = document.querySelector(`.ar-panel-card:not([data-type])[data-name="${name}"]`);
        if (exists) { showAlert(I18N_AR_ERR_NAME_EXISTS.replace('{{name}}', name)); throw new Error(); }
    }

    const panelPlainText   = document.getElementById('panelPlainText').value.trim();
    const embedTitle       = document.getElementById('panelEmbedTitle').value.trim();
    const embedDescription = document.getElementById('panelEmbedDescription').value.trim();
    const embedFooter      = document.getElementById('panelEmbedFooter').value.trim();
    const rawImage         = document.getElementById('panelEmbedImage').value.trim();
    const rawThumb         = document.getElementById('panelEmbedThumbnail').value.trim();
    const embedColor       = document.getElementById('panelEmbedColor').value.trim() || '#5865F2';
    const mode             = document.getElementById('panelMode').value;
    const isPlainType      = !!panelPlainText;
    const hasEmbedContent  = !!(embedTitle || embedDescription);

    const urlOk = v => !v || v === '-' || /^https?:\/\/.+\..+/.test(v);
    if (!urlOk(rawImage)) { showAlert(I18N_AR_ERR_IMG_URL); throw new Error(); }
    if (!urlOk(rawThumb)) { showAlert(I18N_AR_ERR_THUMB_URL); throw new Error(); }
    if (!/^#[0-9A-Fa-f]{6}$/.test(embedColor)) { showAlert(I18N_AR_ERR_COLOR); throw new Error(); }

    const channelId = document.getElementById('panelSendPreviewChannel').value;
    if (!channelId) { showAlert(I18N_AR_ERR_NO_CH); throw new Error(); }

    if (!panelPlainText && !embedTitle && !embedDescription) {
        showAlert(I18N_AR_ERR_NO_CONTENT); throw new Error();
    }

    const validBtns = _inlineBtns.filter(b => b.roleId && b.label);
    if (validBtns.length === 0) { showAlert(I18N_AR_ERR_NO_BUTTONS); throw new Error(); }

    if (!originalName) {
        if (_btnPanelCount >= 20) { showAlert(I18N_AR_ERR_PANEL_LIMIT); throw new Error(); }
    }

    const el = id => document.getElementById(id);

    const _apEmbedTotal = [
        el('panelEmbedAuthorName')?.value.trim(), embedTitle, embedDescription, embedFooter,
        ...apEmbedFields.filter(f => f.name && f.value).flatMap(f => [f.name, f.value])
    ].reduce((s, v) => s + (v || '').length, 0);
    if (_apEmbedTotal > 6000) { showAlert(I18N_ERR_EMBED_TOTAL); throw new Error(); }

    const payload = {
        name,
        mode,
        messageType: isPlainType && hasEmbedContent ? 'both' : isPlainType ? 'plain' : 'embed',
        plainText:   panelPlainText,
        channelId:   channelId,
        embedTitle,
        embedDescription,
        embedFooter,
        embedColor,
        embedImage:     rawImage === '-' ? '' : rawImage,
        embedThumbnail: rawThumb === '-' ? '' : rawThumb,
        embedAuthorName: el('panelEmbedAuthorName')?.value.trim() || '',
        embedAuthorUrl:  el('panelEmbedAuthorUrl')?.value.trim()  || '',
        embedAuthorIcon: el('panelEmbedAuthorIcon')?.value.trim() || '',
        embedTitleUrl:   el('panelEmbedTitleUrl')?.value.trim()   || '',
        embedFooterIcon: el('panelEmbedFooterIcon')?.value.trim() || '',
        embedTimestamp:  el('panelEmbedTimestamp')?.checked        || false,
        embedFields:     apEmbedFields.filter(f => f.name && f.value),
    };

    const url = originalName
        ? `/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(originalName)}`
        : `/api/guild/${GUILD_ID}/autorole-button`;

    const res  = await fetch(url, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); throw new Error(data.message); }

    // Simpan tombol inline — untuk panel baru maupun edit
    const btns = _inlineBtns.filter(b => b.roleId && b.label);
    try {
        await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}/buttons`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ buttons: btns })
        });
    } catch(e) { console.error('Failed to save inline buttons:', e); }

    const pendingCh = _pendingBtnSendChannel;
    _pendingBtnSendChannel = '';
    let sentChId = '', sentMsgId = '';
    if (pendingCh) {
        try {
            const sendRes  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}/send`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId: pendingCh })
            });
            const sendData = await sendRes.json();
            if (sendData.success) {
                sentChId  = sendData.channelId || pendingCh;
                sentMsgId = sendData.messageId || '';
                showToast(data.message + ' ✅', 'success');
            } else {
                showAlert(`Send failed: ${sendData.message}`);
                showToast(data.message, 'success');
            }
        } catch { showToast(data.message, 'success'); }
    } else {
        showToast(data.message, 'success');
    }

    // Update or add card in the list
    const list = document.getElementById('panelGrid');
    const emptyEl = document.getElementById('emptyPanels');
    const effectiveSentChId  = sentChId  || (originalName ? _editingPanelSentChannelId : '');
    const effectiveSentMsgId = sentMsgId || (originalName ? _editingPanelSentMsgId : '');
    const effectiveChId = effectiveSentChId || payload.channelId;
    const newCard = _arRenderBtnCard(name, effectiveChId, payload.mode, effectiveSentChId, effectiveSentMsgId);
    const existing = list.querySelector(`.ar-panel-card:not([data-type])[data-name="${name}"]`);
    if (existing) {
        existing.replaceWith(newCard);
    } else {
        if (emptyEl) emptyEl.style.display = 'none';
        list.appendChild(newCard);
        _btnPanelCount++;
    }
    if (window.lucide) lucide.createIcons();
    _arRefreshBtnStats();

    openCreatePanel();
    } catch(e) { /* validation/network errors already shown via showAlert */ }
    finally { _savingPanel = false; _saveBtns.forEach(b => b && (b.disabled = false)); }
}

let _editingPanelName  = '';
let _editingPanelIsSent = false;
let _editingPanelSentChannelId = '';
let _editingPanelSentMsgId = '';
let _pendingBtnSendChannel = '';

async function saveAndSendPanel() {
    const channelId = document.getElementById('panelSendPreviewChannel').value;
    if (!channelId) { showAlert(I18N_AR_ERR_NO_CH_FIRST); return; }
    _pendingBtnSendChannel = channelId;
    await savePanel();
}

function resetPanelToOriginal() {
    if (_editingPanelName) openEditPanel(_editingPanelName, _editingPanelIsSent);
}

// ══════════════════════════════════════════════════════════════════════════════
// INLINE BUTTON EDITOR (di dalam modal Panel Baru)
// ══════════════════════════════════════════════════════════════════════════════
let _inlineBtns = [];

function parseBtnLabel(label) {
    if (!label) return '';
    const re = /<(a?):([^:>]+):(\d+)>/g;
    const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    let firstEmoji = null;
    const text = label.replace(re, (_, anim, name, id) => {
        if (!firstEmoji) {
            const ext = anim === 'a' ? 'gif' : 'webp';
            firstEmoji = `<img src="https://cdn.discordapp.com/emojis/${id}.${ext}?size=32" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`;
        }
        return '';
    }).trim();
    return (firstEmoji || '') + esc(text);
}

function renderInlineBtnTable() {
    const table   = document.getElementById('inlineBtnTable');
    const empty   = document.getElementById('inlineBtnEmpty');
    const counter = document.getElementById('inlineBtnCounter');
    if (!table) return;
    counter.textContent = `${_inlineBtns.length}/25`;
    if (_inlineBtns.length === 0) {
        table.innerHTML = '';
        empty.style.display = '';
        return;
    }
    empty.style.display = 'none';
    const trashSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`;
    table.innerHTML = _inlineBtns.map((btn, i) => {
        const style    = btn.style || 1;
        const label    = btn.label || '';
        return `
        <div class="btn-card" id="inrow-${i}">
            <div class="btn-card-top">
                <span class="btn-num-badge">${i + 1}</span>
                <span id="inrow-preview-${i}" class="btn-preview-chip ${label ? `style-${style}` : 'style-empty'}">${label ? parseBtnLabel(label) : 'no label'}</span>
                <span style="flex:1;"></span>
                <button class="ar-btn-delete" onclick="removeInlineBtn(${i})" title="Delete">${trashSvg}</button>
            </div>
            <div class="btn-card-fields">
                <select class="react-select" id="inrow-role-${i}" onchange="updateInlineBtn(${i})">
                    <option value="">— Select Role —</option>
                    ${ALL_ROLES.map(r => `<option value="${r.id}" style="color:${r.color}" ${r.id === btn.roleId ? 'selected' : ''}>@${r.name}</option>`).join('')}
                </select>
                <input type="text" class="react-input" id="inrow-label-${i}"
                       value="${label.replace(/"/g, '&quot;')}"
                       placeholder="Button label..." maxlength="80"
                       oninput="updateInlineBtn(${i})">
                <select class="react-select" id="inrow-style-${i}" onchange="updateInlineBtn(${i})">
                    ${STYLE_OPTIONS.map(o => `<option value="${o.v}" ${String(style) === o.v ? 'selected' : ''}>${o.l}</option>`).join('')}
                </select>
            </div>
        </div>`;
    }).join('');
    updatePanelPreviewBtns();
}

function updateInlineBtn(i) {
    const label = (document.getElementById(`inrow-label-${i}`)?.value || '').trim();
    const style = parseInt(document.getElementById(`inrow-style-${i}`)?.value || '1');
    _inlineBtns[i] = {
        roleId: document.getElementById(`inrow-role-${i}`)?.value || '',
        label,
        style,
    };
    const previewEl = document.getElementById(`inrow-preview-${i}`);
    if (previewEl) {
        previewEl.className = `btn-preview-chip ${label ? `style-${style}` : 'style-empty'}`;
        previewEl.innerHTML = label ? parseBtnLabel(label) : 'no label';
    }
    document.getElementById('inlineBtnCounter').textContent = `${_inlineBtns.length}/25`;
    updatePanelPreviewBtns();
}

function addInlineBtnRow() {
    if (_inlineBtns.length >= 25) return showAlert(I18N_AR_ERR_MAX_BTNS);
    _inlineBtns.push({ roleId: '', label: '', style: 1 });
    renderInlineBtnTable();
    setTimeout(() => { document.getElementById('panelFormCard').scrollIntoView({ behavior: 'smooth', block: 'end' }); }, 50);
}

function removeInlineBtn(i) {
    _inlineBtns.splice(i, 1);
    renderInlineBtnTable();
}

function updatePanelPreviewBtns() {
    const container = document.getElementById('apModalPreviewBtns');
    if (!container) return;
    const styleClass = { 1: 'ar-btn-1', 2: 'ar-btn-2', 3: 'ar-btn-3', 4: 'ar-btn-4' };
    container.innerHTML = _inlineBtns
        .filter(b => b.label)
        .map(b => `<span class="ar-btn-chip ${styleClass[b.style] || 'ar-btn-1'}">${parseBtnLabel(b.label)}</span>`)
        .join('');
}

// ── Card render helpers (no-reload DOM updates) ───────────────────────────

function _escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function _arRenderBtnCard(name, channelId, mode, sentChannelId, sentMsgId) {
    const chName    = channelId ? (CHANNELS[channelId] || channelId) : '';
    const isSent    = !!(sentChannelId && sentMsgId);
    const modeClass = mode === 'single' ? 'mode-single' : 'mode-multi';
    const modeLabel = mode === 'single' ? 'Single' : 'Multi';
    const safeName  = _escHtml(name);
    const rightBtn  = isSent
        ? `<a class="btn btn-outline btn-sm" href="https://discord.com/channels/${GUILD_ID}/${sentChannelId}/${sentMsgId}" target="_blank"><i data-lucide="external-link" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i> ${_escHtml(I18N_AR_VIEW_BTN)}</a>`
        : `<button class="btn btn-outline btn-sm" onclick="openSendPanel('${safeName}')"><i data-lucide="send" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i> ${_escHtml(I18N_AR_SEND_BTN)}</button>`;
    const div = document.createElement('div');
    div.className = 'ar-panel-card';
    div.dataset.name      = name;
    div.dataset.channelId = channelId || '';
    div.dataset.sent      = isSent ? 'true' : 'false';
    div.innerHTML = `<div class="ar-panel-row-left">
        <span class="ar-panel-name"><i data-lucide="circle-dot" style="width:13px;height:13px;"></i>${safeName}</span>
        ${chName ? `<span class="ar-panel-channel"><i data-lucide="hash" style="width:11px;height:11px;"></i>${_escHtml(chName)}</span>` : ''}
        <span class="ar-panel-mode ${modeClass}">${modeLabel}</span>
    </div><div class="ar-panel-row-right">
        <button class="btn btn-outline btn-sm" onclick="openEditPanel('${safeName}',${isSent})"><i data-lucide="pencil" style="width:13px;height:13px;vertical-align:middle;margin-right:.25rem;"></i>${_escHtml(I18N_AR_EDIT_BTN)}</button>
        ${rightBtn}
        <button class="btn btn-sm ar-btn-delete" onclick="deletePanel('${safeName}')"><i data-lucide="trash-2"></i></button>
    </div>`;
    return div;
}

function _arRenderReactCard(name, channelId, mode, sentChannelId, sentMsgId) {
    const chName    = channelId ? (CHANNELS[channelId] || channelId) : '';
    const isSent    = !!(sentChannelId && sentMsgId);
    const modeClass = mode === 'single' ? 'mode-single' : 'mode-multi';
    const modeLabel = mode === 'single' ? 'Single' : 'Multi';
    const safeName  = _escHtml(name);
    const rightBtn  = isSent
        ? `<a class="btn btn-outline btn-sm" href="https://discord.com/channels/${GUILD_ID}/${sentChannelId}/${sentMsgId}" target="_blank"><i data-lucide="external-link" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i> ${_escHtml(I18N_AR_VIEW_BTN)}</a>`
        : `<button class="btn btn-outline btn-sm" onclick="openSendReactPanel('${safeName}')"><i data-lucide="send" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i> ${_escHtml(I18N_AR_SEND_BTN)}</button>`;
    const div = document.createElement('div');
    div.className = 'ar-panel-card';
    div.dataset.name      = name;
    div.dataset.type      = 'reaction';
    div.dataset.channelId = channelId || '';
    div.dataset.sent      = isSent ? 'true' : 'false';
    div.innerHTML = `<div class="ar-panel-row-left">
        <span class="ar-panel-name"><i data-lucide="smile" style="width:13px;height:13px;"></i>${safeName}</span>
        ${chName ? `<span class="ar-panel-channel"><i data-lucide="hash" style="width:11px;height:11px;"></i>${_escHtml(chName)}</span>` : ''}
        <span class="ar-panel-mode ${modeClass}">${modeLabel}</span>
    </div><div class="ar-panel-row-right">
        <button class="btn btn-outline btn-sm" onclick="openEditReactPanel('${safeName}',${isSent})"><i data-lucide="pencil" style="width:13px;height:13px;vertical-align:middle;margin-right:.25rem;"></i>${_escHtml(I18N_AR_EDIT_BTN)}</button>
        ${rightBtn}
        <button class="btn btn-sm ar-btn-delete" onclick="deleteReactPanel('${safeName}')"><i data-lucide="trash-2"></i></button>
    </div>`;
    return div;
}

function _arRefreshBtnStats() {
    const full = _btnPanelCount >= 20;
    document.getElementById('arBtnStatTotal').textContent       = _btnPanelCount;
    document.getElementById('arBtnStatSlots').textContent       = `${_btnPanelCount}/20`;
    document.getElementById('arBtnStatSlots').style.color       = full ? '#ed4245' : '';
    document.getElementById('arBtnStatSlotsIcon').className     = `stat-icon${full ? '' : ' stat-icon-comm'}`;
    document.getElementById('arBtnStatSlotsIcon').style.cssText = full ? 'color:#ed4245;background:rgba(237,66,69,.12);' : '';
    document.getElementById('arBtnLimitBanner').style.display   = full ? '' : 'none';
}

function _arRefreshReactStats() {
    const full = _reactPanelCount >= 20;
    document.getElementById('arReactStatTotal').textContent       = _reactPanelCount;
    document.getElementById('arReactStatSlots').textContent       = `${_reactPanelCount}/20`;
    document.getElementById('arReactStatSlots').style.color       = full ? '#ed4245' : '';
    document.getElementById('arReactStatSlotsIcon').className     = `stat-icon${full ? '' : ' stat-icon-comm'}`;
    document.getElementById('arReactStatSlotsIcon').style.cssText = full ? 'color:#ed4245;background:rgba(237,66,69,.12);' : '';
    document.getElementById('arReactLimitBanner').style.display   = full ? '' : 'none';
}

let _deleteConfirmCallback = null;
function openDeleteConfirm(name, isSent, callback) {
    document.getElementById('deletePanelMsg').textContent = I18N_AR_DEL_PANEL_MSG.replace('{{name}}', `"${name}"`);
    document.getElementById('deletePanelWarning').style.display = isSent ? '' : 'none';
    _deleteConfirmCallback = callback;
    openModal('deletePanelBackdrop', 'deletePanelModal');
    if (window.lucide) lucide.createIcons();
}
function closeDeleteConfirm() { closeModal('deletePanelBackdrop', 'deletePanelModal'); _deleteConfirmCallback = null; }
async function doDeleteConfirm() {
    const cb = _deleteConfirmCallback;
    closeDeleteConfirm();
    if (cb) await cb();
}

async function deletePanel(name) {
    const card   = document.querySelector(`.ar-panel-card:not([data-type])[data-name="${name}"]`);
    const isSent = card?.dataset.sent === 'true';
    openDeleteConfirm(name, isSent, async () => {
        const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
            if (card) card.remove();
            _btnPanelCount--;
            const full = _btnPanelCount >= 20;
            document.getElementById('arBtnLimitBanner').style.display    = 'none';
            document.getElementById('arBtnStatTotal').textContent        = _btnPanelCount;
            document.getElementById('arBtnStatSlots').textContent        = `${_btnPanelCount}/20`;
            document.getElementById('arBtnStatSlots').style.color        = full ? '#ed4245' : '';
            document.getElementById('arBtnStatSlotsIcon').className      = `stat-icon${full ? '' : ' stat-icon-comm'}`;
            document.getElementById('arBtnStatSlotsIcon').style.cssText  = full ? 'color:#ed4245;background:rgba(237,66,69,.12);' : '';
            if (_btnPanelCount === 0) document.getElementById('emptyPanels').style.display = '';
            if (_editingPanelName === name) openCreatePanel();
            showToast(data.message, 'success');
        } else {
            showAlert(data.message);
        }
    });
}

// ── Kirim panel ──────────────────────────────────────────────────────────────
let _sendPanelName = '';
let _sendPanelChannelId = '';
function openSendPanel(name) {
    const card = document.querySelector(`.ar-panel-card[data-name="${name}"]:not([data-type])`);
    const channelId = card?.dataset.channelId || '';
    if (!channelId) {
        openEditPanel(name, false);
        return;
    }
    _sendPanelName      = name;
    _sendPanelChannelId = channelId;
    const channelName   = CHANNELS[channelId] || channelId;
    document.getElementById('sendPanelName').textContent        = `"${name}"`;
    document.getElementById('sendPanelChannelName').textContent = `#${channelName}`;
    document.getElementById('sendPanelMsg').textContent         = '';
    openModal('sendPanelBackdrop', 'sendPanelModal');
}
function closeSendPanel() { closeModal('sendPanelBackdrop', 'sendPanelModal'); }

async function doSendPanel() {
    const res = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_sendPanelName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId: _sendPanelChannelId })
    });
    const data = await res.json();
    if (!data.success) { showAlert(data.message); return; }

    const sentChId  = data.channelId || _sendPanelChannelId;
    const sentMsgId = data.messageId || '';
    const list = document.getElementById('panelGrid');
    const mode = list.querySelector(`.ar-panel-card:not([data-type])[data-name="${_sendPanelName}"]`)?.querySelector('.ar-panel-mode')?.textContent?.toLowerCase() || 'multi';
    const newCard = _arRenderBtnCard(_sendPanelName, sentChId, mode, sentChId, sentMsgId);
    const existing = list.querySelector(`.ar-panel-card:not([data-type])[data-name="${_sendPanelName}"]`);
    if (existing) { existing.replaceWith(newCard); if (window.lucide) lucide.createIcons(); }

    if (_editingPanelName === _sendPanelName) {
        _editingPanelSentChannelId = sentChId;
        _editingPanelSentMsgId     = sentMsgId;
        document.getElementById('panelBtnSend').style.display = 'none';
        const chSel = document.getElementById('panelSendPreviewChannel');
        chSel.value = sentChId;
        setCselDisabled(chSel, true);
        setCselDisabled(document.getElementById('panelMode'), true);
    }

    closeSendPanel();
    showToast(data.message, 'success');
}

