}

function closeReactPanelModal() { closeModal('reactPanelBackdrop', 'reactPanelModal'); }

let _savedReactPanelName = '';

async function sendReactAfterSave() {
    const msg       = document.getElementById('reactPanelSendMsg');
    const channelId = document.getElementById('reactPanelSendChannel').value;
    if (!channelId) return showMsg(msg, 'Please select a channel first.', 'error');

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(_savedReactPanelName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId })
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');
    showMsg(msg, '✅ Panel sent successfully!', 'success');
    setTimeout(() => { closeReactPanelModal(); _reloadKeepHash(); }, 900);
}

async function saveReactPanel() {
    const msg          = document.getElementById('reactPanelMsg');
    const originalName = document.getElementById('reactPanelOriginalName').value;
    const name         = originalName || document.getElementById('reactPanelName').value.trim().toLowerCase();

    if (!name || !/^[a-zA-Z0-9_-]{1,32}$/.test(name))
        return showMsg(msg, 'Invalid panel name. Use letters, numbers, - or _.', 'error');

    const isPlainType      = document.getElementById('reactPanelTypePlain').checked;
    const embedTitle       = document.getElementById('reactPanelEmbedTitle').value.trim();
    const embedDescription = document.getElementById('reactPanelEmbedDescription').value.trim();
    const embedFooter      = document.getElementById('reactPanelEmbedFooter').value.trim();
    const rawImage         = document.getElementById('reactPanelEmbedImage').value.trim();
    const rawThumb         = document.getElementById('reactPanelEmbedThumbnail').value.trim();
    const embedColor       = document.getElementById('reactPanelEmbedColor').value.trim() || '#5865F2';
    const mode             = document.getElementById('reactPanelMode').value;
    const panelPlainText   = document.getElementById('reactPanelPlainText').value.trim();

    if (isPlainType) {
        if (!panelPlainText) return showMsg(msg, 'Plain text message cannot be empty.', 'error');
    } else {
        const urlOk = v => !v || v === '-' || /^https?:\/\/.+\..+/.test(v);
        if (!urlOk(rawImage)) return showMsg(msg, 'Invalid image URL. Must start with https://...', 'error');
        if (!urlOk(rawThumb)) return showMsg(msg, 'Invalid thumbnail URL. Must start with https://...', 'error');
        if (!/^#[0-9A-Fa-f]{6}$/.test(embedColor))
            return showMsg(msg, 'Invalid embed color. Example: #5865F2', 'error');
    }

    if (!originalName) {
        const inlineChannelVal = document.getElementById('reactPanelSendChannelInline').value;
        if (!inlineChannelVal)
            return showMsg(msg, 'Please select a channel to send the panel to.', 'error');

        const validReacts = _inlineReacts.filter(r => r.emoji && r.roleId);
        if (validReacts.length === 0)
            return showMsg(msg, 'Add at least 1 reaction before saving the panel.', 'error');
    }

    const payload = {
        name, mode,
        messageType: isPlainType ? 'plain' : 'embed',
        plainText: panelPlainText, embedTitle, embedDescription, embedFooter, embedColor,
        embedImage:     rawImage === '-' ? '' : rawImage,
        embedThumbnail: rawThumb === '-' ? '' : rawThumb,
    };

    const url = originalName
        ? `/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(originalName)}`
        : `/api/guild/${GUILD_ID}/autorole-reaction`;

    const res  = await fetch(url, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');

    // Simpan reactions inline
    const reacts = _inlineReacts.filter(r => r.emoji && r.roleId);
    try {
        await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}/reactions`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reactions: reacts })
        });
    } catch(e) { console.error('Gagal simpan reactions inline:', e); }

    if (originalName) {
        showMsg(msg, data.message, 'success');
        setTimeout(() => { closeReactPanelModal(); _reloadKeepHash(); }, 800);
    } else {
        const inlineChannelId = document.getElementById('reactPanelSendChannelInline').value;
        if (inlineChannelId) {
            showMsg(msg, '✅ Panel disimpan! Mengirim ke channel...', 'success');
            try {
                const sendRes  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}/send`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channelId: inlineChannelId })
                });
                const sendData = await sendRes.json();
                if (sendData.success) {
                    showMsg(msg, '✅ Panel saved and sent to channel!', 'success');
                } else {
                    showMsg(msg, `⚠️ Panel saved, but failed to send: ${sendData.message}`, 'error');
                }
            } catch { showMsg(msg, '⚠️ Panel saved, but failed to send.', 'error'); }
            setTimeout(() => { closeReactPanelModal(); _reloadKeepHash(); }, 1200);
        } else {
            showMsg(msg, '✅ Panel saved! Select a channel to send it.', 'success');
            document.getElementById('reactPanelSendChannel').value   = '';
            document.getElementById('reactPanelSendMsg').textContent = '';
            _savedReactPanelName = name;
            _showReactPanelFooter('send');
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// INLINE REACTION EDITOR
// ══════════════════════════════════════════════════════════════════════════════
let _inlineReacts = [];

function renderInlineReactTable() {
    const table   = document.getElementById('inlineReactTable');
    const empty   = document.getElementById('inlineReactEmpty');
    const counter = document.getElementById('inlineReactCounter');
    if (!table) return;
    counter.textContent = `${_inlineReacts.length}/20`;
    if (_inlineReacts.length === 0) {
        table.innerHTML = '';
        empty.style.display = '';
        return;
    }
    empty.style.display = 'none';
    const header = `
        <div class="react-col-header">
            <span></span><span></span>
            <span>🎭 Role</span>
            <span>✨ Emoji</span>
            <span></span>
        </div>`;
    const rows = _inlineReacts.map((r, i) => {
        const emojiDisplay = _emojiDisplayFromStored(r.emoji);
        const hasEmoji     = !!r.emoji;
        const inputVal     = r.emoji ? (r.emoji.includes(':') ? `<:${r.emoji}>` : r.emoji) : '';
        return `
        <div class="react-editor-card" id="inreact-${i}">
            <span class="react-num-badge">${i + 1}</span>
            <div class="react-emoji-bubble ${hasEmoji ? 'has-emoji' : ''}" id="inreact-bubble-${i}"
                 title="${hasEmoji ? 'Preview emoji' : 'No emoji selected'}">
                ${hasEmoji ? emojiDisplay : '<span class="react-empty-icon">✨</span>'}
            </div>
            <div class="react-fields">
                <select class="react-select" id="inreact-role-${i}" onchange="updateInlineReact(${i})">
                    <option value="">— Select Role —</option>
                    ${ALL_ROLES.map(role => `<option value="${role.id}" style="color:${role.color}" ${role.id === r.roleId ? 'selected' : ''}>@${role.name}</option>`).join('')}
                </select>
                <div class="react-emoji-input-wrap">
                    <span class="react-emoji-prefix">✨</span>
                    <input type="text" class="react-input${inputVal ? ' emoji-valid' : ''}" id="inreact-emoji-${i}"
                           value="${inputVal.replace(/"/g, '&quot;')}"
                           placeholder="Ketuk emoji…" maxlength="8"
                           oninput="_onEmojiInput(${i})"
                           onpaste="_onEmojiPaste(event,${i})">
                </div>
            </div>
            <button class="ar-btn-delete" onclick="removeInlineReact(${i})" title="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            </button>
        </div>`;
    }).join('');
    table.innerHTML = header + rows;
    updateReactPanelPreviewReacts();
}

// ── Emoji input: hanya 1 emoji yang valid ────────────────────────────────────

function _extractFirstEmoji(raw) {
    raw = (raw || '').trim();
    if (!raw) return null;
    // Custom emoji Discord: <:name:id> atau <a:name:id>
    const custom = raw.match(/^<a?:([^:>\s]{1,32}):(\d{5,20})>/);
    if (custom) return custom[0];
    // Unicode emoji via Intl.Segmenter (modern browsers)
    if (typeof Intl !== 'undefined' && Intl.Segmenter) {
        try {
            const seg = new Intl.Segmenter(undefined, { granularity: 'grapheme' });
            for (const { segment } of seg.segment(raw)) {
                if (/\p{Emoji}/u.test(segment) && !/^[0-9#*]$/.test(segment)) return segment;
            }
        } catch {}
    }
    // Fallback regex
    const m = raw.match(/\p{Extended_Pictographic}(?:‍\p{Extended_Pictographic}|️|⃣|[\u{1F3FB}-\u{1F3FF}])*/u);
    return m ? m[0] : null;
}

function _applyEmojiToInput(i, emoji) {
    const input = document.getElementById(`inreact-emoji-${i}`);
    if (!input) return;
    if (emoji) {
        input.value = emoji;
        input.classList.add('emoji-valid');
        input.classList.remove('emoji-invalid');
    } else {
        input.classList.remove('emoji-valid');
    }
    updateInlineReact(i);
}

// Cek apakah teks sedang dalam proses pengetikan custom emoji <:nama:id>
function _isTypingCustomEmoji(raw) {
    // Izinkan selama belum ada '>' (masih dalam proses mengetik format custom emoji)
    return raw.startsWith('<') && !raw.includes('>');
}

function _onEmojiInput(i) {
    const input = document.getElementById(`inreact-emoji-${i}`);
    if (!input) return;
    const raw   = input.value;

    // Sedang mengetik custom emoji <:nama:id> — jangan interupsi
    if (_isTypingCustomEmoji(raw)) {
        input.classList.remove('emoji-valid', 'emoji-invalid');
        updateInlineReact(i);
        return;
    }

    const emoji = _extractFirstEmoji(raw);

    if (emoji) {
        input.value = emoji;
        input.classList.add('emoji-valid');
        input.classList.remove('emoji-invalid');
    } else if (raw.length > 0) {
        // Bukan emoji & bukan custom emoji — tolak dengan animasi
        input.classList.add('emoji-invalid');
        input.classList.remove('emoji-valid');
        setTimeout(() => {
            const el = document.getElementById(`inreact-emoji-${i}`);
            if (el && !_extractFirstEmoji(el.value) && !_isTypingCustomEmoji(el.value)) {
                el.value = '';
                el.classList.remove('emoji-invalid', 'emoji-valid');
            }
        }, 500);
    } else {
        input.classList.remove('emoji-valid', 'emoji-invalid');
    }
    updateInlineReact(i);
}

function _onEmojiPaste(e, i) {
    e.preventDefault();
    const pasted = (e.clipboardData || window.clipboardData).getData('text');
    const emoji  = _extractFirstEmoji(pasted);
    _applyEmojiToInput(i, emoji);
    if (!emoji) {
        const input = document.getElementById(`inreact-emoji-${i}`);
        if (input) {
            input.classList.add('emoji-invalid');
            setTimeout(() => input.classList.remove('emoji-invalid'), 600);
        }
    }
}

// Konversi stored emoji (name:id atau unicode) ke HTML di dalam bubble
function _emojiDisplayFromStored(stored) {
    if (!stored) return '';
    if (stored.includes(':')) {
        // Custom emoji — tampilkan nama terpotong di dalam bubble
        const name = stored.split(':')[0];
        const label = name.length > 6 ? name.slice(0, 5) + '…' : name;
        return `<span class="react-custom-tag">:${label}:</span>`;
    }
    // Unicode emoji — validasi apakah benar-benar emoji (bukan teks biasa)
    const isEmoji = /\p{Emoji}/u.test(stored) && !/^[a-zA-Z0-9\s]+$/.test(stored);
    if (!isEmoji) {
        // Bukan emoji valid — tampilkan tanda tanya
        return `<span style="font-size:1rem;opacity:.4;">?</span>`;
    }
    return stored;
}

function updateInlineReact(i) {
    const emojiRaw    = (document.getElementById(`inreact-emoji-${i}`)?.value || '').trim();
    const customMatch = emojiRaw.match(/^<a?:([^:>\s]{1,32}):(\d{5,20})>$/);
    const emojiStored = customMatch ? `${customMatch[1]}:${customMatch[2]}` : emojiRaw;

    _inlineReacts[i] = {
        roleId: document.getElementById(`inreact-role-${i}`)?.value || '',
        emoji:  emojiStored,
    };

    // Live-update emoji bubble
    const bubble = document.getElementById(`inreact-bubble-${i}`);
    if (bubble) {
        const rawInput   = document.getElementById(`inreact-emoji-${i}`)?.value || '';
        const isTyping   = _isTypingCustomEmoji(rawInput);
        const isCustom   = emojiStored.includes(':');
        const isUnicode  = !isCustom && /\p{Emoji}/u.test(emojiStored) && !/^[a-zA-Z0-9\s]+$/.test(emojiStored);
        const isValid    = isCustom || isUnicode;

        if (isTyping) {
            // Sedang mengetik custom emoji — tampilkan animasi loading
            bubble.innerHTML = `<span style="font-size:.75rem;opacity:.5;letter-spacing:.05em;">…</span>`;
            bubble.classList.remove('has-emoji');
            bubble.title = 'Mengetik format custom emoji';
        } else if (emojiStored && isValid) {
            bubble.innerHTML = _emojiDisplayFromStored(emojiStored);
            bubble.classList.add('has-emoji');
            bubble.title = 'Preview emoji';
        } else if (emojiStored) {
            bubble.innerHTML = `<span style="font-size:.9rem;opacity:.35;">?</span>`;
            bubble.classList.remove('has-emoji');
            bubble.title = 'Bukan emoji yang valid';
        } else {
            bubble.innerHTML = '<span class="react-empty-icon">✨</span>';
            bubble.classList.remove('has-emoji');
            bubble.title = 'No emoji selected';
        }
    }

    document.getElementById('inlineReactCounter').textContent = `${_inlineReacts.length}/20`;
    updateReactPanelPreviewReacts();
}

function addInlineReactRow() {
    if (_inlineReacts.length >= 20) return alert('Maks 20 reaction per panel.');
    _inlineReacts.push({ emoji: '', roleId: '' });
    renderInlineReactTable();
    const body = document.getElementById('reactPanelModal').querySelector('.mb-modal-body');
    setTimeout(() => { body.scrollTop = body.scrollHeight; }, 50);
}

function removeInlineReact(i) {
    _inlineReacts.splice(i, 1);
    renderInlineReactTable();
}

function updateReactPanelPreviewReacts() {
    const container = document.getElementById('reactPanelPreviewReacts');
    if (!container) return;
    container.innerHTML = _inlineReacts
        .filter(r => r.emoji)
        .map(r => {
            const isCustom = r.emoji.includes(':');
            const display  = isCustom ? `<span style="font-size:.75rem;color:var(--text-muted)">:${r.emoji.split(':')[0]}:</span>` : r.emoji;
            const roleName = ALL_ROLES.find(role => role.id === r.roleId)?.name || '';
            return `<span class="ar-react-chip">${display}${roleName ? `<span class="ar-btn-role">@${roleName}</span>` : ''}</span>`;
        }).join('');
}

async function deleteReactPanel(name) {
    const card   = document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${name}"]`);
    const isSent = card?.querySelector('.status-sent') !== null;
    const msg    = isSent
        ? `Delete panel "${name}"?\n\n⚠️ The message already sent on Discord will also be permanently deleted.`
        : `Delete panel "${name}"?`;
    if (!confirm(msg)) return;
    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) _reloadKeepHash();
    else alert(data.message);
}

let _sendReactPanelName = '';
function openSendReactPanel(name) {
    _sendReactPanelName = name;
    document.getElementById('sendReactPanelName').textContent = name;
    document.getElementById('sendReactPanelChannel').value    = '';
    document.getElementById('sendReactPanelMsg').textContent  = '';
    openModal('sendReactPanelBackdrop', 'sendReactPanelModal');
}
function closeSendReactPanel() { closeModal('sendReactPanelBackdrop', 'sendReactPanelModal'); }

async function doSendReactPanel() {
    const msg       = document.getElementById('sendReactPanelMsg');
    const channelId = document.getElementById('sendReactPanelChannel').value;
    if (!channelId) return showMsg(msg, 'Please select a channel first.', 'error');

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(_sendReactPanelName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId })
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');
    showMsg(msg, data.message, 'success');
    setTimeout(() => { closeSendReactPanel(); _reloadKeepHash(); }, 1000);
}

async function saveAllButtons() {
    const msg     = document.getElementById('btnMsg');
    const buttons = collectButtonsFromEditor();

    // Validasi wajib
    for (let i = 0; i < buttons.length; i++) {
        if (!buttons[i].roleId) return showMsg(msg, `Button #${i+1}: Please select a role first.`, 'error');
        if (!buttons[i].label)  return showMsg(msg, `Button #${i+1}: Label cannot be empty.`, 'error');
        if (buttons[i].label.length > 80) return showMsg(msg, `Button #${i+1}: Label exceeds 80 characters.`, 'error');
    }

    // Validasi duplikat
    const seen = {};
    for (let i = 0; i < buttons.length; i++) {
        if (seen[buttons[i].roleId] !== undefined) {
            return showMsg(msg, `Button #${seen[buttons[i].roleId]+1} and #${i+1} use the same role.`, 'error');
        }
        seen[buttons[i].roleId] = i;
    }

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_btnPanelName)}/buttons`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ buttons })
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');
    showMsg(msg, `${buttons.length} button(s) saved successfully!`, 'success');
    _btnData = buttons;
    renderBtnEditorTable();
    setTimeout(() => { closeBtnModal(); _reloadKeepHash(); }, 800);
}
</script>

