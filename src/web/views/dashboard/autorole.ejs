    const msg = document.getElementById('joinMsg');
    const payload = {
        memberEnabled: document.getElementById('joinMemberEnabled').checked,
        memberRoleId:  document.getElementById('joinMemberRole').value,
        botEnabled:    document.getElementById('joinBotEnabled').checked,
        botRoleId:     document.getElementById('joinBotRole').value,
