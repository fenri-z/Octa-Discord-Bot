// AUTOROLE REACTION — PANEL PREVIEW (side panel)
// ══════════════════════════════════════════════════════════════════════════════

let _selectedReactPanel = null;

document.getElementById('reactPanelGrid').addEventListener('click', e => {
    if (e.target.closest('.ar-panel-actions')) return;
    const card = e.target.closest('.ar-panel-card[data-type="reaction"]');
    if (card) selectReactPanelPreview(card.dataset.name);
});

async function selectReactPanelPreview(name) {
    if (_selectedReactPanel === name) { closeReactPreviewPanel(); return; }
    if (_selectedReactPanel) {
        document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${_selectedReactPanel}"]`)?.classList.remove('selected');
    }
    _selectedReactPanel = name;
    document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${name}"]`)?.classList.add('selected');

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-reaction/${encodeURIComponent(name)}`);
    const data = await res.json();
    if (!data.success) return;

    renderReactPreviewPanel(data.panel);
    document.getElementById('apReactPreviewTitle').textContent = name;
    document.getElementById('apReactPreviewPlaceholder').style.display = 'none';
    document.getElementById('apReactPreviewContent').style.display = '';
    document.getElementById('apReactPreviewPanel').classList.add('open');
    document.getElementById('apReactPreviewBackdrop').classList.add('open');
}

function renderReactPreviewPanel(panel) {
    const isPlain = panel.messageType === 'plain';
    const plainEl = document.getElementById('apReactPanelPreviewPlain');
    const embedEl = document.getElementById('apReactPanelPreviewEmbed');

    if (isPlain) {
        plainEl.style.display = 'block';
        embedEl.style.display = 'none';
        plainEl.innerHTML = resolveHtmlMentions(mdToHtml(panel.plainText || ''));
    } else {
        plainEl.style.display = 'none';
        embedEl.style.display = 'flex';
        const color = panel.embedColor || '#5865F2';
        document.getElementById('apReactPanelPreviewPill').style.background = color;
        document.getElementById('apReactPanelPreviewTitle').textContent      = panel.embedTitle       || '';
        document.getElementById('apReactPanelPreviewDesc').textContent       = panel.embedDescription || '';
        document.getElementById('apReactPanelPreviewFooter').textContent     = panel.embedFooter      || '';

        const imgEl = document.getElementById('apReactPanelPreviewImage');
        if (panel.embedImage && /^https?:\/\//.test(panel.embedImage)) { imgEl.src = panel.embedImage; imgEl.style.display = 'block'; }
        else imgEl.style.display = 'none';

        const thumbEl = document.getElementById('apReactPanelPreviewThumb');
        if (panel.embedThumbnail && /^https?:\/\//.test(panel.embedThumbnail)) { thumbEl.src = panel.embedThumbnail; thumbEl.style.display = 'block'; }
        else thumbEl.style.display = 'none';
    }

    document.getElementById('apReactPanelPreviewReacts').innerHTML = (panel.reactions || [])
        .map(r => {
            const emojiDisplay = r.emoji.includes(':') ? `<span style="font-size:.8rem;color:var(--text-muted);">:${r.emoji.split(':')[0]}:</span>` : r.emoji;
            return `<span class="ar-react-chip">${emojiDisplay}</span>`;
        }).join('');
}

function closeReactPreviewPanel() {
    document.getElementById('apReactPreviewPanel').classList.remove('open');
    document.getElementById('apReactPreviewBackdrop').classList.remove('open');
    document.getElementById('apReactPreviewPlaceholder').style.display = '';
    document.getElementById('apReactPreviewContent').style.display = 'none';
    document.getElementById('apReactPreviewTitle').textContent = 'Preview';
    if (_selectedReactPanel) {
        document.querySelector(`.ar-panel-card[data-type="reaction"][data-name="${_selectedReactPanel}"]`)?.classList.remove('selected');
        _selectedReactPanel = null;
    }
}

function filterReactPanels(q) {
    q = q.toLowerCase();
    document.querySelectorAll('.ar-panel-card[data-type="reaction"]').forEach(c => {
        c.style.display = c.dataset.name.toLowerCase().includes(q) ? '' : 'none';
    });
}

