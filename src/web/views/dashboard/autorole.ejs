    </div>
</div>

<!-- ══════════════════════════════════════
     MODAL: Add Multiple Buttons
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="multiBackdrop" onclick="closeMultiModal()"></div>
<div class="mb-modal mb-modal-sm" id="multiModal" data-flt-ignore>
    <div class="mb-modal-header">
        <h2>＋＋ Add Multiple Buttons</h2>
        <button class="mb-modal-close" onclick="closeMultiModal()">✕</button>
    </div>
    <div class="mb-modal-body">
        <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1rem;">
            Select how many buttons to add at once.
        </p>
