<!-- ══════════════════════════════════════
     MODAL: Delete Confirm (shared)
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="deletePanelBackdrop" onclick="closeDeleteConfirm()"></div>
<div class="mb-modal mb-modal-sm" id="deletePanelModal" data-flt-ignore>
    <div class="mb-modal-header">
        <h2><i data-lucide="trash-2" style="width:16px;height:16px;vertical-align:middle;margin-right:.4rem;color:#da373c;"></i><%= t('autorole.delete_panel_title') %></h2>
        <button class="mb-modal-close" onclick="closeDeleteConfirm()">✕</button>
    </div>
    <div class="mb-modal-body">
        <p id="deletePanelMsg" style="color:var(--text-muted);font-size:.9rem;margin:0;"></p>
        <p id="deletePanelWarning" style="display:none;color:#da373c;font-size:.82rem;margin-top:.6rem;background:rgba(218,55,60,.1);border-radius:6px;padding:.5rem .75rem;">
            <i data-lucide="alert-triangle" style="width:13px;height:13px;vertical-align:middle;margin-right:.3rem;"></i>
            <%= t('autorole.delete_panel_warning') %>
        </p>
    </div>
    <div class="mb-modal-footer">
        <div style="display:flex;gap:.75rem;justify-content:flex-end;">
            <button class="btn btn-outline" onclick="closeDeleteConfirm()"><%= t('common.cancel') %></button>
            <button class="btn btn-danger" onclick="doDeleteConfirm()"><i data-lucide="trash-2" style="width:14px;height:14px;vertical-align:middle;margin-right:.3rem;"></i><%= t('common.delete') %></button>
        </div>
    </div>
</div>

<style>
/* ── Tabs ── */
.ar-tabs { display:flex; gap:.5rem; margin-bottom:1.25rem; flex-wrap:wrap; }
.ar-tab {
    padding:.5rem 1.25rem; border-radius:var(--radius);
    background:var(--bg2); border:1px solid var(--border);
    color:var(--text-muted); cursor:pointer; font-size:.9rem;
    transition:all .15s;
}
.ar-tab:hover { border-color:var(--accent); color:var(--text); }
.ar-tab.active { background:var(--accent); border-color:var(--accent); color:#fff; font-weight:600; }

/* ── Section divider ── */
.ar-section { margin-bottom:.5rem; }
.ar-section-title { font-weight:600; font-size:.9rem; color:var(--text-muted); margin-bottom:.75rem; text-transform:uppercase; letter-spacing:.04em; }
.ar-divider { border:none; border-top:1px solid var(--border); margin:1.25rem 0; }
.section-desc { color:var(--text-muted); font-size:.875rem; margin-bottom:1.25rem; }
.hint-inline { font-size:.78rem; color:var(--text-muted); font-weight:400; }

/* ── Panel card (compact row) ── */
.ar-panel-card {
    display:flex; align-items:center; gap:.6rem;
    background:var(--bg3); border:1px solid var(--border);
    border-radius:8px; padding:.5rem .75rem;
    margin-bottom:.4rem; transition:border-color .15s;
}
.ar-panel-card:hover { border-color:var(--accent); }
.ar-panel-row-left  { display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; flex:1; min-width:0; }
.ar-panel-row-right { display:flex; align-items:center; gap:.3rem; flex-shrink:0; margin-left:auto; }
.ar-panel-name {
    font-weight:600; font-size:.875rem; display:flex; align-items:center; gap:.3rem;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0;
}
.ar-panel-mode {
    font-size:.72rem; padding:2px 7px; border-radius:12px; white-space:nowrap; flex-shrink:0;
}
.mode-single { background:rgba(254,231,92,.15); color:#FEE75C; }
.mode-multi  { background:rgba(87,242,135,.15); color:#57F287; }
[data-theme="light"] .mode-single { background:rgba(180,130,0,.12); color:#8a6200; }
[data-theme="light"] .mode-multi  { background:rgba(0,140,70,.10);  color:#1a7a4c; }
.ar-panel-channel {
    font-size:.72rem; color:#5865F2; display:inline-flex; align-items:center;
    gap:.2rem; white-space:nowrap; flex-shrink:0;
    background:rgba(88,101,242,.12); padding:2px 7px; border-radius:12px;
}
.ar-btn-chip {
    font-size:.875rem; padding:0 1rem; height:32px; line-height:32px;
    border-radius:5px; font-weight:500;
    display:inline-flex; align-items:center; gap:.3rem; white-space:nowrap;
    cursor:default; user-select:none;
}
.ar-btn-chip .ar-btn-role { opacity:.65; font-size:.7rem; }
/* ButtonStyle: 1=Primary(blue), 2=Secondary(grey), 3=Success(green), 4=Danger(red) */
.ar-btn-1 { background:#5865F2; color:#fff; }
.ar-btn-3 { background:#248046; color:#fff; }
.ar-btn-4 { background:#da373c; color:#fff; }
.ar-btn-2 { background:#4e5058; color:#fff; }
.ar-react-chip {
    font-size:.75rem; padding:2px 8px; border-radius:6px;
    background:rgba(88,101,242,.15); color:#7289da;
    display:inline-flex; align-items:center; gap:.3rem; white-space:nowrap;
}
.ar-react-chip .ar-btn-role { opacity:.65; font-size:.7rem; }
/* Action buttons in panel card — always compact, no touch-target override */
.ar-panel-row-right .btn {
    min-height:28px !important; padding:.25rem .55rem !important;
    font-size:.78rem !important; line-height:1.2;
}
.ar-btn-delete {
    background:transparent; border:1.5px solid var(--border);
    color:var(--red); border-radius:var(--radius); cursor:pointer;
    transition:all .15s; min-height:28px !important; padding:.2rem .45rem;
    display:flex; align-items:center; justify-content:center;
}
.ar-btn-delete:hover { background:rgba(237,66,69,.1); border-color:var(--red); }
@media(max-width:520px) {
    .ar-panel-mode, .ar-panel-channel { display:none; }
}
.ar-saved-header { display:flex; align-items:center; gap:.75rem; margin-bottom:.75rem; }
.ar-saved-label  { font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); white-space:nowrap; }
.ar-saved-line   { flex:1; height:1px; background:var(--border); }
@media(max-width:520px) {
    .ar-saved-header { justify-content:space-between; }
    .ar-saved-label  { white-space:normal; line-height:1.3; max-width:72px; }
    .ar-saved-line   { display:none; }
}

/* ══════════════════════════════════════
   BUTTON EDITOR — card-based redesign
══════════════════════════════════════ */
.btn-card {
    background: var(--bg3);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: .75rem 1rem;
    margin-bottom: .6rem;
    transition: border-color .2s, box-shadow .2s;
}
.btn-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px color-mix(in srgb,var(--accent) 12%,transparent), 0 4px 14px rgba(0,0,0,.15);
}
.btn-card.has-duplicate {
    border-color: var(--red) !important;
    box-shadow: 0 0 0 1px rgba(237,66,69,.25) !important;
}

/* ── Card top bar: badge + preview chip + delete ── */
.btn-card-top {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-bottom: .6rem;
}
.btn-num-badge {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--bg2);
    border: 1.5px solid var(--border);
    color: var(--text-muted);
    font-size: .68rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.btn-preview-chip {
    font-size: .875rem;
    padding: 0 1rem;
    height: 32px;
    line-height: 32px;
    border-radius: 5px;
    font-weight: 500;
    max-width: 220px;
    min-width: 60px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: filter .15s;
    flex-shrink: 1;
    cursor: default;
    user-select: none;
    border: none;
    display: inline-flex;
    align-items: center;
}
.btn-preview-chip.style-1 { background: #5865F2; color: #fff; }
.btn-preview-chip.style-2 { background: #4e5058; color: #fff; }
.btn-preview-chip.style-3 { background: #248046; color: #fff; }
.btn-preview-chip.style-4 { background: #da373c; color: #fff; }
.btn-preview-chip.style-empty { background: var(--bg2); color: var(--text-muted); border: 1px dashed var(--border); font-style: italic; border-radius: 5px; }

/* ── Card fields: 3-column grid ── */
.btn-card-fields {
    display: grid;
    grid-template-columns: 1fr 1.5fr minmax(130px,160px);
    gap: .5rem;
}
@media(max-width:600px) {
    .btn-card-fields { grid-template-columns: 1fr; }
    .btn-card { padding:.55rem .65rem; }
    .btn-card-top { margin-bottom:.35rem; }
}

/* ── Column header ── */
.btn-col-header { display: none; }
@media(min-width:600px) {
    .btn-col-header {
        display: grid;
        grid-template-columns: 22px auto 1fr 1.5fr minmax(130px,160px) auto;
        gap: .6rem;
        padding: .15rem .25rem .4rem 1rem;
        font-size: .68rem; font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase; letter-spacing: .06em;
        align-items: center;
    }
}

/* ── Field inputs (shared with react editor) ── */
.btn-card .react-select,
.btn-card .react-input {
    /* inherits from .react-select / .react-input defined above */
}

/* legacy — hide old header (jaga kompatibilitas) */
.btn-editor-header { display: none !important; }

/* ── Modal editor layout ── */
.mb-editor-layout { display:flex; gap:1.5rem; flex-direction:column; }
@media(min-width:860px){
    .mb-editor-layout  { flex-direction:row; align-items:flex-start; }
    .mb-editor-form    { flex:1; min-width:0; }
    .mb-editor-preview { width:380px; flex-shrink:0; position:sticky; top:calc(var(--navbar-h, 64px) + 1.5rem); }
}
.preview-label { font-size:.75rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.5rem; }


/* ── Panel page layout: list + preview ── */
.ap-page-layout { display:grid; grid-template-columns:minmax(0,1fr) 460px; gap:1.5rem; align-items:start; }
.ap-list-col { min-width:0; }

/* Preview panel (PC: sticky) */
.ap-preview-panel {
    position:sticky; top:1rem;
    background:var(--bg2); border:1px solid var(--border);
    border-radius:var(--radius); overflow:hidden;
    max-height:calc(100vh - 5rem); display:flex; flex-direction:column;
}
.ap-preview-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:.7rem 1rem; border-bottom:1px solid var(--border); flex-shrink:0;
}
.ap-preview-title { font-size:.85rem; font-weight:600; color:var(--text-muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ap-preview-close {
    display:none; background:none; border:none; color:var(--text-muted);
    cursor:pointer; font-size:1rem; padding:.2rem .4rem;
    border-radius:6px; transition:background .15s; flex-shrink:0;
    -webkit-tap-highlight-color:transparent;
}
.ap-preview-close:hover { background:var(--bg3); color:var(--text); }
.ap-preview-body { overflow-y:auto; flex:1; padding:.75rem; }
.ap-preview-placeholder {
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    gap:.6rem; padding:2.5rem 1rem;
    color:var(--text-muted); font-size:.85rem; text-align:center; min-height:200px;
}

/* Card selected state */
.ar-panel-card { cursor:pointer; }
.ar-panel-card.selected { border-color:var(--accent); box-shadow:0 0 0 1px var(--accent); }


/* Mobile: bottom sheet */
@media (max-width:1100px) {
    .ap-page-layout { grid-template-columns:1fr; }
    .ap-preview-panel {
        position:fixed; bottom:0; left:0; right:0;
        border-radius:16px 16px 0 0; border-bottom:none;
        max-height:none; height:auto; overflow:hidden; display:block;
        transform:translateY(110%); visibility:hidden;
        transition:transform .3s cubic-bezier(.4,0,.2,1), visibility 0s .3s;
        z-index:350;
    }
    .ap-preview-panel.open {
        transform:translateY(0); visibility:visible;
        transition:transform .3s cubic-bezier(.4,0,.2,1), visibility 0s 0s;
        box-shadow:0 -12px 40px rgba(0,0,0,.7);
    }
    .ap-preview-header { position:sticky; top:0; z-index:1; background:var(--bg2); }
    .ap-preview-body { overflow-y:auto; max-height:62vh; padding:.75rem; padding-bottom:max(env(safe-area-inset-bottom,0px),1.25rem); }
    .ap-preview-close { display:block; }
    .ap-preview-backdrop {
        position:fixed; inset:0; background:rgba(0,0,0,.72); z-index:349;
        opacity:0; pointer-events:none; transition:opacity .25s;
    }
    .ap-preview-backdrop.open { opacity:1; pointer-events:auto; }
}
@media (min-width:1101px) { .ap-preview-backdrop { display:none !important; } }

/* ── Toolbar & search ── */
.mb-toolbar { display:flex; gap:.75rem; align-items:center; margin-bottom:1.25rem; flex-wrap:wrap; }
.mb-search  { flex:1; min-width:180px; max-width:320px; }
.empty-state { text-align:center; padding:2.5rem 1rem; color:var(--text-muted); }

/* ── Multi count buttons ── */
.multi-count-btn { min-width:80px; }
.multi-count-btn:hover { background:var(--accent); border-color:var(--accent); color:#fff; }


/* ── Reaction editor card ── */
.react-editor-card {
    background: var(--bg3);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: .75rem 1rem;
    margin-bottom: .6rem;
    transition: border-color .2s, box-shadow .2s;
    display: flex;
    align-items: center;
    gap: .75rem;
}
.react-editor-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px color-mix(in srgb,var(--accent) 15%,transparent), 0 4px 14px rgba(0,0,0,.18);
}
.react-num-badge {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--bg2);
    border: 1.5px solid var(--border);
    color: var(--text-muted);
    font-size: .68rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.react-emoji-bubble {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: var(--bg2);
    border: 2px dashed var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
    transition: border-color .2s, background .2s, transform .15s;
    cursor: pointer;
    user-select: none;
    overflow: hidden;
    text-align: center;
    line-height: 1;
}
.react-emoji-bubble:hover {
    border-color: var(--accent);
    background: color-mix(in srgb,var(--accent) 8%,transparent);
    transform: scale(1.05);
}
.react-emoji-bubble.has-emoji {
    border: 2px solid color-mix(in srgb,var(--accent) 50%,transparent);
    background: color-mix(in srgb,var(--accent) 8%,transparent);
    transform: scale(1.05);
}
.react-emoji-bubble.has-emoji:hover { transform: scale(1.12); }
.react-emoji-bubble .react-empty-icon {
    font-size: 1.1rem; opacity: .3;
}
.react-emoji-bubble .react-custom-tag {
    font-size: .55rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1.2;
    max-width: 44px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: center;
    padding: 0 2px;
}
.react-fields {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: .5rem;
    min-width: 0;
}
@media(max-width:540px) {
    .react-fields { grid-template-columns: 1fr; }
    .react-num-badge { display: none; }
}
/* ── Reaction column header ── */
.react-col-header {
    display: none;
}
@media(min-width:540px) {
    .react-col-header {
        display: grid;
        grid-template-columns: 22px 48px 1fr auto;
        gap: .75rem;
        align-items: center;
        padding: .2rem .25rem .4rem 1rem;
        font-size: .68rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .06em;
    }
}

.react-select, .react-input {
    background: var(--bg2);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: .85rem;
    padding: .5rem .65rem;
    width: 100%;
    outline: none;
    transition: border-color .18s, box-shadow .18s;
    line-height: 1.4;
    min-height: 36px;
    box-sizing: border-box;
}
.react-select { cursor: pointer; }
.react-select:focus, .react-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb,var(--accent) 18%,transparent);
}
.react-select:hover, .react-input:hover {
    border-color: color-mix(in srgb,var(--accent) 50%,transparent);
}
.react-select option { background: var(--bg2); color: var(--text); }


/* ── Card: everything vertically centered ── */
.react-editor-card { align-items: center; }

/* ── Embed builder sections (matching message-builder) ── */
.ee-body     { border:1px solid var(--border); border-radius:10px; overflow:visible; }
.ee-section  { padding:.85rem 1rem; }
.ee-sep      { height:1px; background:var(--border); }
.ee-sec-label { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); margin-bottom:.5rem; }
.ee-title-input { font-weight:600 !important; }
.mb-section { border:1px solid var(--border); border-radius:var(--radius); overflow:visible; margin-bottom:.85rem; }
.mb-section-head {
    display:flex; align-items:center; justify-content:space-between;
    padding:.45rem .85rem; background:var(--bg3);
    border-bottom:1px solid var(--border);
    border-radius:var(--radius) var(--radius) 0 0;
}
.mb-section-title { font-size:.8rem; font-weight:600; color:var(--text); display:flex; align-items:center; gap:.4rem; }
.mb-section-body  { padding:.85rem; display:flex; flex-direction:column; gap:.7rem; }
.mb-color-pk { width:30px; height:30px; padding:2px; border-radius:6px; border:1px solid var(--border); background:none; cursor:pointer; }
.cc-ph-dark-btn { font-size:.68rem; padding:2px 8px; background:rgba(255,255,255,.05); color:rgba(255,255,255,.35); border-color:rgba(255,255,255,.1); }
.cc-ph-dark-btn:hover { background:rgba(255,255,255,.12); color:rgba(255,255,255,.75); border-color:rgba(255,255,255,.2); }
.cc-ph-dark-btn.active { background:rgba(88,101,242,.2); border-color:rgba(88,101,242,.4); color:#c0c7ff; }
[data-theme="light"] .cc-ph-dark-btn { background:rgba(0,0,0,.04); color:var(--text-muted); border-color:var(--border); }
[data-theme="light"] .cc-ph-dark-btn:hover { background:rgba(0,0,0,.08); color:var(--text); }
.cc-field-row { display:flex; gap:.6rem; align-items:flex-start; background:var(--bg3); border:1px solid var(--border); border-radius:8px; padding:.65rem .75rem; margin-bottom:.45rem; }
.cc-field-inputs { flex:1; min-width:0; display:flex; flex-direction:column; gap:.4rem; }
.cc-field-num { font-size:.73rem; color:var(--text-muted); font-weight:600; }
.cc-field-del { flex-shrink:0; align-self:flex-start; }
.cc-field-inline-row { display:flex; align-items:center; gap:.5rem; margin-top:.15rem; }
.cc-field-inline-row label { font-size:.8rem; color:var(--text-muted); cursor:pointer; display:flex; align-items:center; gap:.3rem; }
.ee-body .cc-field-inline-row input[type="checkbox"] { accent-color:#5865F2; }
.ee-body .cc-field-row { background:var(--bg2); }
.input-sm { font-size:.85rem !important; padding:.35rem .65rem !important; }
.mb-url-pair { display:grid; grid-template-columns:1fr 1fr; gap:.5rem; }


/* ── Preview section: hide on narrow screens, show toggle button ── */
.ap-preview-toggle {
    display:none; width:100%; margin-top:.75rem;
    background:var(--bg3); border:1px solid var(--border);
    border-radius:8px; padding:.5rem .75rem;
    font-size:.82rem; color:var(--text-muted); cursor:pointer;
    align-items:center; justify-content:center; gap:.4rem;
    transition:background .15s;
}
.ap-preview-toggle:hover { background:var(--bg2); color:var(--text); }

/* ── Mobile/tablet responsiveness ── */
@media(max-width:860px) {
    /* Preview di bawah form — limit tinggi & scroll */
    .mb-editor-preview {
        width:100%;
        position:relative !important;
        top:auto !important;
    }
    .mb-editor-preview .dc-window {
        max-width:100%;
        overflow-x:hidden;
    }
}

@media(max-width:600px) {
    /* Settings card lebih compact */
    #panelFormCard.settings-card,
    #reactPanelFormCard.settings-card { padding:1rem .85rem; }

    /* URL pair stack vertikal */
    .mb-url-pair { grid-template-columns:1fr; }

    /* Footer form — wrap dan tombol equal width */
    #panelFooterForm,
    #reactPanelFooterForm {
        flex-wrap:wrap;
        gap:.4rem;
    }
    #panelFooterForm .footer-spacer,
    #reactPanelFooterForm .footer-spacer { display:none; }
    #panelFooterForm .btn,
    #reactPanelFooterForm .btn { flex:1; min-width:80px; justify-content:center; }
    #panelBtnReset,
    #reactPanelBtnReset { flex:0 0 auto !important; min-width:auto !important; }

    /* Btn-card-top chip tidak terlalu lebar */
    .btn-preview-chip { max-width:calc(100% - 80px); }

    /* Footer tombol — tidak perlu touch-target 44px saat inline form */
    #panelFooterForm .btn,
    #reactPanelFooterForm .btn { min-height:38px !important; padding:.4rem .7rem !important; font-size:.83rem !important; }

    /* Kolom header reaction tersembunyi di mobile */
    .react-col-header { display:none !important; }

    /* Reaction card — badge tersembunyi, layout lebih compact */
    .react-num-badge { display:none; }
    .react-editor-card { padding:.55rem .65rem; gap:.5rem; }
    .react-emoji-bubble { width:40px; height:40px; font-size:1.25rem; }

    /* Button editor col header tersembunyi */
    .btn-col-header { display:none !important; }

    /* Add Button — override 44px touch target */
    #panelInlineButtons .btn.btn-primary,
    #btnModal .btn.btn-primary { min-height:34px !important; padding:.25rem .6rem !important; font-size:.8rem !important; }

    /* Role Buttons header row wrap rapi */
    #panelInlineButtons > div { align-items:center; }
}

@media(max-width:400px) {
    /* Padding settings card minimal */
    #panelFormCard.settings-card,
    #reactPanelFormCard.settings-card { padding:.75rem .6rem; }

    /* Sembunyikan preview Discord di layar sangat kecil */
    .mb-editor-preview { display:none; }
    .ap-preview-toggle { display:flex; }
    .mb-editor-preview.force-show { display:block !important; }

    /* Btn card lebih compact */
    .btn-card { padding:.45rem .55rem; }
    .btn-card-top { margin-bottom:.25rem; }
    .btn-num-badge { width:18px; height:18px; font-size:.62rem; }
    .react-select, .react-input { font-size:.82rem; padding:.4rem .55rem; min-height:34px; }

    /* Add button compact */
    #panelInlineButtons .btn.btn-primary { min-height:32px !important; padding:.2rem .5rem !important; font-size:.78rem !important; }
}
</style>

<script>
const GUILD_ID  = '<%= guild.id %>';
const ALL_ROLES = <%- JSON.stringify(roles) %>;
const CHANNELS  = <%- JSON.stringify(Object.fromEntries(channels.map(c=>[c.id,c.name]))) %>;
const ROLES_MAP = <%- JSON.stringify(Object.fromEntries(roles.map(r=>[r.id,{name:r.name,color:r.color}]))) %>;
const I18N_AR_DEL_PANEL_MSG    = '<%- t("autorole.delete_panel_msg") %>';
const I18N_AR_ERR_MAX_BTNS    = '<%- t("autorole.err_max_buttons") %>';
const I18N_AR_ERR_PANEL_FULL  = '<%- t("autorole.err_panel_full") %>';
const I18N_AR_ERR_MAX_REACTS  = '<%- t("autorole.err_max_reactions") %>';
const I18N_AR_ERR_INVALID_NAME   = <%- JSON.stringify(t("autorole.err_invalid_name")) %>;
const I18N_AR_ERR_NAME_EXISTS    = <%- JSON.stringify(t("autorole.err_name_exists")) %>;
const I18N_AR_ERR_IMG_URL        = <%- JSON.stringify(t("autorole.err_invalid_image_url")) %>;
const I18N_AR_ERR_THUMB_URL      = <%- JSON.stringify(t("autorole.err_invalid_thumb_url")) %>;
const I18N_AR_ERR_COLOR          = <%- JSON.stringify(t("autorole.err_invalid_color")) %>;
const I18N_AR_ERR_NO_CH          = <%- JSON.stringify(t("autorole.err_no_channel")) %>;
const I18N_AR_ERR_NO_CH_FIRST    = <%- JSON.stringify(t("autorole.err_no_channel_first")) %>;
const I18N_AR_ERR_NO_CONTENT     = <%- JSON.stringify(t("autorole.err_no_content")) %>;
const I18N_AR_ERR_NO_BUTTONS     = <%- JSON.stringify(t("autorole.err_no_buttons")) %>;
const I18N_AR_ERR_NO_REACTIONS   = <%- JSON.stringify(t("autorole.err_no_reactions")) %>;
const I18N_AR_ERR_PANEL_LIMIT    = <%- JSON.stringify(t("autorole.err_btn_panel_limit")) %>;
const I18N_ERR_EMBED_TOTAL       = <%- JSON.stringify(t("common.err_embed_total_limit")) %>;
let _btnPanelCount               = <%= panels.length %>;
let _reactPanelCount             = <%= reactPanels.length %>;
const I18N_AR_BTN_ERR_NO_ROLE   = <%- JSON.stringify(t("autorole.btn_err_no_role")) %>;
const I18N_AR_BTN_ERR_NO_LABEL  = <%- JSON.stringify(t("autorole.btn_err_no_label")) %>;
const I18N_AR_BTN_ERR_LABEL_LNG = <%- JSON.stringify(t("autorole.btn_err_label_long")) %>;
const I18N_AR_BTN_ERR_DUP_ROLE  = <%- JSON.stringify(t("autorole.btn_err_dup_role")) %>;
const I18N_AR_EDIT_BTN  = <%- JSON.stringify(t("autorole.edit_panel_btn")) %>;
const I18N_AR_SEND_BTN  = <%- JSON.stringify(t("autorole.send_btn")) %>;
const I18N_AR_VIEW_BTN  = <%- JSON.stringify(t("autorole.view_btn")) %>;

function updatePanelPreviewChannel() {
    const el = document.getElementById('apPreviewChannel');
    if (!el) return;
    const id   = document.getElementById('panelSendPreviewChannel')?.value;
    const name = id && CHANNELS[id] ? CHANNELS[id] : 'preview';
    el.innerHTML = `<span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>${escHtml(name)}`;
}
function updateReactPanelPreviewChannel() {
    const el = document.getElementById('rpPreviewChannel');
    if (!el) return;
    const id   = document.getElementById('reactSendPreviewChannel')?.value;
    const name = id && CHANNELS[id] ? CHANNELS[id] : 'preview';
    el.innerHTML = `<span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>${escHtml(name)}`;
}

// ── Utilities ──────────────────────────────────────────────────────────────
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function isHttpImg(url) { return url && /^https?:\/\/.+\.(png|jpe?g|gif|webp|bmp|avif)(?:[?#]|$)/i.test(url); }
function apResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    el.style.height = el.scrollHeight + 'px';
}
function apResizeAll() {
    requestAnimationFrame(() => { document.querySelectorAll('.mb-url-area,.mb-auto-resize').forEach(apResizeArea); });
}
function apUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
function _apCountEl(el) {
    const ct = el.nextElementSibling;
    if (!ct || !ct.classList.contains('mb-char-count')) return;
    const len = el.value.length;
    const max = parseInt(el.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}

// ── Placeholder picker ─────────────────────────────────────────────────────
const AP_PLACEHOLDERS = [
    { group: 'USER', items: [
        ['{user.mention}',   'Mention user'],
        ['{user.username}',  'Username'],
        ['{user.id}',        'User ID'],
        ['{user.avatar}',    'Avatar URL'],
    ]},
    { group: 'SERVER', items: [
        ['{server.name}',    'Server name'],
        ['{server.id}',      'Server ID'],
        ['{server.members}', 'Member count'],
        ['{server.icon}',    'Server icon URL'],
    ]},
];
function buildApPhPicker(pickerId, targetId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    let html = '';
    AP_PLACEHOLDERS.forEach(({ group, items }, gi) => {
        if (gi > 0) html += `<div style="grid-column:1/-1;height:1px;background:rgba(255,255,255,.1);margin:.2rem 0;"></div>`;
        html += `<div class="ph-group-label" style="grid-column:1/-1;">${group}</div>`;
        items.forEach(([ph, desc]) => {
            html += `<button type="button" class="ph-item" onclick="insertApPlaceholder('${targetId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`;
        });
    });
    el.innerHTML = html;
}
function insertApPlaceholder(targetId, text) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const start = el.selectionStart ?? el.value.length;
    const end   = el.selectionEnd   ?? el.value.length;
    el.value = el.value.slice(0, start) + text + el.value.slice(end);
    el.dispatchEvent(new Event('input', { bubbles: true }));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
}

// ── Embed fields — Button panel ────────────────────────────────────────────
let apEmbedFields = [];
function addApField() {
    if (apEmbedFields.length >= 25) return;
    apEmbedFields.push({ name: '', value: '', inline: false });
    renderApFields(); updatePanelPreview();
}
function removeApField(idx) {
    apEmbedFields.splice(idx, 1); renderApFields(); updatePanelPreview();
}
const _trashSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`;
function renderApFields() {
    const container = document.getElementById('apFieldsList');
    const countEl   = document.getElementById('apFieldCount');
    if (!container) return;
    if (countEl) countEl.textContent = `(${apEmbedFields.length} / 25)`;
    if (!apEmbedFields.length) { container.innerHTML = ''; return; }
    container.innerHTML = apEmbedFields.map((f, i) => `
        <div class="cc-field-row">
            <div class="cc-field-inputs">
                <div class="cc-field-num">Field #${i + 1}</div>
                <div class="mb-count-wrap">
                    <input type="text" class="input" placeholder="Field name…" maxlength="256" value="${escHtml(f.name)}"
                        oninput="apEmbedFields[${i}].name=this.value;_apCountEl(this);updatePanelPreview()">
                    <div class="mb-char-count">${f.name.length} / 256</div>
                </div>
                <div class="mb-count-wrap" style="margin-top:.35rem;">
                    <textarea class="input" placeholder="Field value…" maxlength="1024" rows="2" style="resize:vertical;"
                        oninput="apEmbedFields[${i}].value=this.value;_apCountEl(this);updatePanelPreview()">${escHtml(f.value)}</textarea>
                    <div class="mb-char-count">${f.value.length} / 1024</div>
