// AUTOROLE BUTTON — PANEL MODAL
// (Field sinkron: name, mode, embedTitle, embedDescription, embedFooter,
//  embedColor, embedImage, embedThumbnail — sama persis dengan command JS)
// ══════════════════════════════════════════════════════════════════════════════

function togglePanelTypePanel() {
    const isPlain = document.getElementById('panelTypePlain').checked;
    document.getElementById('panelPlainPanel').style.display = isPlain ? 'block' : 'none';
    document.getElementById('panelEmbedPanel').style.display = isPlain ? 'none'  : 'block';
    updatePanelPreview();
}
document.querySelectorAll('input[name="panelMessageType"]').forEach(el =>
    el.addEventListener('change', togglePanelTypePanel)
);

function updatePanelPreview() {
    const isPlain  = document.getElementById('panelTypePlain').checked;
    const plainEl  = document.getElementById('panelPreviewPlain');
    const embedEl  = document.getElementById('panelPreviewEmbed');

    if (isPlain) {
        const text = document.getElementById('panelPlainText').value;
        const html = resolveHtmlMentions(mdToHtml(text));
        plainEl.innerHTML     = html;
        plainEl.style.display = html.trim() ? 'block' : 'none';
        embedEl.style.display = 'none';
        return;
    }

    plainEl.style.display = 'none';
    embedEl.style.display = 'flex';

    const title  = document.getElementById('panelEmbedTitle').value;
    const desc   = document.getElementById('panelEmbedDescription').value;
    const footer = document.getElementById('panelEmbedFooter').value;
    const image  = document.getElementById('panelEmbedImage').value.trim();
    const thumb  = document.getElementById('panelEmbedThumbnail').value.trim();
    const color  = document.getElementById('panelEmbedColor').value || '#5865F2';

    document.getElementById('panelPreviewPill').style.background = color;
    document.getElementById('panelPreviewTitle').textContent     = title;
    document.getElementById('panelPreviewDesc').textContent      = desc;
    document.getElementById('panelPreviewFooter').textContent    = footer;

    const imgEl   = document.getElementById('panelPreviewImage');
    const thumbEl = document.getElementById('panelPreviewThumb');
    const validUrl = v => v && v !== '-' && /^https?:\/\/.+\..+/.test(v);
    if (validUrl(image))  { imgEl.src   = image;   imgEl.style.display = ''; }
    else                  { imgEl.src   = '';       imgEl.style.display = 'none'; }
    if (validUrl(thumb))  { thumbEl.src = thumb;    thumbEl.style.display = ''; }
    else                  { thumbEl.src = '';        thumbEl.style.display = 'none'; }
}

function _fillPanelForm(panel) {
    document.getElementById('panelEmbedTitle').value       = panel.embedTitle       || '';
    document.getElementById('panelEmbedDescription').value = panel.embedDescription || '';
    document.getElementById('panelEmbedFooter').value      = panel.embedFooter      || '';
    document.getElementById('panelEmbedImage').value       = panel.embedImage       || '';
    document.getElementById('panelEmbedThumbnail').value   = panel.embedThumbnail   || '';

    const color = panel.embedColor && /^#[0-9A-Fa-f]{6}$/.test(panel.embedColor)
        ? panel.embedColor : '#5865F2';
    document.getElementById('panelEmbedColor').value       = color;
    document.getElementById('panelColorPicker').value      = color;
    document.getElementById('panelMode').value             = panel.mode || 'multi';
    const isPlain = panel.messageType === 'plain';
    document.getElementById(isPlain ? 'panelTypePlain' : 'panelTypeEmbed').checked = true;
    document.getElementById('panelPlainText').value = panel.plainText || '';
    togglePanelTypePanel();
}

function _resetPanelForm() {
    document.getElementById('panelName').value             = '';
    document.getElementById('panelEmbedTitle').value       = '';
    document.getElementById('panelEmbedDescription').value = '';
    document.getElementById('panelEmbedFooter').value      = '';
    document.getElementById('panelEmbedImage').value       = '';
    document.getElementById('panelEmbedThumbnail').value   = '';
    document.getElementById('panelEmbedColor').value       = '#5865F2';
    document.getElementById('panelColorPicker').value      = '#5865F2';
    document.getElementById('panelMode').value             = 'multi';
    document.getElementById('panelMsg').textContent        = '';
    document.getElementById('panelTypeEmbed').checked = true;
    document.getElementById('panelPlainText').value   = '';
    _inlineBtns = [];
    renderInlineBtnTable();
    togglePanelTypePanel();
}

function openCreatePanel() {
    document.getElementById('panelModalTitle').textContent = 'Panel Baru';
    document.getElementById('panelOriginalName').value     = '';
    document.getElementById('panelIsSent').value           = '0';
    document.getElementById('panelName').disabled          = false;
    _resetPanelForm();
    // Tampilkan section tombol inline & sembunyikan hint
    document.getElementById('panelInlineButtons').style.display = '';
    document.getElementById('panelPreviewHint').style.display   = 'none';
    // Tampilkan dropdown channel (hanya untuk panel baru)
    document.getElementById('panelChannelGroup').style.display = '';
    document.getElementById('panelSendChannelInline').value    = '';
    // Reset footer ke state form
    _showPanelFooter('form');
    openModal('panelBackdrop', 'panelModal');
}

async function openEditPanel(name) {
    document.getElementById('panelModalTitle').textContent = `Edit Panel: ${name}`;
    document.getElementById('panelOriginalName').value     = name;
    document.getElementById('panelName').value             = name;
    document.getElementById('panelName').disabled          = true;
    document.getElementById('panelMsg').textContent        = '';
    // Tampilkan section tombol inline saat edit (sama dengan panel baru)
    document.getElementById('panelInlineButtons').style.display = '';
    document.getElementById('panelPreviewHint').style.display   = 'none';

    // Load data embed + tombol dari API
    try {
        const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}`);
        const data = await res.json();
        if (data.success && data.panel) {
            _fillPanelForm(data.panel);
            // Load tombol yang sudah ada ke editor inline
            _inlineBtns = (data.panel.buttons || []).map(b => ({
                roleId: b.roleId,
                label:  b.label,
                style:  b.style || 1,
            }));
            renderInlineBtnTable();

        }
    } catch(e) { console.error(e); }

    // Sembunyikan dropdown channel (hanya untuk panel baru)
    document.getElementById('panelChannelGroup').style.display = 'none';
    // Reset footer ke state form
    _showPanelFooter('form');
    openModal('panelBackdrop', 'panelModal');
}

function closePanelModal() { closeModal('panelBackdrop', 'panelModal'); }

function _showPanelFooter(state) {
    document.getElementById('panelFooterForm').style.display = state === 'form' ? '' : 'none';
    document.getElementById('panelFooterSend').style.display = state === 'send' ? '' : 'none';
}

let _savedPanelName = '';

async function sendAfterSave() {
    const msg       = document.getElementById('panelSendMsg');
    const channelId = document.getElementById('panelSendChannel').value;
    if (!channelId) return showMsg(msg, 'Pilih channel terlebih dahulu.', 'error');

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_savedPanelName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId })
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');
    showMsg(msg, '✅ Panel berhasil dikirim!', 'success');
    setTimeout(() => { closePanelModal(); _reloadKeepHash(); }, 900);
}

async function savePanel() {
    const msg          = document.getElementById('panelMsg');
    const originalName = document.getElementById('panelOriginalName').value;
    const name         = originalName || document.getElementById('panelName').value.trim().toLowerCase();

    if (!name || !/^[a-zA-Z0-9_-]{1,32}$/.test(name))
        return showMsg(msg, 'Nama panel tidak valid. Gunakan huruf, angka, - atau _.', 'error');

    const isPlainType      = document.getElementById('panelTypePlain').checked;
    const embedTitle       = document.getElementById('panelEmbedTitle').value.trim();
    const embedDescription = document.getElementById('panelEmbedDescription').value.trim();
    const embedFooter      = document.getElementById('panelEmbedFooter').value.trim();
    const rawImage         = document.getElementById('panelEmbedImage').value.trim();
    const rawThumb         = document.getElementById('panelEmbedThumbnail').value.trim();
    const embedColor       = document.getElementById('panelEmbedColor').value.trim() || '#5865F2';
    const mode             = document.getElementById('panelMode').value;
    const panelPlainText   = document.getElementById('panelPlainText').value.trim();

    if (isPlainType) {
        if (!panelPlainText) return showMsg(msg, 'Isi pesan teks biasa tidak boleh kosong.', 'error');
    } else {
        // Validasi URL gambar jika diisi (bukan '-')
        const urlOk = v => !v || v === '-' || /^https?:\/\/.+\..+/.test(v);
        if (!urlOk(rawImage)) return showMsg(msg, 'URL Gambar tidak valid. Harus https://...', 'error');
        if (!urlOk(rawThumb)) return showMsg(msg, 'URL Thumbnail tidak valid. Harus https://...', 'error');

        // Validasi warna hex
        if (!/^#[0-9A-Fa-f]{6}$/.test(embedColor))
            return showMsg(msg, 'Warna embed tidak valid. Contoh: #5865F2', 'error');
    }

    // Validasi khusus panel baru
    if (!originalName) {
        const inlineChannelVal = document.getElementById('panelSendChannelInline').value;
        if (!inlineChannelVal)
            return showMsg(msg, 'Pilih channel tujuan pengiriman panel.', 'error');

        const validBtns = _inlineBtns.filter(b => b.roleId && b.label);
        if (validBtns.length === 0)
            return showMsg(msg, 'Tambahkan minimal 1 tombol role sebelum menyimpan panel.', 'error');
    }

    const payload = {
        name,
        mode,
        messageType: isPlainType ? 'plain' : 'embed',
        plainText:   panelPlainText,
        embedTitle,
        embedDescription,
        embedFooter,
        embedColor,
        embedImage:     rawImage === '-' ? '' : rawImage,
        embedThumbnail: rawThumb === '-' ? '' : rawThumb,
    };

    const url = originalName
        ? `/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(originalName)}`
        : `/api/guild/${GUILD_ID}/autorole-button`;

    const res  = await fetch(url, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');

    // Simpan tombol inline — untuk panel baru maupun edit
    const btns = _inlineBtns.filter(b => b.roleId && b.label);
    try {
        await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}/buttons`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ buttons: btns })
        });
    } catch(e) { console.error('Gagal simpan tombol inline:', e); }

    if (originalName) {
        // Edit panel — langsung tutup
        showMsg(msg, data.message, 'success');
        setTimeout(() => { closePanelModal(); _reloadKeepHash(); }, 800);
    } else {
        // Panel baru — cek apakah ada channel yang dipilih
        const inlineChannelId = document.getElementById('panelSendChannelInline').value;
        if (inlineChannelId) {
            // Auto-kirim ke channel yang sudah dipilih
            showMsg(msg, '✅ Panel disimpan! Mengirim ke channel...', 'success');
            try {
                const sendRes  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}/send`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channelId: inlineChannelId })
                });
                const sendData = await sendRes.json();
                if (sendData.success) {
                    showMsg(msg, '✅ Panel berhasil disimpan dan dikirim ke channel!', 'success');
                } else {
                    showMsg(msg, `⚠️ Panel disimpan, tapi gagal kirim: ${sendData.message}`, 'error');
                }
            } catch(e) {
                showMsg(msg, '⚠️ Panel disimpan, tapi gagal kirim. Coba kirim manual.', 'error');
            }
            setTimeout(() => { closePanelModal(); _reloadKeepHash(); }, 1200);
        } else {
            // Tidak ada channel dipilih — tampilkan footer kirim seperti sebelumnya
            showMsg(msg, '✅ Panel disimpan! Pilih channel untuk mengirimnya ke Discord.', 'success');
            document.getElementById('panelSendChannel').value   = '';
            document.getElementById('panelSendMsg').textContent = '';
            _savedPanelName = name;
            _showPanelFooter('send');
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// INLINE BUTTON EDITOR (di dalam modal Panel Baru)
// ══════════════════════════════════════════════════════════════════════════════
let _inlineBtns = [];

function renderInlineBtnTable() {
    const table   = document.getElementById('inlineBtnTable');
    const empty   = document.getElementById('inlineBtnEmpty');
    const counter = document.getElementById('inlineBtnCounter');
    if (!table) return;
    counter.textContent = `${_inlineBtns.length}/25 tombol`;
    if (_inlineBtns.length === 0) {
        table.innerHTML = '';
        empty.style.display = '';
        return;
    }
    empty.style.display = 'none';
    table.innerHTML = _inlineBtns.map((btn, i) => `
        <div class="btn-editor-row" id="inrow-${i}">
            <span class="row-num">${i + 1}</span>
            <select class="select-sm" id="inrow-role-${i}" onchange="updateInlineBtn(${i})">
                <option value="">— Role —</option>
                ${ALL_ROLES.map(r => `<option value="${r.id}" style="color:${r.color}" ${r.id === btn.roleId ? 'selected' : ''}>@${r.name}</option>`).join('')}
            </select>
            <input type="text" class="input-sm" id="inrow-label-${i}"
                   value="${(btn.label || '').replace(/"/g, '&quot;')}"
                   placeholder="Label tombol..." maxlength="80"
                   oninput="updateInlineBtn(${i})">
            <select class="select-sm" id="inrow-style-${i}" onchange="updateInlineBtn(${i})">
                ${STYLE_OPTIONS.map(o => `<option value="${o.v}" ${String(btn.style || '1') === o.v ? 'selected' : ''}>${o.l}</option>`).join('')}
            </select>
            <button class="ar-btn-delete" onclick="removeInlineBtn(${i})" title="Hapus"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
        </div>
    `).join('');
    // Update live preview tombol di embed preview
    updatePanelPreviewBtns();
}

function updateInlineBtn(i) {
    _inlineBtns[i] = {
        roleId: document.getElementById(`inrow-role-${i}`)?.value || '',
        label:  (document.getElementById(`inrow-label-${i}`)?.value || '').trim(),
        style:  parseInt(document.getElementById(`inrow-style-${i}`)?.value || '1'),
    };
    document.getElementById('inlineBtnCounter').textContent = `${_inlineBtns.length}/25 tombol`;
    updatePanelPreviewBtns();
}

function addInlineBtnRow() {
    if (_inlineBtns.length >= 25) return alert('Maks 25 tombol per panel.');
    _inlineBtns.push({ roleId: '', label: '', style: 1 });
    renderInlineBtnTable();
    const body = document.getElementById('panelModal').querySelector('.mb-modal-body');
    setTimeout(() => { body.scrollTop = body.scrollHeight; }, 50);
}

function removeInlineBtn(i) {
    _inlineBtns.splice(i, 1);
    renderInlineBtnTable();
}

function updatePanelPreviewBtns() {
    const container = document.getElementById('panelPreviewBtns');
    if (!container) return;
    const styleClass = { 1: 'ar-btn-1', 2: 'ar-btn-2', 3: 'ar-btn-3', 4: 'ar-btn-4' };
    container.innerHTML = _inlineBtns
        .filter(b => b.label)
        .map(b => {
            const roleName = ALL_ROLES.find(r => r.id === b.roleId)?.name || '';
            return `<span class="ar-btn-chip ${styleClass[b.style] || 'ar-btn-1'}">
                ${b.label}
                ${roleName ? `<span class="ar-btn-role">@${roleName}</span>` : ''}
            </span>`;
        }).join('');
}

async function deletePanel(name) {
    // Cek apakah panel ini sudah pernah dikirim
    const card   = document.querySelector(`.ar-panel-card[data-name="${name}"]`);
    const isSent = card?.querySelector('.status-sent') !== null;
    const msg    = isSent
        ? `Hapus panel "${name}"?\n\n⚠️ Pesan yang sudah terkirim di Discord juga akan dihapus secara permanen.`
        : `Hapus panel "${name}"?`;
    if (!confirm(msg)) return;
    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) _reloadKeepHash();
    else alert(data.message);
}

// ── Kirim panel ──────────────────────────────────────────────────────────────
let _sendPanelName = '';
function openSendPanel(name) {
    _sendPanelName = name;
    document.getElementById('sendPanelName').textContent = name;
    document.getElementById('sendPanelChannel').value    = '';
    document.getElementById('sendPanelMsg').textContent  = '';
    openModal('sendPanelBackdrop', 'sendPanelModal');
}
function closeSendPanel() { closeModal('sendPanelBackdrop', 'sendPanelModal'); }

async function doSendPanel() {
    const msg       = document.getElementById('sendPanelMsg');
    const channelId = document.getElementById('sendPanelChannel').value;
    if (!channelId) return showMsg(msg, 'Pilih channel terlebih dahulu.', 'error');

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_sendPanelName)}/send`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channelId })
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');
    showMsg(msg, data.message, 'success');
    setTimeout(() => { closeSendPanel(); _reloadKeepHash(); }, 1000);
}

// ══════════════════════════════════════════════════════════════════════════════
// KELOLA TOMBOL — BULK EDITOR
// (style disimpan sebagai integer 1-4, sama dengan ButtonStyle di discord.js)
// ══════════════════════════════════════════════════════════════════════════════
let _btnPanelName = '';
let _btnData      = [];

// Map: value di select → ButtonStyle integer (Primary=1, Secondary=2, Success=3, Danger=4)
const STYLE_OPTIONS = [
    { v: '1', l: '🔵 Biru (Primary)'    },
    { v: '3', l: '🟢 Hijau (Success)'   },
    { v: '4', l: '🔴 Merah (Danger)'    },
    { v: '2', l: '⚪ Abu-abu (Secondary)'},
];

function buildRoleOptions(selectedId = '') {
    return ALL_ROLES.map(r =>
        `<option value="${r.id}" style="color:${r.color}" ${r.id === selectedId ? 'selected' : ''}>@${r.name}</option>`
    ).join('');
}

function buildStyleOptions(selectedVal = '1') {
    return STYLE_OPTIONS.map(o =>
        `<option value="${o.v}" ${String(selectedVal) === o.v ? 'selected' : ''}>${o.l}</option>`
    ).join('');
}

function renderBtnEditorTable() {
    const table   = document.getElementById('btnEditorTable');
    const counter = document.getElementById('btnCounter');
    counter.textContent = `${_btnData.length}/25 tombol`;

    if (_btnData.length === 0) {
        table.innerHTML = `
            <div class="btn-editor-header">
                <span>#</span><span>Role</span><span>Label Tombol</span><span>Warna</span><span></span>
            </div>
            <p style="color:var(--text-muted);font-size:.875rem;padding:.5rem 0">
                Belum ada tombol. Klik <strong>＋ Tambah Tombol</strong> untuk menambahkan.
            </p>`;
        return;
    }

    table.innerHTML = `
        <div class="btn-editor-header">
            <span>#</span><span>Role</span><span>Label Tombol</span><span>Warna</span><span></span>
        </div>
        ${_btnData.map((btn, i) => `
        <div class="btn-editor-row" id="btnrow-${i}">
            <span class="row-num">${i + 1}</span>
            <select class="select-sm" id="brow-role-${i}" onchange="checkDuplicateRoles()">
                <option value="">— Role —</option>
                ${buildRoleOptions(btn.roleId)}
            </select>
            <input type="text" class="input-sm" id="brow-label-${i}"
                   value="${(btn.label || '').replace(/"/g, '&quot;')}"
                   placeholder="Label tombol..." maxlength="80">
            <select class="select-sm" id="brow-style-${i}">
                ${buildStyleOptions(String(btn.style || '1'))}
            </select>
            <button class="ar-btn-delete" onclick="removeButtonRow(${i})" title="Hapus"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></button>
        </div>
        `).join('')}
    `;
    setTimeout(checkDuplicateRoles, 0);
}

async function openManageButtons(name) {
    _btnPanelName = name;
    document.getElementById('btnModalPanelName').textContent = name;
    document.getElementById('btnMsg').textContent            = '';
    await refreshBtnData();
    renderBtnEditorTable();
    openModal('btnBackdrop', 'btnModal');
}
function closeBtnModal() { closeModal('btnBackdrop', 'btnModal'); }

async function refreshBtnData() {
    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_btnPanelName)}`);
    const data = await res.json();
    if (!data.success) return;
    _btnData = data.panel.buttons || [];
}

function addButtonRow() {
    if (_btnData.length >= 25) return alert('Panel sudah penuh (maks 25 tombol).');
    _btnData.push({ roleId: '', label: '', style: 1 });
    renderBtnEditorTable();
    const body = document.getElementById('btnModal').querySelector('.mb-modal-body');
    setTimeout(() => { body.scrollTop = body.scrollHeight; }, 50);
}

function addMultipleRows() { openModal('multiBackdrop', 'multiModal'); }
function closeMultiModal() { closeModal('multiBackdrop', 'multiModal'); }

function confirmMultiAdd(count) {
    closeMultiModal();
    const toAdd = Math.min(count, 25 - _btnData.length);
    for (let i = 0; i < toAdd; i++) _btnData.push({ roleId: '', label: '', style: 1 });
    renderBtnEditorTable();
    const body = document.getElementById('btnModal').querySelector('.mb-modal-body');
    setTimeout(() => { body.scrollTop = body.scrollHeight; }, 50);
}
function confirmMultiAddCustom() {
    const val = parseInt(document.getElementById('multiCustomCount').value);
    if (!val || val < 1 || val > 25) return;
    confirmMultiAdd(val);
}

function removeButtonRow(i) {
    _btnData.splice(i, 1);
    renderBtnEditorTable();
}

function collectButtonsFromEditor() {
    return _btnData.map((_, i) => ({
        roleId: document.getElementById(`brow-role-${i}`)?.value  || '',
        label:  (document.getElementById(`brow-label-${i}`)?.value || '').trim(),
        // style disimpan sebagai integer — sinkron dengan ButtonStyle di discord.js
        style:  parseInt(document.getElementById(`brow-style-${i}`)?.value || '1'),
    }));
}

function checkDuplicateRoles() {
    const buttons   = collectButtonsFromEditor();
    const roleCount = {};
    buttons.forEach(b => { if (b.roleId) roleCount[b.roleId] = (roleCount[b.roleId] || 0) + 1; });

    buttons.forEach((b, i) => {
        const row = document.getElementById(`btnrow-${i}`);
        const sel = document.getElementById(`brow-role-${i}`);
        if (!row || !sel) return;
        const isDup = b.roleId && roleCount[b.roleId] > 1;
        row.style.borderColor = isDup ? 'var(--red)' : '';
        sel.style.borderColor  = isDup ? 'var(--red)' : '';
        sel.title = isDup ? '⚠️ Role ini sudah dipakai tombol lain' : '';
    });

    const dupCount = Object.values(roleCount).filter(c => c > 1).length;
    const counter  = document.getElementById('btnCounter');
    if (counter) {
        counter.textContent = `${buttons.length}/25 tombol` + (dupCount ? ` · ⚠️ ${dupCount} role duplikat` : '');
        counter.style.color = dupCount ? 'var(--red)' : '';
    }
}

async function saveAllButtons() {
    const msg     = document.getElementById('btnMsg');
    const buttons = collectButtonsFromEditor();

    // Validasi wajib
    for (let i = 0; i < buttons.length; i++) {
        if (!buttons[i].roleId) return showMsg(msg, `Tombol #${i+1}: Pilih role terlebih dahulu.`, 'error');
        if (!buttons[i].label)  return showMsg(msg, `Tombol #${i+1}: Label tidak boleh kosong.`, 'error');
        if (buttons[i].label.length > 80) return showMsg(msg, `Tombol #${i+1}: Label melebihi 80 karakter.`, 'error');
    }

    // Validasi duplikat
    const seen = {};
    for (let i = 0; i < buttons.length; i++) {
        if (seen[buttons[i].roleId] !== undefined) {
            return showMsg(msg, `Tombol #${seen[buttons[i].roleId]+1} dan #${i+1} menggunakan role yang sama.`, 'error');
        }
        seen[buttons[i].roleId] = i;
    }

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(_btnPanelName)}/buttons`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ buttons })
    });
    const data = await res.json();
    if (!data.success) return showMsg(msg, data.message, 'error');
    showMsg(msg, `${buttons.length} tombol berhasil disimpan!`, 'success');
    _btnData = buttons;
    renderBtnEditorTable();
    setTimeout(() => { closeBtnModal(); _reloadKeepHash(); }, 800);
}
</script>

