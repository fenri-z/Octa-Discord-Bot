// ── Markdown Discord → HTML (preview plain text panel) ────────────────────
function mdToHtml(text) {
    if (!text) return '';
    function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function inline(s) {
        const store = [];
        s = s.replace(/`(.+?)`/g, (_,c) => { const i=store.length; store.push('<code style="background:#2b2d31;padding:1px 5px;border-radius:3px;font-size:.85em;font-family:Consolas,monospace;">'+c+'</code>'); return '\x01C'+i+'\x01'; });
        s = s
            .replace(/\[([^\]]+)\]\(\s*(https?:\/\/[^\s)]+)\s*\)/g,'<a href="$2" target="_blank" rel="noopener noreferrer" style="color:#00b0f4;text-decoration:none;">$1</a>')
            .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
            .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
            .replace(/\*(.+?)\*/g,'<em>$1</em>')
            .replace(/__(.+?)__/g,'<u>$1</u>')
            .replace(/~~(.+?)~~/g,'<s>$1</s>')
            .replace(/\|\|(.+?)\|\|/g,'<span style="background:#202225;border-radius:2px;color:transparent;cursor:pointer;" onclick="this.style.color=\'#dbdee1\'">$1</span>')
            .replace(/(href="[^"]*")|((https?:\/\/[^\s<>"']+))/g,(m,h,_,u)=>{ if(h) return m; const c=u.replace(/[.,;:!?)\]>]+$/,''); return '<a href="'+c+'" target="_blank" rel="noopener noreferrer" style="color:#00b0f4;text-decoration:underline;">'+c+'</a>'; });
        return s.replace(/\x01C(\d+)\x01/g,(_,i)=>store[+i]);
    }
    const lines=text.split('\n'), out=[];
    let inCode=false, codeBuf=[];
    for(let i=0;i<lines.length;i++){
        const raw=lines[i];
        if(!inCode && /^```/.test(raw)){ inCode=true; codeBuf=[]; continue; }
        if(inCode){ if(/^```\s*$/.test(raw.trim())){ inCode=false; out.push('<div style="display:block;background:#1e1f22;border-radius:4px;padding:.4rem .75rem;font-family:Consolas,monospace;font-size:.82em;white-space:pre;overflow-x:auto;color:#dbdee1;">'+esc(codeBuf.join('\n'))+'</div>'); } else codeBuf.push(raw); continue; }
        let m;
        if((m=raw.match(/^>>> (.*)$/))){ const rest=[m[1],...lines.slice(i+1)].join('\n'); out.push('<div style="display:block;border-left:4px solid #4e5058;padding:.1em .75em;margin:.1em 0;color:#dbdee1;">'+inline(esc(rest))+'</div>'); break; }
        if((m=raw.match(/^> (.+)$/))){ out.push('<div style="display:block;border-left:4px solid #4e5058;padding:.1em .75em;margin:.05em 0;color:#dbdee1;">'+inline(esc(m[1]))+'</div>'); continue; }
        if((m=raw.match(/^### (.+)$/))){ out.push('<div style="display:block;font-size:1.05em;font-weight:700;margin:.3em 0 .1em;">'+inline(esc(m[1]))+'</div>'); continue; }
        if((m=raw.match(/^## (.+)$/))){ out.push('<div style="display:block;font-size:1.25em;font-weight:700;margin:.3em 0 .2em;">'+inline(esc(m[1]))+'</div>'); continue; }
        if((m=raw.match(/^# (.+)$/))){ out.push('<div style="display:block;font-size:1.5em;font-weight:700;margin:.3em 0 .2em;">'+inline(esc(m[1]))+'</div>'); continue; }
        if((m=raw.match(/^-# (.+)$/))){ out.push('<div style="display:block;font-size:.75em;color:#80848e;margin:.05em 0;">'+inline(esc(m[1]))+'</div>'); continue; }
        out.push(inline(esc(raw)));
    }
    if(inCode&&codeBuf.length) out.push('<div style="display:block;background:#1e1f22;border-radius:4px;padding:.4rem .75rem;font-family:Consolas,monospace;font-size:.82em;white-space:pre;color:#dbdee1;">'+esc(codeBuf.join('\n'))+'</div>');
    let result='';
    for(let j=0;j<out.length;j++){
        const isBlock=out[j].startsWith('<div'),prevBlock=j>0&&out[j-1].startsWith('<div');
        if(j>0&&!isBlock&&!prevBlock) result+='<br>';
        result+=out[j];
    }
    return result;
}

// ── Mention resolution ────────────────────────────────────────────────────
const _mCache={}, _rCache={}, _cCache={};
function _badge(color,text,bg){bg=bg||color+'26';return '<span style="color:'+color+';background:'+bg+';border-radius:3px;padding:0 2px;font-weight:600;">'+text+'</span>';}
async function _fetchMember(id){if(_mCache[id]!==undefined)return;_mCache[id]='f';try{const d=await(await fetch('/api/guild/'+GUILD_ID+'/members/search?q='+encodeURIComponent(id))).json();_mCache[id]=(d.success&&d.members?.[0]?.display)||null;}catch{_mCache[id]=null;}updatePanelPreview();}
async function _fetchRole(id){if(_rCache[id]!==undefined)return;_rCache[id]='f';try{const d=await(await fetch('/api/guild/'+GUILD_ID+'/roles/'+id)).json();_rCache[id]=(d.success&&d.role?.name)?{name:d.role.name,color:d.role.color}:null;}catch{_rCache[id]=null;}updatePanelPreview();}
async function _fetchChannel(id){if(_cCache[id]!==undefined)return;_cCache[id]='f';try{const d=await(await fetch('/api/guild/'+GUILD_ID+'/channels/'+id)).json();_cCache[id]=(d.success&&d.channel?.name)?{name:d.channel.name}:null;}catch{_cCache[id]=null;}updatePanelPreview();}

function resolveHtmlMentions(html){
    if(!html) return '';
    return html
        .replace(/&lt;(a?):([^:&]+):(\d+)&gt;/g,(_,anim,name,id)=>{const ext=anim==='a'?'gif':'webp';return `<img src="https://cdn.discordapp.com/emojis/${id}.${ext}?size=32" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`;})
        .replace(/&lt;@&amp;(\d+)&gt;/g,(_,id)=>{const s=ROLES_MAP[id];if(s)return _badge(s.color,'@'+s.name);const c=_rCache[id];if(c===undefined)_fetchRole(id);return c&&c!=='f'?_badge(c.color,'@'+c.name):_badge('#99aab5',c===null?'@unknown-role':'@...');})
        .replace(/&lt;@!?(\d+)&gt;/g,(_,id)=>{const c=_mCache[id];if(c===undefined)_fetchMember(id);return _badge('#7289da',c&&c!=='f'?'@'+c:c===null?'@unknown-user':'@...','rgba(88,101,242,.15)');})
        .replace(/&lt;#(\d+)&gt;/g,(_,id)=>{if(CHANNELS[id])return _badge('#7289da','#'+CHANNELS[id],'rgba(88,101,242,.15)');const c=_cCache[id];if(c===undefined)_fetchChannel(id);return c&&c!=='f'?_badge('#7289da','#'+c.name,'rgba(88,101,242,.15)'):_badge('#7289da',c===null?'#unknown':'#...','rgba(88,101,242,.15)');})
        .replace(/@everyone\b/g, () => _badge('#7289da','@everyone','rgba(88,101,242,.15)'))
        .replace(/@here\b/g,     () => _badge('#7289da','@here',    'rgba(88,101,242,.15)'));
}

// ── Tab ──────────────────────────────────────────────────────────────────────
const TAB_META = {
    join:     { title: '<%= t("autorole.join_title") %>',     desc: '<%- t("autorole.join_desc") %>' },
    booster:  { title: '<%= t("autorole.booster_title") %>',  desc: '<%- t("autorole.booster_desc") %>' },
    button:   { title: '<%= t("autorole.button_title") %>',   desc: '<%- t("autorole.button_desc") %>' },
    reaction: { title: '<%= t("autorole.reaction_title") %>', desc: '<%- t("autorole.reaction_desc") %>' },
};

function switchTab(tab) {
    document.querySelectorAll('.ar-tab-content').forEach(el => el.style.display = 'none');
    document.getElementById(`tab-${tab}`).style.display = '';
    sessionStorage.setItem('ar_tab', tab);

    const subJoin     = document.getElementById('sidebarSubJoin');
    const subBooster  = document.getElementById('sidebarSubBooster');
    const subButton   = document.getElementById('sidebarSubButton');
    const subReaction = document.getElementById('sidebarSubReaction');
    if (subJoin)     subJoin.classList.toggle('active',     tab === 'join');
    if (subBooster)  subBooster.classList.toggle('active',  tab === 'booster');
    if (subButton)   subButton.classList.toggle('active',   tab === 'button');
    if (subReaction) subReaction.classList.toggle('active', tab === 'reaction');

    const meta = TAB_META[tab];
    if (meta) {
        const h1 = document.querySelector('.page-header h1');
        const p  = document.querySelector('.page-header p');
        if (h1) h1.textContent = meta.title;
        if (p)  p.textContent  = meta.desc;
    }
}

function _restoreTab() {
    const urlTab = new URLSearchParams(window.location.search).get('tab');
    const tab    = urlTab || sessionStorage.getItem('ar_tab') || 'join';
    const valid  = ['join', 'booster', 'button', 'reaction'];
    switchTab(valid.includes(tab) ? tab : 'join');
}
document.addEventListener('DOMContentLoaded', _restoreTab);
document.addEventListener('DOMContentLoaded', function () {
    const pendingBtn  = sessionStorage.getItem('_openSendPanel');
    const pendingReact = sessionStorage.getItem('_openSendReactPanel');
    if (pendingBtn)   { sessionStorage.removeItem('_openSendPanel');      setTimeout(() => openSendPanel(pendingBtn), 150); }
    if (pendingReact) { sessionStorage.removeItem('_openSendReactPanel'); setTimeout(() => openSendReactPanel(pendingReact), 150); }
});

function _reloadKeepHash(msg, type) { if (msg) queueToast(msg, type || 'success'); location.reload(); }

// openModal / closeModal tersedia global dari footer.ejs
function showMsg(el, text, type) {
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

function setCselDisabled(selectEl, disabled) {
    selectEl.disabled = disabled;
    const wrap = selectEl.closest('.csel');
    if (!wrap) return;
    wrap.classList.toggle('disabled', disabled);
    const trigger = wrap.querySelector('.csel-trigger');
    if (trigger) trigger.tabIndex = disabled ? -1 : 0;
}

