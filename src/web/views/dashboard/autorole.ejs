}

function _showReactPanelFooter(state) {
    document.getElementById('reactPanelFooterForm').style.display = state === 'form' ? '' : 'none';
    document.getElementById('reactPanelFooterSend').style.display = state === 'send' ? '' : 'none';
}

function openCreateReactPanel() {
    document.getElementById('reactPanelModalTitle').textContent = 'Panel Reaction Baru';
