                        👁 Show Preview
                    </button>
                    <div class="mb-editor-preview" data-form="react">
                        <div class="preview-label"><%- t('common.preview') %></div>
                        <div class="dc-window">
                            <div id="rpPreviewChannel" class="dc-channel-bar">
                                <span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>preview
                            </div>
                            <div class="dc-message">
                                <div class="dc-avatar">
                                    <img src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                         alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                                </div>
                                <div class="dc-msg-body">
                                    <div class="dc-username-row">
                                        <%- locals.botNavName || 'Bot' %>
                                        <span class="dc-app-badge"><svg width="9" height="9" viewBox="0 0 12 12" fill="none"><path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> APP</span>
                                        <span class="dc-timestamp">Today at 12:00</span>
                                    </div>
                                    <div id="rpModalPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                    <div id="rpModalPreviewEmbed" class="dc-embed" style="display:none;">
                                        <div id="rpModalPreviewPill" class="dc-embed-pill" style="background:#5865F2;"></div>
                                        <div class="dc-embed-body">
                                            <div class="dc-embed-main">
                                                <div class="dc-embed-content">
                                                    <div id="rpModalPreviewAuthor" class="dc-embed-author" style="display:none;"></div>
                                                    <div id="rpModalPreviewTitle"  class="dc-embed-title"  style="display:none;"></div>
                                                    <div id="rpModalPreviewDesc"   class="dc-embed-desc"   style="display:none;"></div>
                                                    <div id="rpModalPreviewFields" class="dc-embed-fields" style="display:none;"></div>
                                                </div>
                                                <div id="rpModalPreviewThumb" class="dc-embed-thumb" style="display:none;">
                                                    <img id="rpModalPreviewThumbImg" src="" alt="">
                                                </div>
                                            </div>
                                            <div id="rpModalPreviewImage" class="dc-embed-image" style="display:none;">
                                                <img id="rpModalPreviewImageImg" src="" alt="">
                                            </div>
                                            <div id="rpModalPreviewFooter" class="dc-embed-footer" style="display:none;"></div>
                                        </div>
                                    </div>
                                    <div id="reactPanelPreviewReacts" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.5rem;"></div>
                                    <div id="rpModalPreviewEmpty" class="dc-embed-empty">Fill in the form to see preview</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="reactPanelMsg" class="form-message" style="margin-top:.75rem;"></div>
                <div id="reactPanelFooterForm" style="display:flex;gap:.5rem;align-items:center;margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);">
                    <button id="reactPanelBtnReset" class="btn btn-outline" onclick="resetReactPanelToOriginal()" style="display:none;" title="Discard changes and reload original data">
                        <i data-lucide="rotate-ccw" style="width:13px;height:13px;vertical-align:middle;margin-right:.3rem;"></i><%= t('common.reset') %>
                    </button>
                    <span class="footer-spacer" style="flex:1;"></span>
                    <button class="btn btn-outline" onclick="closeReactPanelModal()"><%= t('common.cancel') %></button>
                    <button class="btn btn-outline" onclick="saveReactPanel()"><i data-lucide="save" style="width:14px;height:14px;vertical-align:middle;margin-right:.3rem;"></i><%= t('common.save') %></button>
                    <button id="reactPanelBtnSend" class="btn btn-primary" onclick="saveAndSendReactPanel()" style="display:none;"><i data-lucide="send" style="width:14px;height:14px;vertical-align:middle;margin-right:.3rem;"></i><%= t('autorole.send_btn') %></button>
                </div>
            </div>

            <!-- Grid panel reaction -->
            <div class="ar-saved-header">
                <span class="ar-saved-label">Saved Panels</span>
                <div class="ar-saved-line"></div>
            </div>
            <div id="arReactLimitBanner" style="background:rgba(240,178,50,.1);border:1px solid rgba(240,178,50,.3);border-radius:8px;padding:.55rem .85rem;margin-bottom:.75rem;font-size:.82rem;color:#f0b232;display:flex;align-items:center;gap:.5rem;<%- reactPanels.length < 20 ? 'display:none;' : '' %>">
                <i data-lucide="alert-triangle" style="width:14px;height:14px;flex-shrink:0;"></i>
                <%- t('autorole.err_btn_panel_limit') %>
            </div>
            <div id="reactPanelGrid">
                    <div class="empty-state" id="emptyReactPanels"<%- reactPanels.length > 0 ? ' style="display:none;"' : '' %>>
                        <p style="margin-bottom:.5rem"><i data-lucide="smile" style="width:2rem;height:2rem;color:var(--text-muted);"></i></p>
                        <p><%- t('autorole.react_no_panels') %></p>
                        <p style="color:var(--text-muted);font-size:.85rem;margin-top:.5rem">
                            <%= t('autorole.discord_cmd_hint') %>
                            <code>/autorole-reaction create</code>.
                        </p>
                    </div>
                    <% reactPanels.forEach(p => { %>
                    <% const sentRP = sentReactPanels[p.name]; %>
                    <div class="ar-panel-card" data-name="<%= p.name %>" data-type="reaction" data-channel-id="<%= p.channelId || '' %>" data-sent="<%= sentRP ? 'true' : 'false' %>">
                        <div class="ar-panel-row-left">
                            <span class="ar-panel-name"><i data-lucide="smile" style="width:13px;height:13px;"></i><%= p.name %></span>
                            <% const chReact = channels.find(c => c.id === (sentRP ? sentRP.channelId : p.channelId)); %>
                            <% if (chReact) { %><span class="ar-panel-channel"><i data-lucide="hash" style="width:11px;height:11px;"></i><%= chReact.name %></span><% } %>
                            <span class="ar-panel-mode <%= p.mode === 'single' ? 'mode-single' : 'mode-multi' %>"><%= p.mode === 'single' ? 'Single' : 'Multi' %></span>
                        </div>
                        <div class="ar-panel-row-right">
                            <button class="btn btn-outline btn-sm" onclick="openEditReactPanel('<%= p.name %>', <%= sentRP ? 'true' : 'false' %>)"><i data-lucide="pencil" style="width:13px;height:13px;vertical-align:middle;margin-right:.25rem;"></i><%= t('autorole.edit_panel_btn') %></button>
                            <% if (sentRP) { %>
                                <a class="btn btn-outline btn-sm" href="https://discord.com/channels/<%= guild.id %>/<%= sentRP.channelId %>/<%= sentRP.messageId %>" target="_blank"><i data-lucide="external-link" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i><%= t('autorole.view_btn') %></a>
                            <% } else { %>
                                <button class="btn btn-outline btn-sm" onclick="openSendReactPanel('<%= p.name %>')"><i data-lucide="send" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i> <%= t('autorole.send_btn') %></button>
                            <% } %>
                            <button class="btn btn-sm ar-btn-delete" onclick="deleteReactPanel('<%= p.name %>')"><i data-lucide="trash-2"></i></button>
                        </div>
                    </div>
                    <% }) %>
            </div><!-- /reactPanelGrid -->
        </div><!-- /tab-reaction -->
    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<%- include('../partials/bottom-nav') %>

<!-- ══════════════════════════════════════
     MODAL: Kelola Tombol (Bulk Editor)
══════════════════════════════════════ -->
<div class="mb-modal-backdrop" id="btnBackdrop" onclick="closeBtnModal()"></div>
<div class="mb-modal mb-modal-wide" id="btnModal" data-flt-ignore>
