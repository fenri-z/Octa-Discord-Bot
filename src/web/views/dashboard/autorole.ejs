// ── Panel preview (side panel) ────────────────────────────────────────────────
let _selectedPanel = null;

document.getElementById('panelGrid').addEventListener('click', e => {
    if (e.target.closest('.ar-panel-actions')) return;
    const card = e.target.closest('.ar-panel-card');
    if (card) selectPanelPreview(card.dataset.name);
});

async function selectPanelPreview(name) {
    if (_selectedPanel === name) { closePreviewPanel(); return; }

    if (_selectedPanel) {
        document.querySelector(`.ar-panel-card[data-name="${_selectedPanel}"]`)?.classList.remove('selected');
    }
    _selectedPanel = name;
    document.querySelector(`.ar-panel-card[data-name="${name}"]`)?.classList.add('selected');

    const res  = await fetch(`/api/guild/${GUILD_ID}/autorole-button/${encodeURIComponent(name)}`);
    const data = await res.json();
    if (!data.success) return;

    renderPreviewPanel(data.panel);

    document.getElementById('apPreviewTitle').textContent = name;
    document.getElementById('apPreviewPlaceholder').style.display = 'none';
    document.getElementById('apPreviewContent').style.display = '';
    document.getElementById('apPreviewPanel').classList.add('open');
    document.getElementById('apPreviewBackdrop').classList.add('open');
}

function renderPreviewPanel(panel) {
    const isPlain = panel.messageType === 'plain';
    const plainEl = document.getElementById('apPanelPreviewPlain');
    const embedEl = document.getElementById('apPanelPreviewEmbed');

    if (isPlain) {
        plainEl.style.display = 'block';
        embedEl.style.display = 'none';
        plainEl.innerHTML = resolveHtmlMentions(mdToHtml(panel.plainText || ''));
    } else {
        plainEl.style.display = 'none';
        embedEl.style.display = 'flex';

        const color = panel.embedColor || '#5865F2';
        document.getElementById('apPanelPreviewPill').style.background  = color;
        document.getElementById('apPanelPreviewTitle').textContent       = panel.embedTitle       || '';
        document.getElementById('apPanelPreviewDesc').textContent        = panel.embedDescription || '';
        document.getElementById('apPanelPreviewFooter').textContent      = panel.embedFooter      || '';

        const imgEl = document.getElementById('apPanelPreviewImage');
        if (panel.embedImage && /^https?:\/\//.test(panel.embedImage)) { imgEl.src = panel.embedImage; imgEl.style.display = 'block'; }
        else imgEl.style.display = 'none';

        const thumbEl = document.getElementById('apPanelPreviewThumb');
        if (panel.embedThumbnail && /^https?:\/\//.test(panel.embedThumbnail)) { thumbEl.src = panel.embedThumbnail; thumbEl.style.display = 'block'; }
        else thumbEl.style.display = 'none';
    }

    // Render tombol
    const styleClass = { 1:'ar-btn-1', 2:'ar-btn-2', 3:'ar-btn-3', 4:'ar-btn-4' };
    document.getElementById('apPanelPreviewBtns').innerHTML = (panel.buttons || [])
        .filter(b => b.label)
        .map(b => `<span class="ar-btn-chip ${styleClass[b.style] || 'ar-btn-1'}">${b.label}</span>`)
        .join('');
}

function closePreviewPanel() {
    document.getElementById('apPreviewPanel').classList.remove('open');
    document.getElementById('apPreviewBackdrop').classList.remove('open');
    document.getElementById('apPreviewPlaceholder').style.display = '';
    document.getElementById('apPreviewContent').style.display = 'none';
    document.getElementById('apPreviewTitle').textContent = 'Preview';
    if (_selectedPanel) {
        document.querySelector(`.ar-panel-card[data-name="${_selectedPanel}"]`)?.classList.remove('selected');
        _selectedPanel = null;
    }
}

// ── Filter panels ─────────────────────────────────────────────────────────────
function filterPanels(q) {
    q = q.toLowerCase();
    document.querySelectorAll('.ar-panel-card').forEach(c => {
        c.style.display = c.dataset.name.toLowerCase().includes(q) ? '' : 'none';
    });
}

