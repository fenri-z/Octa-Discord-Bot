function toggleReactPanelTypePanel() {
    const isPlain = document.getElementById('reactPanelTypePlain').checked;
    document.getElementById('reactPanelPlainPanel').style.display = isPlain ? 'block' : 'none';
    document.getElementById('reactPanelEmbedPanel').style.display = isPlain ? 'none'  : 'block';
    updateReactPanelPreview();
}
document.querySelectorAll('input[name="reactPanelMessageType"]').forEach(el =>
    el.addEventListener('change', toggleReactPanelTypePanel)
);

function updateReactPanelPreview() {
    const isPlain  = document.getElementById('reactPanelTypePlain').checked;
    const plainEl  = document.getElementById('reactPanelPreviewPlain');
    const embedEl  = document.getElementById('reactPanelPreviewEmbed');

    if (isPlain) {
        const text = document.getElementById('reactPanelPlainText').value;
        const html = resolveHtmlMentions(mdToHtml(text));
        plainEl.innerHTML     = html;
        plainEl.style.display = html.trim() ? 'block' : 'none';
        embedEl.style.display = 'none';
        return;
    }

    plainEl.style.display = 'none';
    embedEl.style.display = 'flex';

    const title  = document.getElementById('reactPanelEmbedTitle').value;
    const desc   = document.getElementById('reactPanelEmbedDescription').value;
    const footer = document.getElementById('reactPanelEmbedFooter').value;
    const image  = document.getElementById('reactPanelEmbedImage').value.trim();
    const thumb  = document.getElementById('reactPanelEmbedThumbnail').value.trim();
    const color  = document.getElementById('reactPanelEmbedColor').value || '#5865F2';

    document.getElementById('reactPanelPreviewPill').style.background = color;
    document.getElementById('reactPanelPreviewTitle').textContent     = title;
    document.getElementById('reactPanelPreviewDesc').textContent      = desc;
    document.getElementById('reactPanelPreviewFooter').textContent    = footer;

    const validUrl = v => v && v !== '-' && /^https?:\/\/.+\..+/.test(v);
    const imgEl   = document.getElementById('reactPanelPreviewImage');
    const thumbEl = document.getElementById('reactPanelPreviewThumb');
    if (validUrl(image)) { imgEl.src = image; imgEl.style.display = ''; } else { imgEl.src = ''; imgEl.style.display = 'none'; }
    if (validUrl(thumb)) { thumbEl.src = thumb; thumbEl.style.display = ''; } else { thumbEl.src = ''; thumbEl.style.display = 'none'; }
}

function _fillReactPanelForm(panel) {
    document.getElementById('reactPanelEmbedTitle').value       = panel.embedTitle       || '';
    document.getElementById('reactPanelEmbedDescription').value = panel.embedDescription || '';
    document.getElementById('reactPanelEmbedFooter').value      = panel.embedFooter      || '';
    document.getElementById('reactPanelEmbedImage').value       = panel.embedImage       || '';
    document.getElementById('reactPanelEmbedThumbnail').value   = panel.embedThumbnail   || '';
    const color = panel.embedColor && /^#[0-9A-Fa-f]{6}$/.test(panel.embedColor) ? panel.embedColor : '#5865F2';
    document.getElementById('reactPanelEmbedColor').value  = color;
    document.getElementById('reactPanelColorPicker').value = color;
    document.getElementById('reactPanelMode').value        = panel.mode || 'multi';
    const isPlain = panel.messageType === 'plain';
    document.getElementById(isPlain ? 'reactPanelTypePlain' : 'reactPanelTypeEmbed').checked = true;
    document.getElementById('reactPanelPlainText').value = panel.plainText || '';
    toggleReactPanelTypePanel();
}

function _resetReactPanelForm() {
    document.getElementById('reactPanelName').value             = '';
    document.getElementById('reactPanelEmbedTitle').value       = '';
    document.getElementById('reactPanelEmbedDescription').value = '';
    document.getElementById('reactPanelEmbedFooter').value      = '';
    document.getElementById('reactPanelEmbedImage').value       = '';
    document.getElementById('reactPanelEmbedThumbnail').value   = '';
    document.getElementById('reactPanelEmbedColor').value       = '#5865F2';
    document.getElementById('reactPanelColorPicker').value      = '#5865F2';
    document.getElementById('reactPanelMode').value             = 'multi';
    document.getElementById('reactPanelMsg').textContent        = '';
    document.getElementById('reactPanelTypeEmbed').checked = true;
