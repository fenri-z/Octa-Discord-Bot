<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'autorole' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1><%= t('autorole.join_title') %></h1>
            <p><%= t('autorole.join_desc') %></p>
        </div>

        <!-- ══════════════════════════════════════
             TAB: AUTOROLE JOIN
        ══════════════════════════════════════ -->
        <div id="tab-join" class="ar-tab-content">

            <!-- ── How to Use: Join ──────────────────────────────────────────────── -->
            <div class="settings-card" style="margin-bottom:1.5rem;">
                <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                    <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                    <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('autorole.join_how_to_use') %></h2>
                </div>
                <div class="guide-grid">
                    <div class="guide-step">
                        <div class="guide-num">1</div>
                        <div class="guide-title"><%= t('autorole.join_step1_title') %></div>
                        <div class="guide-desc"><%- t('autorole.join_step1_desc') %></div>
                    </div>
                    <div class="guide-step">
                        <div class="guide-num">2</div>
                        <div class="guide-title"><%= t('autorole.join_step2_title') %></div>
                        <div class="guide-desc"><%- t('autorole.join_step2_desc') %></div>
                    </div>
                    <div class="guide-step">
                        <div class="guide-num">3</div>
                        <div class="guide-title"><%= t('autorole.join_step3_title') %></div>
                        <div class="guide-desc"><%- t('autorole.join_step3_desc') %></div>
                    </div>
                </div>
                <div class="guide-tip">💡 <%- t('autorole.join_tip') %></div>
            </div>

            <div class="settings-card">
                <p class="section-desc"><%- t('autorole.join_desc_full') %></p>

                <!-- Member -->
                <div class="ar-section">
                    <div class="ar-section-title">Member <span style="color:#ed4245;">*</span></div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="joinMemberEnabled" class="toggle-input"
                                   <%= joinData.memberEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('autorole.enable_members') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('autorole.role_for_member') %></label>
                        <select id="joinMemberRole" class="select">
                            <option value=""><%= t('common.select_role') %></option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= joinData.memberRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="ar-divider"></div>

                <!-- Bot -->
                <div class="ar-section">
                    <div class="ar-section-title">Bot <span style="color:#ed4245;">*</span></div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="joinBotEnabled" class="toggle-input"
                                   <%= joinData.botEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('autorole.enable_bots') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('autorole.role_for_bot') %></label>
                        <select id="joinBotRole" class="select">
                            <option value=""><%= t('common.select_role') %></option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= joinData.botRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                        <div class="hint"><%= t('common.roles_hint') %></div>
                    </div>
                </div>

                <div class="ar-divider"></div>

                <!-- Semua -->
                <div class="ar-section">
                    <div class="ar-section-title"><%= t('autorole.join_section_all') %> <span style="font-size:.75rem;font-weight:400;color:var(--text-muted);">(member + bot)</span></div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="joinAllEnabled" class="toggle-input"
                                   <%= joinData.allEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('autorole.enable_all') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('autorole.role_for_all') %></label>
                        <select id="joinAllRole" class="select">
                            <option value=""><%= t('common.select_role') %></option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= joinData.allRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                        <div class="hint"><%- t('autorole.join_hint_all') %></div>
                    </div>
                </div>

                <div id="joinMsg" class="form-message"></div>
            </div>
        </div>

        <!-- ══════════════════════════════════════
             TAB: AUTOROLE BOOSTER
        ══════════════════════════════════════ -->
        <div id="tab-booster" class="ar-tab-content" style="display:none;">

            <!-- ── How to Use: Booster ───────────────────────────────────────────── -->
            <div class="settings-card" style="margin-bottom:1.5rem;">
                <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                    <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                    <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('autorole.ar_boost_how_to_use') %></h2>
                </div>
                <div class="guide-grid">
                    <div class="guide-step">
                        <div class="guide-num">1</div>
                        <div class="guide-title"><%= t('autorole.ar_boost_step1_title') %></div>
                        <div class="guide-desc"><%- t('autorole.ar_boost_step1_desc') %></div>
                    </div>
                    <div class="guide-step">
                        <div class="guide-num">2</div>
                        <div class="guide-title"><%= t('autorole.ar_boost_step2_title') %></div>
                        <div class="guide-desc"><%- t('autorole.ar_boost_step2_desc') %></div>
                    </div>
                    <div class="guide-step">
                        <div class="guide-num">3</div>
                        <div class="guide-title"><%= t('autorole.ar_boost_step3_title') %></div>
                        <div class="guide-desc"><%- t('autorole.ar_boost_step3_desc') %></div>
                    </div>
                </div>
                <div class="guide-tip">💡 <%- t('autorole.ar_boost_tip') %></div>
            </div>

            <div class="settings-card">
                <p class="section-desc"><%- t('autorole.booster_tab_desc') %></p>

                <div class="ar-section">
                    <div class="ar-section-title"><%= t('autorole.booster_section_title') %></div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="boosterAutoroleEnabled" class="toggle-input"
                                   <%= boosterData.autoroleEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('autorole.enable_booster') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('autorole.role_for_booster') %> <span style="color:#ed4245;">*</span></label>
                        <select id="boosterAutoroleRole" class="select">
                            <option value=""><%= t('common.select_role') %></option>
                            <% roles.forEach(role => { %>
                                <option value="<%= role.id %>"
                                        style="color: <%= role.color %>"
                                        <%= boosterData.autoroleRoleId === role.id ? 'selected' : '' %>>
                                    @<%= role.name %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="ar-divider"></div>

                <div class="ar-section">
                    <div class="ar-section-title"><%= t('autorole.autoremove_title') %></div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="boosterAutoremoveEnabled" class="toggle-input"
                                   <%= boosterData.autoremoveEnabled ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span><%= t('autorole.autoremove_toggle') %></span>
                        </label>
                        <div class="hint" style="margin-top:.5rem;"><%= t('autorole.autoremove_hint') %></div>
                    </div>
                </div>

                <div id="boosterMsg" class="form-message"></div>
            </div>
        </div>

        <!-- ══════════════════════════════════════
             TAB: AUTOROLE BUTTON
        ══════════════════════════════════════ -->
        <div id="tab-button" class="ar-tab-content" style="display:none;">

            <!-- ── Stats cards ── -->
            <div class="stats-grid" style="margin-bottom:1.5rem;">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-comm"><i data-lucide="circle-dot"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="arBtnStatTotal"><%= panels.length %></div>
                        <div class="stat-label">Total Panels</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon stat-icon-comm"><i data-lucide="hash"></i></div>
                    <div class="stat-info">
                        <div class="stat-value"><%= panels.filter(p => p.channelId).length %></div>
                        <div class="stat-label">With Channel</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div id="arBtnStatSlotsIcon" class="stat-icon <%= panels.length >= 20 ? '' : 'stat-icon-comm' %>" style="<%= panels.length >= 20 ? 'color:#ed4245;background:rgba(237,66,69,.12);' : '' %>"><i data-lucide="layers"></i></div>
                    <div class="stat-info">
                        <div id="arBtnStatSlots" class="stat-value" style="<%= panels.length >= 20 ? 'color:#ed4245;' : '' %>"><%= panels.length %>/20</div>
                        <div class="stat-label">Slots Used</div>
                    </div>
                </div>
            </div>

            <!-- ── How to Use: Button ────────────────────────────────────────────── -->
            <div class="settings-card" style="margin-bottom:1.5rem;">
                <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                    <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                    <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('autorole.button_how_to_use') %></h2>
                </div>
                <div class="guide-grid">
                    <div class="guide-step">
                        <div class="guide-num">1</div>
                        <div class="guide-title"><%= t('autorole.button_step1_title') %></div>
                        <div class="guide-desc"><%- t('autorole.button_step1_desc') %></div>
                    </div>
                    <div class="guide-step">
                        <div class="guide-num">2</div>
                        <div class="guide-title"><%= t('autorole.button_step2_title') %></div>
                        <div class="guide-desc"><%- t('autorole.button_step2_desc') %></div>
                    </div>
                    <div class="guide-step">
                        <div class="guide-num">3</div>
                        <div class="guide-title"><%= t('autorole.button_step3_title') %></div>
                        <div class="guide-desc"><%- t('autorole.button_step3_desc') %></div>
                    </div>
                </div>
                <div class="guide-tip">💡 <%- t('autorole.button_tip') %></div>
            </div>

            <!-- Panel form card -->
            <div class="settings-card" id="panelFormCard" style="margin-bottom:1.5rem;" data-flt-ignore>
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;">
                    <h2 id="panelModalTitle" style="margin:0;font-size:1.05rem;font-weight:600;"><%= t('autorole.new_panel_title') %></h2>
                    <button id="panelCancelEdit" class="btn btn-sm btn-outline" onclick="closePanelModal()" style="display:none;">
                        <i data-lucide="x" style="width:13px;height:13px;vertical-align:middle;margin-right:.2rem;"></i>Cancel Edit
                    </button>
                </div>
                <input type="hidden" id="panelOriginalName">
                <input type="hidden" id="panelIsSent" value="0">

                <div class="mb-editor-layout">
                    <!-- ── Form kiri ── -->
                    <div class="mb-editor-form">

                        <div class="form-group">
                            <label class="label"><%= t('autorole.panel_name_label') %> <span style="color:#ed4245;">*</span></label>
                            <input type="text" id="panelName" class="input" placeholder="e.g.: choose-role" maxlength="32">
                            <div class="hint"><%- t('autorole.panel_name_hint') %></div>
                        </div>

                        <div class="form-group" id="panelChannelGroup" style="display:none;">
                            <label class="label">Channel <span style="color:#ed4245;">*</span></label>
                            <select id="panelSendPreviewChannel" class="select" data-flt-ignore onchange="updatePanelPreviewChannel()">
                                <option value="">— Select channel —</option>
                                <% channels.forEach(c => { %>
                                    <option value="<%= c.id %>">#<%= c.name %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="label"><%= t('autorole.mode_label') %></label>
                            <select id="panelMode" class="select">
                                <option value="multi"><%= t('autorole.mode_multi') %></option>
                                <option value="single"><%= t('autorole.mode_single') %></option>
                            </select>
                        </div>

                        <!-- Plain text panel -->
                        <div id="panelPlainPanel">
                            <div class="mb-section">
                                <div class="mb-section-head">
                                    <span class="mb-section-title"><i data-lucide="message-square" style="width:13px;height:13px;color:var(--accent);flex-shrink:0;"></i> <%= t('common.plain_text_message') %> <span style="color:#ed4245;">*</span> <span style="font-size:.7rem;font-weight:400;color:var(--text-muted);">(<%= t('common.or_embed') %>)</span></span>
                                    <div class="ph-btn-group">
                                        <div class="ph-picker-anchor">
                                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('panelPlainPhPicker',event)">{…} Placeholder</button>
                                            <div class="ph-dropdown" id="panelPlainPhPicker" style="display:none;"></div>
                                        </div>
                                        <div class="ph-picker-anchor mention-anchor">
                                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('panelPlainMentionPicker',event)">@ Mention</button>
                                            <div class="ph-dropdown mention-dd" id="panelPlainMentionPicker" style="display:none;"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-section-body">
                                    <div class="mb-count-wrap">
                                        <textarea id="panelPlainText" class="textarea mb-auto-resize" rows="5"
                                                  maxlength="2000"
                                                  placeholder="<%= t('autorole.plain_text_ph') %>"
                                                  oninput="apResizeArea(this);apUpdateCount('panelPlainText','panelPlainCount');updatePanelPreview()"></textarea>
                                        <div class="mb-char-count" id="panelPlainCount">0 / 2000</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Embed panel -->
                        <div id="panelEmbedPanel">
                        <div class="mb-section">
                            <div class="mb-section-head">
                                <span class="mb-section-title"><i data-lucide="layers" style="width:13px;height:13px;color:var(--accent);flex-shrink:0;"></i> <%= t('common.embed_builder') %></span>
                                <div style="display:flex;align-items:center;gap:.45rem;">
                                    <span style="font-size:.75rem;color:var(--text-muted);"><%= t('message_builder.label_accent') %></span>
                                    <input type="color" id="panelColorPicker" value="#5865F2" class="mb-color-pk"
                                           oninput="document.getElementById('panelEmbedColor').value=this.value;updatePanelPreview()">
                                    <input type="hidden" id="panelEmbedColor" value="#5865F2">
                                </div>
                            </div>
                            <div class="mb-section-body" style="padding:0;">
                                <div class="ee-body" style="border:none;border-radius:0;">

                                    <div class="ee-section">
                                        <div class="ee-sec-label"><%= t('message_builder.label_author') %></div>
                                        <div class="form-group" style="margin-bottom:.5rem;">
                                            <div class="mb-count-wrap">
                                                <input type="text" id="panelEmbedAuthorName" class="input"
                                                       placeholder="<%= t('message_builder.ph_author_name') %>" maxlength="256" oninput="apUpdateCount('panelEmbedAuthorName','panelAuthorNameCount');updatePanelPreview()">
                                                <div class="mb-char-count" id="panelAuthorNameCount">0 / 256</div>
                                            </div>
                                        </div>
                                        <div class="mb-url-pair">
                                            <textarea id="panelEmbedAuthorUrl" class="input input-sm mb-url-area" rows="1"
                                                   placeholder="<%= t('message_builder.ph_author_url') %>" oninput="apResizeArea(this);updatePanelPreview()"></textarea>
                                            <textarea id="panelEmbedAuthorIcon" class="input input-sm mb-url-area" rows="1"
                                                   placeholder="<%= t('message_builder.ph_author_icon') %>" oninput="apResizeArea(this);updatePanelPreview()"></textarea>
                                        </div>
                                    </div>

                                    <div class="ee-sep"></div>

                                    <div class="ee-section">
                                        <div class="ee-sec-label"><%= t('message_builder.label_title') %></div>
                                        <div class="form-group" style="margin-bottom:.5rem;">
                                            <div class="mb-count-wrap">
                                                <input type="text" id="panelEmbedTitle" class="input ee-title-input"
                                                       placeholder="<%= t('message_builder.ph_embed_title') %>"
                                                       maxlength="256" oninput="apUpdateCount('panelEmbedTitle','panelTitleCount');updatePanelPreview()">
                                                <div class="mb-char-count" id="panelTitleCount">0 / 256</div>
                                            </div>
                                        </div>
                                        <textarea id="panelEmbedTitleUrl" class="input input-sm mb-url-area" rows="1"
                                               placeholder="<%= t('message_builder.ph_title_url') %>" oninput="apResizeArea(this);updatePanelPreview()"></textarea>
                                    </div>

                                    <div class="ee-sep"></div>

                                    <div class="ee-section">
                                        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.3rem;margin-bottom:.45rem;">
                                            <div class="ee-sec-label" style="margin:0;"><%= t('message_builder.label_description') %></div>
                                            <div class="ph-btn-group">
                                                <div class="ph-picker-anchor">
                                                    <button type="button" class="ph-toggle-btn cc-ph-dark-btn" onclick="togglePicker('panelDescPhPicker',event)">{…} Placeholder</button>
                                                    <div class="ph-dropdown" id="panelDescPhPicker" style="display:none;"></div>
                                                </div>
                                                <div class="ph-picker-anchor mention-anchor">
                                                    <button type="button" class="ph-toggle-btn cc-ph-dark-btn" onclick="togglePicker('panelEmbedMentionPicker',event)">@ Mention</button>
                                                    <div class="ph-dropdown mention-dd" id="panelEmbedMentionPicker" style="display:none;"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-count-wrap">
                                            <textarea id="panelEmbedDescription" class="textarea mb-auto-resize" rows="4"
                                                      placeholder="<%= t('message_builder.ph_description') %>" maxlength="4096"
                                                      oninput="apResizeArea(this);apUpdateCount('panelEmbedDescription','panelDescCount');updatePanelPreview()"></textarea>
                                            <div class="mb-char-count" id="panelDescCount">0 / 4096</div>
                                        </div>
                                    </div>

                                    <div class="ee-sep"></div>

                                    <div class="ee-section">
                                        <div class="ee-sec-label"><%= t('message_builder.label_media') %></div>
                                        <div class="form-group" style="margin-bottom:.5rem;">
                                            <label class="label"><%= t('message_builder.label_thumbnail') %></label>
                                            <textarea id="panelEmbedThumbnail" class="input input-sm mb-url-area" rows="1"
                                                   placeholder="https://..." oninput="apResizeArea(this);updatePanelPreview()"></textarea>
                                        </div>
                                        <div>
                                            <label class="label"><%= t('message_builder.label_image') %></label>
                                            <textarea id="panelEmbedImage" class="input input-sm mb-url-area" rows="1"
                                                   placeholder="https://..." oninput="apResizeArea(this);updatePanelPreview()"></textarea>
                                        </div>
                                    </div>

                                    <div class="ee-sep"></div>

                                    <div class="ee-section">
                                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem;">
                                            <div class="ee-sec-label" style="margin:0;"><%= t('message_builder.label_fields') %> <span id="apFieldCount" style="font-weight:400;text-transform:none;letter-spacing:0;">(0 / 25)</span></div>
                                            <button type="button" class="btn btn-outline btn-sm" onclick="addApField()">＋ <%= t('message_builder.btn_add_field') %></button>
                                        </div>
                                        <div id="apFieldsList"></div>
                                    </div>

                                    <div class="ee-sep"></div>

                                    <div class="ee-section">
                                        <div class="ee-sec-label"><%= t('message_builder.label_footer') %></div>
                                        <div style="margin-bottom:.5rem;">
                                            <div class="mb-count-wrap">
                                                <input type="text" id="panelEmbedFooter" class="input input-sm"
                                                       style="display:block;width:100%;"
                                                       placeholder="<%= t('message_builder.ph_footer_text') %>" maxlength="2048"
                                                       oninput="apUpdateCount('panelEmbedFooter','panelFooterCount');updatePanelPreview()">
                                                <div class="mb-char-count" id="panelFooterCount">0 / 2048</div>
                                            </div>
                                        </div>
                                        <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;">
                                            <textarea id="panelEmbedFooterIcon" class="input input-sm mb-url-area" rows="1"
                                                   style="flex:1;min-width:120px;"
                                                   placeholder="<%= t('message_builder.ph_footer_icon') %>"
                                                   oninput="apResizeArea(this);updatePanelPreview()"></textarea>
                                            <label class="toggle-label" style="gap:.5rem;cursor:pointer;flex-shrink:0;">
                                                <input type="checkbox" id="panelEmbedTimestamp" class="toggle-input"
                                                       onchange="updatePanelPreview()">
                                                <span class="toggle-slider"></span>
                                                <span class="label" style="margin:0;white-space:nowrap;"><%= t('message_builder.label_timestamp') %></span>
                                            </label>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        </div><!-- /panelEmbedPanel -->

                        <!-- ── Section Tombol (hanya tampil saat buat panel baru) ── -->
                        <div id="panelInlineButtons" style="display:none;margin-top:1.25rem;">
                            <div class="ar-divider"></div>
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem;">
                                <div style="display:flex;align-items:center;gap:.5rem;">
                                    <span style="font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.04em;display:flex;align-items:center;gap:.3rem;"><i data-lucide="circle-dot" style="width:13px;height:13px;"></i> Role Buttons <span style="color:#ed4245;">*</span></span>
                                    <span id="inlineBtnCounter" style="font-size:.72rem;padding:.15rem .45rem;border-radius:999px;background:var(--bg2);border:1px solid var(--border);color:var(--text-muted);">0/25</span>
                                </div>
                                <button type="button" class="btn btn-primary btn-sm" onclick="addInlineBtnRow()" style="gap:.3rem;">
                                    <span style="font-size:1rem;line-height:1;">＋</span> Add Button
                                </button>
                            </div>
