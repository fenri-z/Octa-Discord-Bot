/* ── Preview placeholder resolver ───────────────────────────────── */
function ccMentionBadge(label) {
    return `<span style="color:#7289da;background:rgba(88,101,242,.15);border-radius:3px;padding:0 3px;font-weight:600;">${label}</span>`;
}
function ccChannelBadge(name) {
    return `<span style="color:#7289da;background:rgba(88,101,242,.15);border-radius:3px;padding:0 3px;font-weight:600;">#${name}</span>`;
}
function ccSubtle(text) {
    return `<span style="color:#5d9ef3;font-style:italic;font-size:.85em;">${text}</span>`;
}
function applyInlineMd(s) {
    const saved = [];
    // Protect inline code spans first
    s = s.replace(/`([^`\n]+)`/g, (_, c) => {
        saved.push(`<code class="cc-inline-code">${c}</code>`);
        return '\x00' + (saved.length - 1) + '\x00';
    });
    s = s.replace(/\|\|(.+?)\|\|/g, '<span class="cc-spoiler" title="Spoiler">$1</span>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/___(.+?)___/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    s = s.replace(/__(.+?)__/g, '<u>$1</u>');
    s = s.replace(/\*([^*\n]+)\*/g, '<em>$1</em>');
    s = s.replace(/(?<!\w)_([^_\n]+)_(?!\w)/g, '<em>$1</em>');
    s = s.replace(/~~(.+?)~~/g, '<s>$1</s>');
    s = s.replace(/\[([^\]]+)\]\(https?:\/\/[^)]*\)/g, '<span style="color:#00aff4;text-decoration:underline;cursor:default;">$1</span>');
    s = s.replace(/\x00(\d+)\x00/g, (_, i) => saved[+i]);
    return s;
}
function applyDiscordMarkdown(s) {
    const lines = s.split('\n');
    const out = [];
    let inCb = false, cbLines = [];
    for (const line of lines) {
        if (/^```/.test(line)) {
            if (!inCb) { inCb = true; cbLines = []; }
            else { out.push('<span class="cc-code-block">' + cbLines.join('\n') + '</span>'); inCb = false; }
            continue;
        }
        if (inCb) { cbLines.push(line); continue; }
        let m;
        if ((m = line.match(/^### (.*)/)))        { out.push('<strong style="font-size:1em;">'    + applyInlineMd(m[1]) + '</strong>'); continue; }
        if ((m = line.match(/^## (.*)/)))         { out.push('<strong style="font-size:1.17em;">' + applyInlineMd(m[1]) + '</strong>'); continue; }
        if ((m = line.match(/^# (.*)/)))          { out.push('<strong style="font-size:1.5em;">'  + applyInlineMd(m[1]) + '</strong>'); continue; }
        if ((m = line.match(/^-# (.*)/)))         { out.push('<span style="font-size:.78em;color:var(--text-muted);">' + applyInlineMd(m[1]) + '</span>'); continue; }
        if ((m = line.match(/^&gt;(?: (.*))?$/))) { out.push('<span class="cc-blockquote">' + applyInlineMd(m[1] || '') + '</span>'); continue; }
        out.push(applyInlineMd(line));
    }
    if (inCb && cbLines.length) out.push('<span class="cc-code-block">' + cbLines.join('\n') + '</span>');
    return out.join('<br>');
}

function resolveCcPreview(text, richMentions = false) {
    if (!text) return '';
    let s = escHtml(text);
    const u = escHtml(CC_SAMPLE.user_username);
    s = s
        .replace(/\{user\.username\}/g, u)
        .replace(/\{user\.id\}/g,       escHtml(CC_SAMPLE.user_id))
        .replace(/\{user\.avatar\}/g,   ccSubtle(escHtml(CC_SAMPLE.user_avatar || '[avatar url]')))
        .replace(/\{user\.mention\}/g,  ccMentionBadge('@' + u))
        .replace(/\{user\}/g,           ccMentionBadge('@' + u))
        .replace(/\{server\.name\}/g,   escHtml(CC_SAMPLE.server_name))
        .replace(/\{server\.id\}/g,     escHtml(CC_SAMPLE.server_id))
        .replace(/\{server\.icon\}/g,   ccSubtle(escHtml(CC_SAMPLE.server_icon || '[icon url]')))
        // Legacy
        .replace(/\{member\}/g,         ccMentionBadge('@' + u))
        .replace(/\{username\}/g,       u)
        .replace(/\{nickname\}/g,       u)
        .replace(/\{id\}/g,             escHtml(CC_SAMPLE.user_id))
        .replace(/\{tag\}/g,            u)
        .replace(/\{server\}/g,         escHtml(CC_SAMPLE.server_name))
        .replace(/\{channel\}/g,        ccChannelBadge(escHtml(CC_SAMPLE.channel_name)));
    if (richMentions) {
        // Discord raw mention syntax (matched after escHtml: < → &lt; > → &gt; & → &amp;)
        s = s
            .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => {
                const r = CC_ROLES[id];
                if (!r) return ccMentionBadge('@Unknown Role');
                const col = r.color && r.color !== '#000000' ? r.color : null;
                return col
                    ? `<span style="color:${col};background:${col}22;border-radius:3px;padding:0 3px;font-weight:600;">@${escHtml(r.name)}</span>`
                    : ccMentionBadge('@' + escHtml(r.name));
            })
            .replace(/&lt;@(\d+)&gt;/g, () => ccMentionBadge('@user'))
            .replace(/&lt;#(\d+)&gt;/g, (_, id) => {
                const name = CC_CHANNELS[id];
                return ccChannelBadge(name ? escHtml(name) : id);
            });
    }
    return applyDiscordMarkdown(s);
}

