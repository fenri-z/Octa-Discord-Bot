/* ── Placeholder / Mention picker ───────────────────────────────── */
function toggleCcPicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) {
        el.style.display = 'grid';
        if (event?.currentTarget) event.currentTarget.classList.add('active');
    }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});

function buildCcPhPicker(pickerId, targetId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    let html = '';
    CC_PLACEHOLDERS.forEach(({ group, items }, gi) => {
        if (gi > 0) html += `<div style="grid-column:1/-1;height:1px;background:rgba(255,255,255,.1);margin:.2rem 0;"></div>`;
        html += `<div class="ph-group-label">${group}</div>`;
        items.forEach(([ph, desc]) => {
            html += `<button type="button" class="ph-item" onclick="insertPlaceholder('${targetId}','${ph}');closeCcPickers()">
                <code>${ph}</code><span>${desc}</span>
            </button>`;
        });
    });
    el.innerHTML = html;
}

function buildCcMentionDd(pickerId, targetId) {
    const dd = document.getElementById(pickerId);
    if (!dd) return;
    dd.innerHTML = '';
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => {
            el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
    dd.appendChild(inp);
    function addItem(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => { insertPlaceholder(targetId, mention); closeCcPickers(); });
        dd.appendChild(b);
    }
    function addHdr(t) {
        const h = document.createElement('div');
        h.className = 'ph-group-label'; h.textContent = t; dd.appendChild(h);
    }
    const rKeys = Object.keys(CC_ROLES);
    if (rKeys.length) {
        addHdr('Roles');
        rKeys.forEach(id => {
            const r = CC_ROLES[id];
            addItem(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`);
        });
    }
    const cKeys = Object.keys(CC_CHANNELS);
    if (cKeys.length) {
        addHdr('Channels');
        cKeys.forEach(id => addItem(`<span>#${CC_CHANNELS[id]}</span>`, `<#${id}>`));
    }
}

function closeCcPickers() {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
}

/* ── Edit command ────────────────────────────────────────────────── */
function _fillFormFromCmd(cmd) {
    const res = cmd.response || {};
    document.getElementById('ccTrigger').value           = cmd.trigger || '';
    document.getElementById('ccMode').value              = cmd.mode    || 'prefix';
    document.getElementById('ccPlainText').value         = res.text    || '';
    document.getElementById('ccPlainImage').value        = res.plainImageURL || '';
    document.getElementById('ccEmbedAuthor').value       = res.author?.name    || '';
    document.getElementById('ccEmbedAuthorUrl').value    = res.author?.url     || '';
    document.getElementById('ccEmbedAuthorIcon').value   = res.author?.iconURL || '';
    document.getElementById('ccEmbedTitle').value        = res.title    || '';
    document.getElementById('ccEmbedTitleUrl').value     = res.titleUrl || '';
    document.getElementById('ccEmbedDesc').value         = res.description || '';
    document.getElementById('ccEmbedThumbnail').value    = res.thumbnailURL || '';
    document.getElementById('ccEmbedImage').value        = res.imageURL     || '';
    document.getElementById('ccEmbedFooter').value       = res.footer?.text    || '';
    document.getElementById('ccEmbedFooterIcon').value   = res.footer?.iconURL || '';
    document.getElementById('ccEmbedTimestamp').checked  = !!res.timestamp;
    document.getElementById('ccEmbedColor').value        = res.color || '#5865F2';
    embedFields = (res.fields || []).map(f => ({ name: f.name||'', value: f.value||'', inline: !!f.inline }));
    _lastWarnedUrl.clear();
    onEeColor(); onEeAuthIcon(); onEeThumb(); onEeImage(); onEeFooterIcon();
    renderEmbedFields();
    ccResizeAll();
    ccUpdateCount('ccPlainText', 'ccPlainCount');
    ccUpdateCount('ccEmbedDesc', 'ccDescCount');
    updatePreview();
}

function loadCommandForEdit(idx) {
    const cmd = commands[idx];
    if (!cmd) return;
    editingIdx = idx;
    _savedEditingCmd = JSON.parse(JSON.stringify(cmd));
    _fillFormFromCmd(cmd);
    document.getElementById('ccFormTitle').textContent  = `Edit: "${cmd.trigger}"`;
    document.getElementById('ccCancelEdit').style.display = '';
    if (window.lucide) lucide.createIcons();
    document.getElementById('ccFormCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
    window._floatDirty?.();
}

function cancelEdit() {
    editingIdx = -1;
    _savedEditingCmd = null;
    document.getElementById('ccFormTitle').textContent  = i18n.add_title;
    document.getElementById('ccCancelEdit').style.display = 'none';
    clearForm();
}

// Init pickers
buildCcPhPicker('ccPlainPhPicker', 'ccPlainText');
buildCcMentionDd('ccPlainMentionPicker', 'ccPlainText');
buildCcPhPicker('ccDescPhPicker', 'ccEmbedDesc');
buildCcMentionDd('ccDescMentionPicker', 'ccEmbedDesc');

/* ── Auto-resize helpers ─────────────────────────────────────────── */
function ccResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    el.style.height = el.scrollHeight + 'px';
}
function ccResizeAll() {
    requestAnimationFrame(() => {
        document.querySelectorAll('#ccFormCard .mb-url-area, #ccFormCard .mb-auto-resize').forEach(ccResizeArea);
    });
}
function ccUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}

window._floatSave = async function () {
    const ok = addCommandFromForm();
    if (!ok) throw new Error('validation'); // throw so float bar does NOT hide or re-capture
    await saveCommands();
};

window._floatReset = function () {
    if (editingIdx >= 0 && _savedEditingCmd) {
        _fillFormFromCmd(_savedEditingCmd);
        window._floatClean?.();
    } else {
        editingIdx = -1;
        _savedEditingCmd = null;
        document.getElementById('ccFormTitle').textContent = i18n.add_title;
        document.getElementById('ccCancelEdit').style.display = 'none';
        clearForm();
        commands = JSON.parse(JSON.stringify(savedCommands));
        renderList();
    }
};

window.addEventListener('resize', ccResizeAll);
requestAnimationFrame(ccResizeAll);
</script>

