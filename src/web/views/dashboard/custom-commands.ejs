<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'custom-commands' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <div class="page-header">
            <h1><%= t('custom_commands.page_title') %></h1>
            <p><%= t('custom_commands.page_desc') %></p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="color:#5865F2;"><i data-lucide="terminal"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= commands.length %></div>
                    <div class="stat-label"><%= t('custom_commands.total_commands') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;"><i data-lucide="check-circle"></i></div>
                <div class="stat-info">
                    <div class="stat-value"><%= commands.filter(c => c.enabled).length %></div>
                    <div class="stat-label"><%= t('custom_commands.active_commands') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:<%= commands.length >= 10 ? '#ed4245' : '#FEE75C' %>;"><i data-lucide="layers"></i></div>
                <div class="stat-info">
                    <div class="stat-value" style="<%= commands.length >= 10 ? 'color:#ed4245;' : '' %>"><%= commands.length %>/10</div>
                    <div class="stat-label">Slots Used</div>
                </div>
            </div>
        </div>

        <!-- How to Use -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:#5865F2;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('custom_commands.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('custom_commands.step1_title') %></div>
                    <div class="guide-desc"><%= t('custom_commands.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('custom_commands.step2_title') %></div>
                    <div class="guide-desc"><%= t('custom_commands.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('custom_commands.step3_title') %></div>
                    <div class="guide-desc"><%= t('custom_commands.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('custom_commands.tip') %></div>
        </div>

        <!-- Add Command Form -->
        <div class="settings-card" id="ccFormCard">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-bottom:.9rem;">
                <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
                    <h2 id="ccFormTitle" style="margin:0;"><%= t('custom_commands.add_title') %></h2>
                </div>
                <button type="button" id="ccCancelEdit" class="btn btn-sm" style="display:none;" onclick="cancelEdit()">
                    <i data-lucide="x" style="width:13px;height:13px;"></i> Cancel Edit
                </button>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="form-group">
                    <label class="label"><%= t('custom_commands.trigger_label') %></label>
                    <input type="text" id="ccTrigger" class="input" data-flt-ignore placeholder="<%= t('custom_commands.trigger_placeholder') %>" maxlength="50" oninput="onFormInput()">
                </div>
                <div class="form-group">
                    <label class="label"><%= t('custom_commands.mode_label') %></label>
                    <select id="ccMode" class="select" data-flt-ignore onchange="syncFloatBar()">
                        <option value="prefix"><%= t('custom_commands.mode_prefix') %></option>
                        <option value="exact"><%= t('custom_commands.mode_exact') %></option>
                    </select>
                </div>
            </div>

            <div class="cc-form-preview-row">
                <!-- Left: response inputs -->
                <div class="cc-form-inputs">
                    <div id="ccPlainSection" class="mb-section">
                        <div class="mb-section-head">
                            <span class="mb-section-title" style="display:flex;align-items:center;gap:.4rem;">
                                <i data-lucide="message-square" style="width:13px;height:13px;color:var(--accent);flex-shrink:0;"></i>
                                <%= t('custom_commands.plain_label') %>
                            </span>
                            <div class="ph-btn-group">
                                <div class="ph-picker-anchor">
                                    <button type="button" class="ph-toggle-btn" onclick="toggleCcPicker('ccPlainPhPicker',event)">{…} Placeholder</button>
                                    <div class="ph-dropdown" id="ccPlainPhPicker" style="display:none;"></div>
                                </div>
                                <div class="ph-picker-anchor mention-anchor">
                                    <button type="button" class="ph-toggle-btn" onclick="toggleCcPicker('ccPlainMentionPicker',event)">@ Mention</button>
                                    <div class="ph-dropdown mention-dd" id="ccPlainMentionPicker" style="display:none;"></div>
                                </div>
                            </div>
                        </div>
                        <div class="mb-section-body">
                            <textarea id="ccPlainText" class="input mb-auto-resize" data-flt-ignore rows="3"
                                      placeholder="<%= t('custom_commands.plain_placeholder') %>" maxlength="2000"
                                      oninput="ccResizeArea(this);ccUpdateCount('ccPlainText','ccPlainCount');updatePreview()"></textarea>
                            <div class="mb-char-count" id="ccPlainCount">0 / 2000</div>
                            <textarea id="ccPlainImage" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                      placeholder="Image URL (https://...) — optional"
                                      data-url-label="Image URL"
                                      oninput="ccResizeArea(this);updatePreview()"></textarea>
                        </div>
                    </div>
                    <div id="ccEmbedSection" class="mb-section">
                        <div class="mb-section-head">
                            <span class="mb-section-title" style="display:flex;align-items:center;gap:.4rem;">
                                <i data-lucide="layers" style="width:13px;height:13px;color:var(--accent,#5865F2);flex-shrink:0;"></i>
                                <%= t('custom_commands.ee_builder') %>
                            </span>
                            <div style="display:flex;align-items:center;gap:.45rem;">
                                <span style="font-size:.75rem;color:var(--text-muted);"><%= t('custom_commands.ee_accent') %></span>
                                <input type="color" id="ccEmbedColor" class="cc-ee-color-pk" data-flt-ignore value="#5865F2" oninput="onEeColor()">
                            </div>
                        </div>

                        <div class="mb-section-body" style="padding:0;">
                        <div class="ee-body" style="border:none;border-radius:0;">

                            <!-- AUTHOR -->
                            <div class="ee-section">
                                <div class="ee-sec-label"><%= t('custom_commands.ee_author') %></div>
                                <div class="form-group" style="margin-bottom:.5rem;">
                                    <input type="text" id="ccEmbedAuthor" class="input" data-flt-ignore
                                           placeholder="<%= t('custom_commands.ee_author_name_ph') %>" maxlength="256" oninput="updatePreview()">
                                </div>
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem;">
                                    <textarea id="ccEmbedAuthorUrl" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                           placeholder="<%= t('custom_commands.ee_author_url_ph') %>"
                                           data-url-label="Author URL"
                                           oninput="ccResizeArea(this);updatePreview()"></textarea>
                                    <textarea id="ccEmbedAuthorIcon" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                           placeholder="<%= t('custom_commands.ee_author_icon_ph') %>"
                                           title="Discord only supports public https:// URLs."
                                           data-url-label="Author Icon URL"
                                           oninput="ccResizeArea(this);onEeAuthIcon()"></textarea>
                                </div>
                            </div>

                            <div class="ee-sep"></div>

                            <!-- TITLE -->
                            <div class="ee-section">
                                <div class="ee-sec-label"><%= t('custom_commands.ee_title') %></div>
                                <div class="form-group" style="margin-bottom:.5rem;">
                                    <input type="text" id="ccEmbedTitle" class="input ee-title-input" data-flt-ignore
                                           placeholder="<%= t('custom_commands.ee_title_ph') %>" maxlength="256" oninput="updatePreview()">
                                </div>
                                <textarea id="ccEmbedTitleUrl" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                       placeholder="<%= t('custom_commands.ee_title_url_ph') %>"
                                       data-url-label="Title URL"
                                       oninput="ccResizeArea(this);updatePreview()"></textarea>
                            </div>

                            <div class="ee-sep"></div>

                            <!-- DESCRIPTION -->
                            <div class="ee-section">
                                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.3rem;margin-bottom:.45rem;">
                                    <div class="ee-sec-label" style="margin:0;"><%= t('custom_commands.ee_description') %></div>
                                    <div class="ph-btn-group">
                                        <div class="ph-picker-anchor">
                                            <button type="button" class="ph-toggle-btn cc-ph-dark-btn" onclick="toggleCcPicker('ccDescPhPicker',event)">{…} Placeholder</button>
                                            <div class="ph-dropdown" id="ccDescPhPicker" style="display:none;"></div>
                                        </div>
                                        <div class="ph-picker-anchor mention-anchor">
                                            <button type="button" class="ph-toggle-btn cc-ph-dark-btn" onclick="toggleCcPicker('ccDescMentionPicker',event)">@ Mention</button>
                                            <div class="ph-dropdown mention-dd" id="ccDescMentionPicker" style="display:none;"></div>
                                        </div>
                                    </div>
                                </div>
                                <textarea id="ccEmbedDesc" class="input mb-auto-resize" data-flt-ignore rows="4"
                                          placeholder="<%= t('custom_commands.ee_desc_ph') %>"
                                          maxlength="4096"
                                          oninput="ccResizeArea(this);ccUpdateCount('ccEmbedDesc','ccDescCount');updatePreview()"></textarea>
                                <div class="mb-char-count" id="ccDescCount">0 / 4096</div>
                            </div>

                            <div class="ee-sep"></div>

                            <!-- MEDIA -->
                            <div class="ee-section">
                                <div class="ee-sec-label"><%= t('custom_commands.ee_media') %></div>
                                <div class="form-group" style="margin-bottom:.5rem;">
                                    <label class="label"><%= t('custom_commands.ee_thumbnail') %></label>
                                    <textarea id="ccEmbedThumbnail" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                           placeholder="https://..."
                                           title="Discord only supports public https:// URLs."
                                           data-url-label="Thumbnail URL"
                                           oninput="ccResizeArea(this);onEeThumb()"></textarea>
                                </div>
                                <div>
                                    <label class="label"><%= t('custom_commands.ee_image') %></label>
                                    <textarea id="ccEmbedImage" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                           placeholder="https://..."
                                           title="Discord only supports public https:// URLs."
                                           data-url-label="Image URL"
                                           oninput="ccResizeArea(this);onEeImage()"></textarea>
                                </div>
                            </div>

                            <div class="ee-sep"></div>

                            <!-- FIELDS -->
                            <div class="ee-section">
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem;">
                                    <div class="ee-sec-label" style="margin:0;"><%= t('custom_commands.ee_fields') %> <span id="ccFieldCount" style="font-weight:400;text-transform:none;letter-spacing:0;">(0 / 25)</span></div>
                                    <button type="button" class="btn btn-outline btn-sm" onclick="addEmbedField()">
                                        <i data-lucide="plus" style="width:13px;height:13px;"></i> <%= t('custom_commands.ee_add_field') %>
                                    </button>
                                </div>
                                <div id="ccFieldsList"></div>
                            </div>

                            <div class="ee-sep"></div>

                            <!-- FOOTER -->
                            <div class="ee-section">
                                <div class="ee-sec-label"><%= t('custom_commands.ee_footer') %></div>
                                <div style="margin-bottom:.5rem;">
                                    <input type="text" id="ccEmbedFooter" class="input input-sm" data-flt-ignore
                                           style="display:block;width:100%;box-sizing:border-box;"
                                           placeholder="<%= t('custom_commands.ee_footer_text_ph') %>" maxlength="2048" oninput="updatePreview()">
                                </div>
                                <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;">
                                    <textarea id="ccEmbedFooterIcon" class="input input-sm mb-url-area" data-flt-ignore rows="1"
                                           style="flex:1;min-width:120px;"
                                           placeholder="<%= t('custom_commands.ee_footer_icon_ph') %>"
                                           title="Discord only supports public https:// URLs."
                                           data-url-label="Footer Icon URL"
                                           oninput="ccResizeArea(this);onEeFooterIcon()"></textarea>
                                    <label class="toggle-label" style="gap:.5rem;cursor:pointer;flex-shrink:0;">
                                        <input type="checkbox" id="ccEmbedTimestamp" class="toggle-input" data-flt-ignore onchange="updatePreview()">
                                        <span class="toggle-slider"></span>
                                        <span class="label" style="margin:0;white-space:nowrap;"><%= t('custom_commands.ee_show_timestamp') %></span>
                                    </label>
                                </div>
                            </div>

                        </div><!-- /.ee-body -->
                        </div><!-- /.mb-section-body -->
                    </div>
                </div>

                <!-- Right: Discord-style preview -->
                <div class="cc-preview-panel">
                    <div class="cc-preview-label" onclick="toggleCcPreview()" style="cursor:pointer;user-select:none;" title="Toggle preview">
                        <i id="ccPreviewEyeIcon" data-lucide="eye" style="width:13px;height:13px;flex-shrink:0;"></i> PREVIEW
                    </div>
                    <div class="cc-discord-preview">
                        <div class="cc-dp-channel">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            preview
                        </div>
                        <div class="cc-dp-msg">
                            <div class="cc-dp-ava">
                                <img src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                     alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            </div>
                            <div class="cc-dp-right">
                                <div class="cc-dp-name">
                                    <%- locals.botNavName || 'Bot' %>
                                    <span class="cc-dp-app-badge">
                                        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        APP
                                    </span>
                                    <span class="cc-dp-time">Today at 12:00</span>
                                </div>
                                <div id="ccDpText" class="cc-dp-text" style="display:none;"></div>
                                <div id="ccDpPlainImage" class="cc-dp-plain-image" style="display:none;">
                                    <img id="ccDpPlainImg" src="" alt="" onerror="this.closest('.cc-dp-plain-image').style.display='none'">
                                </div>
                                <div id="ccDpEmbed" class="cc-dp-embed" style="display:none;">
                                    <div id="ccDpEmbedBar" class="cc-dp-embed-bar" style="background:#5865F2;"></div>
                                    <div class="cc-dp-embed-body">
                                        <div class="cc-dp-embed-main">
                                            <div class="cc-dp-embed-content">
                                                <div id="ccDpEmbedAuthor" class="cc-dp-embed-author" style="display:none;"></div>
                                                <div id="ccDpEmbedTitle"  class="cc-dp-embed-title"  style="display:none;"></div>
                                                <div id="ccDpEmbedDesc"   class="cc-dp-embed-desc"   style="display:none;"></div>
                                                <div id="ccDpEmbedFields" class="cc-dp-embed-fields" style="display:none;"></div>
                                            </div>
                                            <div id="ccDpEmbedThumb" class="cc-dp-embed-thumb" style="display:none;">
                                                <img id="ccDpThumbImg" src="" alt="">
                                            </div>
                                        </div>
                                        <div id="ccDpEmbedImage" class="cc-dp-embed-image" style="display:none;">
                                            <img id="ccDpImageImg" src="" alt="">
                                        </div>
                                        <div id="ccDpEmbedFooter" class="cc-dp-embed-footer" style="display:none;"></div>
                                    </div>
                                </div>
                                <div id="ccDpEmpty" class="cc-dp-empty">Type a response to see the preview...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- /.cc-form-preview-row -->

            <div id="ccAddMsg" class="form-message" style="margin-top:.5rem;"></div>
        </div>

        <!-- Command List -->
        <div class="settings-card">
            <h2><%= t('custom_commands.list_title') %> (<span id="cmdCount"><%= commands.length %></span>)</h2>

            <div id="ccList">
                <% if (!commands.length) { %>
                <p style="color:var(--text-muted);font-size:.875rem;text-align:center;padding:1.5rem 0;"><%= t('custom_commands.empty') %></p>
                <% } %>
                <% commands.forEach(function(cmd, i) { %>
                <div class="cc-row" data-idx="<%= i %>">
                    <div class="cc-row-left">
                        <span class="cc-trigger"><code><%= cmd.trigger %></code></span>
                        <span class="cc-badge cc-badge-<%= cmd.mode %>"><%= cmd.mode === 'exact' ? t('custom_commands.badge_exact') : t('custom_commands.badge_prefix') %></span>
                        <span class="cc-badge" style="background:rgba(88,101,242,.15);color:#5865F2;"><%= cmd.responseType === 'embed' ? t('custom_commands.badge_embed') : cmd.responseType === 'both' ? t('custom_commands.badge_both') : t('custom_commands.badge_plain') %></span>
                    </div>
                    <div class="cc-row-right">
                        <label class="toggle-label" style="gap:.35rem;">
                            <input type="checkbox" class="toggle-input cc-enabled" data-flt-ignore <%= cmd.enabled ? 'checked' : '' %> onchange="toggleCmd(this)">
                            <span class="toggle-slider"></span>
                        </label>
                        <button class="btn btn-sm cc-btn-edit" onclick="loadCommandForEdit(parseInt(this.closest('.cc-row').dataset.idx))" title="Edit command">
                            <i data-lucide="pencil" style="width:13px;height:13px;"></i>
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteCommand(this)" title="Delete command">
                            <i data-lucide="trash-2" style="width:14px;height:14px;"></i>
                        </button>
                    </div>
                </div>
                <% }); %>
            </div>
            <div id="ccListMsg" class="form-message" style="margin-top:.75rem;"></div>
        </div>

    </div><!-- /.dash-content-wide -->
    </main>
</div><!-- /.dash-layout -->

<style>
.cc-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: .75rem; padding: .6rem .75rem;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; margin-bottom: .4rem;
    flex-wrap: wrap;
}
.cc-row-left  { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; min-width: 0; }
.cc-row-right { display: flex; align-items: center; gap: .5rem; flex-shrink: 0; }
.cc-trigger code { font-size: .875rem; }
.cc-badge {
    font-size: .75rem; padding: 2px 8px; border-radius: 12px;
    background: rgba(255,255,255,.07); color: var(--text-muted);
}
.cc-badge-exact   { background: rgba(87,242,135,.12); color: #57F287; }
.cc-badge-prefix  { background: rgba(254,231,92,.12);  color: #FEE75C; }
[data-theme="light"] .cc-badge { background: rgba(0,0,0,.06); }
[data-theme="light"] .cc-badge-exact  { background: rgba(40,140,70,.12);  color: #1c7a3f; }
[data-theme="light"] .cc-badge-prefix { background: rgba(180,140,0,.12);  color: #7a5a00; }

@media (max-width: 600px) {
    [style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
}

/* ── Form + Preview layout ──────────────────────────────────────────── */
.cc-form-preview-row {
    display: flex; gap: 1.25rem; align-items: flex-start; margin-top: .25rem;
}
.cc-form-inputs { flex: 1; min-width: 0; }
.cc-preview-panel { width: 460px; flex-shrink: 0; position: sticky; top: calc(var(--navbar-h) + 1.5rem); }

.cc-preview-label {
    font-size: .68rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .1em;
    display: flex; align-items: center; gap: .35rem;
    margin-bottom: .55rem;
}
.cc-preview-label:hover { color: var(--text); }
.cc-discord-preview {
    transition: opacity .2s, transform .2s;
    transform-origin: top center;
}
.cc-preview-hidden .cc-discord-preview {
    opacity: 0; pointer-events: none;
    transform: scaleY(0.92);
    max-height: 0; overflow: hidden; margin: 0; border: none;
}

/* ── Discord preview container (theme-adaptive) ───────────────────── */
.cc-discord-preview {
    background: var(--bg2); border-radius: 10px;
    overflow: hidden; user-select: none;
    border: 1px solid var(--border);
}
.cc-dp-channel {
    background: var(--bg3); border-bottom: 1px solid var(--border);
    padding: .45rem .8rem;
    font-size: .75rem; color: var(--text-muted);
    display: flex; align-items: center; gap: .4rem;
}
.cc-dp-channel svg { opacity: .5; flex-shrink: 0; }

.cc-dp-msg {
    display: flex; gap: .75rem;
    padding: .85rem .85rem .9rem;
}
.cc-dp-ava {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    overflow: hidden; background: #5865F2;
}
.cc-dp-ava img { width: 100%; height: 100%; object-fit: cover; display: block; }
.cc-dp-right { min-width: 0; flex: 1; }

.cc-dp-name {
    display: flex; align-items: center; gap: .35rem; flex-wrap: wrap;
    font-size: .875rem; font-weight: 700; color: var(--text);
    margin-bottom: .25rem; line-height: 1.2;
}
.cc-dp-app-badge {
    display: inline-flex; align-items: center; gap: .2rem;
    font-size: .58rem; font-weight: 700; padding: .12rem .28rem;
    border-radius: 3px; background: #5865F2; color: #fff;
    letter-spacing: .03em; text-transform: uppercase;
    line-height: 1; flex-shrink: 0;
}
.cc-dp-app-badge svg { flex-shrink: 0; }
.cc-dp-time {
    font-size: .72rem; font-weight: 400; color: var(--text-muted);
}

.cc-dp-text {
    font-size: .875rem; color: var(--text);
    line-height: 1.5; word-break: break-word;
    white-space: pre-wrap; margin-bottom: .2rem;
}

/* Plain text image */
.cc-dp-plain-image { margin-top: .35rem; border-radius: 4px; overflow: hidden; max-width: 400px; max-height: 300px; }
.cc-dp-plain-image img { width: 100%; display: block; object-fit: cover; max-height: 300px; }

/* Embed */
.cc-dp-embed {
    display: flex; border-radius: 0 4px 4px 0;
    background: var(--bg3); margin-top: .35rem;
    overflow: hidden; max-width: 100%;
}
.cc-dp-embed-bar { width: 4px; flex-shrink: 0; }
.cc-dp-embed-body { padding: .55rem .75rem; min-width: 0; }
.cc-dp-embed-title {
    font-size: .875rem; font-weight: 700; color: var(--text);
    margin-bottom: .2rem; word-break: break-word; line-height: 1.4;
}
.cc-dp-embed-desc {
    font-size: .8rem; color: var(--text-muted);
    line-height: 1.55; word-break: break-word; white-space: pre-wrap;
}

.cc-dp-empty {
    font-size: .78rem; color: var(--text-muted);
    padding: .2rem 0; font-style: italic; opacity: .6;
}

/* Author */
.cc-dp-embed-author {
    display: flex; align-items: center; gap: .4rem;
    font-size: .78rem; font-weight: 700; color: var(--text);
    margin-bottom: .3rem;
}
.cc-dp-author-icon {
    width: 18px; height: 18px; border-radius: 50%; object-fit: cover;
}
/* Main content + thumbnail */
.cc-dp-embed-main { display: flex; gap: .75rem; align-items: flex-start; }
.cc-dp-embed-content { flex: 1; min-width: 0; }
.cc-dp-embed-thumb { flex-shrink: 0; width: 80px; height: 80px; border-radius: 4px; overflow: hidden; margin-top: .1rem; }
.cc-dp-embed-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* Fields grid */
.cc-dp-embed-fields {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: .35rem .65rem; margin-top: .35rem;
}
.cc-dp-field { }
.cc-dp-field-block { grid-column: 1 / -1; }
.cc-dp-field-name { font-size: .78rem; font-weight: 700; color: var(--text); margin-bottom: .1rem; word-break: break-word; }
.cc-dp-field-val  { font-size: .77rem; color: var(--text-muted); word-break: break-word; white-space: pre-wrap; }

/* Large image */
.cc-dp-embed-image { margin-top: .5rem; border-radius: 4px; overflow: hidden; max-height: 140px; }
.cc-dp-embed-image img { width: 100%; display: block; object-fit: cover; max-height: 140px; }

/* Footer */
.cc-dp-embed-footer {
    display: flex; align-items: center; gap: .35rem; flex-wrap: wrap;
    font-size: .72rem; color: var(--text-muted);
    margin-top: .5rem;
}
.cc-dp-footer-icon { width: 16px; height: 16px; border-radius: 50%; object-fit: cover; }
.cc-dp-footer-sep  { opacity: .5; }

/* Discord markdown in preview */
.cc-inline-code {
    background: rgba(0,0,0,.25); color: #f8cdbc;
    padding: .1em .3em; border-radius: 3px;
    font-family: Consolas, 'Courier New', monospace; font-size: .875em;
}
[data-theme="light"] .cc-inline-code { background: rgba(0,0,0,.07); color: #c0392b; }
.cc-code-block {
    display: block; background: rgba(0,0,0,.22); color: var(--text);
    padding: .4rem .6rem; border-radius: 4px;
    font-family: Consolas, 'Courier New', monospace; font-size: .82em;
    white-space: pre; overflow-x: auto; max-width: 100%; margin: .1rem 0;
}
[data-theme="light"] .cc-code-block { background: rgba(0,0,0,.05); }
.cc-spoiler {
    background: var(--text-muted); color: transparent;
    border-radius: 2px; padding: 0 2px;
    cursor: pointer; transition: color .15s, background .15s; user-select: none;
}
.cc-spoiler:hover { color: var(--text); background: var(--bg3); }
.cc-blockquote {
    display: inline-block; border-left: 3px solid rgba(128,128,128,.5);
    padding-left: .45rem; min-width: calc(100% - .45rem);
}

/* Embed field rows in form */
.cc-field-row {
    display: flex; gap: .6rem; align-items: flex-start;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; padding: .65rem .75rem; margin-bottom: .45rem;
}
.cc-field-inputs { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .4rem; }
.cc-field-inline-row { display: flex; align-items: center; gap: .5rem; margin-top: .15rem; }
.cc-field-inline-row label { font-size: .8rem; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; gap: .3rem; }
.cc-field-num { font-size: .68rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: .1rem; }
.cc-field-del { flex-shrink: 0; margin-top: .1rem; }

@media (max-width: 840px) {
    .cc-form-preview-row { flex-direction: column; }
    .cc-preview-panel { width: 100%; }
}

/* ── mb-section card (Text Message / Embed Builder wrappers) ─────── */
.mb-section {
    border: 1px solid var(--border); border-radius: var(--radius, 10px);
    overflow: visible; margin-bottom: .85rem;
}
.mb-section-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: .45rem .85rem; background: var(--bg3);
    border-bottom: 1px solid var(--border);
    border-radius: var(--radius, 10px) var(--radius, 10px) 0 0;
    flex-wrap: wrap; gap: .4rem;
}
.mb-section-title { font-size: .8rem; font-weight: 600; color: var(--text); display: flex; align-items: center; gap: .4rem; }
.mb-section-body  { padding: .85rem; display: flex; flex-direction: column; gap: .7rem; }

/* ── Auto-resize URL textareas ──────────────────────────────────── */
.mb-url-area {
    resize: none; overflow: hidden; min-height: 34px; line-height: 1.45;
    word-break: break-all; font-family: inherit; font-size: .85rem;
    padding: .4rem .6rem; box-sizing: border-box; width: 100%;
}
.mb-auto-resize { resize: none !important; overflow: hidden !important; }

/* ── Char counter ────────────────────────────────────────────────── */
.mb-char-count {
    text-align: right; font-size: .72rem; color: var(--text-muted);
    margin-top: .18rem; transition: color .2s; user-select: none;
}
.mb-char-count.warn   { color: #f0b232; }
.mb-char-count.danger { color: #ed4245; font-weight: 600; }

/* ── Preview text wrap ───────────────────────────────────────────── */
.cc-dp-text-wrap { min-width: 0; flex: 1; word-break: break-word; overflow-wrap: anywhere; }

/* ── Mobile: prevent preview author/footer from extending ────────── */
@media (max-width: 640px) {
    .cc-dp-embed-footer { flex-wrap: nowrap; overflow: hidden; }
    .cc-dp-embed-footer .cc-dp-text-wrap,
    .cc-dp-embed-author .cc-dp-text-wrap {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1 1 0;
        min-width: 0;
    }
}

/* ── Embed Builder ───────────────────────────────────────────────── */
.cc-ee-color-pk {
    width: 30px; height: 30px; padding: 2px; border-radius: 6px;
    border: 1px solid var(--border); background: none; cursor: pointer;
}
.ee-body {
    border: 1px solid var(--border); border-radius: 10px; overflow: visible;
}
.ee-section { padding: .85rem 1rem; }
.ee-sep { height: 1px; background: var(--border); }
.ee-sec-label {
    font-size: .68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--text-muted); margin-bottom: .5rem;
}
.ee-title-input { font-weight: 600 !important; }
.input-sm { font-size: .85rem !important; padding: .35rem .65rem !important; }

/* ── URL warning state ───────────────────────────────────────────── */
.cc-url-warn {
    border-color: rgba(240,71,71,.55) !important;
    background: rgba(240,71,71,.06) !important;
}
.cc-url-warn-msg {
    font-size: .7rem; color: rgba(240,71,71,.85);
    display: flex; align-items: center; gap: .25rem;
    margin-top: .2rem;
}

/* ── Field cards inside embed builder ───────────────────────────── */
.ee-body .cc-field-row { background: var(--bg2, rgba(255,255,255,.02)); }
.ee-body .cc-field-inline-row input[type="checkbox"] { accent-color: #5865F2; }

/* ── Edit button ─────────────────────────────────────────────────── */
.cc-btn-edit {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.55);
}
[data-theme="light"] .cc-btn-edit {
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text-muted);
}
[data-theme="light"] .cc-btn-edit:hover {
    background: rgba(88,101,242,.1);
    border-color: rgba(88,101,242,.4);
    color: #5865F2;
}
.cc-btn-edit:hover {
    background: rgba(88,101,242,.18);
    border-color: rgba(88,101,242,.4);
    color: #c0c7ff;
}

/* ── Placeholder / Mention picker ────────────────────────────────── */
.ph-picker-anchor { position: relative; }
.ph-toggle-btn {
    font-size: .72rem; padding: 3px 10px;
    border: 1px solid var(--border, #3f4147); border-radius: 5px;
    background: rgba(255,255,255,.04); color: rgba(255,255,255,.5);
    cursor: pointer; font-family: inherit; white-space: nowrap;
    line-height: 1.6; transition: background .15s, color .15s, border-color .15s;
    display: inline-flex; align-items: center; gap: 4px;
}
.ph-toggle-btn:hover { background: rgba(255,255,255,.1); color: var(--text, #dbdee1); border-color: rgba(255,255,255,.2); }
.ph-toggle-btn.active { background: rgba(88,101,242,.18); border-color: rgba(88,101,242,.5); color: #c0c7ff; }
/* Dark panel variant */
.cc-ph-dark-btn {
    font-size: .68rem; padding: 2px 8px;
    background: rgba(255,255,255,.05); color: rgba(255,255,255,.35);
    border-color: rgba(255,255,255,.1);
}
.cc-ph-dark-btn:hover { background: rgba(255,255,255,.12); color: rgba(255,255,255,.75); border-color: rgba(255,255,255,.2); }
.cc-ph-dark-btn.active { background: rgba(88,101,242,.2); border-color: rgba(88,101,242,.4); color: #c0c7ff; }
.ph-btn-group { display: flex; align-items: stretch; flex-shrink: 0; }
.ph-btn-group .ph-picker-anchor:first-child .ph-toggle-btn { border-radius: 5px 0 0 5px; }
.ph-btn-group .ph-picker-anchor:last-child  .ph-toggle-btn { border-radius: 0 5px 5px 0; border-left: none; }
.ph-btn-group .ph-picker-anchor:only-child  .ph-toggle-btn { border-radius: 5px; }
.ph-dropdown {
    position: absolute; top: calc(100% + 4px); right: 0; z-index: 500;
    background: #2b2d31; border: 1px solid #3f4147;
    border-radius: 8px; padding: .5rem; min-width: 300px;
    box-shadow: 0 8px 28px rgba(0,0,0,.65);
    display: grid; grid-template-columns: 1fr 1fr; gap: .25rem;
}
.ph-item {
    display: flex; flex-direction: column; align-items: flex-start;
    padding: .32rem .5rem; border: 1px solid transparent;
    border-radius: 5px; background: transparent;
    cursor: pointer; text-align: left; width: 100%;
    transition: background .12s;
}
.ph-item:hover { background: rgba(255,255,255,.09); border-color: #4f5660; }
.ph-item code { font-size: .76rem; color: #7289da; font-family: monospace; }
.ph-item span { font-size: .67rem; color: #80848e; margin-top: 1px; }
.mention-dd { grid-template-columns: 1fr; min-width: 200px; max-height: 280px; overflow-y: auto; padding: .35rem; }
.mention-dd .ph-item span { font-size: .82rem; color: inherit; margin-top: 0; }
.ph-group-label {
    font-size: .67rem; font-weight: 700; color: #80848e;
    text-transform: uppercase; letter-spacing: .04em;
    padding: .45rem .5rem .1rem; pointer-events: none;
    grid-column: 1 / -1;
}
.mention-search-input {
    width: 100%; box-sizing: border-box; padding: .28rem .45rem;
    font-size: .8rem; background: rgba(255,255,255,.06);
    border: 1px solid #3f4147; border-radius: 4px;
    color: #dbdee1; outline: none; margin-bottom: .15rem;
    grid-column: 1 / -1;
}
.mention-search-input:focus { border-color: var(--accent, #5865F2); }
</style>

<script>
const GUILD_ID = '<%= guild.id %>';
let commands      = <%- JSON.stringify(commands) %>;
let savedCommands = JSON.parse(JSON.stringify(commands));
let embedFields      = []; // { name, value, inline }
let editingIdx       = -1;
let _savedEditingCmd = null;

const i18n = {
    empty:        '<%= t('custom_commands.empty') %>',
    add_title:    '<%= t('custom_commands.add_title') %>',
    badge_exact:  '<%= t('custom_commands.badge_exact') %>',
    badge_prefix: '<%= t('custom_commands.badge_prefix') %>',
    badge_embed:  '<%= t('custom_commands.badge_embed') %>',
    badge_plain:  '<%= t('custom_commands.badge_plain') %>',
    badge_both:   '<%= t('custom_commands.badge_both') %>',
    err_no_trigger: '<%= t('custom_commands.err_no_trigger') %>',
    err_no_text:    '<%= t('custom_commands.err_no_text') %>',
    err_no_embed:   '<%= t('custom_commands.err_no_embed') %>',
    err_no_both:    '<%= t('custom_commands.err_no_both') %>',
};

// Maps for mention picker
const CC_CHANNELS = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;
const CC_ROLES    = <%- JSON.stringify(Object.fromEntries((locals.roles||[]).map(r=>[r.id,{name:r.name,color:r.color||'#99aab5'}]))) %>;
const CC_PLACEHOLDERS = [
    { group: 'USER', items: [
        ['{user.mention}',  'Mention user'],
        ['{user.username}', 'Username'],
        ['{user.id}',       'User ID'],
        ['{user.avatar}',   'Avatar URL'],
    ]},
    { group: 'SERVER', items: [
        ['{server.name}',   'Server name'],
        ['{server.id}',     'Server ID'],
        ['{server.icon}',   'Server icon URL'],
    ]},
];

const CC_SAMPLE = {
    user_username: <%- JSON.stringify(sampleUser.username) %>,
    user_id:       <%- JSON.stringify(sampleUser.id) %>,
    user_avatar:   <%- JSON.stringify(sampleUser.avatarUrl) %>,
    server_name:   <%- JSON.stringify(guild.name) %>,
    server_id:     <%- JSON.stringify(guild.id) %>,
    server_icon:   <%- JSON.stringify(guildIconUrl) %>,
    channel_name:  Object.values(CC_CHANNELS)[0] || 'general',
};

function showMsg(el, text, type) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (type === 'success') setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3500);
}

async function apiFetch(path, method, body) {
    const res = await fetch(`/api/guild/${GUILD_ID}${path}`, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body:    body ? JSON.stringify(body) : undefined,
    });
    return res.json();
}


function updatePreview() {
    const plainImg  = (document.getElementById('ccPlainImage')?.value      || '').trim();
    const text      = (document.getElementById('ccPlainText')?.value       || '').trimEnd();
    const author    = (document.getElementById('ccEmbedAuthor')?.value     || '').trim();
    const aIcon     = (document.getElementById('ccEmbedAuthorIcon')?.value || '').trim();
    const authorUrl = (document.getElementById('ccEmbedAuthorUrl')?.value  || '').trim();
    const title     = (document.getElementById('ccEmbedTitle')?.value      || '').trim();
    const titleUrl  = (document.getElementById('ccEmbedTitleUrl')?.value   || '').trim();
    const desc      = (document.getElementById('ccEmbedDesc')?.value       || '').trimEnd();
    const color  = (document.getElementById('ccEmbedColor')?.value      || '#5865F2');
    const thumb  = (document.getElementById('ccEmbedThumbnail')?.value  || '').trim();
    const image  = (document.getElementById('ccEmbedImage')?.value      || '').trim();
    const footer = (document.getElementById('ccEmbedFooter')?.value     || '').trim();
    const fIcon  = (document.getElementById('ccEmbedFooterIcon')?.value || '').trim();
    const ts     = document.getElementById('ccEmbedTimestamp')?.checked;

    const activeFields = embedFields.filter(f => f.name.trim() || f.value.trim());
    const showText  = text.length > 0;
    const showEmbed = !!(author || title || desc || activeFields.length || image || thumb || footer || ts);

    const showPlainImg = !!(plainImg && isDirectImageUrl(plainImg));
    // Warn: red border if URL is not empty and not a direct image link
    (function() {
        const el = document.getElementById('ccPlainImage');
        if (!el) return;
        const bad = !!plainImg && !isUrlPlaceholder(plainImg) && !isDirectImageUrl(plainImg);
        el.classList.toggle('cc-url-warn', bad);
        el.title = bad
            ? (isHttpUrl(plainImg) ? '⚠ Must be a direct image link (.png, .jpg, .gif, .webp)' : '⚠ URL must start with https://')
            : '';
    })();
    document.getElementById('ccDpText').style.display       = showText     ? '' : 'none';
    document.getElementById('ccDpEmbed').style.display      = showEmbed    ? '' : 'none';
    document.getElementById('ccDpEmpty').style.display      = (!showText && !showEmbed && !showPlainImg) ? '' : 'none';

    if (showText) document.getElementById('ccDpText').innerHTML = resolveCcPreview(text, true);

    const dpPlainImage = document.getElementById('ccDpPlainImage');
    if (showPlainImg) {
        dpPlainImage.style.display = '';
        document.getElementById('ccDpPlainImg').src = resolveSampleUrl(plainImg) || plainImg;
    } else {
        dpPlainImage.style.display = 'none';
    }

    if (showEmbed) {
        document.getElementById('ccDpEmbedBar').style.background = color;

        // Author
        const dpAuthor = document.getElementById('ccDpEmbedAuthor');
        dpAuthor.style.display = author ? '' : 'none';
        if (author) {
            const authorResolved = resolveCcPreview(author);
            const authorText = authorUrl
                ? `<span style="cursor:pointer;text-decoration:underline;text-underline-offset:2px;text-decoration-color:rgba(255,255,255,.35);">${authorResolved}</span>`
                : authorResolved;
            const aIconOk = aIcon && isDirectImageUrl(aIcon);
            dpAuthor.innerHTML = (aIconOk ? `<img class="cc-dp-author-icon" src="${escHtml(resolveSampleUrl(aIcon) || aIcon)}" onerror="this.style.display='none'" alt=""> ` : '') + `<span class="cc-dp-text-wrap">${authorText}</span>`;
        }

        // Title
        const dpTitle = document.getElementById('ccDpEmbedTitle');
        dpTitle.style.display = title ? '' : 'none';
        if (title) {
            const titleResolved = resolveCcPreview(title);
            if (titleUrl) {
                dpTitle.innerHTML = `<span style="color:#5d9ef3;text-decoration:underline;text-underline-offset:2px;cursor:pointer;">${titleResolved}</span>`;
            } else {
                dpTitle.innerHTML = titleResolved;
            }
        }

        // Desc
        const dpDesc = document.getElementById('ccDpEmbedDesc');
        dpDesc.style.display = desc ? '' : 'none';
        if (desc) dpDesc.innerHTML = resolveCcPreview(desc, true);

        // Fields
        const dpFields = document.getElementById('ccDpEmbedFields');
        if (activeFields.length) {
            dpFields.style.display = '';
            dpFields.innerHTML = activeFields.map(f =>
                `<div class="cc-dp-field${f.inline ? '' : ' cc-dp-field-block'}">
                    <div class="cc-dp-field-name">${resolveCcPreview(f.name || '​')}</div>
                    <div class="cc-dp-field-val">${resolveCcPreview(f.value || '​')}</div>
                </div>`
            ).join('');
        } else { dpFields.style.display = 'none'; }

        // Thumbnail
        const dpThumb = document.getElementById('ccDpEmbedThumb');
        const thumbOk = thumb && isDirectImageUrl(thumb);
        dpThumb.style.display = thumbOk ? '' : 'none';
        if (thumbOk) {
            const img = document.getElementById('ccDpThumbImg');
            img.src = resolveSampleUrl(thumb) || thumb; img.onerror = () => { dpThumb.style.display = 'none'; };
        }

        // Image
        const dpImage = document.getElementById('ccDpEmbedImage');
        const imageOk = image && isDirectImageUrl(image);
        dpImage.style.display = imageOk ? '' : 'none';
        if (imageOk) {
            const img = document.getElementById('ccDpImageImg');
            img.src = resolveSampleUrl(image) || image; img.onerror = () => { dpImage.style.display = 'none'; };
        }

        // Footer
        const dpFooter = document.getElementById('ccDpEmbedFooter');
        if (footer || ts) {
            dpFooter.style.display = '';
            const _d = new Date();
            const now = 'Today at ' + _d.toLocaleString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
            dpFooter.innerHTML =
                (fIcon && isDirectImageUrl(fIcon) ? `<img class="cc-dp-footer-icon" src="${escHtml(resolveSampleUrl(fIcon) || fIcon)}" onerror="this.style.display='none'" alt=""> ` : '') +
                (footer ? `<span class="cc-dp-text-wrap">${resolveCcPreview(footer)}</span>` : '') +
                (footer && ts ? '<span class="cc-dp-footer-sep" style="flex-shrink:0;"> • </span>' : '') +
                (ts ? `<span style="flex-shrink:0;">${now}</span>` : '');
        } else { dpFooter.style.display = 'none'; }
    }
    syncFloatBar();
}

/* ── Embed field management ─────────────────────────────────────────── */
function addEmbedField() {
    if (embedFields.length >= 25) return;
    embedFields.push({ name: '', value: '', inline: false });
    renderEmbedFields();
    updatePreview();
}

function removeEmbedField(idx) {
    embedFields.splice(idx, 1);
    renderEmbedFields();
    updatePreview();
}

function renderEmbedFields() {
    const container = document.getElementById('ccFieldsList');
    const countEl   = document.getElementById('ccFieldCount');
    if (countEl) countEl.textContent = `(${embedFields.length} / 25)`;
    if (!embedFields.length) { container.innerHTML = ''; return; }
    container.innerHTML = embedFields.map((f, i) => `
        <div class="cc-field-row" data-fi="${i}">
            <div class="cc-field-inputs">
                <div class="cc-field-num">Field #${i + 1}</div>
                <input type="text" class="input" placeholder="Field name…" maxlength="256" value="${escHtml(f.name)}"
                    oninput="embedFields[${i}].name=this.value;updatePreview()">
                <textarea class="input" placeholder="Field value…" maxlength="1024" rows="2" style="resize:vertical;"
                    oninput="embedFields[${i}].value=this.value;updatePreview()">${escHtml(f.value)}</textarea>
                <div class="cc-field-inline-row">
                    <label>
                        <input type="checkbox" ${f.inline ? 'checked' : ''} onchange="embedFields[${i}].inline=this.checked;updatePreview()">
                        Inline
                    </label>
                </div>
            </div>
            <button type="button" class="btn btn-danger btn-sm cc-field-del" onclick="removeEmbedField(${i})">
                <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
            </button>
        </div>`).join('');
    if (window.lucide) lucide.createIcons();
}

async function saveCommands() {
    const msg  = document.getElementById('ccListMsg');
    const data = await apiFetch('/custom-commands', 'POST', { commands });
    showMsg(msg, data.message, data.success ? 'success' : 'error');
    if (data.success) {
        savedCommands = JSON.parse(JSON.stringify(commands));
        document.getElementById('cmdCount').textContent = commands.length;
    }
    return data.success;
}

function onFormInput() {
    syncFloatBar();
}

function clearForm() {
    document.getElementById('ccTrigger').value          = '';
    document.getElementById('ccPlainText').value        = '';
    document.getElementById('ccPlainImage').value       = '';
    document.getElementById('ccEmbedAuthor').value      = '';
    document.getElementById('ccEmbedAuthorUrl').value   = '';
    document.getElementById('ccEmbedAuthorIcon').value  = '';
    document.getElementById('ccEmbedTitle').value       = '';
    document.getElementById('ccEmbedTitleUrl').value    = '';
    document.getElementById('ccEmbedDesc').value        = '';
    document.getElementById('ccEmbedThumbnail').value   = '';
    document.getElementById('ccEmbedImage').value       = '';
    document.getElementById('ccEmbedFooter').value      = '';
    document.getElementById('ccEmbedFooterIcon').value  = '';
    document.getElementById('ccEmbedTimestamp').checked = false;
    document.getElementById('ccEmbedColor').value       = '#5865F2';
    document.getElementById('ccMode').value = 'prefix';
    const barEl = document.getElementById('ccEeBarEl');
    if (barEl) barEl.style.background = '#5865F2';
    ['ccEmbedAuthorIcon','ccEmbedThumbnail','ccEmbedImage','ccEmbedFooterIcon'].forEach(id => {
        document.getElementById(id)?.classList.remove('cc-url-warn');
    });
    _lastWarnedUrl.clear();
    embedFields = [];
    renderEmbedFields();
    ccResizeAll();
    ccUpdateCount('ccPlainText', 'ccPlainCount');
    ccUpdateCount('ccEmbedDesc', 'ccDescCount');
    updatePreview();
    const addMsg = document.getElementById('ccAddMsg');
    addMsg.textContent = '';
    addMsg.className   = 'form-message';
}

function buildEmbedResponse() {
    const authorName  = document.getElementById('ccEmbedAuthor').value.trim();
    const authorIcon  = document.getElementById('ccEmbedAuthorIcon').value.trim();
    const authorUrl   = document.getElementById('ccEmbedAuthorUrl').value.trim();
    const title       = document.getElementById('ccEmbedTitle').value.trim();
    const titleUrl    = document.getElementById('ccEmbedTitleUrl').value.trim();
    const description = document.getElementById('ccEmbedDesc').value.trim();
    const color       = document.getElementById('ccEmbedColor').value;
    const thumbnail   = document.getElementById('ccEmbedThumbnail').value.trim();
    const imageURL    = document.getElementById('ccEmbedImage').value.trim();
    const footerText  = document.getElementById('ccEmbedFooter').value.trim();
    const footerIcon  = document.getElementById('ccEmbedFooterIcon').value.trim();
    const timestamp   = document.getElementById('ccEmbedTimestamp').checked;
    const cleanFields = embedFields.filter(f => f.name.trim() && f.value.trim())
                        .map(f => ({ name: f.name.trim(), value: f.value.trim(), inline: !!f.inline }));
    const r = { color };
    if (authorName)         r.author       = { name: authorName, iconURL: httpUrlOrNull(authorIcon), url: httpUrlOrNull(authorUrl) };
    if (title)              r.title        = title;
    if (titleUrl && isHttpUrl(titleUrl)) r.titleUrl = titleUrl;
    if (description)        r.description  = description;
    if (cleanFields.length) r.fields       = cleanFields;
    if (thumbnail && isHttpUrl(thumbnail)) r.thumbnailURL = thumbnail;
    if (imageURL && isHttpUrl(imageURL))   r.imageURL     = imageURL;
    if (footerText||footerIcon) r.footer   = { text: footerText, iconURL: httpUrlOrNull(footerIcon) };
    if (timestamp)          r.timestamp    = true;
    return r;
}

function addCommandFromForm() {
    const trigger = document.getElementById('ccTrigger').value.trim();
    const addMsg  = document.getElementById('ccAddMsg');

    // URL validation always runs first — red borders must block save regardless of trigger state
    const badUrl = getInvalidUrlField();
    if (badUrl) {
        const msg = badUrl.reason === 'not_image'
            ? `**${badUrl.label}**: Must be a direct image link ending with .png, .jpg, .gif, or .webp`
            : (/^https?:\/\//i.test(document.getElementById(badUrl.id)?.value || '')
                ? `**${badUrl.label}**: Not a valid URL — must be a public https:// link.`
                : `**${badUrl.label}**: URL must start with https://`);
        showMsg(addMsg, msg, 'error');
        document.getElementById(badUrl.id)?.focus();
        return false;
    }

    if (!trigger) {
        const hasContent = !!(
            document.getElementById('ccPlainText').value.trim() ||
            document.getElementById('ccEmbedAuthor').value.trim() ||
            document.getElementById('ccEmbedTitle').value.trim() ||
            document.getElementById('ccEmbedDesc').value.trim()
        );
        if (hasContent) {
            showMsg(addMsg, i18n.err_no_trigger || 'Trigger / keyword is required.', 'error');
            document.getElementById('ccTrigger').focus();
            return false;
        }
        return true; // form is truly empty, nothing to add
    }

    // Slot limit check — only when adding new (not editing existing)
    if (editingIdx === -1 && commands.length >= 10) {
        showMsg(addMsg, 'Command limit reached (10/10). Delete an existing command first.', 'error');
        return false;
    }

    const mode   = document.getElementById('ccMode').value;
    const text      = document.getElementById('ccPlainText').value.trim();
    const plainImg  = document.getElementById('ccPlainImage').value.trim();
    const embedResp = buildEmbedResponse();
    const hasEmbed  = !!(embedResp.author?.name || embedResp.title || embedResp.description ||
                         embedResp.fields?.length || embedResp.imageURL || embedResp.thumbnailURL ||
                         embedResp.footer?.text || embedResp.timestamp);

    if (!text && !hasEmbed && !plainImg) {
        showMsg(addMsg, i18n.err_no_text, 'error');
        return false;
    }

    let resType, response;
    if (text && hasEmbed)  { resType = 'both';  response = { text, plainImageURL: plainImg || undefined, ...embedResp }; }
    else if (hasEmbed)     { resType = 'embed'; response = embedResp; }
    else                   { resType = 'plain'; response = { text, plainImageURL: plainImg || undefined }; }

    if (editingIdx >= 0) {
        commands[editingIdx] = { ...commands[editingIdx], trigger, mode, responseType: resType, response };
        editingIdx = -1;
        document.getElementById('ccFormTitle').textContent = i18n.add_title;
        document.getElementById('ccCancelEdit').style.display = 'none';
    } else {
        commands.push({ trigger, mode, responseType: resType, response, enabled: true });
    }
    clearForm();
    renderList();
    return true;
}

function deleteCommand(btn) {
    const idx = parseInt(btn.closest('.cc-row').dataset.idx);
    commands.splice(idx, 1);
    renderList();
    window._floatDirty?.();
}

function renderList() {
    const container = document.getElementById('ccList');
    if (!commands.length) {
        container.innerHTML = `<p style="color:var(--text-muted);font-size:.875rem;text-align:center;padding:1.5rem 0;">${i18n.empty}</p>`;
        document.getElementById('cmdCount').textContent = 0;
        return;
    }
    container.innerHTML = commands.map((cmd, i) => `
        <div class="cc-row" data-idx="${i}">
            <div class="cc-row-left">
                <span class="cc-trigger"><code>${escHtml(cmd.trigger)}</code></span>
                <span class="cc-badge cc-badge-${cmd.mode}">${cmd.mode === 'exact' ? i18n.badge_exact : i18n.badge_prefix}</span>
                <span class="cc-badge" style="background:rgba(88,101,242,.15);color:#5865F2;">${cmd.responseType === 'embed' ? i18n.badge_embed : cmd.responseType === 'both' ? i18n.badge_both : i18n.badge_plain}</span>
            </div>
            <div class="cc-row-right">
                <label class="toggle-label" style="gap:.35rem;">
                    <input type="checkbox" class="toggle-input cc-enabled" data-flt-ignore ${cmd.enabled ? 'checked' : ''} onchange="toggleCmd(this)">
                    <span class="toggle-slider"></span>
                </label>
                <button class="btn btn-sm cc-btn-edit" onclick="loadCommandForEdit(${i})" title="Edit command">
                    <i data-lucide="pencil" style="width:13px;height:13px;"></i>
                </button>
                <button class="btn btn-danger btn-sm" onclick="deleteCommand(this)" title="Delete command">
                    <i data-lucide="trash-2" style="width:14px;height:14px;"></i>
                </button>
            </div>
        </div>`).join('');
    if (window.lucide) lucide.createIcons();
    document.getElementById('cmdCount').textContent = commands.length;
    const badge = document.getElementById('ccSlotBadge');
    if (badge) {
        badge.textContent = `${commands.length}/10 slots`;
        badge.style.cssText = commands.length >= 10
            ? 'font-size:.72rem;padding:.2rem .6rem;border-radius:999px;font-weight:600;white-space:nowrap;background:rgba(237,66,69,.18);color:#ed4245;'
            : 'font-size:.72rem;padding:.2rem .6rem;border-radius:999px;font-weight:600;white-space:nowrap;background:rgba(88,101,242,.15);color:#5865F2;';
    }
}

function toggleCmd(el) {
    const idx = parseInt(el.closest('.cc-row').dataset.idx);
    commands[idx].enabled = el.checked;
