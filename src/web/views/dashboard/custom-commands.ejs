}

function syncFloatBar() {
    const formHasContent = !!(
        document.getElementById('ccTrigger').value.trim()          ||
        document.getElementById('ccPlainText').value.trim()        ||
        document.getElementById('ccEmbedAuthor').value.trim()      ||
        document.getElementById('ccEmbedAuthorUrl').value.trim()   ||
        document.getElementById('ccEmbedAuthorIcon').value.trim()  ||
        document.getElementById('ccEmbedTitle').value.trim()       ||
        document.getElementById('ccEmbedTitleUrl').value.trim()    ||
        document.getElementById('ccEmbedDesc').value.trim()        ||
        document.getElementById('ccEmbedThumbnail').value.trim()   ||
        document.getElementById('ccEmbedImage').value.trim()       ||
        document.getElementById('ccEmbedFooter').value.trim()      ||
        document.getElementById('ccEmbedFooterIcon').value.trim()  ||
        document.getElementById('ccEmbedTimestamp').checked        ||
        (document.getElementById('ccEmbedColor').value.toLowerCase() !== '#5865f2') ||
        embedFields.some(f => f.name.trim() || f.value.trim())
    );
    const listClean = JSON.stringify(commands) === JSON.stringify(savedCommands);
    if (!formHasContent && listClean) window._floatClean?.();
    else window._floatDirty?.();
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ── URL validation helpers ──────────────────────────────────── */
function isUrlPlaceholder(url) {
    return /\{(user\.avatar|server\.icon)\}/.test(url);
}
function resolveSampleUrl(url) {
    if (!url) return '';
    return url
        .replace(/\{user\.avatar\}/g, CC_SAMPLE.user_avatar || '')
        .replace(/\{server\.icon\}/g,  CC_SAMPLE.server_icon  || '');
}
function isHttpUrl(url) {
    if (!url) return true; // empty is fine
    if (isUrlPlaceholder(url)) return true; // placeholder resolves to real URL at runtime
    try { const u = new URL(url); return u.protocol === 'http:' || u.protocol === 'https:'; }
    catch { return false; }
}
function httpUrlOrNull(url) {
    return (url && isHttpUrl(url)) ? url : null;
}
function isDirectImageUrl(url) {
    if (!url || isUrlPlaceholder(url)) return true; // placeholder or empty — valid at runtime
    if (!isHttpUrl(url)) return false;
    return /\.(png|jpe?g|gif|webp|bmp|avif)(?:[?#]|$)/i.test(url);
}

const _lastWarnedUrl = new Map();
function validateUrlOnBlur(el, event) {
    // If focus moved to the Reset button, suppress — reset will clear the field anyway
    const target = event?.relatedTarget;
    if (target && (target.id === 'flt-reset' || target.closest?.('#flt-bar'))) return;
    const url = el.value.trim();
    if (!url || isUrlPlaceholder(url) || isHttpUrl(url)) {
        _lastWarnedUrl.delete(el.id);
        return;
    }
    if (_lastWarnedUrl.get(el.id) === url) return;
    _lastWarnedUrl.set(el.id, url);
    const label = el.dataset.urlLabel || 'URL';
    const msg = /^https?:\/\//i.test(url)
        ? `**${label}**: Not a valid URL — must be a public https:// link.`
        : `**${label}**: URL must start with https://`;
    showMsg(null, msg, 'error');
}
function getInvalidUrlField() {
    // [id, label, mustBeImage]
    const fields = [
        ['ccPlainImage',      'Image URL',         true],
        ['ccEmbedAuthorUrl',  'Author URL',         false],
        ['ccEmbedAuthorIcon', 'Author Icon URL',    true],
        ['ccEmbedTitleUrl',   'Title URL',          false],
        ['ccEmbedThumbnail',  'Thumbnail URL',      true],
        ['ccEmbedImage',      'Embed Image URL',    true],
        ['ccEmbedFooterIcon', 'Footer Icon URL',    true],
    ];
    for (const [id, label, mustBeImage] of fields) {
        const el = document.getElementById(id);
        if (!el) continue;
        const url = el.value.trim();
        if (!url || isUrlPlaceholder(url)) continue;
        if (!isHttpUrl(url)) return { id, label, reason: 'not_https' };
        if (mustBeImage && !isDirectImageUrl(url)) return { id, label, reason: 'not_image' };
    }
    return null;
}

function setWarn(inputId, url, requireImage = false) {
    const el = document.getElementById(inputId);
    if (!el) return;
    let bad = false, tip = '';
    if (url && !isUrlPlaceholder(url)) {
        if (!isHttpUrl(url))                        { bad = true; tip = '⚠ URL must start with https://'; }
        else if (requireImage && !isDirectImageUrl(url)) { bad = true; tip = '⚠ Must be a direct image link (.png, .jpg, .gif, .webp)'; }
    }
    el.classList.toggle('cc-url-warn', bad);
    el.title = bad ? tip : '';
}

/* ── Placeholder insert ──────────────────────────────────────── */
function insertPlaceholder(targetId, text) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const start = el.selectionStart ?? el.value.length;
    const end   = el.selectionEnd   ?? el.value.length;
    el.value = el.value.slice(0, start) + text + el.value.slice(end);
    el.selectionStart = el.selectionEnd = start + text.length;
    el.focus();
    el.dispatchEvent(new Event('input', { bubbles: true }));
}

