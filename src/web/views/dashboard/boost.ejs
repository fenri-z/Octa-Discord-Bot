// ── Placeholder picker ─────────────────────────────────────────────────────
const PLACEHOLDERS = [
    ['{member}',   I18N_BOOST_PH_MENTION],
    ['{username}', I18N_BOOST_PH_USERNAME],
    ['{tag}',      I18N_BOOST_PH_TAG],
    ['{server}',   I18N_BOOST_PH_SERVER],
    ['{boosts}',   I18N_BOOST_PH_BOOSTS],
    ['{level}',    I18N_BOOST_PH_LEVEL],
];

let boostLastFocused = 'boostTitle';
['boostTitle','boostDesc','boostFooter'].forEach(id => {
    document.getElementById(id)?.addEventListener('focus', () => boostLastFocused = id);
});

function buildEmbedPicker(pickerId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) =>
        `<button type="button" class="ph-item" onclick="insertPhDyn('${ph}')"><code>${ph}</code><span>${desc}</span></button>`
    ).join('');
}

function buildPlainPicker(pickerId, targetId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) =>
        `<button type="button" class="ph-item" onclick="insertPh('${targetId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
    ).join('');
}

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});

function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

function insertPhDyn(ph) { insertPh(boostLastFocused, ph); }

// ── Save ───────────────────────────────────────────────────────────────────
async function saveBoost() {
    if (!document.getElementById('boostChannel').value)
        return showAlert(I18N_BOOST_ERR_NO_CH);
    const messageType = document.querySelector('input[name="boostMessageType"]:checked')?.value || 'embed';
    const color       = document.getElementById('boostColor').value.trim() || '#FF73FA';
    if (messageType === 'embed' && !/^#[0-9A-Fa-f]{6}$/.test(color))
        return showAlert(I18N_BOOST_ERR_CLR);

    const res = await fetch(`/api/guild/${GUILD_ID}/booster-boost`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            enabled:          document.getElementById('boostEnabled').checked,
            channelId:        document.getElementById('boostChannel').value,
            messageType,
            plainText:        document.getElementById('boostPlainText').value.trim(),
            title:            document.getElementById('boostTitle').value.trim(),
            description:      document.getElementById('boostDesc').value.trim(),
            footerText:       document.getElementById('boostFooter').value.trim(),
            color,
            showMember:       document.getElementById('boostShowMember').checked,
            showMulaiBoost:   document.getElementById('boostShowMulaiBoost').checked,
            showTotalBoost:   document.getElementById('boostShowTotalBoost').checked,
            showLevelServer:  document.getElementById('boostShowLevelServer').checked,
            showThumbnail:    document.getElementById('boostShowThumbnail').checked,
            cardEnabled:        document.getElementById('boostCardEnabled').checked,
            cardWelcomeText:    document.getElementById('boostCardWelcomeText').value.trim()    || 'BOOST!',
            cardSubText:        document.getElementById('boostCardSubText').value.trim(),
            cardBgColor:        document.getElementById('boostCardBgColor').value.trim()        || '#0a0a1e',
            cardBgColor2:       document.getElementById('boostCardBgColor2').value.trim()       || '#1e0a2e',
            cardAccentColor:    document.getElementById('boostCardAccentColor').value.trim()    || '#FF73FA',
            cardAvatarShape:    document.querySelector('input[name="boostCardAvatarShape"]:checked')?.value || 'circle',
            cardBgType:         document.querySelector('input[name="boostCardBgType"]:checked')?.value      || 'gradient',
            cardBgImageUrl:     document.getElementById('boostCardBgImageUrl')?.value.trim()    || '',
            cardOverlayColor:   document.getElementById('boostCardOverlayColor')?.value.trim()  || '#000000',
            cardOverlayOpacity: parseInt(document.getElementById('boostCardOverlayOpacity')?.value || '0'),
            cardTitleColor:     document.getElementById('boostCardTitleColor')?.value.trim()    || '#ffffff',
            cardUsernameColor:  document.getElementById('boostCardUsernameColor')?.value.trim() || '#FF73FA',
            cardMsgColor:       document.getElementById('boostCardMsgColor')?.value.trim()      || '#cccccc',
            cardFont:           document.getElementById('boostCardFont')?.value                 || 'impact',
        })
    });
    const data = await res.json();
    if (data.success) showToast(data.message, 'success');
    else showAlert(data.message);
}

function _buildMentionDd(dd, getTarget) {
    function item(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => {
            const ta = typeof getTarget === 'function' ? getTarget() : getTarget;
            if (!ta) return;
            const s = ta.selectionStart ?? ta.value.length;
            const ep = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, s) + mention + ta.value.slice(ep);
            ta.selectionStart = ta.selectionEnd = s + mention.length;
            ta.focus(); ta.dispatchEvent(new Event('input', {bubbles: true}));
            document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
            document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
        });
        return b;
    }
    function hdr(t) { const h = document.createElement('div'); h.className = 'ph-group-label'; h.textContent = t; return h; }
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => { el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special'));
    dd.appendChild(item('<code>@everyone</code>', '@everyone'));
    dd.appendChild(item('<code>@here</code>', '@here'));
    const rKeys = Object.keys(ROLES);
    if (rKeys.length) {
        dd.appendChild(hdr('Roles'));
        rKeys.forEach(id => { const r = ROLES[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`)); });
    }
    const cKeys = Object.keys(CHANNELS);
    if (cKeys.length) {
        dd.appendChild(hdr('Channels'));
        cKeys.forEach(id => { const name = CHANNELS[id]; dd.appendChild(item(`<span>#${name}</span>`, `<#${id}>`)); });
    }
}

// ── Init ───────────────────────────────────────────────────────────────────
buildEmbedPicker('boostEmbedPicker');
buildPlainPicker('boostPlainPicker', 'boostPlainText');
_buildMentionDd(document.getElementById('boostEmbedMentionPicker'),  () => document.getElementById(boostLastFocused));
_buildMentionDd(document.getElementById('boostPlainMentionPicker'),  () => document.getElementById('boostPlainText'));

if (document.getElementById('boostCardEnabled').checked)
    document.getElementById('boostCardPanel').style.display = 'block';

drawBoostCard().then(() => toggleBoostType());

function mbResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    el.style.height = el.scrollHeight + 'px';
}
function mbUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
function mbInlineCount(inputId, countId) {
    const el = document.getElementById(inputId);
    const ct = document.getElementById(countId);
    if (!el || !ct) return;
    const len = el.value.length;
    const max = parseInt(el.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'input-inline-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.mb-auto-resize').forEach(mbResizeArea);
    mbUpdateCount('boostPlainText',        'boostPlainCount');
    mbInlineCount('boostTitle',            'boostTitleCount');
    mbUpdateCount('boostDesc',             'boostDescCount');
    mbInlineCount('boostFooter',           'boostFooterCount');
    mbInlineCount('boostCardWelcomeText',  'boostCardWelcomeTextCount');
    mbInlineCount('boostCardSubText',      'boostCardSubTextCount');
});

window._floatSave = saveBoost;
</script>

