<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<style>
/* ── Layout 2 kolom (sama pola TikTok/YouTube) ───────────────────────────── */
.tw-panel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: start;
}
@media (max-width: 860px) { .tw-panel-layout { grid-template-columns: 1fr; } }

/* ── Preview sticky ──────────────────────────────────────────────────────── */
.tw-preview-col { position: sticky; top: calc(var(--navbar-h, 56px) + 1rem); }
.preview-label  {
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .08em; margin-bottom: .5rem;
}

/* ── Account card ────────────────────────────────────────────────────────── */
.tw-channel-card {
    border-radius: 10px; padding: 1.1rem; margin-bottom: 1.25rem;
}
.tw-card-header {
    display: flex; align-items: center; gap: .85rem; margin-bottom: 1rem;
}
.tw-card-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    object-fit: cover; flex-shrink: 0; background: #111;
}
.tw-card-avatar-placeholder {
    width: 44px; height: 44px; border-radius: 50%;
    background: #9146FF; display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
}
.tw-card-name { font-weight: 600; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ── Search loading states ───────────────────────────────────────────────── */
@keyframes tw-spin    { to { transform: rotate(360deg); } }
@keyframes tw-shimmer { 0% { background-position:-200% 0; } 100% { background-position:200% 0; } }
@keyframes tw-dot     { 0%,80%,100% { transform:scale(0);opacity:.3; } 40% { transform:scale(1);opacity:1; } }

.tw-spinner {
    width: 13px; height: 13px;
    border: 2px solid rgba(255,255,255,.22);
    border-top-color: #fff;
    border-radius: 50%;
    animation: tw-spin .65s linear infinite;
    display: inline-block; vertical-align: middle; flex-shrink: 0;
}
.tw-skeleton {
    background: linear-gradient(90deg,
        rgba(255,255,255,.04) 25%,
        rgba(255,255,255,.11) 50%,
        rgba(255,255,255,.04) 75%);
    background-size: 200% 100%;
    animation: tw-shimmer 1.4s ease-in-out infinite;
    border-radius: 5px;
}
.tw-dot-row { display:inline-flex; gap:3px; align-items:center; }
.tw-dot-row span {
    width:5px; height:5px; border-radius:50%; background:#9146FF;
    animation: tw-dot 1.2s ease-in-out infinite;
}
.tw-dot-row span:nth-child(2) { animation-delay:.2s; }
.tw-dot-row span:nth-child(3) { animation-delay:.4s; }

/* ── Stats grid ──────────────────────────────────────────────────────────── */
.tw-stats-grid { grid-template-columns: repeat(3,1fr) !important; }

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 860px) {
    .tw-panel-layout  { grid-template-columns: 1fr; }
    .tw-preview-col   { position: static; }
    /* Stats: 2 kolom di tablet */
    .tw-stats-grid    { grid-template-columns: 1fr 1fr !important; }
    .tw-stats-grid .stat-card { min-width: 0; }
    .tw-stats-grid .stat-info { min-width: 0; overflow: hidden; }
    .tw-stats-grid .stat-label { white-space: normal; line-height: 1.3; }
}
@media (max-width: 680px) {
    .dash-main        { padding: 1.25rem 1rem 1.5rem !important; }
    .settings-card    { padding: 1rem !important; }
    .tw-channel-card  { padding: .9rem; }
    .tw-stats-grid    { grid-template-columns: 1fr 1fr !important; }
    .tw-stats-grid .stat-card { min-width: 0; padding: .75rem; gap: .5rem; }
    .tw-stats-grid .stat-info { min-width: 0; overflow: hidden; }
    .tw-stats-grid .stat-label { white-space: normal; line-height: 1.3; }
    .tw-card-header   { gap: .6rem; }
    .tw-card-avatar,
    .tw-card-avatar-placeholder { width: 38px; height: 38px; }
    .tw-card-name     { font-size: .9rem; }
    .tw-card-header .btn-sm { padding: .25rem .4rem; }
    .tw-search-row    { flex-direction: column !important; }
    .tw-search-row .btn { width: 100%; justify-content: center; }
    .tw-action-row    { flex-direction: column !important; }
    .tw-action-row .btn { width: 100%; justify-content: center; }
}
@media (max-width: 480px) {
    .dash-main        { padding: 1rem .75rem 1.5rem !important; }
    .tw-channel-card  { padding: .75rem; }
    .tw-stats-grid .stat-card { padding: .6rem .5rem; gap: .4rem; }
    .tw-stats-grid .stat-icon { width: 30px !important; height: 30px !important; border-radius: 7px !important; flex-shrink: 0; }
    .tw-stats-grid .stat-icon svg { width: 14px !important; height: 14px !important; }
    .tw-stats-grid .stat-value { font-size: 1.1rem; }
    .tw-stats-grid .stat-label { font-size: .63rem; }
    .tw-card-header .btn-sm { padding: .3rem .45rem; }
    .label-with-picker { flex-wrap: wrap; gap: .35rem; }
}

/* ── Responsive: Mobile kecil (≤ 380px) ─────────────────────────────────── */
@media (max-width: 380px) {
    .dash-main        { padding: .85rem .6rem 1.5rem !important; }
    .tw-channel-card  { padding: .65rem; }

    /* Card header: wrap action buttons */
    .tw-card-header   { flex-wrap: wrap; gap: .35rem !important; }
    .tw-card-header > a.btn,
    .tw-card-header > button.btn { padding: .2rem .32rem !important; }

    /* Page header: stack */
    .page-header      { flex-direction: column !important; align-items: flex-start !important; }

    /* Textarea kompak */
    .form-group .textarea { min-height: 70px; }

    /* Lookup result wraps */
    .tw-lookup-result-inner { flex-wrap: wrap !important; }
    .tw-lookup-result-inner .btn { width: 100%; justify-content: center; margin-top: .3rem; }
}
</style>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'twitch' }) %>
    <main class="dash-main" style="max-width:100%;overflow-x:hidden;">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>

        <!-- Header -->
        <div class="page-header" style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
            <div>
                <h1><%= t('twitch.page_title') %></h1>
                <p><%= t('twitch.page_desc') %></p>
            </div>
        </div>

        <!-- Warning: belum dikonfigurasi -->
        <% if (!isConfigured) { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="alert-triangle"></i>
            <div>
                <strong>Twitch is not configured.</strong> Add the following variables to your <code>.env</code> file and restart the bot:
                <div style="margin-top:.5rem;font-size:.82rem;background:rgba(0,0,0,.3);padding:.5rem .75rem;border-radius:6px;font-family:monospace;line-height:1.8;">
                    TWITCH_CLIENT_ID=xxx<br>
                    TWITCH_CLIENT_SECRET=xxx<br>
                    TWITCH_WEBHOOK_SECRET=random_secret<br>
                    BASE_URL=https://domainmu.com
                </div>
                <div style="margin-top:.5rem;font-size:.79rem;color:var(--text-muted);">
                    Daftar aplikasi di <strong>dev.twitch.tv/console</strong> untuk mendapatkan Client ID dan Secret.
                </div>
            </div>
        </div>
        <% } %>

        <!-- Stats -->
        <div class="stats-grid tw-stats-grid" style="margin-bottom:1.5rem;">
            <div class="stat-card">
                <div class="stat-icon" style="color:#9146FF;">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
                </div>
                <div class="stat-info">
                    <div class="stat-value" id="statAccounts"><%= twAccounts.length %></div>
                    <div class="stat-label"><%= t('twitch.stat_monitored') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;">
                    <i data-lucide="radio"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value"><%= twAccounts.filter(a => a.enabled).length %></div>
                    <div class="stat-label"><%= t('twitch.stat_active') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#80848e;">
                    <i data-lucide="list"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-value"><%= maxAccounts - twAccounts.length %></div>
                    <div class="stat-label"><%= t('twitch.stat_slots') %></div>
                </div>
            </div>
        </div>

        <!-- Add Streamer -->
        <% if (twAccounts.length < maxAccounts) { %>
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;">
                <i data-lucide="plus-circle" style="color:#9146FF;width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('twitch.add_title') %></h2>
            </div>
            <p style="font-size:.85rem;color:var(--text-muted);margin:0 0 1rem 0;">
                <%- t('twitch.add_desc', { remaining: maxAccounts - twAccounts.length, max: maxAccounts }) %>
            </p>
            <div class="form-group" style="margin-bottom:0;">
                <label class="label"><%= t('twitch.search_label') %></label>
                <div class="tw-search-row" style="display:flex;gap:.6rem;">
                    <input type="text" id="twLookupInput" class="input"
                           placeholder="username  atau  https://twitch.tv/username"
                           style="flex:1;min-width:0;" maxlength="200" data-flt-ignore
                           onkeydown="if(event.key==='Enter') lookupTwitch()">
                    <button class="btn btn-primary" onclick="lookupTwitch()" id="twLookupBtn"
                            style="white-space:nowrap;flex-shrink:0;<% if (!isConfigured) { %>opacity:.5;cursor:not-allowed;<% } %>"
                            <%= !isConfigured ? 'disabled' : '' %>>
                        <i data-lucide="search" style="width:14px;height:14px;"></i> <%= t('twitch.search_btn') %>
                    </button>
                </div>
            </div>

            <!-- Status bar loading -->
            <div id="twSearchStatus" style="display:none;margin-top:.75rem;padding:.65rem 1rem;background:rgba(145,70,255,.07);border:1px solid rgba(145,70,255,.2);border-radius:8px;align-items:center;gap:.75rem;">
                <div class="tw-spinner" style="border-color:rgba(145,70,255,.25);border-top-color:#9146FF;width:16px;height:16px;border-width:2.5px;"></div>
                <div style="flex:1;min-width:0;">
                    <div style="display:flex;align-items:center;gap:.5rem;">
                        <span id="twStatusText" style="font-size:.83rem;color:#9146FF;font-weight:600;"></span>
                        <span class="tw-dot-row"><span></span><span></span><span></span></span>
                    </div>
                    <div style="font-size:.74rem;color:var(--text-muted);margin-top:.15rem;"><%= t('twitch.searching_wait') %></div>
                </div>
            </div>

            <!-- Skeleton placeholder -->
            <div id="twSearchSkeleton" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border,rgba(255,255,255,.06));">
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <div class="tw-skeleton" style="width:42px;height:42px;border-radius:50%;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:.45rem;">
                        <div class="tw-skeleton" style="height:13px;width:52%;"></div>
                        <div class="tw-skeleton" style="height:10px;width:35%;"></div>
                    </div>
                    <div class="tw-skeleton" style="width:70px;height:30px;border-radius:6px;flex-shrink:0;"></div>
                </div>
            </div>

            <!-- Error / pesan -->
            <div id="twLookupMsg" class="form-message" style="margin-top:.5rem;"></div>

            <!-- Hasil pencarian -->
            <div id="twLookupResult" style="display:none;margin-top:1rem;padding:.85rem;background:var(--card-2,rgba(255,255,255,.04));border-radius:10px;border:1px solid var(--border,rgba(255,255,255,.06));">
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <img id="twLookupThumb" src="" alt=""
                         style="width:42px;height:42px;border-radius:50%;object-fit:cover;flex-shrink:0;background:#111;"
                         onerror="this.style.display='none'">
                    <div style="flex:1;min-width:0;">
                        <div id="twLookupName" style="font-weight:600;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>
                        <div id="twLookupLogin" style="font-size:.78rem;color:var(--text-muted);"></div>
                    </div>
                    <button class="btn btn-success" onclick="addStreamer()" style="flex-shrink:0;">
                        <i data-lucide="plus" style="width:14px;height:14px;"></i> <%= t('twitch.add_btn') %>
                    </button>
                </div>
            </div>
        </div>
        <% } else { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.5rem;">
            <i data-lucide="info"></i>
            <span><%- t('twitch.max_reached', { max: maxAccounts }) %></span>
        </div>
        <% } %>

        <!-- Daftar Streamer -->
        <div id="twAccountList">
        <% if (twAccounts.length === 0) { %>
            <div class="settings-card" style="text-align:center;padding:3rem 1.5rem;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:48px;height:48px;color:#9146FF;opacity:.4;display:block;margin:0 auto .75rem;"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
                <p style="color:var(--text-muted);margin:0;"><%= t('twitch.no_streamers') %></p>
            </div>
        <% } else { %>
        <% twAccounts.forEach(function(acc) { %>
        <div class="settings-card tw-channel-card" id="twCard-<%= acc.userId %>">

            <!-- Header -->
            <div class="tw-card-header">
                <% if (acc.thumbnail) { %>
                <img src="<%= acc.thumbnail %>" alt="" class="tw-card-avatar"
                     referrerpolicy="no-referrer"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="tw-card-avatar-placeholder" style="display:none;">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
                </div>
                <% } else { %>
                <div class="tw-card-avatar-placeholder">
                    <svg viewBox="0 0 24 24" fill="currentColor" style="width:22px;height:22px;color:#fff;"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
                </div>
                <% } %>
                <div style="flex:1;min-width:0;">
                    <div class="tw-card-name"><%= acc.displayName || acc.login %></div>
                    <div style="font-size:.78rem;color:var(--text-muted);margin-top:.1rem;">twitch.tv/<%= acc.login %></div>
                </div>
                <a href="https://twitch.tv/<%= acc.login %>" target="_blank" class="btn btn-sm" style="flex-shrink:0;" title="Buka di Twitch">
                    <i data-lucide="external-link" style="width:13px;height:13px;"></i>
                </a>
                <button class="btn btn-sm btn-danger"
                        data-userid="<%= acc.userId %>"
                        data-name="<%= (acc.displayName||acc.login).replace(/"/g,'&quot;') %>"
                        onclick="removeStreamer(this.dataset.userid, this.dataset.name)"
                        style="flex-shrink:0;" title="Delete streamer">
                    <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                </button>
            </div>

            <!-- 2-kolom: form | preview -->
            <div class="tw-panel-layout">

                <!-- Kiri: form -->
                <div>
                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" class="toggle-input" id="twEnabled-<%= acc.userId %>"
                                   <%= acc.enabled ? 'checked' : '' %>
                                   onchange="updatePreview('<%= acc.userId %>')">
                            <span class="toggle-slider"></span>
                            <span><%= t('twitch.enable_live') %></span>
                        </label>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('common.channel') %></label>
                        <select class="select" id="twChannel-<%= acc.userId %>" onchange="updatePreview('<%= acc.userId %>')">
                            <option value=""><%= t('common.select_channel') %></option>
                            <% (locals.channels||[]).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= acc.channelId===ch.id?'selected':'' %>>#<%= ch.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom:0;">
                        <div class="label-with-picker">
                            <label class="label" style="margin-bottom:0;"><%= t('twitch.custom_msg_label') %></label>
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('twPicker-<%= acc.userId %>',event)">{…} Placeholder</button>
                                <div class="ph-dropdown" id="twPicker-<%= acc.userId %>" style="display:none;"></div>
                            </div>
                        </div>
                        <textarea class="textarea" rows="3" id="twMessage-<%= acc.userId %>"
                                  style="font-size:.82rem;"
                                  oninput="updatePreview('<%= acc.userId %>')"
                        ><%= acc.message || "Hey, **{account}** is **LIVE** on Twitch right now!\nCome join and watch the stream~ 🎉" %></textarea>
                    </div>

                    <!-- Tombol aksi -->
                    <div class="tw-action-row" style="display:flex;justify-content:flex-end;gap:.5rem;padding-top:.85rem;">
                        <button class="btn btn-secondary" onclick="testNotif('<%= acc.userId %>')">
                            <i data-lucide="send" style="width:14px;height:14px;"></i> <%= t('twitch.test_notif_btn') %>
                        </button>
                    </div>
                    <div id="msg-<%= acc.userId %>" class="form-message" style="margin-top:.4rem;"></div>
                </div>

                <!-- Kanan: preview Discord -->
                <div class="tw-preview-col">
                    <div class="preview-label">Preview</div>
                    <div class="cc-discord-preview">
                        <div class="cc-dp-channel">
                            <span style="opacity:.5;font-weight:700;font-size:.85rem;flex-shrink:0;">#</span>
                            <span id="prevCh-<%= acc.userId %>"><%= ((locals.channels||[]).find(c=>c.id===acc.channelId)||{}).name || 'select-channel' %></span>
                        </div>
                        <div class="cc-dp-msg">
                            <div class="cc-dp-ava">
                                <img src="<%- botUser ? botUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                     alt="bot" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            </div>
                            <div class="cc-dp-right">
                                <div class="cc-dp-name">
                                    <span style="color:<%- botUser ? botUser.roleColor : 'var(--text)' %>"><%= botUser ? botUser.username : 'Bot' %></span>
                                    <span class="cc-dp-app-badge">
                                        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        APP
                                    </span>
                                    <span class="cc-dp-time">Today at 12:00 PM</span>
                                </div>
                                <div class="cc-dp-embed" id="prev-<%= acc.userId %>">
                                    <div class="cc-dp-embed-bar" style="background:#9146FF;"></div>
                                    <div class="cc-dp-embed-body">
                                        <div class="cc-dp-embed-main">
                                            <div class="cc-dp-embed-content">
                                                <div class="cc-dp-embed-title">🔴 <%= acc.displayName||acc.login %> is Live Now!</div>
                                                <div class="cc-dp-embed-desc" id="prevDesc-<%= acc.userId %>" style="margin-top:.15rem;margin-bottom:.35rem;"></div>
                                                <div style="margin-top:.35rem;">
                                                    <div style="margin-bottom:.3rem;">
                                                        <div class="cc-dp-field-name">🎙️ Stream Title</div>
                                                        <div class="cc-dp-field-val">[TEST] Example Live Notification</div>
                                                    </div>
                                                    <div style="margin-bottom:.3rem;">
                                                        <div class="cc-dp-field-name">🎮 Category</div>
                                                        <div class="cc-dp-field-val">Just Chatting</div>
                                                    </div>
                                                    <div>
                                                        <div class="cc-dp-field-name">🔗 Link</div>
                                                        <div class="cc-dp-field-val">Click Me ▶</div>
                                                    </div>
                                                </div>
                                            </div>
                                            <% if (acc.thumbnail) { %>
                                            <div class="cc-dp-embed-thumb">
                                                <img src="<%= acc.thumbnail %>" referrerpolicy="no-referrer"
                                                     alt="" onerror="this.closest('.cc-dp-embed-thumb').style.display='none'">
                                            </div>
                                            <% } %>
                                        </div>
                                        <div style="border-radius:4px;overflow:hidden;background:#1a1a1a;aspect-ratio:16/9;max-width:100%;margin-top:.5rem;">
                                            <img id="prevImg-<%= acc.userId %>"
                                                 src="https://static-cdn.jtvnw.net/ttv-static/404_preview-440x248.jpg"
                                                 style="width:100%;display:block;"
                                                 referrerpolicy="no-referrer"
                                                 onerror="this.src='';this.style.display='none'">
                                        </div>
                                        <div class="cc-dp-embed-footer">
                                            <svg viewBox="0 0 24 24" fill="#9146FF" style="width:12px;height:12px;flex-shrink:0;"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
                                            <span>Twitch LIVE</span>
                                            <span class="cc-dp-footer-sep"> • </span>
                                            <span>Today at 12:00 PM</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /tw-panel-layout -->
        </div><!-- /tw-channel-card -->
        <% }); %>
        <% } %>
        </div><!-- /twAccountList -->

    </div><!-- /dash-content-wide -->
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<%- include('../partials/bottom-nav') %>

<script>
const GUILD_ID    = '<%= guild.id %>';
const CHANNELS    = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;
const ROLES_MAP   = <%- JSON.stringify(Object.fromEntries((locals.roles||[]).map(r=>[r.id,r]))) %>;
const CHANNELS_MAP= <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(c=>[c.id,c]))) %>;

const I18N_TW_TIPS       = ['<%= t("twitch.tip_1") %>', '<%= t("twitch.tip_2") %>', '<%= t("twitch.tip_3") %>', '<%= t("twitch.tip_4") %>'];
const I18N_TW_SEARCHING  = '<%= t("twitch.searching") %>';
const I18N_TW_SEARCH_BTN = '<%= t("twitch.search_btn") %>';
const I18N_TW_ERR_NO_CH  = '<%= t("twitch.err_no_channel") %>';
const I18N_TW_ERR_CONN   = '<%= t("twitch.err_conn") %>';
const I18N_TW_SENDING    = '<%= t("twitch.sending_test") %>';
const I18N_TW_NO_CH      = '<%= t("twitch.preview_no_channel") %>';
const I18N_TW_CONFIRM_DEL   = '<%= t("twitch.confirm_delete") %>';
const I18N_TW_STREAM_TITLE  = '<%= t("twitch.preview_stream_title") %>';

// ── Lookup ────────────────────────────────────────────────────────────────────
let _lookupData = null;

async function lookupTwitch() {
    const input      = document.getElementById('twLookupInput').value.trim();
    const btn        = document.getElementById('twLookupBtn');
    const resEl      = document.getElementById('twLookupResult');
    const statusEl   = document.getElementById('twSearchStatus');
    const skeletonEl = document.getElementById('twSearchSkeleton');
    const msgEl      = document.getElementById('twLookupMsg');
    if (!input) return;

    resEl.style.display      = 'none';
    statusEl.style.display   = 'none';
    skeletonEl.style.display = 'none';
    if (msgEl) { msgEl.textContent = ''; msgEl.className = 'form-message'; }
    _lookupData = null;

    btn.disabled  = true;
    btn.innerHTML = `<span class="tw-spinner"></span> ${I18N_TW_SEARCHING}`;

    const tips       = I18N_TW_TIPS;
    let tipIdx       = 0;
    const statusTextEl = document.getElementById('twStatusText');
    if (statusTextEl) statusTextEl.textContent = tips[0];
    statusEl.style.display   = 'flex';
    skeletonEl.style.display = 'block';

    const tipTimer = setInterval(() => {
        tipIdx = (tipIdx + 1) % tips.length;
        if (statusTextEl) statusTextEl.textContent = tips[tipIdx];
    }, 3000);

    try {
        const r    = await fetch(`/api/guild/${GUILD_ID}/twitch/lookup`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ input }),
        });
        const data = await r.json();
        if (!data.success) {
            if (msgEl) showMsg(msgEl, data.message, 'error', true);
            return;
        }
        _lookupData = data.user;
        const thumb = document.getElementById('twLookupThumb');
        thumb.src          = _lookupData.thumbnail || '';
        thumb.style.display = _lookupData.thumbnail ? 'block' : 'none';
        document.getElementById('twLookupName').textContent  = _lookupData.displayName;
        document.getElementById('twLookupLogin').textContent = 'twitch.tv/' + _lookupData.login;
        resEl.style.display = 'block';
    } catch (err) {
        if (msgEl) showMsg(msgEl, I18N_TW_ERR_CONN + err.message, 'error', true);
    } finally {
        clearInterval(tipTimer);
        statusEl.style.display   = 'none';
        skeletonEl.style.display = 'none';
        btn.disabled  = false;
        btn.innerHTML = `<i data-lucide="search" style="width:14px;height:14px;"></i> ${I18N_TW_SEARCH_BTN}`;
        if (window.lucide) lucide.createIcons();
    }
}

async function addStreamer() {
    if (!_lookupData) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/twitch/accounts`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(_lookupData),
    });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.message);
}

// ── Simpan ────────────────────────────────────────────────────────────────────
async function saveStreamer(userId, quiet = false) {
    const msgEl    = document.getElementById(`msg-${userId}`);
    const enabled  = document.getElementById(`twEnabled-${userId}`)?.checked  || false;
    const channelId = document.getElementById(`twChannel-${userId}`)?.value   || '';
    const message  = document.getElementById(`twMessage-${userId}`)?.value?.trim() || '';

    if (enabled && !channelId) {
        showMsg(msgEl, I18N_TW_ERR_NO_CH, 'error');
        document.getElementById(`twChannel-${userId}`)?.focus();
        return { success: false, message: I18N_TW_ERR_NO_CH };
    }

    const r    = await fetch(`/api/guild/${GUILD_ID}/twitch/accounts/${encodeURIComponent(userId)}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enabled, channelId, message }),
    });
    const data = await r.json();
    if (!quiet || !data.success) showMsg(msgEl, data.message, data.success ? 'success' : 'error');
    return data;
}

// ── Test notif ────────────────────────────────────────────────────────────────
async function testNotif(userId) {
    const msgEl = document.getElementById(`msg-${userId}`);
    showMsg(msgEl, I18N_TW_SENDING, 'info');
    const r    = await fetch(`/api/guild/${GUILD_ID}/twitch/accounts/${encodeURIComponent(userId)}/test`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
    });
    const data = await r.json();
    showMsg(msgEl, data.message, data.success ? 'success' : 'error');
}

// ── Hapus streamer ────────────────────────────────────────────────────────────
async function removeStreamer(userId, name) {
    if (!confirm(I18N_TW_CONFIRM_DEL.replace('{{name}}', name))) return;
    const r    = await fetch(`/api/guild/${GUILD_ID}/twitch/accounts/${encodeURIComponent(userId)}`, { method: 'DELETE' });
    const data = await r.json();
    if (data.success) location.reload();
    else alert(data.message);
}

// ── Discord Markdown renderer ──────────────────────────────────────────────────
function discordMd(raw) {
    if (!raw) return '';
    const _t=[]; const _T=i=>`\x00${i}\x00`;
    let _src = raw
        .replace(/<@&(\d+)>/g,  (_,id)=>{ const r=ROLES_MAP[id],c=r?.color||'#5865F2'; _t.push(`<span class="dc-mention" style="color:${c};background:${c}1a;">@${r?r.name:id}</span>`); return _T(_t.length-1); })
        .replace(/<@!?(\d+)>/g, (_,id)=>{ _t.push(`<span class="dc-mention">@${id}</span>`); return _T(_t.length-1); })
        .replace(/<#(\d+)>/g,   (_,id)=>{ const ch=CHANNELS_MAP[id]; _t.push(`<span class="dc-mention">#${ch?ch.name:id}</span>`); return _T(_t.length-1); })
        .replace(/@everyone\b/g,()=>{ _t.push('<span class="dc-mention">@everyone</span>'); return _T(_t.length-1); })
        .replace(/@here\b/g,    ()=>{ _t.push('<span class="dc-mention">@here</span>'); return _T(_t.length-1); });
    let s = _src.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    s = s.replace(/^### (.+)$/gm, '<span style="font-size:.88em;font-weight:700;line-height:1.6;display:block">$1</span>');
    s = s.replace(/^## (.+)$/gm,  '<span style="font-size:1em;font-weight:700;line-height:1.75;display:block">$1</span>');
    s = s.replace(/^# (.+)$/gm,   '<span style="font-size:1.15em;font-weight:700;line-height:2;display:block">$1</span>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>');
    s = s.replace(/\*([^*\n]+?)\*/g,    '<em>$1</em>');
    s = s.replace(/_([^_\n]+?)_/g,      '<em>$1</em>');
    s = s.replace(/__([^_\n]+?)__/g,    '<u>$1</u>');
    s = s.replace(/~~(.+?)~~/g,         '<s>$1</s>');
    s = s.replace(/`([^`]+)`/g, '<code style="background:rgba(255,255,255,.07);padding:0 4px;border-radius:3px;font-size:.83em;font-family:monospace">$1</code>');
    s = s.replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" onclick="return false;" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color:#00b0f4;text-decoration:none">$1</a>');
    s = s.replace(/^&gt; (.+)$/gm, '<span style="border-left:3px solid #4e5058;padding-left:.5em;color:#b5bac1;display:block">$1</span>');
    s = s.replace(/\n/g, '<br>');
    s = s.replace(/\x00(\d+)\x00/g, (_,i)=>_t[+i]);
    return s;
}

// ── Update preview ────────────────────────────────────────────────────────────
function updatePreview(userId) {
    const chanId = document.getElementById(`twChannel-${userId}`)?.value || '';
    document.getElementById(`prevCh-${userId}`).textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : I18N_TW_NO_CH;

    const accName = document.getElementById(`twCard-${userId}`)?.querySelector('.tw-card-name')?.textContent?.trim() || userId;
    const msgRaw  = (document.getElementById(`twMessage-${userId}`)?.value || '').trim();
    const descEl  = document.getElementById(`prevDesc-${userId}`);
    if (descEl) {
        const ph = s => s
            .replace(/{account}/g,  accName)
            .replace(/{login}/g,    userId)
            .replace(/{url}/g,      `https://twitch.tv/${userId}`)
            .replace(/{game}/g,     'Just Chatting')
            .replace(/{title}/g,    I18N_TW_STREAM_TITLE)
            .replace(/{viewers}/g,  '1234');
        const defaultDesc = `Hey, <strong>${accName}</strong> is <strong>LIVE</strong> on Twitch right now!<br>Come join and watch the stream~ 🎉`;
        descEl.innerHTML = msgRaw ? discordMd(ph(msgRaw)) : defaultDesc;
    }
}

// ── Helper ────────────────────────────────────────────────────────────────────
function showMsg(el, text, type, persist) {
    if (!el) return;
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    if (!persist) setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 4000);
}

// ── Placeholder picker ────────────────────────────────────────────────────────
const PH_TWITCH = [
    ['{account}',  '<%= t("twitch.ph_account") %>'],
    ['{login}',    '<%= t("twitch.ph_login") %>'],
    ['{url}',      '<%= t("twitch.ph_url") %>'],
    ['{game}',     '<%= t("twitch.ph_game") %>'],
    ['{title}',    '<%= t("twitch.ph_title") %>'],
    ['{viewers}',  '<%= t("twitch.ph_viewers") %>'],
];

function buildPickers() {
    document.querySelectorAll('[id^="twPicker-"]').forEach(el => {
        const userId = el.id.replace('twPicker-', '');
        el.innerHTML = PH_TWITCH.map(([ph, desc]) =>
            `<button type="button" class="ph-item" onclick="insertPh('twMessage-${userId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
        ).join('');
    });
}

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el        = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});

function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

// Init
buildPickers();
document.querySelectorAll('[id^="twMessage-"]').forEach(el => updatePreview(el.id.replace('twMessage-', '')));
document.getElementById('twLookupInput')?.addEventListener('keydown', e => { if (e.key === 'Enter') lookupTwitch(); });

// ── Mention picker ─────────────────────────────────────────────────────────────
document.querySelectorAll('.ph-picker-anchor:not(.mention-anchor)').forEach(anchor => {
    const ta = anchor.closest('.form-group')?.querySelector('textarea');
    if (!ta) return;
    const ma = document.createElement('div');
    ma.className = 'ph-picker-anchor mention-anchor';
    const btn = document.createElement('button');
    btn.type='button'; btn.className='ph-toggle-btn'; btn.textContent='@ Mention';
    const dd = document.createElement('div');
    dd.className='ph-dropdown mention-dd'; dd.style.display='none';
    btn.addEventListener('click', e => {
        e.stopPropagation();
        document.querySelectorAll('.ph-dropdown').forEach(d=>{ if(d!==dd) d.style.display='none'; });
        document.querySelectorAll('.ph-toggle-btn').forEach(b=>{ if(b!==btn) b.classList.remove('active'); });
        if(dd.style.display!=='none'){ dd.style.display='none'; btn.classList.remove('active'); return; }
        if(!dd.dataset.built){ dd.dataset.built='1'; _buildMentionDd(dd,ta); }
        dd.style.display='grid';
        btn.classList.add('active');
    });
    ma.appendChild(btn); ma.appendChild(dd);
    const grp = document.createElement('div');
    grp.className = 'ph-btn-group';
    anchor.parentNode.insertBefore(grp, anchor);
    grp.appendChild(anchor);
    grp.appendChild(ma);
});
function _buildMentionDd(dd, ta) {
    function item(html, mention) {
        const b=document.createElement('button'); b.type='button'; b.className='ph-item';
        b.innerHTML=html;
        b.addEventListener('click',()=>{ const s=ta.selectionStart,e=ta.selectionEnd; ta.value=ta.value.slice(0,s)+mention+ta.value.slice(e); ta.selectionStart=ta.selectionEnd=s+mention.length; ta.focus(); ta.dispatchEvent(new Event('input',{bubbles:true})); dd.style.display='none'; });
        return b;
    }
    function hdr(t){ const h=document.createElement('div'); h.className='ph-group-label'; h.textContent=t; return h; }
    const inp=document.createElement('input'); inp.type='text'; inp.className='mention-search-input'; inp.placeholder='Search...';
    inp.addEventListener('click',e=>e.stopPropagation());
    inp.addEventListener('input',()=>{ const q=inp.value.toLowerCase(); dd.querySelectorAll('.ph-item').forEach(el=>{ el.style.display=el.textContent.toLowerCase().includes(q)?'':'none'; }); });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special')); dd.appendChild(item('<code>@everyone</code>','@everyone')); dd.appendChild(item('<code>@here</code>','@here'));
    const rKeys=Object.keys(ROLES_MAP);
    if(rKeys.length){ dd.appendChild(hdr('Roles')); rKeys.forEach(id=>{ const r=ROLES_MAP[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`,`<@&${r.id}>`)); }); }
    const cKeys=Object.keys(CHANNELS_MAP);
    if(cKeys.length){ dd.appendChild(hdr('Channels')); cKeys.forEach(id=>{ const c=CHANNELS_MAP[id]; dd.appendChild(item(`<span>#${c.name}</span>`,`<#${c.id}>`)); }); }
}

const _twAllIds = <%- JSON.stringify(twAccounts.map(a => a.userId)) %>;
window._floatSave = async function () {
    if (_twAllIds.length === 0) return;
    const results = await Promise.allSettled(_twAllIds.map(id => saveStreamer(id, true)));
    const ok = results.every(r => r.status === 'fulfilled' && r.value?.success);
    if (ok) showMsg(null, results[0].value.message, 'success');
    else throw new Error();
};
</script>

<%- include('../partials/footer') %>
