<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'welcome' }) %>

    <main class="dash-main" style="max-width:100%;">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1><%= t('welcome.page_title') %></h1>
            <p><%= t('welcome.page_desc') %></p>
        </div>

        <!-- ── How to Use ──────────────────────────────────────────────────────────── -->
        <div class="settings-card" style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.25rem;">
                <i data-lucide="book-open" style="color:var(--accent);width:18px;height:18px;flex-shrink:0;"></i>
                <h2 style="margin:0;font-size:1rem;font-weight:600;"><%= t('welcome.how_to_use') %></h2>
            </div>
            <div class="guide-grid">
                <div class="guide-step">
                    <div class="guide-num">1</div>
                    <div class="guide-title"><%= t('welcome.step1_title') %></div>
                    <div class="guide-desc"><%- t('welcome.step1_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">2</div>
                    <div class="guide-title"><%= t('welcome.step2_title') %></div>
                    <div class="guide-desc"><%- t('welcome.step2_desc') %></div>
                </div>
                <div class="guide-step">
                    <div class="guide-num">3</div>
                    <div class="guide-title"><%= t('welcome.step3_title') %></div>
                    <div class="guide-desc"><%- t('welcome.step3_desc') %></div>
                </div>
            </div>
            <div class="guide-tip">💡 <%- t('welcome.tip') %></div>
        </div>

        <div class="welcome-editor-layout">
            <!-- ── Kolom kiri: form settings ── -->
            <div class="settings-card" style="margin-bottom:0;">

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="welcomeEnabled" class="toggle-input"
                               <%= welcomeData.enabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span><%= t('welcome.enable') %></span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.channel') %> <span style="color:#ed4245;">*</span></label>
                    <select id="welcomeChannel" class="select">
                        <option value=""><%= t('common.select_channel') %></option>
                        <% (locals.channels || []).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= welcomeData.channelId === ch.id ? 'selected' : '' %>>
                                #<%= ch.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.message_type') %></label>
                    <div style="display:flex;gap:.75rem;">
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="welcomeMessageType" id="typePlain" value="plain"
                                   <%= (welcomeData.messageType || 'plain') === 'plain' ? 'checked' : '' %>>
                            <span><%= t('common.plain_text') %></span>
                        </label>
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="welcomeMessageType" id="typeEmbed" value="embed"
                                   <%= (welcomeData.messageType || 'plain') === 'embed' ? 'checked' : '' %>>
                            <span><%= t('common.embed') %></span>
                        </label>
                    </div>
                </div>

                <!-- ── Panel Teks Biasa ── -->
                <div id="plainTextPanel" class="form-group" style="display:none;">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;"><%= t('common.plain_text_message') %></label>
                        <div class="ph-btn-group">
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('plainPicker',event)">{…} Placeholder</button>
                                <div class="ph-dropdown" id="plainPicker" style="display:none;"></div>
                            </div>
                            <div class="ph-picker-anchor mention-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('plainMentionPicker',event)">@ Mention</button>
                                <div class="ph-dropdown mention-dd" id="plainMentionPicker" style="display:none;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="textarea-count-wrap">
                        <textarea id="welcomePlainText" class="textarea mb-auto-resize" rows="3"
                                  maxlength="2000"
                                  placeholder="Hello {member}, welcome to **{server}**! 🎉 You are member #**{count}**."
                                  oninput="mbResizeArea(this);mbInlineCount('welcomePlainText','welcomePlainCount')"><%= welcomeData.plainText %></textarea>
                        <span class="input-inline-count" id="welcomePlainCount">0 / 2000</span>
                    </div>
                </div>

                <!-- ── Panel Embed ── -->
                <div id="embedPanel">

                <div class="form-group">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;"><%= t('common.embed_title') %></label>
                        <div class="ph-btn-group">
                            <div class="ph-picker-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('embedPicker',event)">{…} Placeholder</button>
                                <div class="ph-dropdown" id="embedPicker" style="display:none;"></div>
                            </div>
                            <div class="ph-picker-anchor mention-anchor">
                                <button type="button" class="ph-toggle-btn" onclick="togglePicker('embedMentionPicker',event)">@ Mention</button>
                                <div class="ph-dropdown mention-dd" id="embedMentionPicker" style="display:none;"></div>
                            </div>
                        </div>
                    </div>
                    <input type="text" id="welcomeTitle" class="input"
                           placeholder="👋 Welcome to {server}!"
                           value="<%= welcomeData.title %>">
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.embed_description') %></label>
                    <div class="textarea-count-wrap">
                        <textarea id="welcomeDescription" class="textarea mb-auto-resize" rows="3"
                                  maxlength="3500"
                                  placeholder="Hello {member}, glad to have you here! 🎉&#10;You are member #**{count}**."
                                  oninput="mbResizeArea(this);mbInlineCount('welcomeDescription','welcomeDescCount')"><%= welcomeData.description %></textarea>
                        <span class="input-inline-count" id="welcomeDescCount">0 / 3500</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.embed_color') %></label>
                    <div style="display:flex;gap:.75rem;align-items:center;">
                        <input type="color" id="welcomeColorPicker" value="<%= welcomeData.color || '#5865F2' %>"
                               style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                               oninput="syncHex('welcomeColor','welcomeColorPicker')">
                        <input type="text" id="welcomeColor" class="input" style="max-width:130px;"
                               placeholder="#5865F2" maxlength="7"
                               value="<%= welcomeData.color || '#5865F2' %>"
                               oninput="syncPicker('welcomeColor','welcomeColorPicker')">
                    </div>
                </div>

                <div class="form-group">
                    <label class="label"><%= t('common.footer_label') %> <span style="font-weight:400;color:var(--text-muted)"><%= t('common.footer_optional') %></span></label>
                    <input type="text" id="welcomeFooter" class="input"
                           placeholder="<%= t('common.footer_placeholder') %>"
                           value="<%= welcomeData.footerText || '' %>">
                </div>

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="welcomeThumbnail" class="toggle-input"
                               <%= welcomeData.thumbnail ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span><%= t('common.thumbnail_label') %></span>
                    </label>
                </div>

                </div><!-- /embedPanel -->

                <div class="form-group" style="margin-top:1.5rem;border-top:1px solid var(--border);padding-top:1.25rem;">
                    <label class="label" style="margin-bottom:.75rem;"><%= t('welcome.card_section') %></label>
                    <label class="toggle-label">
                        <input type="checkbox" id="cardEnabled" class="toggle-input"
                               <%= welcomeData.cardEnabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span><%= t('welcome.card_enable') %></span>
                    </label>
                </div>

                <div id="cardPanel" style="display:none;">

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label"><%= t('welcome.avatar_shape') %></label>
                            <div style="display:flex;gap:.6rem;margin-top:.2rem;">
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                    <input type="radio" name="cardAvatarShape" value="circle" <%= (welcomeData.cardAvatarShape||'circle')==='circle'?'checked':'' %>>
                                    <span><%= t('welcome.shape_circle') %></span>
                                </label>
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                    <input type="radio" name="cardAvatarShape" value="square" <%= welcomeData.cardAvatarShape==='square'?'checked':'' %>>
                                    <span><%= t('welcome.shape_square') %></span>
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('welcome.font_label') %></label>
                            <select id="cardFont" class="select" style="font-size:.82rem;">
                                <% [['impact','Impact'],['arial','Arial'],['georgia','Georgia'],['courier','Courier New'],['verdana','Verdana']].forEach(function(f){ %>
                                    <option value="<%= f[0] %>" <%= (welcomeData.cardFont||'impact')===f[0]?'selected':'' %>><%= f[1] %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label"><%= t('welcome.bg_type') %></label>
                        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.2rem;">
                            <% [['gradient', t('welcome.bg_gradient')],['solid', t('welcome.bg_solid')],['image', t('welcome.bg_image')],['transparent', t('welcome.bg_transparent')]].forEach(function(bt){ %>
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                <input type="radio" name="cardBgType" value="<%= bt[0] %>" <%= (welcomeData.cardBgType||'gradient')===bt[0]?'checked':'' %>>
                                <span><%= bt[1] %></span>
                            </label>
                            <% }) %>
                        </div>
                    </div>

                    <div id="cardBgGradientPanel" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label" id="cardBgColor1Label"><%= t('welcome.bg_left') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardBgColorPicker" value="<%= welcomeData.cardBgColor||'#1a1a2e' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardBgColor','cardBgColorPicker')" onchange="syncHex('cardBgColor','cardBgColorPicker')">
                                <input type="text" id="cardBgColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardBgColor||'#1a1a2e' %>" oninput="syncPicker('cardBgColor','cardBgColorPicker')">
                            </div>
                        </div>
                        <div class="form-group" id="cardBgColor2Group">
                            <label class="label"><%= t('welcome.bg_right') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardBgColor2Picker" value="<%= welcomeData.cardBgColor2||'#16213e' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardBgColor2','cardBgColor2Picker')" onchange="syncHex('cardBgColor2','cardBgColor2Picker')">
                                <input type="text" id="cardBgColor2" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardBgColor2||'#16213e' %>" oninput="syncPicker('cardBgColor2','cardBgColor2Picker')">
                            </div>
                        </div>
                    </div>

                    <div id="cardBgImagePanel" style="display:none;" class="form-group">
                        <label class="label"><%= t('welcome.bg_image_url') %></label>
                        <input type="text" id="cardBgImageUrl" class="input"
                               placeholder="https://example.com/background.jpg"
                               value="<%= welcomeData.cardBgImageUrl||'' %>">
                        <div class="hint" style="margin-top:.3rem;"><%= t('welcome.bg_image_hint') %></div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label"><%= t('welcome.overlay_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardOverlayColorPicker" value="<%= welcomeData.cardOverlayColor||'#000000' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardOverlayColor','cardOverlayColorPicker')" onchange="syncHex('cardOverlayColor','cardOverlayColorPicker')">
                                <input type="text" id="cardOverlayColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardOverlayColor||'#000000' %>" oninput="syncPicker('cardOverlayColor','cardOverlayColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label" style="display:flex;justify-content:space-between;">
                                <span><%= t('welcome.overlay_opacity') %></span>
                                <span id="cardOverlayOpacityVal" style="color:var(--text-muted);font-weight:400;"><%= welcomeData.cardOverlayOpacity||'0' %>%</span>
                            </label>
                            <input type="range" id="cardOverlayOpacity" min="0" max="100"
                                   value="<%= welcomeData.cardOverlayOpacity||'0' %>"
                                   style="width:100%;margin-top:.45rem;accent-color:var(--accent,#5865f2);"
                                   oninput="document.getElementById('cardOverlayOpacityVal').textContent=this.value+'%';drawCardPreview()">
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label"><%= t('welcome.title_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardTitleColorPicker" value="<%= welcomeData.cardTitleColor||'#ffffff' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardTitleColor','cardTitleColorPicker')" onchange="syncHex('cardTitleColor','cardTitleColorPicker')">
                                <input type="text" id="cardTitleColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardTitleColor||'#ffffff' %>" oninput="syncPicker('cardTitleColor','cardTitleColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('welcome.username_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardUsernameColorPicker" value="<%= welcomeData.cardUsernameColor||welcomeData.cardAccentColor||'#5865F2' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardUsernameColor','cardUsernameColorPicker')" onchange="syncHex('cardUsernameColor','cardUsernameColorPicker')">
                                <input type="text" id="cardUsernameColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardUsernameColor||welcomeData.cardAccentColor||'#5865F2' %>" oninput="syncPicker('cardUsernameColor','cardUsernameColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('welcome.msg_color') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardMsgColorPicker" value="<%= welcomeData.cardMsgColor||'#cccccc' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardMsgColor','cardMsgColorPicker')" onchange="syncHex('cardMsgColor','cardMsgColorPicker')">
                                <input type="text" id="cardMsgColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardMsgColor||'#cccccc' %>" oninput="syncPicker('cardMsgColor','cardMsgColorPicker')">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label"><%= t('welcome.avatar_border') %></label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="cardAccentPicker" value="<%= welcomeData.cardAccentColor||'#5865F2' %>"
                                       style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;"
                                       oninput="syncHex('cardAccentColor','cardAccentPicker')" onchange="syncHex('cardAccentColor','cardAccentPicker')">
                                <input type="text" id="cardAccentColor" class="input" style="max-width:110px;" maxlength="7"
                                       value="<%= welcomeData.cardAccentColor||'#5865F2' %>" oninput="syncPicker('cardAccentColor','cardAccentPicker')">
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label"><%= t('welcome.large_text') %></label>
                        <div class="input-count-wrap">
                            <input type="text" id="cardWelcomeText" class="input" maxlength="20"
                                   placeholder="WELCOME" value="<%= welcomeData.cardWelcomeText||'WELCOME' %>"
                                   oninput="mbInlineCount('cardWelcomeText','cardWelcomeTextCount')">
                            <span class="input-inline-count" id="cardWelcomeTextCount">0 / 20</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="label"><%= t('welcome.small_text') %></label>
                        <div class="input-count-wrap">
                            <input type="text" id="cardSubText" class="input" maxlength="60"
                                   placeholder="TO {server}" value="<%= welcomeData.cardSubText||'TO {server}' %>"
                                   oninput="mbInlineCount('cardSubText','cardSubTextCount')">
                            <span class="input-inline-count" id="cardSubTextCount">0 / 60</span>
                        </div>
                        <div class="hint" style="margin-top:.3rem;"><code>{server}</code> · <code>{count}</code> · <code>{tag}</code></div>
                    </div>

                </div>

                <div id="welcomeMsg" class="form-message"></div>
            </div>

            <!-- ── Kolom kanan: Discord preview ── -->
            <div class="preview-panel">
                <div class="preview-label"><%= t('common.preview') %></div>

                <!-- Tiruan tampilan Discord -->
                <div class="dc-window">
                    <div class="dc-channel-bar">
                        <span class="dc-channel-hash">#</span>
                        <span id="prevChannelName"><%= t('common.preview_no_channel') %></span>
                    </div>
                    <!-- Card preview (above message) -->
                    <div id="cardPreviewWrap" style="display:none;padding:.75rem 1rem .25rem;">
                        <canvas id="cardCanvas" width="760" height="247"
                                style="width:100%;border-radius:12px;display:block;"></canvas>
                        <div style="font-size:.7rem;color:#80848e;margin-top:.3rem;text-align:right;">Welcome Card Preview</div>
                    </div>

                    <div class="dc-messages">
                        <div class="dc-message">
                            <img class="dc-avatar" src="<%- loginUser && botUser ? botUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="bot avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="dc-msg-body">
                                <span class="dc-username" style="color:<%- botUser ? botUser.roleColor : '#ffffff' %>"><%= botUser ? botUser.username : 'Bot' %></span>
                                <span class="dc-timestamp">Today at 12:00 PM</span>
                                <!-- Teks biasa preview -->
                                <div id="previewPlainMsg" class="dc-plain-msg" style="display:none;"></div>
                                <img id="previewCardInPlain" style="display:none;width:100%;max-width:440px;border-radius:8px;margin-top:.4rem;" alt="">
                                <!-- Embed Discord -->
                                <div class="dc-embed" id="previewEmbed">
                                    <div class="dc-embed-pill" id="previewPill"></div>
                                    <div class="dc-embed-body">
                                        <div class="dc-embed-main">
                                            <div class="dc-embed-content">
                                                <div class="dc-embed-title" id="previewTitle"></div>
                                                <div class="dc-embed-desc" id="previewDesc"></div>
                                                <div class="dc-embed-fields" id="previewFields"></div>
                                            </div>
                                            <div class="dc-embed-thumb" id="previewThumb" style="display:none;">
                                                <img id="previewThumbImg"
                                                     src="<%- loginUser ? loginUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                                     alt="thumb" style="width:100%;height:100%;object-fit:cover;display:block;"
                                                     onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                                            </div>
                                        </div>
                                        <img id="previewCardInEmbed" style="display:none;width:100%;border-radius:4px;margin-top:.4rem;" alt="">
                                        <div class="dc-embed-footer" id="previewFooter"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<%- include('../partials/bottom-nav') %>

<style>
.welcome-editor-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 900px) {
    .welcome-editor-layout { grid-template-columns: 1fr; }
}
#cardPanel { margin-top: .5rem; }
</style>

<script>
// ── Sample data untuk preview ──────────────────────────────────────────────
const SAMPLE = {
    member:         '@' + <%- JSON.stringify(loginUser.displayName) %>,
    username:       <%- JSON.stringify(loginUser.username) %>,
    displayName:    <%- JSON.stringify(loginUser.displayName) %>,
    roleColor:      <%- JSON.stringify(loginUser.roleColor) %>,
    tag:            <%- JSON.stringify(loginUser.username) %> + '#0',
    avatarUrl:      <%- JSON.stringify(loginUser.avatarUrl) %>,
    server:         <%- JSON.stringify(guild.name) %>,
    count:          '<%= guild.memberCount %>',
    inviter:        'OctaUser#1234',
    invite_code:    'abc123',
    total_invites:  '42',
    account_created:'3 years ago',
};

// Markdown Discord → HTML
function mdToHtml(text) {
    if (!text) return '';

    // Escape HTML entities pada string mentah
    function esc(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Format inline — input harus sudah di-escape
    function inline(s) {
        // Lindungi isi code span dari auto-link & format lain (seperti Discord)
        const codeStore = [];
        s = s.replace(/`(.+?)`/g, (_, code) => {
            const i = codeStore.length;
            codeStore.push('<code style="background:#2b2d31;padding:1px 5px;border-radius:3px;font-size:.85em;font-family:\'Consolas\',monospace;">' + code + '</code>');
            return '\x01C' + i + '\x01';
        });

        s = s
            // Masked link [teks](url) — spasi opsional di dalam kurung (seperti Discord)
            .replace(/\[([^\]]+)\]\(\s*(https?:\/\/[^\s)]+)\s*\)/g,
                '<a href="$2" target="_blank" rel="noopener noreferrer" style="color:#00b0f4;text-decoration:none;">$1</a>')
            .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
            .replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g,         '<em>$1</em>')
            .replace(/__(.+?)__/g,         '<u>$1</u>')
            .replace(/~~(.+?)~~/g,         '<s>$1</s>')
            .replace(/\|\|(.+?)\|\|/g,     '<span class="dc-spoiler" title="Klik untuk lihat spoiler" onclick="this.classList.toggle(\'shown\')">$1</span>')
            // Bare URL — auto-link, skip URL yang sudah ada di dalam href="..."
            // Pakai alternation (bukan lookbehind) agar kompatibel semua browser
            .replace(/(href="[^"]*")|((https?:\/\/[^\s<>"']+))/g, (match, hrefAttr, _, url) => {
                if (hrefAttr) return match;
                const clean = url.replace(/[.,;:!?)\]>]+$/, '');
                return '<a href="' + clean + '" target="_blank" rel="noopener noreferrer" style="color:#00b0f4;text-decoration:underline;">' + clean + '</a>';
            });

        // Kembalikan code spans
        return s.replace(/\x01C(\d+)\x01/g, (_, i) => codeStore[+i]);
    }

    // Proses baris dari teks RAW (belum di-escape) agar pattern > # dll. tidak rusak
    const lines = text.split('\n');
    const out   = [];
    let inCode  = false;
    let codeBuf = [];

    for (let i = 0; i < lines.length; i++) {
        const raw = lines[i];   // baris mentah, belum di-escape

        // ── Code block (``` ... ```) — escape konten, jangan proses inline ──
        if (!inCode && /^```/.test(raw)) {
            inCode  = true;
            codeBuf = [];
            continue;
        }
        if (inCode) {
            if (/^```\s*$/.test(raw.trim())) {
                inCode = false;
                out.push(
                    '<div style="display:block;background:#1e1f22;border-radius:4px;' +
                    'padding:.4rem .75rem;margin:.3rem 0;font-family:\'Consolas\',\'Courier New\',monospace;' +
                    'font-size:.82em;white-space:pre;overflow-x:auto;line-height:1.4;color:#dbdee1;">' +
                    esc(codeBuf.join('\n')) + '</div>'
                );
            } else {
                codeBuf.push(raw);
            }
            continue;
        }

        let m;

        // ── Multi-line blockquote (>>> sisa pesan) — cek di raw ──────────
        if ((m = raw.match(/^>>> (.*)$/))) {
            const rest = [m[1], ...lines.slice(i + 1)].join('\n');
            out.push(
                '<div style="display:block;border-left:4px solid #4e5058;' +
                'padding:.1em .75em;margin:.1em 0;color:#dbdee1;">' +
                inline(esc(rest)) + '</div>'
            );
            break;
        }

        // ── Single blockquote (> text) — cek di raw ─────────────────────
        if ((m = raw.match(/^> (.+)$/))) {
            out.push(
                '<div style="display:block;border-left:4px solid #4e5058;' +
                'padding:.1em .75em;margin:.05em 0;color:#dbdee1;">' +
                inline(esc(m[1])) + '</div>'
            );
            continue;
        }

        // ── Headings (### sebelum ## sebelum #) — cek di raw ─────────────
        if ((m = raw.match(/^### (.+)$/))) {
            out.push('<div style="display:block;font-size:1.05em;font-weight:700;margin:.3em 0 .1em;">' + inline(esc(m[1])) + '</div>');
            continue;
        }
        if ((m = raw.match(/^## (.+)$/))) {
            out.push('<div style="display:block;font-size:1.25em;font-weight:700;margin:.3em 0 .2em;">' + inline(esc(m[1])) + '</div>');
            continue;
        }
        if ((m = raw.match(/^# (.+)$/))) {
            out.push('<div style="display:block;font-size:1.5em;font-weight:700;line-height:1.3;margin:.3em 0 .2em;">' + inline(esc(m[1])) + '</div>');
            continue;
        }

        // ── Subtext Discord (-# text) — cek di raw ───────────────────────
        if ((m = raw.match(/^-# (.+)$/))) {
            out.push('<div style="display:block;font-size:.75em;color:#80848e;margin:.05em 0;">' + inline(esc(m[1])) + '</div>');
            continue;
        }

        // ── Teks biasa ────────────────────────────────────────────────────
        out.push(inline(esc(raw)));
    }

    // Code block tidak ditutup — render saja
    if (inCode && codeBuf.length) {
        out.push(
            '<div style="display:block;background:#1e1f22;border-radius:4px;' +
            'padding:.4rem .75rem;font-family:\'Consolas\',monospace;' +
            'font-size:.82em;white-space:pre;color:#dbdee1;">' +
            esc(codeBuf.join('\n')) + '</div>'
        );
    }

    // Join: <br> antar inline, tidak ada separator di sekitar block element
    let result = '';
    for (let j = 0; j < out.length; j++) {
        const isBlock   = out[j].startsWith('<div');
        const prevBlock = j > 0 && out[j - 1].startsWith('<div');
        if (j > 0 && !isBlock && !prevBlock) result += '<br>';
        result += out[j];
    }
    return result;
}

// Resolve placeholder + Discord mention syntax SETELAH mdToHtml
// ── Cache nama member & role hasil fetch ──────────────────────────────────
const memberCache  = {};   // 'fetching' | { label, color } | null
const roleCache    = {};   // 'fetching' | { name, color }  | null
const channelCache = {};   // 'fetching' | { name }         | null

function mentionBadge(color, text, bg) {
    bg = bg || color + '26';
    return '<span style="color:' + color + ';background:' + bg + ';border-radius:3px;padding:0 2px;font-weight:600;">' + text + '</span>';
}

// Sentinel values:
//   undefined  = belum pernah di-fetch
//   'fetching' = sedang di-fetch
//   null       = fetch done but not found (don't retry)
//   string / object = hasil sukses

async function resolveMentionId(id, guildId) {
    if (memberCache[id] !== undefined) return;   // sudah di-fetch atau sedang di-fetch
    memberCache[id] = 'fetching';
    try {
        const res  = await fetch('/api/guild/' + guildId + '/members/search?q=' + encodeURIComponent(id));
        const data = await res.json();
        memberCache[id] = (data.success && data.members && data.members.length > 0 && data.members[0].display)
            ? data.members[0].display
            : null;
    } catch(e) {
        console.error('[member fetch error]', id, e);
        memberCache[id] = null;
    }
    updatePreview();
}

async function resolveRoleId(id, guildId) {
    if (roleCache[id] !== undefined) return;     // sudah di-fetch atau sedang di-fetch
    roleCache[id] = 'fetching';
    try {
        const res  = await fetch('/api/guild/' + guildId + '/roles/' + id);
        const data = await res.json();
        roleCache[id] = (data.success && data.role && data.role.name)
            ? { name: data.role.name, color: data.role.color }
            : null;
    } catch(e) {
        console.error('[role fetch error]', id, e);
        roleCache[id] = null;
    }
    updatePreview();
}

async function resolveChannelId(id, guildId) {
    if (channelCache[id] !== undefined) return;  // sudah di-fetch atau sedang di-fetch
    channelCache[id] = 'fetching';
    try {
        const res  = await fetch('/api/guild/' + guildId + '/channels/' + id);
        const data = await res.json();
        channelCache[id] = (data.success && data.channel && data.channel.name)
            ? { name: data.channel.name }
            : null;
    } catch(e) {
        console.error('[channel fetch error]', id, e);
        channelCache[id] = null;
    }
    updatePreview();
}

// Fase 1a: untuk title/footer — {member} → @displayName sebagai teks biasa (sesuai Discord)
function resolvePlaceholdersTitle(text) {
    if (!text) return '';
    return text
        .replace(/\{member\}/g,          SAMPLE.member)
        .replace(/\{username\}/g,        SAMPLE.username)
        .replace(/\{tag\}/g,             SAMPLE.tag)
        .replace(/\{server\}/g,          SAMPLE.server)
        .replace(/\{count\}/g,           SAMPLE.count)
        .replace(/\{inviter\}/g,         SAMPLE.inviter)
        .replace(/\{invite\.code\}/g,    SAMPLE.invite_code)
        .replace(/\{total\.invites\}/g,  SAMPLE.total_invites)
        .replace(/\{account\.created\}/g,SAMPLE.account_created);
}

// Fase 1b: untuk description/plain — {member} → marker yang akan jadi mention badge
function resolvePlaceholders(text) {
    if (!text) return '';
    return text
        .replace(/\{member\}/g,          '\x00MENTION_MEMBER\x00')   // marker sementara
        .replace(/\{username\}/g,        SAMPLE.username)
        .replace(/\{tag\}/g,             SAMPLE.tag)
        .replace(/\{server\}/g,          SAMPLE.server)
        .replace(/\{count\}/g,           SAMPLE.count)
        .replace(/\{inviter\}/g,         SAMPLE.inviter)
        .replace(/\{invite\.code\}/g,    SAMPLE.invite_code)
        .replace(/\{total\.invites\}/g,  SAMPLE.total_invites)
        .replace(/\{account\.created\}/g,SAMPLE.account_created);
}

// Fase 2: inject HTML badge untuk mention Discord (setelah mdToHtml sudah escape)
function resolveHtmlMentions(html) {
    if (!html) return '';
    const guildId = '<%= guild.id %>';
    return html
        // ── Custom emoji: <a:name:id> animated & <:name:id> static ────────
        .replace(/&lt;a:(\w+):(\d+)&gt;/g, (_, name, id) => `<img src="https://cdn.discordapp.com/emojis/${id}.gif" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`)
        .replace(/&lt;:(\w+):(\d+)&gt;/g,  (_, name, id) => `<img src="https://cdn.discordapp.com/emojis/${id}.webp" class="dc-emoji" alt=":${name}:" onerror="this.style.display='none'">`)
        // ── Marker {member} → badge ────────────────────────────────────────
        .replace(/\x00MENTION_MEMBER\x00/g, mentionBadge('#7289da', SAMPLE.member, 'rgba(88,101,242,.15)'))
        // ── Discord mention: <@&ID> role — harus dicek SEBELUM <@ID> user ──
        .replace(/&lt;@&amp;(\d+)&gt;/g, (_, id) => {
            // Coba dari ROLES map dulu (sudah di-load saat halaman dibuka)
            const staticRole = ROLES[id];
            if (staticRole) {
                return mentionBadge(staticRole.color, '@' + staticRole.name);
            }
            // Fallback: fetch dari API
            const cached = roleCache[id];
            if (cached === undefined) resolveRoleId(id, guildId);
            if (cached && cached !== 'fetching') {
                return mentionBadge(cached.color, '@' + cached.name);
            }
            return mentionBadge('#99aab5', cached === null ? '@unknown-role' : '@...');
        })
        // ── Discord mention: <@ID> atau <@!ID> user ────────────────────────
        .replace(/&lt;@!?(\d+)&gt;/g, (_, id) => {
            const cached = memberCache[id];
            if (cached === undefined) resolveMentionId(id, guildId);
            const label = cached && cached !== 'fetching' ? '@' + cached
                        : cached === null                 ? '@unknown-user'
                        : '@...';
            return mentionBadge('#7289da', label, 'rgba(88,101,242,.15)');
        })
        // ── Discord mention: <#ID> channel ─────────────────────────────────
        .replace(/&lt;#(\d+)&gt;/g, (_, id) => {
            // Coba dari CHANNELS map dulu (channel teks yang sudah di-load)
            if (CHANNELS[id]) return mentionBadge('#7289da', '#' + CHANNELS[id], 'rgba(88,101,242,.15)');
            // Fallback: fetch dari API (untuk channel non-teks: announcement, forum, dll.)
            const cached = channelCache[id];
            if (cached === undefined) resolveChannelId(id, guildId);
            if (cached && cached !== 'fetching') {
                return mentionBadge('#7289da', '#' + cached.name, 'rgba(88,101,242,.15)');
            }
            return mentionBadge('#7289da', cached === null ? '#unknown-channel' : '#...', 'rgba(88,101,242,.15)');
        })
        .replace(/@everyone\b/g, () => mentionBadge('#7289da', '@everyone', 'rgba(88,101,242,.15)'))
        .replace(/@here\b/g,     () => mentionBadge('#7289da', '@here',     'rgba(88,101,242,.15)'));
}

// ── Tentukan posisi card: di dalam embed/plain atau standalone ───────────
function _syncCardPlacement() {
    const enabled  = document.getElementById('cardEnabled').checked;
    const wrap     = document.getElementById('cardPreviewWrap');
    const imgEmbed = document.getElementById('previewCardInEmbed');
    const imgPlain = document.getElementById('previewCardInPlain');

    if (!enabled) {
        wrap.style.display = 'none';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = 'none';
        return;
    }

    const canvas  = document.getElementById('cardCanvas');
    const dataUrl = canvas ? canvas.toDataURL() : '';
    if (imgEmbed && dataUrl) imgEmbed.src = dataUrl;
    if (imgPlain && dataUrl) imgPlain.src = dataUrl;

    const isPlain = document.getElementById('typePlain').checked;

    if (isPlain) {
        // Plain mode: card menyatu di bawah teks jika pesan tidak kosong
        const plainVal    = (document.getElementById('welcomePlainText') || {}).value || '';
        const hasContent  = !!plainVal.trim();

        wrap.style.display = hasContent ? 'none'  : 'block';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = hasContent ? 'block' : 'none';
    } else {
        // Embed mode: card selalu masuk ke dalam embed, tidak pernah standalone
        wrap.style.display = 'none';
        if (imgEmbed) imgEmbed.style.display = 'block';
        if (imgPlain) imgPlain.style.display = 'none';
    }
}

// ── Welcome card canvas preview (async untuk support background image) ───
async function drawCardPreview() {
    const enabled = document.getElementById('cardEnabled').checked;
    if (!enabled) { _syncCardPlacement(); return; }

    const canvas = document.getElementById('cardCanvas');
    const ctx    = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;

    const bgType   = document.querySelector('input[name="cardBgType"]:checked')?.value || 'gradient';
    const bg1      = document.getElementById('cardBgColor')?.value      || '#1a1a2e';
    const bg2      = document.getElementById('cardBgColor2')?.value     || '#16213e';
    const bgImgUrl = (document.getElementById('cardBgImageUrl')?.value  || '').trim();
    const overlayClr = document.getElementById('cardOverlayColor')?.value   || '#000000';
    const overlayOp  = (parseInt(document.getElementById('cardOverlayOpacity')?.value || '0')) / 100;
    const accent   = document.getElementById('cardAccentColor')?.value  || '#5865F2';
    const titleClr = document.getElementById('cardTitleColor')?.value   || '#ffffff';
    const userClr  = document.getElementById('cardUsernameColor')?.value || accent;
    const msgClr   = document.getElementById('cardMsgColor')?.value     || '#cccccc';
    const shape    = document.querySelector('input[name="cardAvatarShape"]:checked')?.value || 'circle';
    const fontSel  = document.getElementById('cardFont')?.value         || 'impact';
    const fontMap  = { impact:"Impact,'Arial Black',sans-serif", arial:'Arial,Helvetica,sans-serif',
                       georgia:"Georgia,'Times New Roman',serif", courier:"'Courier New',Courier,monospace",
                       verdana:'Verdana,Geneva,sans-serif' };
    const fontFam  = fontMap[fontSel] || fontMap.impact;
    const bigText  = document.getElementById('cardWelcomeText')?.value  || 'WELCOME';
    const sub      = (document.getElementById('cardSubText')?.value     || 'TO {server}')
                       .replace(/{server}/gi, SAMPLE.server)
                       .replace(/{count}/gi,  SAMPLE.count)
                       .replace(/{tag}/gi,    SAMPLE.tag);

    // Tampilkan/sembunyikan panel sesuai bgType
    const gradPanel = document.getElementById('cardBgGradientPanel');
    const imgPanel  = document.getElementById('cardBgImagePanel');
    const col2Grp   = document.getElementById('cardBgColor2Group');
    const hasBgColor = bgType !== 'image' && bgType !== 'transparent';
    if (gradPanel) gradPanel.style.display = hasBgColor ? 'grid' : 'none';
    if (imgPanel)  imgPanel.style.display  = bgType === 'image' ? 'block' : 'none';
    if (col2Grp)   col2Grp.style.display   = bgType === 'gradient' ? 'block' : 'none';
    const lbl = document.getElementById('cardBgColor1Label');
    if (lbl) lbl.textContent = bgType === 'gradient' ? 'Left Background' : 'Background Color';

    ctx.clearRect(0, 0, W, H);

    // Rounded rect helper
    function rr(x, y, w, h, r) {
        ctx.beginPath();
        ctx.moveTo(x+r, y);
        ctx.lineTo(x+w-r, y); ctx.quadraticCurveTo(x+w, y, x+w, y+r);
        ctx.lineTo(x+w, y+h-r); ctx.quadraticCurveTo(x+w, y+h, x+w-r, y+h);
        ctx.lineTo(x+r, y+h); ctx.quadraticCurveTo(x, y+h, x, y+h-r);
        ctx.lineTo(x, y+r); ctx.quadraticCurveTo(x, y, x+r, y);
        ctx.closePath();
    }

    // ── Background ────────────────────────────────────────────────────────
    if (bgType === 'transparent') {
        // Canvas sudah di-clearRect — tidak perlu isi apa-apa
        // Agar terlihat di preview, gambai checkerboard transparan
        const sz = 12;
        for (let y = 0; y < H; y += sz) {
            for (let x = 0; x < W; x += sz) {
                ctx.fillStyle = (Math.floor(x/sz) + Math.floor(y/sz)) % 2 === 0 ? '#c0c0c0' : '#909090';
                ctx.fillRect(x, y, sz, sz);
            }
        }
        // Clip rounded
        ctx.save();
        rr(0, 0, W, H, 16); ctx.clip();
        // Sudah digambar tapi perlu clip dulu — gambar ulang di dalam clip
        for (let y = 0; y < H; y += sz) {
            for (let x = 0; x < W; x += sz) {
                ctx.fillStyle = (Math.floor(x/sz) + Math.floor(y/sz)) % 2 === 0 ? '#c0c0c0' : '#909090';
                ctx.fillRect(x, y, sz, sz);
            }
        }
        ctx.restore();
    } else if (bgType === 'image' && bgImgUrl) {
        // Gunakan proxy server-side agar canvas tidak diblokir CORS
        const proxyUrl = '/api/guild/<%= guild.id %>/image-proxy?url=' + encodeURIComponent(bgImgUrl);
        try {
            await new Promise((res, rej) => {
                const img = new Image();
                img.onload = () => {
                    ctx.save();
                    rr(0, 0, W, H, 16); ctx.clip();
                    const sc = Math.max(W / img.width, H / img.height);
                    ctx.drawImage(img, (W - img.width*sc)/2, (H - img.height*sc)/2, img.width*sc, img.height*sc);
                    ctx.restore();
                    res();
                };
                img.onerror = rej;
                img.src = proxyUrl;
            });
        } catch {
            rr(0, 0, W, H, 16);
            const gd = ctx.createLinearGradient(0, 0, W, H);
            gd.addColorStop(0, bg1); gd.addColorStop(1, bg2);
            ctx.fillStyle = gd; ctx.fill();
        }
    } else if (bgType === 'solid') {
        rr(0, 0, W, H, 16); ctx.fillStyle = bg1; ctx.fill();
    } else {
        rr(0, 0, W, H, 16);
        const gd = ctx.createLinearGradient(0, 0, W, H);
        gd.addColorStop(0, bg1); gd.addColorStop(1, bg2);
        ctx.fillStyle = gd; ctx.fill();
    }

    // ── Overlay ───────────────────────────────────────────────────────────
    if (overlayOp > 0) {
        ctx.save();
        rr(0, 0, W, H, 16); ctx.clip();
        ctx.globalAlpha = overlayOp;
        ctx.fillStyle = overlayClr;
        ctx.fillRect(0, 0, W, H);
        ctx.globalAlpha = 1;
        ctx.restore();
    }

    // ── Decorative circles ────────────────────────────────────────────────
    ctx.globalAlpha = 0.07; ctx.fillStyle = accent;
    ctx.beginPath(); ctx.arc(W-60, 40, 80, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(W-20, H-20, 60, 0, Math.PI*2); ctx.fill();
    ctx.globalAlpha = 1;

    // ── Avatar ────────────────────────────────────────────────────────────
    const AS = 120, BD = 5;
    const avL = 50, avT = (H - AS - BD*2) / 2;
    const TX  = avL + AS + BD*2 + 40;
    const isSquare = shape === 'square';

    // Border avatar
    ctx.fillStyle = accent;
    if (isSquare) {
        rr(avL, avT, AS+BD*2, AS+BD*2, 20); ctx.fill();
    } else {
        ctx.beginPath(); ctx.arc(avL+(AS+BD*2)/2, avT+(AS+BD*2)/2, (AS+BD*2)/2, 0, Math.PI*2); ctx.fill();
    }

    // Gambar avatar asli atau fallback placeholder
    const avatarProxyUrl = '/api/guild/<%= guild.id %>/image-proxy?url=' + encodeURIComponent(SAMPLE.avatarUrl);
    await new Promise(resAvatar => {
        const avImg = new Image();
        avImg.onload = () => {
            ctx.save();
            if (isSquare) {
                rr(avL+BD, avT+BD, AS, AS, 14); ctx.clip();
            } else {
                ctx.beginPath(); ctx.arc(avL+BD+AS/2, avT+BD+AS/2, AS/2, 0, Math.PI*2); ctx.clip();
            }
            ctx.drawImage(avImg, avL+BD, avT+BD, AS, AS);
            ctx.restore();
            resAvatar();
        };
        avImg.onerror = () => {
            ctx.fillStyle = '#5a6070';
            if (isSquare) { rr(avL+BD, avT+BD, AS, AS, 14); ctx.fill(); }
            else { ctx.beginPath(); ctx.arc(avL+BD+AS/2, avT+BD+AS/2, AS/2, 0, Math.PI*2); ctx.fill(); }
            const cx = avL+BD+AS/2, cy = avT+BD+AS/2;
            ctx.fillStyle = '#8892a4';
            ctx.beginPath(); ctx.arc(cx, cy-20, 22, 0, Math.PI*2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(cx, cy+40, 35, 28, 0, 0, Math.PI*2); ctx.fill();
            resAvatar();
        };
        avImg.src = avatarProxyUrl;
    });

    // ── Teks (semua menggunakan font yang dipilih) ────────────────────────
    const availW = W - TX - 20;
    // Auto-scale title font size to fit available width
    let titleFs = 54;
    ctx.font = `900 ${titleFs}px ${fontFam}`;
    while (titleFs > 20 && ctx.measureText(bigText).width > availW) {
        titleFs -= 2;
        ctx.font = `900 ${titleFs}px ${fontFam}`;
    }
    ctx.shadowColor = titleClr; ctx.shadowBlur = 8;
    ctx.fillStyle = titleClr;
    ctx.fillText(bigText, TX, 115);
    ctx.shadowBlur = 0;

    ctx.shadowColor = 'rgba(0,0,0,0.5)'; ctx.shadowBlur = 4;
    ctx.font = `700 24px ${fontFam}`;
    ctx.fillStyle = userClr;
    ctx.fillText(SAMPLE.username, TX, 157, availW);
    ctx.shadowBlur = 0;

    ctx.font = `600 16px ${fontFam}`;
    ctx.fillStyle = msgClr;
    ctx.fillText(sub, TX, 192, availW);

    _syncCardPlacement();
}

// ── Toggle panel tipe pesan ────────────────────────────────────────────
function toggleMessageTypePanel() {
    const isPlain = document.getElementById('typePlain').checked;
    document.getElementById('plainTextPanel').style.display  = isPlain ? 'block' : 'none';
    document.getElementById('embedPanel').style.display      = isPlain ? 'none'  : 'block';
    updatePreview();
}
document.querySelectorAll('input[name="welcomeMessageType"]').forEach(el =>
    el.addEventListener('change', toggleMessageTypePanel)
);

// ── Card panel toggle ──────────────────────────────────────────────────
function toggleCardPanel() {
    const en = document.getElementById('cardEnabled').checked;
    document.getElementById('cardPanel').style.display = en ? 'block' : 'none';
    return drawCardPreview();
}
document.getElementById('cardEnabled').addEventListener('change', toggleCardPanel);

// Card input listeners
['cardWelcomeText','cardUserPrefix','cardSubText',
 'cardBgColor','cardBgColor2','cardAccentColor','cardTitleColor',
 'cardUsernameColor','cardMsgColor','cardBgImageUrl','cardFont'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input',  () => drawCardPreview());
    if (el) el.addEventListener('change', () => drawCardPreview());
});
document.querySelectorAll('input[name="cardAvatarShape"], input[name="cardBgType"]').forEach(el =>
    el.addEventListener('change', () => drawCardPreview())
);

function syncHex(inputId, pickerId) {
    document.getElementById(inputId).value = document.getElementById(pickerId).value;
    updatePreview();
    if (inputId.startsWith('card')) drawCardPreview();
}
function syncPicker(inputId, pickerId) {
    const val = document.getElementById(inputId).value;
    if (/^#[0-9A-Fa-f]{6}$/.test(val))
        document.getElementById(pickerId).value = val;
    updatePreview();
    if (inputId.startsWith('card')) drawCardPreview();
}

// ── Placeholder picker ────────────────────────────────────────────────────
const I18N_WL_PH_MENTION         = '<%= t("welcome.ph_mention") %>';
const I18N_WL_PH_USERNAME        = '<%= t("welcome.ph_username") %>';
const I18N_WL_PH_TAG             = '<%= t("welcome.ph_tag") %>';
const I18N_WL_PH_SERVER          = '<%= t("welcome.ph_server") %>';
const I18N_WL_PH_COUNT           = '<%= t("welcome.ph_count") %>';
const I18N_WL_PH_INVITER         = '<%= t("welcome.ph_inviter") %>';
const I18N_WL_PH_INVITE_CODE     = '<%= t("welcome.ph_invite_code") %>';
const I18N_WL_PH_TOTAL_INVITES   = '<%= t("welcome.ph_total_invites") %>';
const I18N_WL_PH_ACCOUNT_CREATED = '<%= t("welcome.ph_account_created") %>';
const PLACEHOLDERS = [
    ['{member}',         I18N_WL_PH_MENTION],
    ['{username}',       I18N_WL_PH_USERNAME],
    ['{tag}',            I18N_WL_PH_TAG],
    ['{server}',         I18N_WL_PH_SERVER],
    ['{count}',          I18N_WL_PH_COUNT],
    ['{inviter}',        I18N_WL_PH_INVITER],
    ['{invite.code}',    I18N_WL_PH_INVITE_CODE],
    ['{total.invites}',  I18N_WL_PH_TOTAL_INVITES],
    ['{account.created}',I18N_WL_PH_ACCOUNT_CREATED],
];

let _lastFocusedEmbed = 'welcomeDescription';
document.getElementById('welcomeTitle')?.addEventListener('focus', () => _lastFocusedEmbed = 'welcomeTitle');
document.getElementById('welcomeDescription')?.addEventListener('focus', () => _lastFocusedEmbed = 'welcomeDescription');

function buildPicker(pickerId, mode) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) => {
        const tgt = mode === 'embed' ? '_lastFocusedEmbed' : "'welcomePlainText'";
        return '<button type="button" class="ph-item" onclick="insertPh(' + tgt + ',\'' + ph + '\')">' +
               '<code>' + ph + '</code><span>' + desc + '</span></button>';
    }).join('');
}
function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
    if (wasHidden) { el.style.display = 'grid'; if (event?.currentTarget) event.currentTarget.classList.add('active'); }
}
document.addEventListener('click', () => {
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
});
function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}
// ── Channels map untuk preview nama channel ────────────────────────────────
const CHANNELS = <%- JSON.stringify(
    Object.fromEntries((locals.channels || []).map(ch => [ch.id, ch.name]))
) %>;
const I18N_NO_CH         = '<%= t("common.preview_no_channel") %>';
const I18N_WL_ERR_NO_CH  = <%- JSON.stringify(t("welcome.err_no_channel")) %>;

// ── Roles map untuk preview mention role ──────────────────────────────────
const ROLES = <%- JSON.stringify(
    Object.fromEntries(
        (locals.roles || []).map(r => [r.id, { name: r.name, color: r.color }])
    )
) %>;

// ── Auto-log saat load untuk memudahkan debug ────────────────────────────
window._debugWelcome = () => ({ CHANNELS, ROLES, memberCache, roleCache });

function updatePreview() {
    const color  = document.getElementById('welcomeColor').value || '#5865F2';
    const thumb  = document.getElementById('welcomeThumbnail').checked;
    const chanId = document.getElementById('welcomeChannel').value;

    // Cek tipe pesan
    const isPlainMode = document.getElementById('typePlain').checked;
    document.getElementById('previewPlainMsg').style.display = isPlainMode ? 'block' : 'none';
    document.getElementById('previewEmbed').style.display    = isPlainMode ? 'none'  : 'flex';

    if (isPlainMode) {
        const plainVal = (document.getElementById('welcomePlainText') || {}).value || '';
        let plainHtml = resolveHtmlMentions(mdToHtml(resolvePlaceholders(plainVal)));

        const msgsEl = document.querySelector('.dc-messages');
        if (plainHtml.trim()) {
            document.getElementById('previewPlainMsg').innerHTML = plainHtml;
            document.getElementById('previewPlainMsg').style.display = 'block';
            if (msgsEl) msgsEl.style.display = 'block';
        } else {
            document.getElementById('previewPlainMsg').style.display = 'none';
            if (msgsEl) msgsEl.style.display = 'none';
        }
        const chanId2 = document.getElementById('welcomeChannel').value;
        document.getElementById('prevChannelName').textContent = chanId2 && CHANNELS[chanId2] ? CHANNELS[chanId2] : I18N_NO_CH;
        _syncCardPlacement();
        return;
    }

    // Cek apakah embed punya konten untuk ditampilkan
    const _titleVal = document.getElementById('welcomeTitle').value.trim();
    const _descVal  = document.getElementById('welcomeDescription').value.trim();
    const _msgsEl = document.querySelector('.dc-messages');

    if (!_titleVal && !_descVal) {
        // Bersihkan semua elemen embed agar konten lama tidak tertinggal
        document.getElementById('previewTitle').innerHTML  = '';
        document.getElementById('previewDesc').innerHTML   = '';
        document.getElementById('previewFields').innerHTML = '';
        document.getElementById('previewFooter').innerHTML = '';
        document.getElementById('previewThumb').style.display = 'none';
        const _cardActive = document.getElementById('cardEnabled').checked;
        if (_cardActive) {
            // Card aktif tapi tidak ada teks — embed tetap tampil, card akan muncul sebagai gambar embed
            if (_msgsEl) _msgsEl.style.display = 'block';
            document.getElementById('previewEmbed').style.display = 'flex';
        } else {
            if (_msgsEl) _msgsEl.style.display = 'none';
            document.getElementById('previewEmbed').style.display = 'none';
        }
        const chanName2 = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : I18N_NO_CH;
        document.getElementById('prevChannelName').textContent = chanName2;
        _syncCardPlacement();
        return;
    }
    if (_msgsEl) _msgsEl.style.display = 'block';

    // Pill color
    document.getElementById('previewPill').style.background = color;

    // Title & desc — mdToHtml dulu (escape), baru resolvePlaceholders (inject HTML mention)
    document.getElementById('previewTitle').innerHTML = mdToHtml(resolvePlaceholdersTitle(document.getElementById('welcomeTitle').value));
    document.getElementById('previewDesc').innerHTML = resolveHtmlMentions(mdToHtml(resolvePlaceholders(document.getElementById('welcomeDescription').value)));

    // Footer
    const footerEl = document.getElementById('previewFooter');
    const footer = document.getElementById('welcomeFooter').value.trim();
    if (footer && footer !== '-') {
        footerEl.innerHTML = resolveHtmlMentions(mdToHtml(resolvePlaceholders(footer)));
    } else {
        footerEl.textContent = '';
    }

    // Thumbnail
    const thumbEl = document.getElementById('previewThumb');
    thumbEl.style.display = thumb ? 'block' : 'none';

    // Channel name
    const chanName = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : I18N_NO_CH;
    document.getElementById('prevChannelName').textContent = chanName;
    // Update channel bar hash color bila channel dipilih
    const hashEl = document.querySelector('.dc-channel-hash');
    if (hashEl) hashEl.style.color = chanId ? '#dbdee1' : '#80848e';

    _syncCardPlacement();
}

// ── Pasang listener ke semua input ────────────────────────────────────────
['welcomeTitle','welcomeDescription','welcomeFooter','welcomeColor',
 'welcomeEnabled','welcomeThumbnail','welcomeChannel','welcomePlainText']
    .forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', updatePreview);
        if (el) el.addEventListener('change', updatePreview);
    });

buildPicker('embedPicker', 'embed');
buildPicker('plainPicker', 'plain');
function _buildMentionDd(dd, getTarget) {
    function item(html, mention) {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'ph-item';
        b.innerHTML = html;
        b.addEventListener('click', () => {
            const ta = typeof getTarget === 'function' ? getTarget() : getTarget;
            if (!ta) return;
            const s = ta.selectionStart ?? ta.value.length;
            const ep = ta.selectionEnd ?? ta.value.length;
            ta.value = ta.value.slice(0, s) + mention + ta.value.slice(ep);
            ta.selectionStart = ta.selectionEnd = s + mention.length;
            ta.focus(); ta.dispatchEvent(new Event('input', {bubbles: true}));
            document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
            document.querySelectorAll('.ph-toggle-btn').forEach(b => b.classList.remove('active'));
        });
        return b;
    }
    function hdr(t) { const h = document.createElement('div'); h.className = 'ph-group-label'; h.textContent = t; return h; }
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'mention-search-input'; inp.placeholder = 'Search...';
    inp.addEventListener('click', e => e.stopPropagation());
    inp.addEventListener('input', () => {
        const q = inp.value.toLowerCase();
        dd.querySelectorAll('.ph-item').forEach(el => { el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none'; });
    });
    dd.appendChild(inp);
    dd.appendChild(hdr('Special'));
    dd.appendChild(item('<code>@everyone</code>', '@everyone'));
    dd.appendChild(item('<code>@here</code>', '@here'));
    const rKeys = Object.keys(ROLES);
    if (rKeys.length) {
        dd.appendChild(hdr('Roles'));
        rKeys.forEach(id => { const r = ROLES[id]; dd.appendChild(item(`<span style="color:${r.color}">@${r.name}</span>`, `<@&${id}>`)); });
    }
    const cKeys = Object.keys(CHANNELS);
    if (cKeys.length) {
        dd.appendChild(hdr('Channels'));
        cKeys.forEach(id => { const name = CHANNELS[id]; dd.appendChild(item(`<span>#${name}</span>`, `<#${id}>`)); });
    }
}
_buildMentionDd(document.getElementById('embedMentionPicker'), () => document.getElementById(_lastFocusedEmbed));
_buildMentionDd(document.getElementById('plainMentionPicker'), () => document.getElementById('welcomePlainText'));
// Gambar card selesai dulu sebelum updatePreview (cegah race condition canvas vs imgPlain)
toggleCardPanel().then(() => toggleMessageTypePanel());
// ── Save ───────────────────────────────────────────────────────────────────
async function saveWelcome(guildId) {
    const msg = document.getElementById('welcomeMsg');
    if (!document.getElementById('welcomeChannel').value)
        return showAlert(I18N_WL_ERR_NO_CH);
    const payload = {
        enabled:           document.getElementById('welcomeEnabled').checked,
        channelId:         document.getElementById('welcomeChannel').value,
        title:             document.getElementById('welcomeTitle').value.trim(),
        description:       document.getElementById('welcomeDescription').value.trim(),
        color:             document.getElementById('welcomeColor').value.trim() || '#5865F2',
        footerText:        document.getElementById('welcomeFooter').value.trim(),
        thumbnail:         document.getElementById('welcomeThumbnail').checked,
        messageType:       document.querySelector('input[name="welcomeMessageType"]:checked')?.value || 'embed',
        plainText:         (document.getElementById('welcomePlainText') || {}).value?.trim() || '',
        cardEnabled:        document.getElementById('cardEnabled').checked,
        cardWelcomeText:    document.getElementById('cardWelcomeText').value.trim()   || 'WELCOME',
        cardUserPrefix:     '',
        cardSubText:        document.getElementById('cardSubText').value.trim()        || 'TO {server}',
        cardBgColor:        document.getElementById('cardBgColor').value.trim()        || '#1a1a2e',
        cardBgColor2:       document.getElementById('cardBgColor2').value.trim()       || '#16213e',
        cardAccentColor:    document.getElementById('cardAccentColor').value.trim()    || '#5865F2',
        cardTextColor:      document.getElementById('cardTitleColor')?.value.trim()    || '#ffffff',
        cardAvatarShape:    document.querySelector('input[name="cardAvatarShape"]:checked')?.value || 'circle',
        cardBgType:         document.querySelector('input[name="cardBgType"]:checked')?.value      || 'gradient',
        cardBgImageUrl:     document.getElementById('cardBgImageUrl')?.value.trim()    || '',
        cardOverlayColor:   document.getElementById('cardOverlayColor')?.value.trim()  || '#000000',
        cardOverlayOpacity: parseInt(document.getElementById('cardOverlayOpacity')?.value || '0'),
        cardTitleColor:     document.getElementById('cardTitleColor')?.value.trim()    || '#ffffff',
        cardUsernameColor:  document.getElementById('cardUsernameColor')?.value.trim() || '#5865F2',
        cardMsgColor:       document.getElementById('cardMsgColor')?.value.trim()      || '#cccccc',
        cardFont:           document.getElementById('cardFont')?.value                 || 'impact',
    };
    const res  = await fetch(`/api/guild/${guildId}/welcome`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) showToast(data.message, 'success');
    else showAlert(data.message);
}

function showMsg(el, text, type) {
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3000);
}

function mbResizeArea(el) {
    if (!el) return;
    el.style.height = '1px';
    el.style.height = el.scrollHeight + 'px';
}
function mbUpdateCount(taId, countId) {
    const ta = document.getElementById(taId);
    const ct = document.getElementById(countId);
    if (!ta || !ct) return;
    const len = ta.value.length;
    const max = parseInt(ta.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'mb-char-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
function mbInlineCount(inputId, countId) {
    const el = document.getElementById(inputId);
    const ct = document.getElementById(countId);
    if (!el || !ct) return;
    const len = el.value.length;
    const max = parseInt(el.getAttribute('maxlength')) || 0;
    ct.textContent = len + ' / ' + max;
    ct.className = 'input-inline-count' + (len >= max ? ' danger' : len >= max * 0.9 ? ' warn' : '');
}
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.mb-auto-resize').forEach(mbResizeArea);
    mbInlineCount('welcomePlainText',   'welcomePlainCount');
    mbInlineCount('welcomeDescription', 'welcomeDescCount');
    mbInlineCount('cardWelcomeText',    'cardWelcomeTextCount');
    mbInlineCount('cardSubText',        'cardSubTextCount');
});

window._floatSave = () => saveWelcome('<%= guild.id %>');
</script>

