<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'booster' }) %>

    <main class="dash-main" style="max-width:100%;">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1>Boost Notification</h1>
            <p>Notifikasi otomatis saat member melakukan boost server.</p>
        </div>

        <!-- ══════════════════════════════════════
             TAB: BOOST NOTIFICATION
        ══════════════════════════════════════ -->
        <div id="tab-boost" class="booster-editor-layout">

            <!-- Kolom kiri: form -->
            <div class="settings-card" style="margin-bottom:0;">

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="boostEnabled" class="toggle-input"
                               <%= boostData.enabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span>Aktifkan Boost Notification</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="label">Channel Notifikasi</label>
                    <select id="boostChannel" class="select">
                        <option value="">— Pilih channel —</option>
                        <% (locals.channels || []).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= boostData.channelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Tipe Pesan</label>
                    <div style="display:flex;gap:.75rem;">
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="boostMessageType" id="boostTypeEmbed" value="embed"
                                   <%= (boostData.messageType || 'plain') === 'embed' ? 'checked' : '' %>>
                            <span>Embed</span>
                        </label>
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="boostMessageType" id="boostTypePlain" value="plain"
                                   <%= (boostData.messageType || 'plain') === 'plain' ? 'checked' : '' %>>
                            <span>Teks Biasa</span>
                        </label>
                    </div>
                </div>

                <!-- Panel Teks Biasa -->
                <div id="boostPlainPanel" class="form-group" style="display:none;">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;">Isi Pesan Teks Biasa</label>
                        <div class="ph-picker-anchor">
                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('boostPlainPicker',event)">{…} Placeholder</button>
                            <div class="ph-dropdown" id="boostPlainPicker" style="display:none;"></div>
                        </div>
                    </div>
                    <textarea id="boostPlainText" class="textarea" rows="4"
                              placeholder="🚀 {member} baru saja boost **{server}**! Total boost: **{boosts}**."
                              oninput="updateBoostPreview()"><%= boostData.plainText %></textarea>
                </div>

                <!-- Panel Embed -->
                <div id="boostEmbedPanel">
                    <div style="display:flex;justify-content:flex-end;margin-bottom:.35rem;">
                        <div class="ph-picker-anchor">
                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('boostEmbedPicker',event)">{…} Placeholder</button>
                            <div class="ph-dropdown" id="boostEmbedPicker" style="display:none;"></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label">Judul Embed</label>
                        <input type="text" id="boostTitle" class="input"
                               placeholder="🚀 Server Boost Baru!"
                               value="<%= boostData.title %>"
                               oninput="updateBoostPreview()">
                    </div>

                    <div class="form-group">
                        <label class="label">Deskripsi Embed</label>
                        <textarea id="boostDesc" class="textarea" rows="4"
                                  placeholder="Terima kasih {member} sudah boost server ini! 💖" oninput="updateBoostPreview()"><%= boostData.description %></textarea>
                    </div>

                    <div class="form-group">
                        <label class="label">Warna Embed</label>
                        <div style="display:flex;gap:.75rem;align-items:center;">
                            <input type="color" id="boostColorPicker" value="<%= boostData.color || '#FF73FA' %>"
                                   style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                                   oninput="syncHex('boostColor','boostColorPicker');updateBoostPreview()">
                            <input type="text" id="boostColor" class="input" style="max-width:130px;"
                                   placeholder="#FF73FA" maxlength="7"
                                   value="<%= boostData.color || '#FF73FA' %>"
                                   oninput="syncPicker('boostColor','boostColorPicker');updateBoostPreview()">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label">Footer <span style="font-weight:400;color:var(--text-muted)">(opsional)</span></label>
                        <input type="text" id="boostFooter" class="input"
                               placeholder="Kosongkan untuk menghapus"
                               value="<%= boostData.footerText || '' %>"
                               oninput="updateBoostPreview()">
                    </div>

                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="boostShowThumbnail" class="toggle-input"
                                   <%= boostData.showThumbnail !== false ? 'checked' : '' %> onchange="updateBoostPreview()">
                            <span class="toggle-slider"></span>
                            <span>Tampilkan foto profil member (thumbnail)</span>
                        </label>
                    </div>

                    <div class="form-group" style="border-top:1px solid var(--border);padding-top:1rem;margin-top:.5rem;">
                        <label class="label" style="margin-bottom:.75rem;">Field Info</label>
                        <div style="display:flex;flex-direction:column;gap:.6rem;">
                            <label class="toggle-label">
                                <input type="checkbox" id="boostShowMember" class="toggle-input"
                                       <%= boostData.showMember ? 'checked' : '' %> onchange="updateBoostPreview()">
                                <span class="toggle-slider"></span><span>👤 Member</span>
                            </label>
                            <label class="toggle-label">
                                <input type="checkbox" id="boostShowMulaiBoost" class="toggle-input"
                                       <%= boostData.showMulaiBoost ? 'checked' : '' %> onchange="updateBoostPreview()">
                                <span class="toggle-slider"></span><span>🚀 Mulai Boost</span>
                            </label>
                            <label class="toggle-label">
                                <input type="checkbox" id="boostShowTotalBoost" class="toggle-input"
                                       <%= boostData.showTotalBoost ? 'checked' : '' %> onchange="updateBoostPreview()">
                                <span class="toggle-slider"></span><span>✨ Total Boost</span>
                            </label>
                            <label class="toggle-label">
                                <input type="checkbox" id="boostShowLevelServer" class="toggle-input"
                                       <%= boostData.showLevelServer ? 'checked' : '' %> onchange="updateBoostPreview()">
                                <span class="toggle-slider"></span><span>🏅 Level Server</span>
                            </label>
                        </div>
                    </div>
                </div><!-- /boostEmbedPanel -->

                <!-- ── Boost Card ── -->
                <div class="form-group" style="margin-top:1.5rem;border-top:1px solid var(--border);padding-top:1.25rem;">
                    <label class="label" style="margin-bottom:.75rem;">Boost Card</label>
                    <label class="toggle-label">
                        <input type="checkbox" id="boostCardEnabled" class="toggle-input"
                               <%= boostData.cardEnabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span>Kirim gambar boost card</span>
                    </label>
                </div>
                <div id="boostCardPanel" style="display:none;">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label">Bentuk Avatar</label>
                            <div style="display:flex;gap:.6rem;margin-top:.2rem;">
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                    <input type="radio" name="boostCardAvatarShape" value="circle" <%= (boostData.cardAvatarShape||'circle')==='circle'?'checked':'' %>>
                                    <span>Lingkaran</span>
                                </label>
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                    <input type="radio" name="boostCardAvatarShape" value="square" <%= boostData.cardAvatarShape==='square'?'checked':'' %>>
                                    <span>Kotak</span>
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Font</label>
                            <select id="boostCardFont" class="select" style="font-size:.82rem;">
                                <% [['impact','Impact'],['arial','Arial'],['georgia','Georgia'],['courier','Courier New'],['verdana','Verdana']].forEach(function(f){ %>
                                    <option value="<%= f[0] %>" <%= (boostData.cardFont||'impact')===f[0]?'selected':'' %>><%= f[1] %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="label">Tipe Background</label>
                        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:.2rem;">
                            <% [['gradient','Gradien'],['solid','Solid'],['image','Gambar URL'],['transparent','Transparan']].forEach(function(bt){ %>
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.85rem;">
                                <input type="radio" name="boostCardBgType" value="<%= bt[0] %>" <%= (boostData.cardBgType||'gradient')===bt[0]?'checked':'' %>>
                                <span><%= bt[1] %></span>
                            </label>
                            <% }) %>
                        </div>
                    </div>
                    <div id="boostCardBgGradientPanel" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label" id="boostCardBgColor1Label">Latar Kiri</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardBgColorPicker" value="<%= boostData.cardBgColor||'#0a0a1e' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardBgColor','boostCardBgColorPicker');drawBoostCard()">
                                <input type="text" id="boostCardBgColor" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardBgColor||'#0a0a1e' %>" oninput="bcSyncP('boostCardBgColor','boostCardBgColorPicker');drawBoostCard()">
                            </div>
                        </div>
                        <div class="form-group" id="boostCardBgColor2Group">
                            <label class="label">Latar Kanan</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardBgColor2Picker" value="<%= boostData.cardBgColor2||'#1e0a2e' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardBgColor2','boostCardBgColor2Picker');drawBoostCard()">
                                <input type="text" id="boostCardBgColor2" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardBgColor2||'#1e0a2e' %>" oninput="bcSyncP('boostCardBgColor2','boostCardBgColor2Picker');drawBoostCard()">
                            </div>
                        </div>
                    </div>
                    <div id="boostCardBgImagePanel" style="display:none;" class="form-group">
                        <label class="label">URL Gambar Latar</label>
                        <input type="text" id="boostCardBgImageUrl" class="input" placeholder="https://..." value="<%= boostData.cardBgImageUrl||'' %>">
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label">Warna Overlay</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardOverlayColorPicker" value="<%= boostData.cardOverlayColor||'#000000' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardOverlayColor','boostCardOverlayColorPicker');drawBoostCard()">
                                <input type="text" id="boostCardOverlayColor" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardOverlayColor||'#000000' %>" oninput="bcSyncP('boostCardOverlayColor','boostCardOverlayColorPicker');drawBoostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label" style="display:flex;justify-content:space-between;"><span>Opasitas Overlay</span><span id="boostCardOverlayOpacityVal" style="color:var(--text-muted);font-weight:400;"><%= boostData.cardOverlayOpacity||'0' %>%</span></label>
                            <input type="range" id="boostCardOverlayOpacity" min="0" max="100" value="<%= boostData.cardOverlayOpacity||'0' %>" style="width:100%;margin-top:.45rem;accent-color:var(--accent,#5865f2);" oninput="document.getElementById('boostCardOverlayOpacityVal').textContent=this.value+'%';drawBoostCard()">
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
                        <div class="form-group">
                            <label class="label">Warna Judul</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardTitleColorPicker" value="<%= boostData.cardTitleColor||'#ffffff' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardTitleColor','boostCardTitleColorPicker');drawBoostCard()">
                                <input type="text" id="boostCardTitleColor" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardTitleColor||'#ffffff' %>" oninput="bcSyncP('boostCardTitleColor','boostCardTitleColorPicker');drawBoostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Warna Nama Pengguna</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardUsernameColorPicker" value="<%= boostData.cardUsernameColor||'#FF73FA' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardUsernameColor','boostCardUsernameColorPicker');drawBoostCard()">
                                <input type="text" id="boostCardUsernameColor" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardUsernameColor||'#FF73FA' %>" oninput="bcSyncP('boostCardUsernameColor','boostCardUsernameColorPicker');drawBoostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Warna Pesan (sub teks)</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardMsgColorPicker" value="<%= boostData.cardMsgColor||'#cccccc' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardMsgColor','boostCardMsgColorPicker');drawBoostCard()">
                                <input type="text" id="boostCardMsgColor" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardMsgColor||'#cccccc' %>" oninput="bcSyncP('boostCardMsgColor','boostCardMsgColorPicker');drawBoostCard()">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label">Warna Border Avatar</label>
                            <div style="display:flex;gap:.5rem;align-items:center;">
                                <input type="color" id="boostCardAccentPicker" value="<%= boostData.cardAccentColor||'#FF73FA' %>" style="width:38px;height:32px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none;" oninput="bcSync('boostCardAccentColor','boostCardAccentPicker');drawBoostCard()">
                                <input type="text" id="boostCardAccentColor" class="input" style="max-width:110px;" maxlength="7" value="<%= boostData.cardAccentColor||'#FF73FA' %>" oninput="bcSyncP('boostCardAccentColor','boostCardAccentPicker');drawBoostCard()">
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="label">Teks Besar</label>
                        <input type="text" id="boostCardWelcomeText" class="input" maxlength="20" placeholder="BOOST!" value="<%= boostData.cardWelcomeText||'BOOST!' %>">
                    </div>
                    <div class="form-group">
                        <label class="label">Teks Kecil Bawah</label>
                        <input type="text" id="boostCardSubText" class="input" maxlength="60" placeholder="Thank you for boosting!" value="<%= boostData.cardSubText||'Thank you for boosting!' %>">
                        <div class="hint" style="margin-top:.3rem;"><code>{server}</code> · <code>{boosts}</code> · <code>{level}</code></div>
                    </div>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" onclick="saveBoost()">Simpan</button>
                </div>
                <div id="boostMsg" class="form-message"></div>
            </div>

            <!-- Kolom kanan: preview -->
            <div class="preview-panel">
                <div class="preview-label">Preview</div>
                <div class="dc-window">
                    <div class="dc-channel-bar">
                        <span class="dc-channel-hash">#</span>
                        <span id="boostPrevChannel">pilih-channel</span>
                    </div>
                    <div class="dc-messages">
                        <!-- Card standalone: tampil ketika tidak ada konten pesan -->
                        <div id="boostCardPreviewWrap" style="display:none;padding:.75rem 1rem .25rem;">
                            <canvas id="boostCardCanvas" width="760" height="247" style="width:100%;border-radius:12px;display:block;"></canvas>
                        </div>
                        <div class="dc-message">
                            <img class="dc-avatar"
                                 src="<%- locals.botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                 alt="avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                            <div class="dc-msg-body">
                                <span class="dc-username" style="color:<%- botUser ? botUser.roleColor : '#ffffff' %>"><%- botUser ? botUser.username : 'Bot' %></span>
                                <span class="dc-timestamp">Hari ini pukul 12:00</span>
                                <!-- Plain text preview -->
                                <div id="boostPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                                <!-- Card menyatu di bawah teks biasa -->
                                <img id="boostCardInPlain" style="display:none;width:100%;max-width:440px;border-radius:8px;margin-top:.4rem;" alt="">
                                <!-- Embed preview -->
                                <div class="dc-embed" id="boostPreviewEmbed">
                                    <div class="dc-embed-pill" id="boostPreviewPill" style="background:#FF73FA;"></div>
                                    <div class="dc-embed-content">
                                        <div class="dc-embed-title" id="boostPreviewTitle"></div>
                                        <div class="dc-embed-desc"  id="boostPreviewDesc"></div>
                                        <div class="dc-embed-fields" id="boostPreviewFields"></div>
                                        <!-- Card menyatu di dalam embed -->
                                        <img id="boostCardInEmbed" style="display:none;width:100%;border-radius:4px;margin-top:.4rem;" alt="">
                                        <div class="dc-embed-footer" id="boostPreviewFooter"></div>
                                    </div>
                                    <img class="dc-embed-thumb" id="boostPreviewThumb"
                                         src="<%- loginUser ? loginUser.avatarUrl : 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                                         alt="thumb">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════
             TAB: UNBOOST NOTIFICATION
        ══════════════════════════════════════ -->
        <div id="tab-unboost" class="booster-editor-layout" style="display:none;">

            <!-- Kolom kiri: form -->
            <div class="settings-card" style="margin-bottom:0;">

                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="unboostEnabled" class="toggle-input"
                               <%= unboostData.enabled ? 'checked' : '' %>>
                        <span class="toggle-slider"></span>
                        <span>Aktifkan Unboost Notification</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="label">Channel Notifikasi</label>
                    <select id="unboostChannel" class="select">
                        <option value="">— Pilih channel —</option>
                        <% (locals.channels || []).forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= unboostData.channelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="label">Tipe Pesan</label>
                    <div style="display:flex;gap:.75rem;">
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="unboostMessageType" id="unboostTypeEmbed" value="embed"
                                   <%= (unboostData.messageType || 'plain') === 'embed' ? 'checked' : '' %>>
                            <span>Embed</span>
                        </label>
                        <label class="radio-label" style="display:flex;align-items:center;gap:.5rem;cursor:pointer;">
                            <input type="radio" name="unboostMessageType" id="unboostTypePlain" value="plain"
                                   <%= (unboostData.messageType || 'plain') === 'plain' ? 'checked' : '' %>>
                            <span>Teks Biasa</span>
                        </label>
                    </div>
                </div>

                <!-- Panel Teks Biasa -->
                <div id="unboostPlainPanel" class="form-group" style="display:none;">
                    <div class="label-with-picker">
                        <label class="label" style="margin-bottom:0;">Isi Pesan Teks Biasa</label>
                        <div class="ph-picker-anchor">
                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('unboostPlainPicker',event)">{…} Placeholder</button>
                            <div class="ph-dropdown" id="unboostPlainPicker" style="display:none;"></div>
                        </div>
                    </div>
                    <textarea id="unboostPlainText" class="textarea" rows="4"
                              placeholder="💔 {member} telah berhenti boost **{server}**. Total boost: **{boosts}**."
                              oninput="updateUnboostPreview()"><%= unboostData.plainText %></textarea>
                </div>

                <!-- Panel Embed -->
                <div id="unboostEmbedPanel">
                    <div style="display:flex;justify-content:flex-end;margin-bottom:.35rem;">
                        <div class="ph-picker-anchor">
                            <button type="button" class="ph-toggle-btn" onclick="togglePicker('unboostEmbedPicker',event)">{…} Placeholder</button>
                            <div class="ph-dropdown" id="unboostEmbedPicker" style="display:none;"></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label">Judul Embed</label>
                        <input type="text" id="unboostTitle" class="input"
                               placeholder="💔 Boost Berakhir"
                               value="<%= unboostData.title %>"
                               oninput="updateUnboostPreview()">
                    </div>

                    <div class="form-group">
                        <label class="label">Deskripsi Embed</label>
                        <textarea id="unboostDesc" class="textarea" rows="4"
                                  placeholder="{member} telah mencabut boost-nya dari server." oninput="updateUnboostPreview()"><%= unboostData.description %></textarea>
                    </div>

                    <div class="form-group">
                        <label class="label">Warna Embed</label>
                        <div style="display:flex;gap:.75rem;align-items:center;">
                            <input type="color" id="unboostColorPicker" value="<%= unboostData.color || '#ED4245' %>"
                                   style="width:44px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:0;background:none;"
                                   oninput="syncHex('unboostColor','unboostColorPicker');updateUnboostPreview()">
                            <input type="text" id="unboostColor" class="input" style="max-width:130px;"
                                   placeholder="#ED4245" maxlength="7"
                                   value="<%= unboostData.color || '#ED4245' %>"
                                   oninput="syncPicker('unboostColor','unboostColorPicker');updateUnboostPreview()">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="label">Footer <span style="font-weight:400;color:var(--text-muted)">(opsional)</span></label>
                        <input type="text" id="unboostFooter" class="input"
                               placeholder="Kosongkan untuk menghapus"
                               value="<%= unboostData.footerText || '' %>"
                               oninput="updateUnboostPreview()">
                    </div>

                    <div class="form-group">
                        <label class="toggle-label">
                            <input type="checkbox" id="unboostShowThumbnail" class="toggle-input"
                                   <%= unboostData.showThumbnail !== false ? 'checked' : '' %> onchange="updateUnboostPreview()">
                            <span class="toggle-slider"></span>
                            <span>Tampilkan foto profil member (thumbnail)</span>
                        </label>
                    </div>

                    <div class="form-group" style="border-top:1px solid var(--border);padding-top:1rem;margin-top:.5rem;">
                        <label class="label" style="margin-bottom:.75rem;">Field Info</label>
                        <div style="display:flex;flex-direction:column;gap:.6rem;">
                            <label class="toggle-label">
                                <input type="checkbox" id="unboostShowMember" class="toggle-input"
