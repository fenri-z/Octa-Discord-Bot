<script>
const GUILD_ID = '<%= guild.id %>';
const CHANNELS = <%- JSON.stringify(Object.fromEntries((locals.channels||[]).map(ch=>[ch.id,ch.name]))) %>;

const SAMPLE = {
    member:    '@<%= loginUser ? loginUser.displayName.replace(/'/g,"") : "BoostUser" %>',
    username:  '<%= loginUser ? loginUser.username.replace(/'/g,"") : "BoostUser" %>',
    tag:       '<%= loginUser ? loginUser.username.replace(/'/g,"") : "BoostUser" %>#0',
    server:    '<%- guild.name.replace(/'/g,"\\'") %>',
    boosts:    '<%= guild.premiumSubscriptionCount ?? 0 %>',
    level:     '<%= guild.premiumTier %>',
    avatarUrl: '<%- loginUser ? loginUser.avatarUrl : "https://cdn.discordapp.com/embed/avatars/0.png" %>',
};

// ── TAB switching ──────────────────────────────────────────────────────────
const TAB_META = {
    boost:   { title: 'Boost Notification',   desc: 'Notifikasi otomatis saat member melakukan boost server.' },
    unboost: { title: 'Unboost Notification', desc: 'Notifikasi otomatis saat member menghapus boost server.' },
};

function switchTab(tab) {
    document.querySelectorAll('.booster-editor-layout').forEach(el => el.style.display = 'none');
    document.getElementById(`tab-${tab}`).style.display = '';
    sessionStorage.setItem('booster_tab', tab);

    const subBoost   = document.getElementById('sidebarSubBoost');
    const subUnboost = document.getElementById('sidebarSubUnboost');
    if (subBoost)   subBoost.classList.toggle('active',   tab === 'boost');
    if (subUnboost) subUnboost.classList.toggle('active', tab === 'unboost');

    const meta = TAB_META[tab];
    if (meta) {
        const h1 = document.querySelector('.page-header h1');
        const p  = document.querySelector('.page-header p');
        if (h1) h1.textContent = meta.title;
        if (p)  p.textContent  = meta.desc;
    }
}

function _restoreTab() {
    const urlTab = new URLSearchParams(window.location.search).get('tab');
    const tab    = (urlTab === 'boost' || urlTab === 'unboost') ? urlTab
                 : sessionStorage.getItem('booster_tab') || 'boost';
    switchTab(tab);
}
document.addEventListener('DOMContentLoaded', _restoreTab);

// ── Toggle tipe pesan ──────────────────────────────────────────────────────
function toggleBoostType() {
    const isPlain = document.getElementById('boostTypePlain').checked;
    document.getElementById('boostPlainPanel').style.display  = isPlain ? 'block' : 'none';
    document.getElementById('boostEmbedPanel').style.display  = isPlain ? 'none'  : 'block';
    updateBoostPreview();
    drawBoostCard();
}
function toggleUnboostType() {
    const isPlain = document.getElementById('unboostTypePlain').checked;
    document.getElementById('unboostPlainPanel').style.display = isPlain ? 'block' : 'none';
    document.getElementById('unboostEmbedPanel').style.display = isPlain ? 'none'  : 'block';
    updateUnboostPreview();
    drawUnboostCard();
}

document.querySelectorAll('input[name="boostMessageType"]').forEach(el =>
    el.addEventListener('change', toggleBoostType));
document.querySelectorAll('input[name="unboostMessageType"]').forEach(el =>
    el.addEventListener('change', toggleUnboostType));

// ── Markdown → HTML ────────────────────────────────────────────────────────
function mdToHtml(text) {
    if (!text) return '';
    function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function inline(s) {
        return s
            .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
            .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
            .replace(/\*(.+?)\*/g,'<em>$1</em>')
            .replace(/__(.+?)__/g,'<u>$1</u>')
            .replace(/~~(.+?)~~/g,'<s>$1</s>');
    }
    const lines = text.split('\n'), out = [];
    for (const raw of lines) out.push(inline(esc(raw)));
    let result = '';
    for (let j = 0; j < out.length; j++) {
        if (j > 0) result += '<br>';
        result += out[j];
    }
    return result;
}

function resolvePh(text) {
    if (!text) return '';
    return text
        .replace(/\{member\}/g,   `<span style="color:#7289da;background:rgba(88,101,242,.15);border-radius:3px;padding:0 2px;font-weight:600;">${SAMPLE.member}</span>`)
        .replace(/\{username\}/g, SAMPLE.username)
        .replace(/\{tag\}/g,      SAMPLE.tag)
        .replace(/\{server\}/g,   SAMPLE.server)
        .replace(/\{boosts\}/g,   `<strong>${SAMPLE.boosts}</strong>`)
        .replace(/\{level\}/g,    `<strong>${SAMPLE.level}</strong>`);
}

// ── Card color sync helpers ────────────────────────────────────────────────
function bcSync(inputId, pickerId) { document.getElementById(inputId).value = document.getElementById(pickerId).value; }
function bcSyncP(inputId, pickerId) { const v = document.getElementById(inputId).value; if (/^#[0-9A-Fa-f]{6}$/.test(v)) document.getElementById(pickerId).value = v; }

// ── Card toggle ────────────────────────────────────────────────────────────
document.getElementById('boostCardEnabled').addEventListener('change', function() {
    document.getElementById('boostCardPanel').style.display = this.checked ? 'block' : 'none';
    drawBoostCard();
});
document.getElementById('unboostCardEnabled').addEventListener('change', function() {
    document.getElementById('unboostCardPanel').style.display = this.checked ? 'block' : 'none';
    drawUnboostCard();
});
document.querySelectorAll('input[name="boostCardBgType"]').forEach(el => el.addEventListener('change', drawBoostCard));
document.querySelectorAll('input[name="boostCardAvatarShape"]').forEach(el => el.addEventListener('change', drawBoostCard));
document.querySelectorAll('input[name="unboostCardBgType"]').forEach(el => el.addEventListener('change', drawUnboostCard));
document.querySelectorAll('input[name="unboostCardAvatarShape"]').forEach(el => el.addEventListener('change', drawUnboostCard));
['boostCardWelcomeText','boostCardSubText','boostCardFont','boostCardBgImageUrl'].forEach(id => {
    const el = document.getElementById(id); if (el) el.addEventListener('input', drawBoostCard);
});
['unboostCardWelcomeText','unboostCardSubText','unboostCardFont','unboostCardBgImageUrl'].forEach(id => {
    const el = document.getElementById(id); if (el) el.addEventListener('input', drawUnboostCard);
});

// ── Sinkronisasi posisi card di preview (shared logic) ────────────────────
function _syncBoosterCardPlacement(prefix, fieldDefs) {
    const enabled  = document.getElementById(prefix + 'CardEnabled')?.checked;
    const wrap     = document.getElementById(prefix + 'CardPreviewWrap');
    const imgEmbed = document.getElementById(prefix + 'CardInEmbed');
    const imgPlain = document.getElementById(prefix + 'CardInPlain');

    if (!enabled) {
        if (wrap)     wrap.style.display     = 'none';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = 'none';
        return;
    }

    const canvas  = document.getElementById(prefix + 'CardCanvas');
    const dataUrl = canvas ? canvas.toDataURL() : '';
    if (imgEmbed && dataUrl) imgEmbed.src = dataUrl;
    if (imgPlain && dataUrl) imgPlain.src = dataUrl;

    const isPlain = document.getElementById(prefix + 'TypePlain')?.checked;
    if (isPlain) {
        // Mode teks biasa: card selalu muncul di dalam pesan OCTA (imgPlain), tidak pernah standalone
        if (wrap)     wrap.style.display     = 'none';
        if (imgEmbed) imgEmbed.style.display = 'none';
        if (imgPlain) imgPlain.style.display = 'block';
    } else {
        // Mode embed: card selalu masuk ke dalam embed, tidak pernah standalone
        if (wrap)     wrap.style.display     = 'none';
        if (imgEmbed) imgEmbed.style.display = 'block';
        if (imgPlain) imgPlain.style.display = 'none';
    }
}

// ── Canvas card drawing (shared logic) ────────────────────────────────────
async function _drawCard(prefix, canvasId, wrapId, defaultBig, defaultSub, defaultAccent, defaultBg1, defaultBg2) {
    const enabled = document.getElementById(prefix + 'CardEnabled').checked;
    if (!enabled) { _syncBoosterCardPlacement(prefix, prefix === 'boost' ? BOOST_FIELDS : UNBOOST_FIELDS); return; }

    const canvas = document.getElementById(canvasId);
    const ctx    = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;

    const g = id => document.getElementById(prefix + 'Card' + id);
    const bgType    = document.querySelector(`input[name="${prefix}CardBgType"]:checked`)?.value || 'gradient';
    const bg1       = g('BgColor')?.value      || defaultBg1;
    const bg2       = g('BgColor2')?.value     || defaultBg2;
    const bgImgUrl  = (g('BgImageUrl')?.value  || '').trim();
    const overlayClr= g('OverlayColor')?.value || '#000000';
    const overlayOp = (parseInt(g('OverlayOpacity')?.value || '0')) / 100;
    const accent    = g('AccentColor')?.value  || defaultAccent;
    const titleClr  = g('TitleColor')?.value   || '#ffffff';
    const userClr   = g('UsernameColor')?.value|| accent;
    const msgClr    = g('MsgColor')?.value     || '#cccccc';
    const shape     = document.querySelector(`input[name="${prefix}CardAvatarShape"]:checked`)?.value || 'circle';
    const fontSel   = g('Font')?.value         || 'impact';
    const fontMap   = { impact:"Impact,'Arial Black',sans-serif", arial:'Arial,Helvetica,sans-serif', georgia:"Georgia,'Times New Roman',serif", courier:"'Courier New',Courier,monospace", verdana:'Verdana,Geneva,sans-serif' };
    const fontFam   = fontMap[fontSel] || fontMap.impact;
    const bigText   = g('WelcomeText')?.value  || defaultBig;
    const sub       = (g('SubText')?.value || defaultSub)
                        .replace(/{server}/gi, SAMPLE.server)
                        .replace(/{boosts}/gi, SAMPLE.boosts)
                        .replace(/{level}/gi,  SAMPLE.level);

    const gradPanel = document.getElementById(prefix + 'CardBgGradientPanel');
    const imgPanel  = document.getElementById(prefix + 'CardBgImagePanel');
    const col2Grp   = document.getElementById(prefix + 'CardBgColor2Group');
    const lbl       = document.getElementById(prefix + 'CardBgColor1Label');
    const hasBgClr  = bgType !== 'image' && bgType !== 'transparent';
    if (gradPanel) gradPanel.style.display = hasBgClr ? 'grid' : 'none';
    if (imgPanel)  imgPanel.style.display  = bgType === 'image' ? 'block' : 'none';
    if (col2Grp)   col2Grp.style.display   = bgType === 'gradient' ? 'block' : 'none';
    if (lbl)       lbl.textContent         = bgType === 'gradient' ? 'Latar Kiri' : 'Warna Latar';

    ctx.clearRect(0, 0, W, H);
    function rr(x,y,w,h,r){ ctx.beginPath(); ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r); ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h); ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r); ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath(); }

    if (bgType === 'transparent') {
        const sz = 12; ctx.save(); rr(0,0,W,H,16); ctx.clip();
        for (let y=0;y<H;y+=sz) for (let x=0;x<W;x+=sz) { ctx.fillStyle=(Math.floor(x/sz)+Math.floor(y/sz))%2===0?'#c0c0c0':'#909090'; ctx.fillRect(x,y,sz,sz); }
        ctx.restore();
    } else if (bgType === 'image' && bgImgUrl) {
        const proxyUrl = `/api/guild/${GUILD_ID}/image-proxy?url=` + encodeURIComponent(bgImgUrl);
        try {
            await new Promise((res,rej) => { const img=new Image(); img.onload=()=>{ctx.save();rr(0,0,W,H,16);ctx.clip();const sc=Math.max(W/img.width,H/img.height);ctx.drawImage(img,(W-img.width*sc)/2,(H-img.height*sc)/2,img.width*sc,img.height*sc);ctx.restore();res();};img.onerror=rej;img.src=proxyUrl;});
        } catch { rr(0,0,W,H,16);const gd=ctx.createLinearGradient(0,0,W,H);gd.addColorStop(0,bg1);gd.addColorStop(1,bg2);ctx.fillStyle=gd;ctx.fill();}
    } else if (bgType === 'solid') { rr(0,0,W,H,16); ctx.fillStyle=bg1; ctx.fill();
    } else { rr(0,0,W,H,16);const gd=ctx.createLinearGradient(0,0,W,H);gd.addColorStop(0,bg1);gd.addColorStop(1,bg2);ctx.fillStyle=gd;ctx.fill(); }

    if (overlayOp>0){ctx.save();rr(0,0,W,H,16);ctx.clip();ctx.globalAlpha=overlayOp;ctx.fillStyle=overlayClr;ctx.fillRect(0,0,W,H);ctx.globalAlpha=1;ctx.restore();}

    ctx.globalAlpha=0.07;ctx.fillStyle=accent;
    ctx.beginPath();ctx.arc(W-60,40,80,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(W-20,H-20,60,0,Math.PI*2);ctx.fill();
    ctx.globalAlpha=1;

    const AS=120,BD=5,avL=50,avT=(H-AS-BD*2)/2,TX=avL+AS+BD*2+40,isSquare=shape==='square';
    ctx.fillStyle=accent;
    if(isSquare){rr(avL,avT,AS+BD*2,AS+BD*2,20);ctx.fill();}
    else{ctx.beginPath();ctx.arc(avL+(AS+BD*2)/2,avT+(AS+BD*2)/2,(AS+BD*2)/2,0,Math.PI*2);ctx.fill();}

    const avatarProxyUrl = `/api/guild/${GUILD_ID}/image-proxy?url=` + encodeURIComponent(SAMPLE.avatarUrl);
    await new Promise(res => {
        const avImg=new Image();
        avImg.onload=()=>{ctx.save();if(isSquare){rr(avL+BD,avT+BD,AS,AS,14);ctx.clip();}else{ctx.beginPath();ctx.arc(avL+BD+AS/2,avT+BD+AS/2,AS/2,0,Math.PI*2);ctx.clip();}ctx.drawImage(avImg,avL+BD,avT+BD,AS,AS);ctx.restore();res();};
        avImg.onerror=()=>{ctx.fillStyle='#5a6070';if(isSquare){rr(avL+BD,avT+BD,AS,AS,14);ctx.fill();}else{ctx.beginPath();ctx.arc(avL+BD+AS/2,avT+BD+AS/2,AS/2,0,Math.PI*2);ctx.fill();}const cx=avL+BD+AS/2,cy=avT+BD+AS/2;ctx.fillStyle='#8892a4';ctx.beginPath();ctx.arc(cx,cy-20,22,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.ellipse(cx,cy+40,35,28,0,0,Math.PI*2);ctx.fill();res();};
        avImg.src=avatarProxyUrl;
    });

    ctx.shadowColor=titleClr;ctx.shadowBlur=8;ctx.font=`900 54px ${fontFam}`;ctx.fillStyle=titleClr;ctx.fillText(bigText,TX,115);ctx.shadowBlur=0;
    ctx.shadowColor='rgba(0,0,0,0.5)';ctx.shadowBlur=4;ctx.font=`700 24px ${fontFam}`;ctx.fillStyle=userClr;ctx.fillText(SAMPLE.username,TX,157);ctx.shadowBlur=0;
    ctx.font=`600 16px ${fontFam}`;ctx.fillStyle=msgClr;ctx.fillText(sub,TX,192);
    _syncBoosterCardPlacement(prefix, prefix === 'boost' ? BOOST_FIELDS : UNBOOST_FIELDS);
}

async function drawBoostCard() {
    await _drawCard('boost','boostCardCanvas','boostCardPreviewWrap','BOOST!','Thank you for boosting!','#FF73FA','#0a0a1e','#1e0a2e');
}
async function drawUnboostCard() {
    await _drawCard('unboost','unboostCardCanvas','unboostCardPreviewWrap','UNBOOST','Boost berakhir...','#ED4245','#1e0a0a','#2e0a0a');
}

// ── Field sample data ──────────────────────────────────────────────────────
const BOOST_FIELDS = [
    { id: 'boostShowMember',     name: '👤 Member',      value: () => SAMPLE.username },
    { id: 'boostShowMulaiBoost', name: '🚀 Mulai Boost', value: () => 'baru saja' },
    { id: 'boostShowTotalBoost', name: '✨ Total Boost',  value: () => `${SAMPLE.boosts} boost` },
    { id: 'boostShowLevelServer',name: '🏅 Level Server', value: () => `Level <%= guild.premiumTier %>` },
];
const UNBOOST_FIELDS = [
    { id: 'unboostShowMember',      name: '👤 Member',      value: () => SAMPLE.username },
    { id: 'unboostShowTotalBoost',  name: '✨ Total Boost',  value: () => `${SAMPLE.boosts} boost` },
    { id: 'unboostShowLevelServer', name: '🏅 Level Server', value: () => `Level <%= guild.premiumTier %>` },
];

function renderFields(fieldDefs, containerId) {
    const el = document.getElementById(containerId);
    const active = fieldDefs.filter(f => document.getElementById(f.id)?.checked);
    if (!active.length) { el.innerHTML = ''; return; }
    el.innerHTML = active.map(f =>
        `<div><div class="dc-field-name">${f.name}</div><div class="dc-field-value">${f.value()}</div></div>`
    ).join('');
}

// ── Preview: Boost ──────────────────────────────────────────────────────────
function updateBoostPreview() {
    const isPlain = document.getElementById('boostTypePlain').checked;
    const plainEl = document.getElementById('boostPreviewPlain');
    const embedEl = document.getElementById('boostPreviewEmbed');
    const chanId  = document.getElementById('boostChannel').value;
    document.getElementById('boostPrevChannel').textContent = chanId && CHANNELS[chanId] ? CHANNELS[chanId] : 'pilih-channel';

    if (isPlain) {
        const html = resolvePh(mdToHtml(document.getElementById('boostPlainText').value));
        plainEl.innerHTML     = html;
        plainEl.style.display = html.trim() ? 'block' : 'none';
        embedEl.style.display = 'none';
    } else {
        plainEl.style.display = 'none';
        const color = document.getElementById('boostColor').value || '#FF73FA';
        document.getElementById('boostPreviewPill').style.background = color;
        document.getElementById('boostPreviewTitle').innerHTML = resolvePh(mdToHtml(document.getElementById('boostTitle').value));
        document.getElementById('boostPreviewDesc').innerHTML  = resolvePh(mdToHtml(document.getElementById('boostDesc').value));
        renderFields(BOOST_FIELDS, 'boostPreviewFields');
        const footer = document.getElementById('boostFooter').value.trim();
        document.getElementById('boostPreviewFooter').innerHTML = footer ? resolvePh(mdToHtml(footer)) : '';
        const hasTitle    = document.getElementById('boostTitle').value.trim();
        const hasDesc     = document.getElementById('boostDesc').value.trim();
        const hasField    = BOOST_FIELDS.some(f => document.getElementById(f.id)?.checked);
        const cardActive  = document.getElementById('boostCardEnabled').checked;
        embedEl.style.display = (hasTitle || hasDesc || hasField || cardActive) ? 'flex' : 'none';
        const thumbEl = document.getElementById('boostPreviewThumb');
        if (thumbEl) thumbEl.style.display = document.getElementById('boostShowThumbnail').checked ? 'block' : 'none';
    }
    _syncBoosterCardPlacement('boost', BOOST_FIELDS);
}

