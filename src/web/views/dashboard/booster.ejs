// ── Color sync ──────────────────────────────────────────────────────────────
function syncHex(inputId, pickerId) {
    document.getElementById(inputId).value = document.getElementById(pickerId).value;
}
function syncPicker(inputId, pickerId) {
    const val = document.getElementById(inputId).value;
    if (/^#[0-9A-Fa-f]{6}$/.test(val)) document.getElementById(pickerId).value = val;
}

// ── Placeholder picker ──────────────────────────────────────────────────────
const PLACEHOLDERS = [
    ['{member}',   'Mention member'],
    ['{username}', 'Nama pengguna'],
    ['{tag}',      'Username#tag'],
    ['{server}',   'Nama server'],
    ['{boosts}',   'Total boost'],
    ['{level}',    'Level server'],
];

// ── Picker: tracks last focused field per section ─────────────────────────
let boostLastFocused   = 'boostTitle';
let unboostLastFocused = 'unboostTitle';

['boostTitle','boostDesc','boostFooter'].forEach(id => {
    document.getElementById(id)?.addEventListener('focus', () => boostLastFocused = id);
});
['unboostTitle','unboostDesc','unboostFooter'].forEach(id => {
    document.getElementById(id)?.addEventListener('focus', () => unboostLastFocused = id);
});

function buildEmbedPicker(pickerId, getTarget) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) =>
        `<button type="button" class="ph-item" onclick="insertPhDyn('${pickerId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
    ).join('');
}

function buildPlainPicker(pickerId, targetId) {
    const el = document.getElementById(pickerId);
    if (!el) return;
    el.innerHTML = PLACEHOLDERS.map(([ph, desc]) =>
        `<button type="button" class="ph-item" onclick="insertPh('${targetId}','${ph}')"><code>${ph}</code><span>${desc}</span></button>`
    ).join('');
}

function togglePicker(id, event) {
    if (event) event.stopPropagation();
    const el = document.getElementById(id);
    const wasHidden = el.style.display === 'none';
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
    if (wasHidden) el.style.display = 'grid';
}
document.addEventListener('click', () => document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none'));

function insertPh(targetId, ph) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const s = el.selectionStart ?? el.value.length;
    el.value = el.value.substring(0, s) + ph + el.value.substring(s);
    el.selectionStart = el.selectionEnd = s + ph.length;
    el.focus();
    el.dispatchEvent(new Event('input'));
    document.querySelectorAll('.ph-dropdown').forEach(d => d.style.display = 'none');
}

function insertPhDyn(pickerId, ph) {
    const targetId = pickerId.startsWith('boost') ? boostLastFocused : unboostLastFocused;
    insertPh(targetId, ph);
}

// ── Save ────────────────────────────────────────────────────────────────────
async function saveBoost() {
    const msg         = document.getElementById('boostMsg');
    if (!document.getElementById('boostChannel').value)
        return showMsg(msg, 'Pilih channel tujuan terlebih dahulu.', 'error');
    const messageType = document.querySelector('input[name="boostMessageType"]:checked')?.value || 'embed';
    const color       = document.getElementById('boostColor').value.trim() || '#FF73FA';
    if (messageType === 'embed' && !/^#[0-9A-Fa-f]{6}$/.test(color))
        return showMsg(msg, 'Format warna tidak valid. Contoh: #FF73FA', 'error');

    const res = await fetch(`/api/guild/${GUILD_ID}/booster-boost`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            enabled:          document.getElementById('boostEnabled').checked,
            channelId:        document.getElementById('boostChannel').value,
            messageType,
            plainText:        document.getElementById('boostPlainText').value.trim(),
            title:            document.getElementById('boostTitle').value.trim(),
            description:      document.getElementById('boostDesc').value.trim(),
            footerText:       document.getElementById('boostFooter').value.trim(),
            color,
            showMember:       document.getElementById('boostShowMember').checked,
            showMulaiBoost:   document.getElementById('boostShowMulaiBoost').checked,
            showTotalBoost:   document.getElementById('boostShowTotalBoost').checked,
            showLevelServer:  document.getElementById('boostShowLevelServer').checked,
            showThumbnail:    document.getElementById('boostShowThumbnail').checked,
            cardEnabled:        document.getElementById('boostCardEnabled').checked,
            cardWelcomeText:    document.getElementById('boostCardWelcomeText').value.trim()    || 'BOOST!',
            cardSubText:        document.getElementById('boostCardSubText').value.trim()        || 'Thank you for boosting!',
            cardBgColor:        document.getElementById('boostCardBgColor').value.trim()        || '#0a0a1e',
            cardBgColor2:       document.getElementById('boostCardBgColor2').value.trim()       || '#1e0a2e',
            cardAccentColor:    document.getElementById('boostCardAccentColor').value.trim()    || '#FF73FA',
            cardAvatarShape:    document.querySelector('input[name="boostCardAvatarShape"]:checked')?.value || 'circle',
            cardBgType:         document.querySelector('input[name="boostCardBgType"]:checked')?.value      || 'gradient',
            cardBgImageUrl:     document.getElementById('boostCardBgImageUrl')?.value.trim()    || '',
            cardOverlayColor:   document.getElementById('boostCardOverlayColor')?.value.trim()  || '#000000',
            cardOverlayOpacity: parseInt(document.getElementById('boostCardOverlayOpacity')?.value || '0'),
            cardTitleColor:     document.getElementById('boostCardTitleColor')?.value.trim()    || '#ffffff',
            cardUsernameColor:  document.getElementById('boostCardUsernameColor')?.value.trim() || '#FF73FA',
            cardMsgColor:       document.getElementById('boostCardMsgColor')?.value.trim()      || '#cccccc',
            cardFont:           document.getElementById('boostCardFont')?.value                 || 'impact',
        })
    });
    const data = await res.json();
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

async function saveUnboost() {
    const msg         = document.getElementById('unboostMsg');
    if (!document.getElementById('unboostChannel').value)
        return showMsg(msg, 'Pilih channel tujuan terlebih dahulu.', 'error');
    const messageType = document.querySelector('input[name="unboostMessageType"]:checked')?.value || 'embed';
    const color       = document.getElementById('unboostColor').value.trim() || '#ED4245';
    if (messageType === 'embed' && !/^#[0-9A-Fa-f]{6}$/.test(color))
        return showMsg(msg, 'Format warna tidak valid. Contoh: #ED4245', 'error');

    const res = await fetch(`/api/guild/${GUILD_ID}/booster-unboost`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            enabled:         document.getElementById('unboostEnabled').checked,
            channelId:       document.getElementById('unboostChannel').value,
            messageType,
            plainText:       document.getElementById('unboostPlainText').value.trim(),
            title:           document.getElementById('unboostTitle').value.trim(),
            description:     document.getElementById('unboostDesc').value.trim(),
            footerText:      document.getElementById('unboostFooter').value.trim(),
            color,
            showMember:      document.getElementById('unboostShowMember').checked,
            showTotalBoost:  document.getElementById('unboostShowTotalBoost').checked,
            showLevelServer: document.getElementById('unboostShowLevelServer').checked,
            showThumbnail:   document.getElementById('unboostShowThumbnail').checked,
            cardEnabled:        document.getElementById('unboostCardEnabled').checked,
            cardWelcomeText:    document.getElementById('unboostCardWelcomeText').value.trim()    || 'UNBOOST',
            cardSubText:        document.getElementById('unboostCardSubText').value.trim()        || 'Boost berakhir...',
            cardBgColor:        document.getElementById('unboostCardBgColor').value.trim()        || '#1e0a0a',
            cardBgColor2:       document.getElementById('unboostCardBgColor2').value.trim()       || '#2e0a0a',
            cardAccentColor:    document.getElementById('unboostCardAccentColor').value.trim()    || '#ED4245',
            cardAvatarShape:    document.querySelector('input[name="unboostCardAvatarShape"]:checked')?.value || 'circle',
            cardBgType:         document.querySelector('input[name="unboostCardBgType"]:checked')?.value      || 'gradient',
            cardBgImageUrl:     document.getElementById('unboostCardBgImageUrl')?.value.trim()    || '',
            cardOverlayColor:   document.getElementById('unboostCardOverlayColor')?.value.trim()  || '#000000',
            cardOverlayOpacity: parseInt(document.getElementById('unboostCardOverlayOpacity')?.value || '0'),
            cardTitleColor:     document.getElementById('unboostCardTitleColor')?.value.trim()    || '#ffffff',
            cardUsernameColor:  document.getElementById('unboostCardUsernameColor')?.value.trim() || '#ED4245',
            cardMsgColor:       document.getElementById('unboostCardMsgColor')?.value.trim()      || '#cccccc',
            cardFont:           document.getElementById('unboostCardFont')?.value                 || 'impact',
        })
    });
    const data = await res.json();
    showMsg(msg, data.message, data.success ? 'success' : 'error');
}

function showMsg(el, text, type) {
    el.textContent = text;
    el.className   = `form-message msg-${type}`;
    setTimeout(() => { el.textContent = ''; el.className = 'form-message'; }, 3000);
}

// ── Init ────────────────────────────────────────────────────────────────────
buildEmbedPicker('boostEmbedPicker');
buildEmbedPicker('unboostEmbedPicker');
buildPlainPicker('boostPlainPicker',   'boostPlainText');
buildPlainPicker('unboostPlainPicker', 'unboostPlainText');

// restore card panels
if (document.getElementById('boostCardEnabled').checked)
    document.getElementById('boostCardPanel').style.display = 'block';
if (document.getElementById('unboostCardEnabled').checked)
    document.getElementById('unboostCardPanel').style.display = 'block';

// Gambar card selesai dulu sebelum toggleType memanggil updatePreview/_syncCardPlacement
// (cegah race condition: canvas belum digambar saat imgPlain.src diset)
Promise.all([drawBoostCard(), drawUnboostCard()]).then(() => {
    toggleBoostType();
    toggleUnboostType();
});
</script>

