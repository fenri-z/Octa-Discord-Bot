<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'invites' }) %>

    <main class="dash-main" style="max-width:100%;">
    <div class="dash-content-wide">
        <%- include('../partials/perm-notice') %>
        <div class="page-header">
            <h1><%= t('invites.page_title') %></h1>
            <p><%= t('invites.page_desc') %></p>
        </div>

        <!-- ── Stats Overview ──────────────────────────────────────────── -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="link"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statTotal"><%= invites.length %></div>
                    <div class="stat-label"><%= t('invites.total_invite') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="trending-up"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statUses"><%= totalUses %></div>
                    <div class="stat-label"><%= t('invites.total_uses') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="user"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statInviters"><%= uniqueInviters %></div>
                    <div class="stat-label"><%= t('invites.unique_inviters') %></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon stat-icon-comm"><i data-lucide="crown"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statTop" style="font-size:.95rem;">
                        <% if (invites.length > 0) { %><%= invites[0].inviterTag %><% } else { %>—<% } %>
                    </div>
                    <div class="stat-label"><%= t('invites.top_invite') %></div>
                </div>
            </div>
        </div>

        <% if (fetchError) { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.25rem;">
            <i data-lucide="alert-triangle"></i>
            <span><%= fetchError %></span>
        </div>
        <% } %>

        <!-- ── Invite Table ─────────────────────────────────────────────── -->
        <div class="settings-card inv-table-card" style="padding:0;">

            <!-- Baris 1: judul + refresh -->
            <div class="inv-header-row" style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border,rgba(255,255,255,.06));">
                <h2 style="margin:0;"><%= t('invites.list_title') %></h2>
                <button class="btn btn-primary" id="refreshBtn" onclick="refreshInvites('<%= guild.id %>')"
                        style="font-size:.85rem;padding:.4rem .9rem;display:flex;align-items:center;gap:.35rem;flex-shrink:0;">
                    <i data-lucide="refresh-cw" style="width:14px;height:14px;"></i> Refresh
                </button>
            </div>

            <!-- Baris 2: filter periode + search -->
            <div class="inv-filter-row" style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.65rem 1.25rem;border-bottom:1px solid var(--border,rgba(255,255,255,.06));flex-wrap:wrap;">
                <div class="inv-period-btns" style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
                    <button class="period-btn active" data-period="all"    onclick="setPeriod(this,'all')"   ><%= t('invites.filter_all') %></button>
                    <button class="period-btn"         data-period="30d"   onclick="setPeriod(this,'30d')"   ><%= t('invites.filter_30d') %></button>
                    <button class="period-btn"         data-period="7d"    onclick="setPeriod(this,'7d')"    ><%= t('invites.filter_7d') %></button>
                    <button class="period-btn"         data-period="today" onclick="setPeriod(this,'today')" ><%= t('invites.filter_today') %></button>
                    <span class="inv-filter-hint" style="font-size:.75rem;color:var(--text-muted);"><%= t('invites.filter_hint') %></span>
                </div>
                <input type="text" id="searchInput" class="input inv-search" data-flt-ignore
                       placeholder="<%= t('invites.search_placeholder') %>"
                       style="width:220px;font-size:.85rem;padding:.38rem .75rem;flex-shrink:0;"
                       oninput="currentPage=1;applyFilter()">
            </div>

            <% if (invites.length === 0 && !fetchError) { %>
            <div style="padding:2.5rem;text-align:center;color:var(--text-muted);">
                <i data-lucide="inbox" style="width:40px;height:40px;opacity:.4;display:block;margin:0 auto .75rem;"></i>
                <%= t('invites.no_invites') %>
            </div>
            <% } else { %>
            <div class="inv-table-wrap">
                <table id="inviteTable" class="inv-table">
                    <thead>
                        <tr>
                            <th class="th-cell inv-col-rank">#</th>
                            <th class="th-cell inv-col-code"><%= t('invites.col_code') %></th>
                            <th class="th-cell inv-col-inviter"><%= t('invites.col_inviter') %></th>
                            <th class="th-cell inv-col-channel">Channel</th>
                            <th class="th-cell inv-col-uses"><%= t('invites.col_uses') %></th>
                            <th class="th-cell inv-col-created"><%= t('invites.col_created') %></th>
                            <th class="th-cell inv-col-expiry"><%= t('invites.col_expiry') %></th>
                            <th class="th-cell inv-col-temp" style="text-align:center;"><%= t('invites.col_temp') %></th>
                        </tr>
                    </thead>
                    <tbody id="inviteTableBody"></tbody>
                </table>
            </div>
            <div id="noResultMsg" style="display:none;padding:2rem;text-align:center;color:var(--text-muted);">
                <%= t('invites.no_results') %>
            </div>
            <% } %>

            <div id="paginationBar" style="display:flex;justify-content:center;align-items:center;gap:.3rem;padding:.65rem 1.25rem;border-top:1px solid var(--border,rgba(255,255,255,.06));flex-wrap:wrap;min-height:0;"></div>
            <div style="padding:.6rem 1.25rem;border-top:1px solid var(--border,rgba(255,255,255,.06));font-size:.8rem;color:var(--text-muted);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
                <span id="tableFooterCount"></span>
                <span id="lastRefreshed"><%= t('invites.data_fetched') %></span>
            </div>
        </div>

    </div>
    <%- include('../partials/dash-footer') %>
    </main>
</div>

<style>
.th-cell {
    padding:.65rem 1rem;
    text-align:left;
    font-size:.7rem;
    text-transform:uppercase;
    letter-spacing:.07em;
    color:var(--text-muted);
    font-weight:600;
    white-space:nowrap;
}
.period-btn {
    background:var(--bg3);
    color:var(--text-muted);
    border:1px solid var(--border);
    border-radius:6px;
    padding:.3rem .75rem;
    font-size:.8rem;
    cursor:pointer;
    transition:background .15s, color .15s, border-color .15s;
}
.period-btn:hover  { background:var(--bg2); color:var(--text); border-color:var(--accent); }
.period-btn.active { background:var(--accent); color:#fff; border-color:var(--accent); }
@keyframes spin { to { transform:rotate(360deg); } }
.page-btn {
    background:var(--bg3,#2a2b38);
    border:1px solid var(--border,rgba(255,255,255,.1));
    border-radius:6px;
    color:var(--text);
    padding:.28rem .6rem;
    font-size:.8rem;
    cursor:pointer;
    min-width:30px;
    text-align:center;
    transition:background .12s,color .12s,border-color .12s;
}
.page-btn:hover:not(:disabled) { border-color:#5865F2;color:#5865F2; }
.page-btn.active { background:#5865F2;color:#fff;border-color:#5865F2; }
.page-btn:disabled { opacity:.35;cursor:not-allowed; }
.page-ellipsis { color:var(--text-muted);font-size:.85rem;padding:0 .2rem;line-height:1; }

/* ── Invite table ────────────────────────────────────────────────────────── */
.inv-table-wrap {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
}
.inv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
}
.inv-td { white-space: nowrap; }
.inv-table thead tr { background: var(--bg3); }
.inv-tr {
    border-top: 1px solid var(--border);
    transition: background .15s;
}
.inv-tr:hover { background: var(--bg3); }
.inv-td { padding: .7rem 1rem; vertical-align: middle; }
.inv-code-link {
    font-family: monospace;
    font-weight: 600;
    color: #5865F2;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
}
.inv-code-link:hover { text-decoration: underline; }

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 680px) {
    .dash-main      { padding: 1.25rem 1rem 1.5rem !important; }

    /* Header bar: judul + refresh wrap */
    .inv-header-row { flex-wrap: wrap; gap: .5rem; }

    /* Filter bar: stack vertikal */
    .inv-filter-row { flex-direction: column !important; align-items: stretch !important; }
    .inv-search     { width: 100% !important; flex-shrink: unset !important; }
    /* Sembunyikan label "berdasarkan tgl. pembuatan" di mobile */
    .inv-filter-hint { display: none; }

    /* Table header padding lebih kecil */
    .th-cell { padding: .5rem .65rem; font-size: .65rem; }
    .inv-td  { padding: .6rem .65rem; }

}

@media (max-width: 480px) {
    .dash-main      { padding: 1rem .75rem 1.5rem !important; }

    /* Header & filter bar padding */
    .inv-header-row { padding: .75rem 1rem; }
    .inv-filter-row { padding: .5rem .75rem; }

    /* Period buttons lebih kecil */
    .period-btn { padding: .25rem .55rem; font-size: .75rem; }

    /* Footer bar */
    #paginationBar { padding: .5rem .75rem; }

    /* inv-table-card: vw trick sudah otomatis, tidak perlu override */
}

/* ── Mobile (≤ 600px): sembunyikan kolom tidak penting ──────────────────── */
@media (max-width: 600px) {
    .th-cell { padding: .45rem .55rem; font-size: .63rem; }
    .inv-td  { padding: .5rem .55rem;  font-size: .8rem; }

    /* Sembunyikan kolom Dibuat, Kadaluarsa, Sementara */
    .inv-col-created,
    .inv-col-expiry,
    .inv-col-temp { display: none; }

    /* Sembunyikan inviter ID panjang, tampilkan hanya username */
    .inv-inviter-id { display: none; }
}

/* ── Mobile kecil (≤ 390px): sembunyikan juga kolom Channel ─────────────── */
@media (max-width: 390px) {
    .dash-main      { padding: 1rem .75rem 1.5rem !important; }
    .inv-col-channel { display: none; }
}
</style>

<script>
const GUILD_ID    = '<%= guild.id %>';
const I18N_INV_PERMANENT  = '<%= t("invites.permanent") %>';
const I18N_INV_EXPIRED    = '<%= t("invites.expired") %>';
const I18N_INV_DAYS_LEFT  = '<%= t("invites.days_left") %>';
const I18N_INV_HOURS_LEFT = '<%= t("invites.hours_left") %>';
const I18N_INV_REFRESHED     = '<%= t("invites.refreshed_at") %>';
const I18N_INV_PAG_NONE      = '<%= t("invites.pagination_none") %>';
const I18N_INV_PAG_RANGE     = '<%= t("invites.pagination_range") %>';
const I18N_INV_ERR_FETCH     = '<%= t("invites.err_fetch") %>';
const I18N_INV_ERR_CONNECT   = '<%= t("invites.err_connect") %>';
const I18N_INV_LOADING       = '<%= t("invites.loading") %>';
const I18N_INV_PERIOD     = {
    all:   '<%= t("invites.filter_all") %>',
    '30d': '<%= t("invites.filter_30d") %>',
    '7d':  '<%= t("invites.filter_7d") %>',
    today: '<%= t("invites.filter_today") %>'
};
let ALL_INVITES   = <%- JSON.stringify(invites) %>;
let currentPeriod = 'all';
let currentPage   = 1;
const PAGE_SIZE   = 10;
let _filtered     = [];

// ── Helpers ──────────────────────────────────────────────────────────────────
function periodCutoff(period) {
    const now = Date.now();
    if (period === '30d')   return now - 30 * 86400000;
    if (period === '7d')    return now - 7  * 86400000;
    if (period === 'today') { const d = new Date(); d.setHours(0,0,0,0); return d.getTime(); }
    return 0;
}

function fmtExpiry(inv) {
    if (!inv.expiresAt) return `<span style="color:#57F287;font-size:.8rem;">${I18N_INV_PERMANENT}</span>`;
    const diff = inv.expiresAt - Date.now();
    const h = Math.floor(diff / 3600000);
    const d = Math.floor(h / 24);
    const label = diff <= 0 ? I18N_INV_EXPIRED : (d > 0 ? I18N_INV_DAYS_LEFT.replace('{n}', d) : I18N_INV_HOURS_LEFT.replace('{n}', h));
    return `<span title="${new Date(inv.expiresAt).toLocaleString('id-ID')}" style="cursor:default;">${label}</span>`;
}

function fmtCreated(inv) {
    if (!inv.createdAt) return '<span style="color:var(--text-muted);">—</span>';
    const d = new Date(inv.createdAt);
    return `<span title="${d.toLocaleString('id-ID')}" style="cursor:default;white-space:nowrap;">${d.toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'})}</span>`;
}

function buildRow(inv, rank) {
    const maxStr = inv.maxUses === 0 ? '∞' : inv.maxUses;
    const tempHtml = inv.temporary
        ? `<span style="background:rgba(254,231,92,.15);color:#FEE75C;border-radius:4px;padding:.2rem .5rem;font-size:.75rem;font-weight:600;">Ya</span>`
        : `<span style="color:var(--text-muted);font-size:.8rem;">—</span>`;
    const inviterIdHtml = inv.inviterId
        ? `<span class="inv-inviter-id" style="font-size:.75rem;color:var(--text-muted);font-family:monospace;">${inv.inviterId}</span>`
        : '';
    return `
    <tr class="inv-tr">
        <td class="inv-td inv-col-rank" style="color:var(--text-muted);font-size:.8rem;">${rank}</td>
        <td class="inv-td inv-col-code">
            <a href="${inv.url}" target="_blank" rel="noopener" class="inv-code-link">
                ${inv.code}
                <i data-lucide="external-link" style="width:12px;height:12px;opacity:.6;flex-shrink:0;"></i>
            </a>
        </td>
        <td class="inv-td inv-col-inviter">
            <div style="display:flex;flex-direction:column;gap:.1rem;">
                <span>${inv.inviterTag}</span>${inviterIdHtml}
            </div>
        </td>
        <td class="inv-td inv-col-channel" style="color:var(--text-muted);">#${inv.channelName}</td>
        <td class="inv-td inv-col-uses">
            <span style="font-weight:700;">${inv.uses}</span>
            <span style="color:var(--text-muted);font-size:.8rem;">/${maxStr}</span>
        </td>
        <td class="inv-td inv-col-created">${fmtCreated(inv)}</td>
        <td class="inv-td inv-col-expiry" style="white-space:nowrap;">${fmtExpiry(inv)}</td>
        <td class="inv-td inv-col-temp" style="text-align:center;">${tempHtml}</td>
    </tr>`;
}

// ── Filter ────────────────────────────────────────────────────────────────────
function applyFilter() {
    const q      = (document.getElementById('searchInput')?.value || '').toLowerCase();
    const cutoff = periodCutoff(currentPeriod);

    _filtered = ALL_INVITES.filter(inv => {
        const withinPeriod = (inv.createdAt ?? 0) >= cutoff;
        const matchSearch  = !q || (inv.code + inv.inviterTag + inv.channelName).toLowerCase().includes(q);
        return withinPeriod && matchSearch;
    });

    // Update stats
    const totalUses      = _filtered.reduce((s, inv) => s + inv.uses, 0);
    const uniqueInviters = new Set(_filtered.map(inv => inv.inviterId).filter(Boolean)).size;
    document.getElementById('statTotal').textContent    = _filtered.length;
    document.getElementById('statUses').textContent     = totalUses;
    document.getElementById('statInviters').textContent = uniqueInviters;
    document.getElementById('statTop').textContent      = _filtered.length > 0 ? _filtered[0].inviterTag : '—';

    renderPage();
}

// ── Render halaman tertentu ───────────────────────────────────────────────────
function renderPage() {
    const tbody = document.getElementById('inviteTableBody');
    const noRes = document.getElementById('noResultMsg');
    if (!tbody) return;

    const totalPages = Math.max(1, Math.ceil(_filtered.length / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    const start     = (currentPage - 1) * PAGE_SIZE;
    const end       = Math.min(start + PAGE_SIZE, _filtered.length);
    const pageItems = _filtered.slice(start, end);

    tbody.innerHTML = pageItems.map((inv, i) => buildRow(inv, start + i + 1)).join('');

    if (noRes) noRes.style.display = _filtered.length === 0 ? 'block' : 'none';

    // Footer count
    const periodLabel = I18N_INV_PERIOD[currentPeriod] || currentPeriod;
    const countEl = document.getElementById('tableFooterCount');
    if (countEl) {
        const _fmt = (tpl, v) => tpl.replace(/\{\{(\w+)\}\}/g, (_,k) => v[k] ?? _);
        countEl.textContent = _filtered.length === 0
            ? _fmt(I18N_INV_PAG_NONE,  { total: ALL_INVITES.length, period: periodLabel })
            : _fmt(I18N_INV_PAG_RANGE, { start: start + 1, end, total: _filtered.length, period: periodLabel });
    }

    renderPagination(totalPages);
    if (window.lucide) lucide.createIcons();
}

// ── Render pagination bar ─────────────────────────────────────────────────────
function renderPagination(totalPages) {
    const bar = document.getElementById('paginationBar');
    if (!bar) return;

    if (totalPages <= 1) { bar.innerHTML = ''; return; }

    const delta = 2;
    const range = [];
    for (let i = Math.max(1, currentPage - delta); i <= Math.min(totalPages, currentPage + delta); i++) range.push(i);

    let html = `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹ Prev</button>`;

    if (range[0] > 1) {
        html += `<button class="page-btn" onclick="goPage(1)">1</button>`;
        if (range[0] > 2) html += `<span class="page-ellipsis">…</span>`;
    }
    range.forEach(p => {
        html += `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`;
    });
    if (range[range.length-1] < totalPages) {
        if (range[range.length-1] < totalPages - 1) html += `<span class="page-ellipsis">…</span>`;
        html += `<button class="page-btn" onclick="goPage(${totalPages})">${totalPages}</button>`;
    }

    html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===totalPages?'disabled':''}>Next ›</button>`;
    bar.innerHTML = html;
}

function goPage(p) {
    const totalPages = Math.ceil(_filtered.length / PAGE_SIZE);
    if (p < 1 || p > totalPages) return;
    currentPage = p;
    renderPage();
    document.querySelector('.settings-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function setPeriod(btn, period) {
    currentPeriod = period;
    currentPage   = 1;
    document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter();
}

// ── Refresh ───────────────────────────────────────────────────────────────────
async function refreshInvites(guildId) {
    const btn = document.getElementById('refreshBtn');
    btn.disabled = true;
    btn.innerHTML = `<i data-lucide="loader" style="width:14px;height:14px;animation:spin 1s linear infinite;"></i> ${I18N_INV_LOADING}`;
    if (window.lucide) lucide.createIcons();
    try {
        const res  = await fetch(`/api/guild/${guildId}/invites`);
        const data = await res.json();
        if (!data.success) { alert(data.message || I18N_INV_ERR_FETCH); return; }
        ALL_INVITES = data.invites;
        currentPage = 1;
        applyFilter();
        document.getElementById('lastRefreshed').textContent = `${I18N_INV_REFRESHED} ${new Date().toLocaleTimeString('id-ID')}`;
    } catch { alert(I18N_INV_ERR_CONNECT); }
    finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="refresh-cw" style="width:14px;height:14px;"></i> Refresh';
        if (window.lucide) lucide.createIcons();
    }
}

document.addEventListener('DOMContentLoaded', () => { applyFilter(); });
</script>

<%- include('../partials/footer') %>
