<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
    <%- include('../partials/sidebar', { activePage: 'invites' }) %>

    <main class="dash-main">
    <div class="dash-content-wide">

        <div class="page-header">
            <h1>Invite Links</h1>
            <p>Semua invite link aktif di server, diurutkan dari penggunaan terbanyak. Invite yang sudah kadaluarsa otomatis tidak ditampilkan.</p>
        </div>

        <!-- ── Stats Overview ──────────────────────────────────────────── -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i data-lucide="link"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statTotal"><%= invites.length %></div>
                    <div class="stat-label">Total Invite</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#57F287;"><i data-lucide="trending-up"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statUses"><%= totalUses %></div>
                    <div class="stat-label">Total Digunakan</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#5865F2;"><i data-lucide="user"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statInviters"><%= uniqueInviters %></div>
                    <div class="stat-label">Pengundang Unik</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#FEE75C;"><i data-lucide="crown"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="statTop" style="font-size:.95rem;">
                        <% if (invites.length > 0) { %><%= invites[0].inviterTag %><% } else { %>—<% } %>
                    </div>
                    <div class="stat-label">Pengundang Teratas</div>
                </div>
            </div>
        </div>

        <% if (fetchError) { %>
        <div class="perm-card perm-warn" style="margin-bottom:1.25rem;">
            <i data-lucide="alert-triangle"></i>
            <span><%= fetchError %></span>
        </div>
        <% } %>

        <!-- ── Invite Table ─────────────────────────────────────────────── -->
        <div class="settings-card" style="padding:0;overflow:hidden;">

            <!-- Baris 1: judul + refresh -->
            <div style="display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border,rgba(255,255,255,.06));">
                <h2 style="margin:0;">Daftar Invite</h2>
                <button class="btn btn-primary" id="refreshBtn" onclick="refreshInvites('<%= guild.id %>')"
                        style="font-size:.85rem;padding:.4rem .9rem;display:flex;align-items:center;gap:.35rem;flex-shrink:0;">
                    <i data-lucide="refresh-cw" style="width:14px;height:14px;"></i> Refresh
                </button>
            </div>

            <!-- Baris 2: filter periode + search -->
            <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.65rem 1.25rem;border-bottom:1px solid var(--border,rgba(255,255,255,.06));flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
                    <button class="period-btn active" data-period="all"    onclick="setPeriod(this,'all')"   >Semua</button>
                    <button class="period-btn"         data-period="30d"   onclick="setPeriod(this,'30d')"   >30 Hari</button>
                    <button class="period-btn"         data-period="7d"    onclick="setPeriod(this,'7d')"    >7 Hari</button>
                    <button class="period-btn"         data-period="today" onclick="setPeriod(this,'today')" >Hari Ini</button>
                    <span style="font-size:.75rem;color:var(--text-muted);">berdasarkan tgl. pembuatan</span>
                </div>
                <input type="text" id="searchInput" class="input" placeholder="Cari kode / pengundang / channel…"
                       style="width:220px;font-size:.85rem;padding:.38rem .75rem;flex-shrink:0;"
                       oninput="applyFilter()">
            </div>

            <% if (invites.length === 0 && !fetchError) { %>
            <div style="padding:2.5rem;text-align:center;color:var(--text-muted);">
                <i data-lucide="inbox" style="width:40px;height:40px;opacity:.4;display:block;margin:0 auto .75rem;"></i>
                Tidak ada invite link aktif di server ini.
            </div>
            <% } else { %>
            <div style="overflow-x:auto;">
                <table id="inviteTable" style="width:100%;border-collapse:collapse;font-size:.875rem;">
                    <thead>
                        <tr style="background:var(--bg-3,#2b2d31);">
                            <th class="th-cell" style="width:2.5rem;">#</th>
                            <th class="th-cell">Kode Invite</th>
                            <th class="th-cell">Pengundang</th>
                            <th class="th-cell">Channel</th>
                            <th class="th-cell" style="text-align:right;">Digunakan</th>
                            <th class="th-cell">Dibuat</th>
                            <th class="th-cell">Kadaluarsa</th>
                            <th class="th-cell" style="text-align:center;">Sementara</th>
                        </tr>
                    </thead>
                    <tbody id="inviteTableBody"></tbody>
                </table>
            </div>
            <div id="noResultMsg" style="display:none;padding:2rem;text-align:center;color:var(--text-muted);">
                Tidak ada invite yang cocok dengan filter saat ini.
            </div>
            <% } %>

            <div style="padding:.75rem 1.25rem;border-top:1px solid var(--border,rgba(255,255,255,.06));font-size:.8rem;color:var(--text-muted);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
                <span id="tableFooterCount"></span>
                <span id="lastRefreshed">Data diambil saat halaman dimuat</span>
            </div>
        </div>

    </div>
    </main>
</div>

<style>
.th-cell {
    padding:.65rem 1rem;
    text-align:left;
    font-size:.7rem;
    text-transform:uppercase;
    letter-spacing:.07em;
    color:var(--text-muted);
    font-weight:600;
    white-space:nowrap;
}
.period-btn {
    background:var(--bg-3,#2b2d31);
    color:var(--text-secondary);
    border:1px solid var(--border,rgba(255,255,255,.08));
    border-radius:6px;
    padding:.3rem .75rem;
    font-size:.8rem;
    cursor:pointer;
    transition:background .15s, color .15s, border-color .15s;
}
.period-btn:hover  { background:var(--bg-4,#3b3d44); color:var(--text-primary); }
.period-btn.active { background:#5865F2; color:#fff; border-color:#5865F2; }
@keyframes spin { to { transform:rotate(360deg); } }
</style>

<script>
const GUILD_ID   = '<%= guild.id %>';
let ALL_INVITES  = <%- JSON.stringify(invites) %>;
let currentPeriod = 'all';

// ── Helpers ──────────────────────────────────────────────────────────────────
function periodCutoff(period) {
    const now = Date.now();
    if (period === '30d')   return now - 30 * 86400000;
    if (period === '7d')    return now - 7  * 86400000;
    if (period === 'today') {
        const d = new Date(); d.setHours(0,0,0,0); return d.getTime();
    }
    return 0;
}

function fmtExpiry(inv) {
    if (!inv.expiresAt) return `<span style="color:#57F287;font-size:.8rem;">Permanen</span>`;
    const diff = inv.expiresAt - Date.now();
    const h = Math.floor(diff / 3600000);
    const d = Math.floor(h / 24);
    const label = diff <= 0 ? 'Kadaluarsa' : (d > 0 ? `${d}h lagi` : `${h}j lagi`);
    return `<span title="${new Date(inv.expiresAt).toLocaleString('id-ID')}" style="cursor:default;">${label}</span>`;
}

function fmtCreated(inv) {
    if (!inv.createdAt) return '<span style="color:var(--text-muted);">—</span>';
    const d = new Date(inv.createdAt);
    return `<span title="${d.toLocaleString('id-ID')}" style="cursor:default;white-space:nowrap;">${d.toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'})}</span>`;
}

function buildRow(inv, rank) {
    const maxStr = inv.maxUses === 0 ? '∞' : inv.maxUses;
    const tempHtml = inv.temporary
        ? `<span style="background:rgba(254,231,92,.15);color:#FEE75C;border-radius:4px;padding:.2rem .5rem;font-size:.75rem;font-weight:600;">Ya</span>`
        : `<span style="color:var(--text-muted);font-size:.8rem;">—</span>`;
    const inviterIdHtml = inv.inviterId
        ? `<span style="font-size:.75rem;color:var(--text-muted);font-family:monospace;">${inv.inviterId}</span>`
        : '';
    return `
    <tr class="inv-row" data-created="${inv.createdAt ?? 0}"
        data-search="${(inv.code+inv.inviterTag+inv.channelName).toLowerCase()}"
        style="border-top:1px solid var(--border,rgba(255,255,255,.05));transition:background .15s;"
        onmouseover="this.style.background='var(--bg-3,#2b2d31)'" onmouseout="this.style.background=''">
        <td style="padding:.7rem 1rem;color:var(--text-muted);font-size:.8rem;">${rank}</td>
        <td style="padding:.7rem 1rem;">
            <a href="${inv.url}" target="_blank" rel="noopener"
               style="font-family:monospace;font-weight:600;color:#5865F2;text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;"
               onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">
                ${inv.code}
                <i data-lucide="external-link" style="width:12px;height:12px;opacity:.6;flex-shrink:0;"></i>
            </a>
        </td>
        <td style="padding:.7rem 1rem;color:var(--text-primary);">
            <div style="display:flex;flex-direction:column;gap:.1rem;">
                <span>${inv.inviterTag}</span>${inviterIdHtml}
            </div>
        </td>
        <td style="padding:.7rem 1rem;color:var(--text-secondary);">#${inv.channelName}</td>
        <td style="padding:.7rem 1rem;text-align:right;">
            <span style="font-weight:700;color:var(--text-primary);">${inv.uses}</span>
            <span style="color:var(--text-muted);font-size:.8rem;">/${maxStr}</span>
        </td>
        <td style="padding:.7rem 1rem;">${fmtCreated(inv)}</td>
        <td style="padding:.7rem 1rem;white-space:nowrap;color:var(--text-secondary);">${fmtExpiry(inv)}</td>
        <td style="padding:.7rem 1rem;text-align:center;">${tempHtml}</td>
    </tr>`;
}

// ── Core render ───────────────────────────────────────────────────────────────
function applyFilter() {
    const tbody   = document.getElementById('inviteTableBody');
    if (!tbody) return;

    const q       = (document.getElementById('searchInput')?.value || '').toLowerCase();
    const cutoff  = periodCutoff(currentPeriod);

    const filtered = ALL_INVITES.filter(inv => {
        const withinPeriod = (inv.createdAt ?? 0) >= cutoff;
        const matchSearch  = !q || (inv.code + inv.inviterTag + inv.channelName).toLowerCase().includes(q);
        return withinPeriod && matchSearch;
    });

    // Render rows
    tbody.innerHTML = filtered.map((inv, i) => buildRow(inv, i + 1)).join('');

    // Update stats
    const totalUses      = filtered.reduce((s, inv) => s + inv.uses, 0);
    const uniqueInviters = new Set(filtered.map(inv => inv.inviterId).filter(Boolean)).size;
    const topInviter     = filtered.length > 0 ? filtered[0].inviterTag : '—';

    document.getElementById('statTotal').textContent    = filtered.length;
    document.getElementById('statUses').textContent     = totalUses;
    document.getElementById('statInviters').textContent = uniqueInviters;
    document.getElementById('statTop').textContent      = topInviter;

    const noRes = document.getElementById('noResultMsg');
    if (noRes) noRes.style.display = filtered.length === 0 ? 'block' : 'none';

    const periodLabel = {
        all: 'semua periode', '30d': '30 hari terakhir',
        '7d': '7 hari terakhir', today: 'hari ini'
    }[currentPeriod];
    document.getElementById('tableFooterCount').textContent =
        `${filtered.length} dari ${ALL_INVITES.length} invite ditampilkan (${periodLabel})`;

    if (window.lucide) lucide.createIcons();
}

function setPeriod(btn, period) {
    currentPeriod = period;
    document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter();
}

// ── Refresh ───────────────────────────────────────────────────────────────────
async function refreshInvites(guildId) {
    const btn = document.getElementById('refreshBtn');
    btn.disabled = true;
    btn.innerHTML = '<i data-lucide="loader" style="width:14px;height:14px;animation:spin 1s linear infinite;"></i> Memuat…';
    if (window.lucide) lucide.createIcons();

    try {
        const res  = await fetch(`/api/guild/${guildId}/invites`);
        const data = await res.json();
        if (!data.success) { alert(data.message || 'Gagal mengambil invite.'); return; }

        ALL_INVITES = data.invites;
        applyFilter();

        const now = new Date().toLocaleTimeString('id-ID');
        document.getElementById('lastRefreshed').textContent = `Diperbarui pukul ${now}`;
    } catch {
        alert('Gagal menghubungi server.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="refresh-cw" style="width:14px;height:14px;"></i> Refresh';
        if (window.lucide) lucide.createIcons();
    }
}

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    applyFilter();
});
</script>

<%- include('../partials/footer') %>
