                <div class="lp-avatar-status"></div>
            </div>
        </div>

    </div>
</div>

<!-- ── Why Section ────────────────────────────────────────────────────────── -->
<section class="lp-why">
    <div class="lp-why-inner">

        <h2 class="lp-why-heading"><%= t('landing.why_prefix') %> <span class="gw"><%- locals.botNavName || 'Bot' %>?</span></h2>

        <!-- Row 1: Moderation — text left, mock right -->
        <div class="lp-why-row">
            <div class="lp-why-text">
                <div class="lp-why-label" style="color:#ED4245;"><%= t('landing.why1_label') %></div>
                <h3><%= t('landing.why1_title') %></h3>
                <p><%= t('landing.why1_desc') %></p>
            </div>
            <div class="lp-why-visual">
                <div class="lp-mock">
                    <div class="lp-mock-bar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
