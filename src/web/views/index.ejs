<%- include('partials/head') %>

<style>
/* ── Landing Page ───────────────────────────────────────────────────────── */
/* Reset grid body — halaman ini tidak punya navbar */
body {
    display: block; /* hapus grid — semua section stack normal */
    background-color: #0b0c15;
    background-image:
        radial-gradient(ellipse 70% 55% at 92% 8%,  rgba(88,101,242,.16) 0%, transparent 55%),
        radial-gradient(ellipse 50% 45% at 8%  90%, rgba(87,242,135,.06) 0%, transparent 50%),
        radial-gradient(ellipse 60% 40% at 50% 55%, rgba(88,101,242,.05) 0%, transparent 60%);
    background-attachment: fixed;
}

/* ─── Hero ──────────────────────────────────────────────────────────────── */
.lp-hero { position: relative; overflow: hidden; }
.lp-hero-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 7rem 3rem 5rem;
    display: grid;
    grid-template-columns: 1fr 380px;
    align-items: center;
    gap: 4rem;
    position: relative; z-index: 1;
}

/* Online badge */
.lp-online-badge {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(87,242,135,.1);
    border: 1px solid rgba(87,242,135,.25);
    color: #57F287;
    border-radius: 999px;
    font-size: .72rem; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; padding: .3rem 1rem;
    margin-bottom: 1.5rem;
}
.lp-online-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #57F287; box-shadow: 0 0 7px rgba(87,242,135,.9);
    animation: dot-pulse 2s ease-in-out infinite;
}
@keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: .5; transform: scale(.8); }
}

/* Main title */
.lp-title {
    font-size: clamp(2.5rem, 6.5vw, 4rem);
    font-weight: 800; letter-spacing: -.04em; line-height: 1.08;
    margin-bottom: 1.25rem; color: #fff;
    display: flex; align-items: baseline; flex-wrap: wrap; gap: .15em;
}
.lp-cursor {
    display: inline-block;
    width: 3px; height: .82em; border-radius: 2px;
    background: #5865F2; margin-left: 2px; vertical-align: middle;
    animation: cursor-blink 1s step-end infinite;
}
@keyframes cursor-blink { 50% { opacity: 0; } }

.lp-subtitle {
    font-size: 1rem; color: var(--text-muted);
    line-height: 1.8; max-width: 440px; margin-bottom: 2.25rem;
}

/* CTA row */
.lp-cta-row { display: flex; gap: .7rem; flex-wrap: wrap; margin-bottom: 2rem; }
.lp-btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .8rem 1.85rem; border-radius: 12px;
    font-weight: 700; font-size: .9rem;
    text-decoration: none;
    transition: transform .15s, box-shadow .2s, background .2s;
    white-space: nowrap; line-height: 1;
}
.lp-btn-primary {
    background: #5865F2; color: #fff;
    box-shadow: 0 4px 20px rgba(88,101,242,.45);
}
.lp-btn-primary:hover {
    background: #4752c4; transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(88,101,242,.55);
}
.lp-btn-ghost {
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.13);
    color: var(--text);
}
.lp-btn-ghost:hover { background: rgba(255,255,255,.12); transform: translateY(-2px); }
.lp-btn svg { width: 18px; height: 18px; flex-shrink: 0; }

/* Right: Bot avatar */
.lp-hero-right { display: flex; justify-content: center; align-items: center; }
.lp-avatar-wrap {
    position: relative; width: 340px; height: 340px; flex-shrink: 0;
}
.lp-avatar-glow {
    position: absolute; inset: -40px; border-radius: 50%;
    background: radial-gradient(circle, rgba(88,101,242,.25) 0%, transparent 65%);
    animation: ava-pulse 3.5s ease-in-out infinite;
}
@keyframes ava-pulse {
    0%, 100% { transform: scale(1); opacity: .8; }
    50%       { transform: scale(1.06); opacity: 1; }
}
.lp-avatar-ring1 {
    position: absolute; inset: -12px; border-radius: 50%;
    border: 1.5px solid rgba(88,101,242,.45);
    animation: ring-cw 15s linear infinite;
}
.lp-avatar-ring1::before {
    content: ''; position: absolute;
    top: 3px; left: 50%; transform: translateX(-50%);
    width: 9px; height: 9px; border-radius: 50%;
    background: #5865F2; box-shadow: 0 0 10px #5865F2;
}
.lp-avatar-ring2 {
    position: absolute; inset: -26px; border-radius: 50%;
    border: 1px solid rgba(88,101,242,.2);
    animation: ring-cw 28s linear infinite reverse;
}
.lp-avatar-ring2::before {
    content: ''; position: absolute;
    bottom: 10px; right: 14px;
    width: 6px; height: 6px; border-radius: 50%;
    background: #57F287; box-shadow: 0 0 7px #57F287;
}
@keyframes ring-cw { to { transform: rotate(360deg); } }

.lp-avatar-img {
    width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
    border: 4px solid rgba(88,101,242,.7);
    box-shadow: 0 0 0 1px rgba(255,255,255,.1), 0 0 30px rgba(88,101,242,.3);
    position: relative; z-index: 2; display: block;
}
.lp-avatar-status {
    position: absolute; bottom: 20px; right: 20px;
    width: 26px; height: 26px; border-radius: 50%;
    background: #57F287; border: 3px solid #0b0c15;
    box-shadow: 0 0 12px rgba(87,242,135,.7);
    z-index: 3;
}

/* ─── Why Section ───────────────────────────────────────────────────────── */
.lp-why {
    background: transparent;
    padding: 5.5rem 3rem;
}
.lp-why-inner { max-width: 1100px; margin: 0 auto; }

.lp-why-heading {
    text-align: center;
    font-size: clamp(1.9rem, 5.5vw, 2.8rem);
    font-weight: 800; letter-spacing: -.03em; margin-bottom: 4.5rem; color: #fff;
}
.lp-why-heading .gw {
    background: linear-gradient(90deg, #57F287 0%, #5865F2 48%, #FEE75C 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

.lp-why-row {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4.5rem; align-items: center; margin-bottom: 5.5rem;
}
.lp-why-row:last-child { margin-bottom: 0; }
.lp-why-row.rev .lp-why-visual { order: -1; }

.lp-why-label {
    font-size: .71rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; margin-bottom: .6rem;
    display: flex; align-items: center; gap: .45rem;
}
.lp-why-label::before {
    content: ''; display: inline-block;
    width: 16px; height: 2px; border-radius: 1px;
    background: currentColor; opacity: .7;
}
.lp-why-text h3 {
    font-size: clamp(1.35rem, 3.5vw, 1.8rem);
    font-weight: 800; letter-spacing: -.025em; margin-bottom: .8rem; color: #fff;
}
.lp-why-text p {
    font-size: .9rem; color: var(--text-muted); line-height: 1.8; max-width: 390px;
}

/* Discord chat mock */
.lp-mock {
    background: #2b2d31; border-radius: 16px; overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
}
.lp-mock-bar {
    background: #1e1f22; padding: .6rem 1rem;
    display: flex; align-items: center; gap: .45rem;
    font-size: .75rem; color: rgba(255,255,255,.4);
    border-bottom: 1px solid rgba(0,0,0,.35);
}
.lp-mock-bar svg { width: 14px; height: 14px; opacity: .5; }
.lp-mock-body { padding: 1.1rem; }
.lp-mock-msg { display: flex; gap: .75rem; margin-bottom: .85rem; }
.lp-mock-msg:last-child { margin-bottom: 0; }
.lp-mock-ava {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    overflow: hidden;
}
.lp-mock-ava img { width: 100%; height: 100%; object-fit: cover; display: block; }
.lp-mock-msg-body { min-width: 0; }
.lp-mock-name {
    font-size: .78rem; font-weight: 700; color: #fff;
    display: flex; align-items: center; gap: .35rem; margin-bottom: .25rem;
}
.lp-mock-tag {
    font-size: .58rem; font-weight: 700; padding: .08rem .3rem;
    border-radius: 3px; background: #5865F2; color: #fff;
    letter-spacing: .04em; text-transform: uppercase;
}
.lp-mock-embed {
    border-left: 4px solid; background: rgba(0,0,0,.22);
    border-radius: 0 8px 8px 0; padding: .85rem 1rem; margin-top: .2rem;
}
.lp-mock-embed-title { font-size: .82rem; font-weight: 700; color: #fff; margin-bottom: .3rem; }
.lp-mock-embed-desc { font-size: .75rem; color: rgba(255,255,255,.62); line-height: 1.6; }
.lp-mock-embed-fields {
    display: flex; flex-wrap: wrap; gap: .4rem 1.25rem;
    margin-top: .55rem;
}
.lp-mock-field { font-size: .73rem; }
.lp-mock-field-name { font-weight: 700; color: rgba(255,255,255,.8); margin-bottom: .1rem; }
.lp-mock-field-val { color: rgba(255,255,255,.5); }

/* ─── Feature Grid ──────────────────────────────────────────────────────── */
.lp-features { max-width: 1100px; margin: 0 auto; padding: 4.5rem 3rem 5rem; }
.lp-sect-title { text-align: center; margin-bottom: 2.5rem; }
.lp-sect-title h2 {
    font-size: clamp(1.4rem, 5vw, 1.9rem); font-weight: 800;
    letter-spacing: -.025em; margin-bottom: .5rem;
}
.lp-sect-title p {
    color: var(--text-muted); font-size: .88rem; max-width: 400px;
    margin: 0 auto; line-height: 1.65;
}
.lp-feat-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: .85rem;
}
.lp-feat-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 1.25rem;
    transition: border-color .2s, box-shadow .2s, transform .18s; cursor: default;
}
.lp-feat-card:hover {
    border-color: rgba(88,101,242,.4);
    box-shadow: 0 6px 28px rgba(0,0,0,.3); transform: translateY(-3px);
}
.lp-feat-icon {
    width: 42px; height: 42px; border-radius: 11px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: .9rem;
    background: var(--ic-bg, rgba(88,101,242,.15));
    color: var(--ic-color, #7289da);
}
.lp-feat-icon svg { width: 20px; height: 20px; }
.lp-feat-card h3 { font-size: .82rem; font-weight: 700; margin-bottom: .3rem; color: var(--text); }
.lp-feat-card p  { font-size: .74rem; color: var(--text-muted); line-height: 1.65; margin: 0; }

/* ─── Bottom CTA ────────────────────────────────────────────────────────── */
.lp-bottom {
    background: transparent;
    border-top: none;
    text-align: center; padding: 5rem 2rem 6rem;
}

/* ─── Footer override (site-footer.ejs punya bg hardcoded) ─────────────── */
.site-footer {
    background: transparent !important;
    border-top: none !important;
}
.lp-bottom h2 {
    font-size: clamp(1.3rem, 5vw, 1.8rem); font-weight: 800;
    letter-spacing: -.02em; margin-bottom: .65rem;
}
.lp-bottom p {
    color: var(--text-muted); font-size: .9rem;
    max-width: 360px; margin: 0 auto 2rem; line-height: 1.65;
}

/* ─── Powered by + icon buttons ─────────────────────────────────────────── */
.lp-powered {
    display: flex; align-items: center; gap: .45rem;
    font-size: .78rem; color: var(--text-muted); margin-top: 1.5rem;
    overflow: hidden;
}
.lp-powered svg { width: 16px; height: 16px; flex-shrink: 0; opacity: .6; }
.lp-powered a { color: #7289da; text-decoration: none; }
.lp-powered a:hover { text-decoration: underline; }
.lp-icon-btns {
    display: none;
    gap: .65rem; margin-top: 1.35rem; justify-content: center;
}
.lp-icon-btn {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; justify-content: center;
    color: var(--text); text-decoration: none;
    transition: background .15s, transform .15s;
}
.lp-icon-btn:hover { background: rgba(255,255,255,.13); transform: translateY(-2px); }
.lp-icon-btn svg { width: 22px; height: 22px; }

/* ─── Responsive ────────────────────────────────────────────────────────── */
/* ── Tablet (≤ 1024px) ───────────────────────────────────────────────────── */
@media (max-width: 1024px) {
    .lp-hero-inner {
        grid-template-columns: 1fr; text-align: center;
        padding: 3.5rem 2rem 3.5rem; gap: 2rem;
    }
    .lp-hero-left  { order: 2; }
    .lp-hero-right { order: 1; }
    .lp-online-badge { margin-left: auto; margin-right: auto; display: inline-flex; }
    .lp-title { justify-content: center; font-size: clamp(2rem, 8vw, 3rem); }
    .lp-subtitle { margin-left: auto; margin-right: auto; font-size: .95rem; }
    .lp-cta-row { justify-content: center; }
    .lp-powered { justify-content: center; }
    .lp-icon-btns { display: flex; }
    .lp-avatar-wrap { width: 200px; height: 200px; }
    .lp-avatar-status { width: 20px; height: 20px; bottom: 14px; right: 14px; }
    .lp-why-row, .lp-why-row.rev { grid-template-columns: 1fr; gap: 2rem; }
    .lp-why-row.rev .lp-why-visual { order: 0; }
    .lp-why-text p { max-width: 100%; }
    .lp-why-text h3 { font-size: 1.5rem; }
    .lp-feat-grid { grid-template-columns: repeat(3, 1fr); }
    .lp-features { padding: 3rem 2rem 4rem; }
    .lp-bottom { padding: 3.5rem 2rem 4.5rem; }
}
/* ── Mobile besar (≤ 768px) ──────────────────────────────────────────────── */
@media (max-width: 768px) {
    .lp-hero-inner { padding: 3rem 1.5rem 3rem; }
    .lp-avatar-wrap { width: 180px; height: 180px; }
    .lp-title { font-size: clamp(1.8rem, 9vw, 2.4rem); }
    .lp-subtitle { font-size: .88rem; }
    .lp-why { padding: 3rem 1.5rem; }
    .lp-why-heading { font-size: clamp(1.5rem, 7vw, 2rem); margin-bottom: 2.25rem; }
    .lp-why-row { margin-bottom: 3rem; }
    .lp-features { padding: 2.5rem 1.25rem 3.5rem; }
    .lp-feat-grid { grid-template-columns: repeat(2, 1fr); }
}
/* ── Mobile kecil (≤ 480px) ──────────────────────────────────────────────── */
@media (max-width: 480px) {
    .lp-hero-inner { padding: 2.5rem 1.25rem 2.5rem; gap: 1.5rem; }
    .lp-avatar-wrap { width: 155px; height: 155px; }
    .lp-avatar-status { width: 18px; height: 18px; bottom: 10px; right: 10px; }
    .lp-avatar-ring1 { inset: -8px; }
    .lp-avatar-ring2 { inset: -18px; }
    .lp-online-badge { font-size: .65rem; padding: .25rem .85rem; }
    .lp-btn { padding: .75rem 1.5rem; font-size: .85rem; }
    .lp-feat-grid { grid-template-columns: 1fr; }
    .lp-bottom { padding: 3rem 1.25rem 4rem; }
    .lp-mock { border-radius: 12px; }
}
</style>

<!-- ── Hero ──────────────────────────────────────────────────────────────── -->
<div class="lp-hero">
    <div class="lp-hero-inner">

        <!-- Left: Text -->
        <div class="lp-hero-left">
            <div class="lp-online-badge">
                <span class="lp-online-dot"></span>
                <%= t('landing.badge') %>
            </div>
            <h1 class="lp-title">
                <%- locals.botNavName || locals.botName || 'OCTA BOT' %><span class="lp-cursor"></span>
            </h1>
            <p class="lp-subtitle">
                <%= t('landing.subtitle') %>
            </p>
