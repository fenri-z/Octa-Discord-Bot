<aside class="sidebar">
    <div class="sidebar-guild">
        <button class="sidebar-server-btn" onclick="toggleServerSelector()">
            <% if (guild.iconURL()) { %><img src="<%= guild.iconURL() %>" alt="<%= guild.name %>" class="sidebar-guild-icon">
            <% } else { %><div class="sidebar-guild-icon-placeholder"><%= guild.name.charAt(0) %></div><% } %>
            <span class="sidebar-guild-name"><%= guild.name %></span>
            <span class="sidebar-server-chevron"><i data-lucide="chevron-down"></i></span>
        </button>
        <div class="sidebar-server-dd" id="sidebarServerDD">
            <% (locals.mutualGuilds || []).forEach(function(g) { %>
                <% if (g.isActive) { %>
                    <div class="sidebar-server-dd-item active">
                        <% if (g.iconURL) { %><img src="<%= g.iconURL %>" alt="" class="sidebar-guild-icon">
                        <% } else { %><div class="sidebar-guild-icon-placeholder"><%= g.name.charAt(0) %></div><% } %>
                        <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= g.name %></span>
                        <i data-lucide="check" style="width:13px;height:13px;flex-shrink:0;margin-left:4px;"></i>
                    </div>
                <% } else { %>
                    <a href="/dashboard/<%= g.id %>" class="sidebar-server-dd-item">
                        <% if (g.iconURL) { %><img src="<%= g.iconURL %>" alt="" class="sidebar-guild-icon">
                        <% } else { %><div class="sidebar-guild-icon-placeholder"><%= g.name.charAt(0) %></div><% } %>
                        <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= g.name %></span>
                    </a>
                <% } %>
            <% }); %>
            <div class="sidebar-server-dd-divider"></div>
            <a href="/dashboard" class="sidebar-server-dd-item sidebar-server-dd-change">
                <i data-lucide="layout-grid"></i> <%= t('sidebar.all_servers') %>
            </a>
        </div>
    </div>
    <nav class="sidebar-nav">
        <a href="/dashboard/<%= guild.id %>" class="sidebar-link<%= activePage === 'home' ? ' active' : '' %>"><i data-lucide="layout-dashboard"></i> Overview</a>
        <span class="sidebar-group-label">Notification</span>
        <a href="/dashboard/<%= guild.id %>/welcome"              class="sidebar-sublink<%= activePage === 'welcome'          ? ' active' : '' %>"><i data-lucide="user-plus"></i> Welcome Notification</a>
        <a href="/dashboard/<%= guild.id %>/goodbye"              class="sidebar-sublink<%= activePage === 'goodbye'          ? ' active' : '' %>"><i data-lucide="log-out"></i> Goodbye Notification</a>
        <a href="/dashboard/<%= guild.id %>/booster?tab=boost"    class="sidebar-sublink" id="sidebarSubBoost"><i data-lucide="zap"></i> Boost Notification</a>
        <a href="/dashboard/<%= guild.id %>/booster?tab=unboost"  class="sidebar-sublink" id="sidebarSubUnboost"><i data-lucide="zap-off"></i> Unboost Notification</a>
        <span class="sidebar-group-label">Auto Role</span>
        <a href="/dashboard/<%= guild.id %>/autorole?tab=join"    class="sidebar-sublink" id="sidebarSubJoin"><i data-lucide="users"></i> Autorole Join</a>
        <a href="/dashboard/<%= guild.id %>/autorole?tab=booster" class="sidebar-sublink" id="sidebarSubBooster"><i data-lucide="zap"></i> Autorole Booster</a>
        <a href="/dashboard/<%= guild.id %>/autorole?tab=button"   class="sidebar-sublink" id="sidebarSubButton"><i data-lucide="mouse-pointer-2"></i> Autorole Button</a>
        <a href="/dashboard/<%= guild.id %>/autorole?tab=reaction" class="sidebar-sublink" id="sidebarSubReaction"><i data-lucide="smile"></i> Autorole Reaction</a>
        <span class="sidebar-group-label">Moderation</span>
        <a href="/dashboard/<%= guild.id %>/automod"   class="sidebar-sublink<%= activePage === 'automod'   ? ' active' : '' %>"><i data-lucide="shield-check"></i> Automod</a>
        <a href="/dashboard/<%= guild.id %>/warnings"  class="sidebar-sublink<%= activePage === 'warnings'  ? ' active' : '' %>"><i data-lucide="triangle-alert"></i> Warning System</a>
        <a href="/dashboard/<%= guild.id %>/modlog"    class="sidebar-sublink<%= activePage === 'modlog'    ? ' active' : '' %>"><i data-lucide="scroll-text"></i> Mod Log</a>
        <span class="sidebar-group-label">Community</span>
        <a href="/dashboard/<%= guild.id %>/ticket"               class="sidebar-sublink<%= activePage === 'ticket'           ? ' active' : '' %>"><i data-lucide="ticket"></i> Ticket</a>
        <a href="/dashboard/<%= guild.id %>/giveaway"             class="sidebar-sublink<%= activePage === 'giveaway'         ? ' active' : '' %>"><i data-lucide="gift"></i> Giveaway</a>
        <a href="/dashboard/<%= guild.id %>/level"                class="sidebar-sublink<%= activePage === 'level'            ? ' active' : '' %>"><i data-lucide="star"></i> Level / XP</a>
        <a href="/dashboard/<%= guild.id %>/starboard"            class="sidebar-sublink<%= activePage === 'starboard'        ? ' active' : '' %>"><i data-lucide="award"></i> Starboard</a>
        <a href="/dashboard/<%= guild.id %>/invites"              class="sidebar-sublink<%= activePage === 'invites'          ? ' active' : '' %>"><i data-lucide="link"></i> Invite Links</a>
        <span class="sidebar-group-label">Utility</span>
        <a href="/dashboard/<%= guild.id %>/custom-commands"      class="sidebar-sublink<%= activePage === 'custom-commands'  ? ' active' : '' %>"><i data-lucide="terminal"></i> Custom Commands</a>
        <a href="/dashboard/<%= guild.id %>/message-builder"      class="sidebar-sublink<%= activePage === 'message-builder'  ? ' active' : '' %>"><i data-lucide="mail"></i> Message Builder</a>
        <a href="/dashboard/<%= guild.id %>/serverstats"          class="sidebar-sublink<%= activePage === 'serverstats'      ? ' active' : '' %>"><i data-lucide="bar-chart-2"></i> Server Stats</a>
        <a href="/dashboard/<%= guild.id %>/extlog"               class="sidebar-sublink<%= activePage === 'extlog'           ? ' active' : '' %>"><i data-lucide="book-open"></i> Extended Logging</a>
        <span class="sidebar-group-label">Social Media</span>
        <a href="/dashboard/<%= guild.id %>/youtube"              class="sidebar-sublink<%= activePage === 'youtube'  ? ' active' : '' %>"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="flex-shrink:0;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg> Youtube Notification</a>
        <a href="/dashboard/<%= guild.id %>/tiktok"               class="sidebar-sublink<%= activePage === 'tiktok'   ? ' active' : '' %>"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="flex-shrink:0;"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg> TikTok Notification</a>
        <a href="/dashboard/<%= guild.id %>/twitch"              class="sidebar-sublink<%= activePage === 'twitch'   ? ' active' : '' %>"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="flex-shrink:0;"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg> Twitch Notification</a>
        <a href="/dashboard/<%= guild.id %>/kick"                class="sidebar-sublink<%= activePage === 'kick'     ? ' active' : '' %>"><svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="flex-shrink:0;"><path d="M2.664 0v24h5.227v-8.01l2.557-2.503 5.186 10.513H21l-7.527-14.6L20.188 3.54h-5.753L8.083 9.872 7.89 9.68V0z"/></svg> Kick Notification</a>
    </nav>

</aside>
<script>
(function () {
    // Tandai sub-link aktif berdasarkan query tab
    var tab = new URLSearchParams(window.location.search).get('tab');
    if (tab) {
        var map = { boost: 'sidebarSubBoost', unboost: 'sidebarSubUnboost', join: 'sidebarSubJoin', booster: 'sidebarSubBooster', button: 'sidebarSubButton', reaction: 'sidebarSubReaction' };
        var el = document.getElementById(map[tab]);
        if (el) el.classList.add('active');
    }

    var SCROLL_KEY = 'octa-sidebar-scroll';
    var sidebar    = document.querySelector('.sidebar');
    var sidebarNav = document.querySelector('.sidebar-nav');
    if (!sidebar) return;

    // ── Restore posisi scroll dari navigasi sebelumnya ──────────────────────
    // Desktop → .sidebar yang scroll; Mobile drawer → .sidebar-nav yang scroll.
    // Set keduanya sekaligus; yang tidak bisa scroll (overflow bukan auto/scroll)
    // akan mengabaikannya secara otomatis.
    var saved = sessionStorage.getItem(SCROLL_KEY);
    if (saved !== null) {
        var pos = parseInt(saved, 10);
        sidebar.scrollTop = pos;
        if (sidebarNav) sidebarNav.scrollTop = pos;
    } else {
        // Belum ada simpanan → scroll ke item aktif (fallback pertama kali)
        var active = sidebar.querySelector('.sidebar-link.active, .sidebar-sublink.active');
        if (active) {
            var sRect  = sidebar.getBoundingClientRect();
            var aRect  = active.getBoundingClientRect();
            var relTop = aRect.top    - sRect.top;
            var relBot = aRect.bottom - sRect.top;
            var sH     = sidebar.clientHeight;
            if (relTop < 0 || relBot > sH) {
                sidebar.scrollTop += relTop - sH / 2 + active.offsetHeight / 2;
            }
        }
    }

    // ── Simpan posisi scroll sebelum pindah halaman ──────────────────────────
    // Ambil nilai terbesar antara .sidebar dan .sidebar-nav (hanya satu
    // yang aktif scroll pada satu waktu, yang lain selalu 0).
    function _savePos() {
        var pos = Math.max(sidebar.scrollTop, sidebarNav ? sidebarNav.scrollTop : 0);
        sessionStorage.setItem(SCROLL_KEY, pos);
    }

    // Simpan saat klik link (tepat sebelum navigasi terjadi)
    sidebar.addEventListener('click', function (e) {
        if (e.target.closest('a[href]')) _savePos();
    });

    // Simpan juga saat user scroll sidebar manual (debounced 150 ms)
    var _t;
    function _onScroll() {
        clearTimeout(_t);
        _t = setTimeout(_savePos, 150);
    }
    sidebar.addEventListener('scroll', _onScroll, { passive: true });
    if (sidebarNav) sidebarNav.addEventListener('scroll', _onScroll, { passive: true });
})();
</script>
