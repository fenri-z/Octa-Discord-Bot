<%
const _colors  = { video: '#FF0000', short: '#FF6B35', live: '#CC0000' };
const _titles  = { video: `📹 ${ytCh.name} — Video Baru!`, short: `🎬 ${ytCh.name} — Short Baru!`, live: `🔴 ${ytCh.name} is Live Now!` };
const _fields  = { video: 'Judul Video', short: 'Judul Short', live: 'Streaming Title' };
const _pill    = _colors[type]  || '#5865F2';
const _title   = _titles[type] || '';
const _field   = _fields[type] || 'Judul';
const _mockTitle = type === 'live'  ? 'Malam Jumat Membership'
                 : type === 'short' ? 'Contoh Judul Short #shorts'
                 : 'Contoh Judul Video yang Akan Muncul';
const _prevId  = `ytPrev-${ytCh.id}-${type}`;
const _mockUrl = 'https://youtube.com/watch?v=dQw4w9WgXcQ';
%>
<div class="dc-window" id="<%= _prevId %>">
    <div class="dc-channel-bar">
        <span class="dc-channel-hash">#</span>
        <span class="yt-prev-ch-name">pilih-channel</span>
    </div>
    <div class="dc-messages">
        <div class="dc-message">
            <img class="dc-avatar"
                 src="<%= botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                 alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
            <div class="dc-msg-body">
                <span class="dc-username"><%= botNavName || 'Bot' %></span>
                <span class="dc-timestamp">Hari ini pukul 12:00</span>

                <!-- Embed -->
                <div class="dc-embed" style="max-width:100%;">
                    <div class="dc-embed-pill yt-prev-pill" style="background:<%= _pill %>;"></div>
                    <div class="dc-embed-inner" style="flex:1;min-width:0;">

                        <!-- Embed title + thumbnail kanan -->
                        <div style="display:flex;align-items:flex-start;gap:.5rem;">
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:.88rem;font-weight:700;color:#00b0f4;margin-bottom:.3rem;
                                            word-break:break-word;line-height:1.3;">
                                    <%= _title %>
                                </div>
                                <!-- Deskripsi: pesan custom -->
                                <div class="dc-plain-msg yt-prev-msg" style="display:none;color:#dbdee1;
                                     font-size:.82rem;margin-bottom:.4rem;"></div>
                            </div>
                            <% if (ytCh.thumbnail) { %>
                            <img src="<%= ytCh.thumbnail %>" referrerpolicy="no-referrer" alt=""
                                 style="width:60px;height:60px;border-radius:4px;object-fit:cover;
                                        flex-shrink:0;margin-top:.1rem;"
                                 onerror="this.style.display='none'">
                            <% } %>
                        </div>

                        <!-- Fields -->
                        <div style="margin-top:.3rem;">
                            <div style="margin-bottom:.3rem;">
                                <div style="font-size:.74rem;font-weight:700;color:#dbdee1;margin-bottom:.1rem;">
                                    <%= _field %>
                                </div>
                                <div style="font-size:.8rem;color:#00b0f4;">
                                    <a href="<%= _mockUrl %>" style="color:#00b0f4;text-decoration:none;">
                                        <%= _mockTitle %>
                                    </a>
                                </div>
                            </div>
                            <div>
                                <div style="font-size:.74rem;font-weight:700;color:#dbdee1;margin-bottom:.1rem;">
                                    Link
                                </div>
                                <div style="font-size:.8rem;">
                                    <a href="<%= _mockUrl %>" style="color:#00b0f4;text-decoration:none;">
                                        Tonton sekarang
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Gambar besar -->
                        <div class="yt-thumb-mock" style="margin-top:.6rem;">
                            <div class="yt-thumb-mock-inner">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>

                    </div>
                </div><!-- /dc-embed -->
            </div>
        </div>
    </div>
</div>
