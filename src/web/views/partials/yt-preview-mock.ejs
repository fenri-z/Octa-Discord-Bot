<%
const _colors  = { video: '#FF0000', short: '#FF6B35', live: '#CC0000' };
const _titles  = { video: `📹 ${ytCh.name} — New Video!`, short: `🎬 ${ytCh.name} — New Short!`, live: `🔴 ${ytCh.name} is Live Right Now!` };
const _fields  = { video: '🎬 Video Title', short: '🎬 Short Title', live: '🎙️ Stream Title' };
const _pill    = _colors[type]  || '#5865F2';
const _title   = _titles[type] || '';
const _field   = _fields[type] || 'Title';
const _mockTitle = type === 'live'  ? 'Live Stream Title Example'
                 : type === 'short' ? 'Example Short Title #shorts'
                 : 'Example Video Title That Will Appear';
const _mockUrl = 'https://youtube.com/watch?v=dQw4w9WgXcQ';
const _defaultDescs = {
    video: `Hey, **${ytCh.name}** just uploaded a new video on YouTube!\nDon't miss it, watch now! 🎉`,
    short: `**${ytCh.name}** just posted a new Short!\nCheck out their quick video, don't miss out! ⚡`,
    live:  `Hey, **${ytCh.name}** is **LIVE** on YouTube right now!\nCome join and watch the stream~ 🎉`,
};
// Simple markdown renderer for initial server-side render (bold + newlines)
const _md = s => (s || '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br>');
const _prevId  = `ytPrev-${ytCh.id}-${type}`;
const _chIdKeys = { video: 'videoChannelId', short: 'shortChannelId', live: 'liveChannelId' };
const _initChName = (() => {
    const chId = ytCh[_chIdKeys[type]];
    if (!chId) return 'select-channel';
    const ch = (locals.channels || []).find(c => c.id === chId);
    return ch ? ch.name : 'select-channel';
})();
%>
<div class="dc-window" id="<%= _prevId %>">
    <div class="dc-channel-bar">
        <span class="dc-channel-hash">#</span>
        <span class="yt-prev-ch-name"><%= _initChName %></span>
    </div>
    <div class="dc-messages">
        <div class="dc-message">
            <img class="dc-avatar"
                 src="<%= botNavAvatar || 'https://cdn.discordapp.com/embed/avatars/0.png' %>"
                 alt="" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
            <div class="dc-msg-body">
                <span class="dc-username"><%= botNavName || 'Bot' %></span>
                <span class="dc-timestamp">Today at 12:00 PM</span>

                <!-- Embed -->
                <div class="dc-embed" style="max-width:100%;">
                    <div class="dc-embed-pill yt-prev-pill" style="background:<%= _pill %>;"></div>
                    <div class="dc-embed-inner" style="flex:1;min-width:0;">

                        <!-- Embed title + thumbnail kanan -->
                        <div style="display:flex;align-items:flex-start;gap:.5rem;">
                            <div style="flex:1;min-width:0;">
                                <a href="<%= _mockUrl %>" onclick="return false;"
                                   style="font-size:.88rem;font-weight:700;color:#00b0f4;margin-bottom:.35rem;
                                          word-break:break-word;line-height:1.3;text-decoration:none;display:block;">
                                    <%= _title %>
                                </a>

                                <!-- Description: custom message atau default -->
                                <div class="dc-plain-msg yt-prev-msg yt-prev-desc"
                                     style="color:#dbdee1;font-size:.80rem;margin-bottom:.45rem;
                                            line-height:1.45;word-break:break-word;">
                                    <%- _md(_defaultDescs[type]) %>
                                </div>
                                <!-- Override saat user ketik custom message (via JS) -->
                                <div class="dc-plain-msg yt-prev-msg"
                                     style="display:none;color:#dbdee1;font-size:.80rem;margin-bottom:.45rem;"></div>
                            </div>
                            <% if (ytCh.thumbnail) { %>
                            <img src="<%= ytCh.thumbnail %>" referrerpolicy="no-referrer" alt=""
                                 style="width:60px;height:60px;border-radius:4px;object-fit:cover;
                                        flex-shrink:0;margin-top:.1rem;"
                                 onerror="this.style.display='none'">
                            <% } %>
                        </div>

                        <!-- Fields -->
                        <div style="margin-top:.25rem;">
                            <div style="margin-bottom:.3rem;">
                                <div style="font-size:.74rem;font-weight:700;color:#dbdee1;margin-bottom:.1rem;">
                                    <%= _field %>
                                </div>
                                <div style="font-size:.8rem;color:#00b0f4;">
                                    <a href="<%= _mockUrl %>" onclick="return false;" style="color:#00b0f4;text-decoration:none;">
                                        <%= _mockTitle %>
                                    </a>
                                </div>
                            </div>
                            <div>
                                <div style="font-size:.74rem;font-weight:700;color:#dbdee1;margin-bottom:.1rem;">
                                    🔗 Link
                                </div>
                                <div style="font-size:.8rem;">
                                    <a href="<%= _mockUrl %>" onclick="return false;" style="color:#00b0f4;text-decoration:none;">
                                        Click Me ▶
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Thumbnail besar -->
                        <div class="yt-thumb-mock" style="margin-top:.6rem;">
                            <div class="yt-thumb-mock-inner">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>

                    </div>
                </div><!-- /dc-embed -->
            </div>
        </div>
    </div>
</div>
