<style>
.flt-bar {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 36px));
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: .65rem .85rem .65rem 1.1rem;
    background: rgba(20, 21, 31, 0.96);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,.11);
    border-radius: 12px;
    box-shadow:
        0 12px 48px rgba(0,0,0,.6),
        0 4px 16px rgba(0,0,0,.35),
        0 0 0 1px rgba(88,101,242,.18);
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    width: clamp(420px, 65vw, 900px);
    transition: transform .3s cubic-bezier(.15,.85,.2,1), opacity .25s ease;
}
[data-theme="light"] .flt-bar {
    background: rgba(255, 255, 255, 0.97);
    border: 1px solid rgba(0,0,0,.1);
    box-shadow:
        0 12px 48px rgba(0,0,0,.14),
        0 4px 16px rgba(0,0,0,.08),
        0 0 0 1px rgba(88,101,242,.14);
}
.flt-bar.flt-visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
}

.flt-bar-left {
    display: flex; align-items: center; gap: .55rem;
    font-size: .84rem; color: var(--text-muted);
    flex: 1; min-width: 0;
}
.flt-pulse {
    width: 7px; height: 7px; border-radius: 50%;
    background: #fee75c; flex-shrink: 0;
    animation: flt-blink 1.4s ease-in-out infinite;
}
@keyframes flt-blink {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: .35; transform: scale(.7); }
}
.flt-bar-right { display: flex; gap: .4rem; flex-shrink: 0; }

.flt-btn-reset {
    background: transparent;
    border: 1px solid rgba(255,255,255,.18);
    color: rgba(255,255,255,.7);
    padding: .42rem .9rem;
    border-radius: 8px;
    font-size: .8rem; font-weight: 600;
    cursor: pointer;
    transition: background .15s, border-color .15s, color .15s;
}
.flt-btn-reset:hover {
    background: rgba(255,255,255,.09);
    border-color: rgba(255,255,255,.35);
    color: #fff;
}
[data-theme="light"] .flt-btn-reset {
    border-color: var(--border);
    color: var(--text-muted);
}
[data-theme="light"] .flt-btn-reset:hover {
    background: var(--bg3);
    border-color: var(--border);
    color: var(--text);
}
.flt-btn-save {
    display: flex; align-items: center; gap: .35rem;
    background: var(--accent, #5865F2);
    border: none; color: #fff;
    padding: .42rem 1rem;
    border-radius: 8px;
    font-size: .8rem; font-weight: 600;
    cursor: pointer;
    transition: filter .15s, opacity .15s, box-shadow .15s;
    box-shadow: 0 2px 12px rgba(88,101,242,.4);
}
.flt-btn-save:hover {
    filter: brightness(1.12);
    box-shadow: 0 4px 18px rgba(88,101,242,.55);
}
.flt-btn-save:disabled { opacity: .5; cursor: default; filter: none; box-shadow: none; }

.flt-spin {
    display: inline-block;
    width: 12px; height: 12px;
    border: 2px solid rgba(255,255,255,.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: flt-spin .6s linear infinite;
}
@keyframes flt-spin { to { transform: rotate(360deg); } }

@media (max-width: 900px) {
    .flt-bar {
        width: calc(100vw - 40px);
        white-space: normal;
    }
}
@media (max-width: 560px) {
    .flt-bar {
        bottom: 12px;
        width: calc(100vw - 20px);
        border-radius: 10px;
        padding: .65rem .85rem;
        flex-direction: column;
        align-items: stretch;
        gap: .5rem;
        white-space: normal;
    }
    .flt-bar-left {
        font-size: .8rem;
        justify-content: center;
        text-align: center;
    }
    .flt-bar-right {
        display: flex;
        gap: .5rem;
    }
    .flt-btn-reset {
        flex: 1;
        padding: .5rem .5rem;
        font-size: .8rem;
        text-align: center;
        border-radius: 7px;
    }
    .flt-btn-save {
        flex: 2;
        padding: .5rem .5rem;
        font-size: .8rem;
        justify-content: center;
        border-radius: 7px;
    }
}
</style>

<div id="flt-bar" class="flt-bar" role="status" aria-live="polite">
    <div class="flt-bar-left">
        <span class="flt-pulse"></span>
        <span><%= t('common.unsaved_changes') %></span>
    </div>
    <div class="flt-bar-right">
        <button id="flt-reset" class="flt-btn-reset"><%= t('common.reset') %></button>
        <button id="flt-save" class="flt-btn-save">
            <i data-lucide="save" style="width:13px;height:13px;"></i>
            <%= t('common.save_changes') %>
        </button>
    </div>
</div>

<script>
(function () {
    const bar     = document.getElementById('flt-bar');
    const saveBtn = document.getElementById('flt-save');
    const resetBtn= document.getElementById('flt-reset');
    if (!bar || !saveBtn || !resetBtn) return;

    let dirty = false;
    let _restoring = false;
    const _initials = new Map();

    function captureInitials() {
        _initials.clear();
        document.querySelectorAll('input, select, textarea').forEach(function (el) {
            if (el.closest('#flt-bar')) return;
            if ('fltIgnore' in el.dataset) return;
            if (el.closest('[data-flt-ignore]')) return;
            _initials.set(el, el.type === 'checkbox' || el.type === 'radio' ? el.checked : el.value);
        });
    }

    function isClean() {
        for (const [el, init] of _initials) {
            if (!el.isConnected) continue;
            const cur = el.type === 'checkbox' || el.type === 'radio' ? el.checked : el.value;
            if (cur !== init) return false;
        }
        return true;
    }

    function show() {
        if (dirty) return;
        dirty = true;
        bar.classList.add('flt-visible');
        if (window.lucide) lucide.createIcons();
    }

    function hide() {
        dirty = false;
        bar.classList.remove('flt-visible');
    }

    function check(e) {
        if (_restoring) return;
        if (e.target.closest('#flt-bar')) return;
        if (!e.target.matches('input, select, textarea')) return;
        if ('fltIgnore' in e.target.dataset) return;
        if (e.target.closest('[data-flt-ignore]')) return;
        isClean() ? hide() : show();
    }

    document.addEventListener('input', check);
    document.addEventListener('change', check);

    saveBtn.addEventListener('click', async function () {
        if (typeof window._floatSave !== 'function') return;
        const origHTML = saveBtn.innerHTML;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<span class="flt-spin"></span>';
        try {
            await window._floatSave();
            captureInitials();
            hide();
        } catch { }
        finally {
            saveBtn.disabled = false;
            saveBtn.innerHTML = origHTML;
            if (window.lucide) lucide.createIcons();
        }
    });

    resetBtn.addEventListener('click', function () {
        _restoring = true;
        _initials.forEach(function (initVal, el) {
            if (!el.isConnected) return;
            if (el.type === 'checkbox' || el.type === 'radio') {
                if (el.checked !== initVal) {
                    el.checked = initVal;
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }
            } else {
                if (el.value !== initVal) {
                    el.value = initVal;
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
        });
        _restoring = false;
        if (typeof window._floatReset === 'function') window._floatReset();
        hide();
    });

    setTimeout(captureInitials, 0);

    window._floatDirty = show;
    window._floatClean = hide;
    window._floatCapture = captureInitials;
}());
</script>
