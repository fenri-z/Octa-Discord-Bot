<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
<%- include('../partials/owner-sidebar', { activePage: 'database' }) %>
<main class="dash-main">

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <%
    const _start = (page - 1) * limit + 1;
    const _end   = Math.min(page * limit, total);
    %>
    <div class="dv-header">
        <div class="dv-header-left">
            <div class="dv-hicon"><i data-lucide="database"></i></div>
            <div>
                <h1 class="dv-title"><%= t('owner.db_title') %></h1>
                <p class="dv-sub" id="dvSubtitle">
                    <% if (total === 0) { %>
                        0 <%= t('owner.db_entries') %>
                    <% } else if (total <= limit) { %>
                        <%= total.toLocaleString() %> <%= t('owner.db_entries') %>
                    <% } else { %>
                        <%= _start.toLocaleString() %>–<%= _end.toLocaleString() %> of <%= total.toLocaleString() %> <%= t('owner.db_entries') %>
                    <% } %>
                </p>
            </div>
        </div>
        <input type="text" id="dvSearch" class="input dv-search" value="<%= q %>"
            placeholder="<%= t('owner.db_search_ph') %>" autocomplete="off" data-flt-ignore>
    </div>

    <!-- ── Add Entry ────────────────────────────────────────────────────────── -->
    <div class="dv-add-card" data-flt-ignore>
        <div class="dv-add-inner">
            <div class="dv-add-icon"><i data-lucide="plus-circle"></i></div>
            <input type="text" id="dvNewKey"   class="input dv-input-key"   placeholder="<%= t('owner.db_add_key_ph') %>" autocomplete="off" spellcheck="false">
            <input type="text" id="dvNewValue" class="input dv-input-val"   placeholder="<%= t('owner.db_add_val_ph') %>" autocomplete="off" spellcheck="false">
            <button class="btn btn-primary dv-add-btn" id="dvAddBtn" onclick="addEntry()">
                <i data-lucide="plus"></i> <span><%= t('owner.db_add_btn') %></span>
            </button>
        </div>
    </div>

    <!-- ── Table ────────────────────────────────────────────────────────────── -->
    <% if (total === 0 && !q) { %>
        <div class="dv-empty">
            <i data-lucide="inbox"></i>
            <p><%= t('owner.db_empty') %></p>
        </div>
    <% } else if (entries.length === 0) { %>
        <div class="dv-empty">
            <i data-lucide="search-x"></i>
            <p><%= t('owner.db_search_ph') %></p>
        </div>
    <% } else { %>
        <div class="dv-table-card">
            <div class="dv-table-head">
                <div class="dv-th dv-th-key">Key</div>
                <div class="dv-th dv-th-val">Value</div>
                <div class="dv-th dv-th-act"></div>
            </div>
            <div class="dv-table-body" id="dvTableBody">
                <% entries.forEach(function(entry) {
                    const keyPrefix = (function(k) {
                        if (k.startsWith('blacklist-user-'))  return 'bl-user';
                        if (k.startsWith('blacklist-guild-')) return 'bl-guild';
                        if (k.startsWith('bot-'))             return 'bot';
                        if (k.startsWith('maintenance'))      return 'sys';
                        if (k.startsWith('youtube-'))         return 'yt';
                        if (k.startsWith('tiktok-'))          return 'tt';
                        if (k.startsWith('dm-guild-'))        return 'dm';
                        if (k.startsWith('prefix-'))          return 'prefix';
                        if (k.startsWith('error-'))           return 'err';
                        return 'other';
                    })(entry.key);
                    const valShort = entry.value.length > 90 ? entry.value.slice(0, 90) : null;
                %>
                <div class="dv-row" data-key="<%= entry.key %>" data-prefix="<%= keyPrefix %>">
                    <div class="dv-td dv-td-key">
                        <span class="dv-prefix-badge dv-pfx-<%= keyPrefix %>"><%= keyPrefix.toUpperCase() %></span>
                        <code class="dv-key-text" title="<%= entry.key %>"><%= entry.key %></code>
                    </div>
                    <div class="dv-td dv-td-val">
                        <span class="dv-val-text" data-full="<%= entry.value %>" data-truncated="<%= valShort !== null %>"><%= valShort ? valShort + '…' : entry.value %><% if (valShort) { %><button class="dv-expand-btn" onclick="toggleVal(this)"><i data-lucide="chevrons-right"></i></button><% } %></span>
                        <textarea class="input dv-val-input" style="display:none;" data-flt-ignore spellcheck="false"><%= entry.value %></textarea>
                    </div>
                    <div class="dv-td dv-td-act">
                        <button class="dv-btn dv-btn-edit"   onclick="startEdit(this)"  title="<%= t('owner.db_save') %>"><i data-lucide="pencil"></i></button>
                        <button class="dv-btn dv-btn-save"   onclick="saveEntry(this)"  style="display:none;" title="<%= t('owner.db_save') %>"><i data-lucide="check"></i></button>
                        <button class="dv-btn dv-btn-cancel" onclick="cancelEdit(this)" style="display:none;"><i data-lucide="x"></i></button>
                        <button class="dv-btn dv-btn-delete" onclick="deleteEntry(this)" title="<%= t('owner.db_delete') %>"><i data-lucide="trash-2"></i></button>
                    </div>
                </div>
                <% }); %>
            </div>

            <!-- ── Server-side Pagination ──────────────────────────────── -->
            <% if (totalPages > 1) { %>
            <div class="dv-pagination">
                <div class="dv-pg-info"><%= _start.toLocaleString() %>–<%= _end.toLocaleString() %> of <%= total.toLocaleString() %></div>
                <div class="dv-pg-controls">
                    <% if (page > 1) { %>
                    <a href="?page=<%= page-1 %>&q=<%= encodeURIComponent(q) %>&limit=<%= limit %>" class="dv-pg-btn"><i data-lucide="chevron-left"></i></a>
                    <% } else { %>
                    <button class="dv-pg-btn" disabled><i data-lucide="chevron-left"></i></button>
                    <% } %>
                    <div class="dv-pg-pages">
                        <% pageRange.forEach(function(p) { %>
                            <% if (p === '…') { %>
                            <span class="dv-pg-ellipsis">…</span>
                            <% } else { %>
                            <a href="?page=<%= p %>&q=<%= encodeURIComponent(q) %>&limit=<%= limit %>"
                               class="dv-pg-btn dv-pg-num<%= p === page ? ' active' : '' %>"><%= p %></a>
                            <% } %>
                        <% }); %>
                    </div>
                    <% if (page < totalPages) { %>
                    <a href="?page=<%= page+1 %>&q=<%= encodeURIComponent(q) %>&limit=<%= limit %>" class="dv-pg-btn"><i data-lucide="chevron-right"></i></a>
                    <% } else { %>
                    <button class="dv-pg-btn" disabled><i data-lucide="chevron-right"></i></button>
                    <% } %>
                </div>
                <select class="dv-pg-size" onchange="dvChangePageSize(+this.value)">
                    <option value="25"  <%= limit === 25  ? 'selected' : '' %>>25 / page</option>
                    <option value="50"  <%= limit === 50  ? 'selected' : '' %>>50 / page</option>
                    <option value="100" <%= limit === 100 ? 'selected' : '' %>>100 / page</option>
                </select>
            </div>
            <% } %>
        </div>
    <% } %>
</main>
</div>

<style>
/* ── Header ──────────────────────────────────────────────────────────────── */
.dv-header {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem;
}
.dv-header-left { display: flex; align-items: center; gap: .9rem; flex: 1; min-width: 0; }
.dv-hicon {
    width: 46px; height: 46px; border-radius: 13px; flex-shrink: 0;
    background: rgba(88,101,242,.18); color: #7289da;
    display: flex; align-items: center; justify-content: center;
}
.dv-hicon svg { width: 22px; height: 22px; }
.dv-title { font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; margin: 0; }
.dv-sub   { font-size: .8rem; color: var(--text-muted); margin: .1rem 0 0; }
.dv-search { width: 260px; font-size: .85rem; }
@media(max-width:640px) {
    .dv-header { flex-direction: column; align-items: flex-start; }
    .dv-search { width: 100%; }
}

/* ── Add form ────────────────────────────────────────────────────────────── */
.dv-add-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 14px; padding: 1rem 1.25rem;
    margin-bottom: 1.25rem;
}
.dv-add-inner {
    display: flex; align-items: center; gap: .65rem; flex-wrap: wrap;
}
.dv-add-icon { color: var(--text-muted); flex-shrink: 0; }
.dv-add-icon svg { width: 18px; height: 18px; }
.dv-input-key { flex: 0 0 280px; min-width: 140px; font-family: monospace; font-size: .83rem; }
.dv-input-val { flex: 1; min-width: 140px; font-family: monospace; font-size: .83rem; }
.dv-add-btn   { flex-shrink: 0; display: flex; align-items: center; gap: .4rem; }
@media(max-width:600px) {
    .dv-input-key, .dv-input-val { flex: 1 1 100%; }
    .dv-add-btn { width: 100%; justify-content: center; }
}

/* ── Table card ──────────────────────────────────────────────────────────── */
.dv-table-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden;
}
.dv-table-head {
    display: grid;
    grid-template-columns: minmax(200px, 360px) 1fr 104px;
    gap: 0;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
    padding: 0;
}
.dv-th {
    padding: .6rem 1rem;
    font-size: .7rem; font-weight: 700;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em;
}
.dv-th-act { text-align: right; }

.dv-table-body { display: flex; flex-direction: column; }

.dv-row {
    display: grid;
    grid-template-columns: minmax(200px, 360px) 1fr 104px;
    border-bottom: 1px solid var(--border);
    transition: background .15s, border-color .15s, box-shadow .15s;
    min-height: 44px;
}
.dv-row:last-child { border-bottom: none; }
.dv-row:hover:not(.is-editing) { background: rgba(88,101,242,.04); }

/* Edit mode — expands to 2-row layout */
.dv-row.is-editing {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    background: rgba(88,101,242,.06);
    border-color: rgba(88,101,242,.4);
    box-shadow: inset 3px 0 0 rgba(88,101,242,.7);
}
.dv-row.is-editing .dv-td-key {
    grid-column: 1; grid-row: 1;
    border-right: none;
    border-bottom: 1px solid rgba(88,101,242,.2);
}
.dv-row.is-editing .dv-td-val {
    grid-column: 1 / -1; grid-row: 2;
    border-right: none; border-top: none;
    padding: .6rem 1rem .75rem;
}
.dv-row.is-editing .dv-td-act {
    grid-column: 2; grid-row: 1;
    border-right: none;
    border-bottom: 1px solid rgba(88,101,242,.2);
    align-self: center;
}

.dv-td {
    padding: .65rem 1rem;
    display: flex; align-items: center;
    min-width: 0;
    border-right: 1px solid var(--border);
}
.dv-td:last-child { border-right: none; }

/* Key cell */
.dv-td-key { gap: .55rem; overflow: hidden; }
.dv-key-text {
    font-size: .78rem; color: var(--text-muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    cursor: default; flex: 1; min-width: 0;
}

/* Prefix badges */
.dv-prefix-badge {
    flex-shrink: 0; font-size: .6rem; font-weight: 800;
    padding: .1rem .42rem; border-radius: 4px; letter-spacing: .04em;
}
.dv-pfx-bl-user  { background: rgba(237,66,69,.18);  color: #f27f81; }
.dv-pfx-bl-guild { background: rgba(237,66,69,.12);  color: #ed9090; }
.dv-pfx-bot      { background: rgba(88,101,242,.2);  color: #949cf7; }
.dv-pfx-sys      { background: rgba(254,204,60,.15); color: #fecc3c; }
.dv-pfx-yt       { background: rgba(255,60,60,.18);  color: #ff6060; }
.dv-pfx-tt       { background: rgba(233,69,140,.18); color: #e9458c; }
.dv-pfx-dm       { background: rgba(87,242,135,.15); color: #57F287; }
.dv-pfx-prefix   { background: rgba(148,92,246,.18); color: #9a6df0; }
.dv-pfx-err      { background: rgba(237,66,69,.18);  color: #f27f81; }
.dv-pfx-other    { background: var(--bg3); color: var(--text-muted); }

/* Value cell */
.dv-td-val { gap: .5rem; overflow: hidden; }
.dv-val-text {
    font-family: monospace; font-size: .8rem; color: var(--text);
    word-break: break-all; line-height: 1.5;
    display: flex; align-items: center; gap: .35rem; flex-wrap: wrap;
    flex: 1; min-width: 0;
}
.dv-expand-btn {
    flex-shrink: 0; background: none; border: none; cursor: pointer;
    color: var(--accent); padding: 0; display: inline-flex;
    transition: color .15s;
}
.dv-expand-btn:hover { color: #7289da; }
.dv-expand-btn svg { width: 13px; height: 13px; }
.dv-expand-btn.expanded { transform: rotate(180deg); }
.dv-val-input {
    font-size: .82rem; font-family: monospace; width: 100%;
    border-color: rgba(88,101,242,.5) !important;
    box-shadow: 0 0 0 2px rgba(88,101,242,.12);
    background: var(--bg3) !important;
    resize: none; overflow: hidden; min-height: 38px;
    line-height: 1.6; display: block;
}

/* Action cell */
.dv-td-act { justify-content: flex-end; gap: .3rem; padding: .5rem .75rem; }
.dv-btn {
    width: 30px; height: 30px; border-radius: 7px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid transparent; background: transparent;
    cursor: pointer; transition: all .18s;
}
.dv-btn svg { width: 13px; height: 13px; }
.dv-btn-edit   { color: var(--text-muted); }
.dv-btn-edit:hover   { color: var(--text);   background: var(--bg3); border-color: var(--border); }
.dv-btn-save   { color: #57F287; }
.dv-btn-save:hover   { background: rgba(87,242,135,.12); border-color: rgba(87,242,135,.3); }
.dv-btn-cancel { color: var(--text-muted); }
.dv-btn-cancel:hover { background: var(--bg3); border-color: var(--border); }
.dv-btn-delete { color: var(--text-muted); }
.dv-btn-delete:hover { color: #f27f81; background: rgba(237,66,69,.1); border-color: rgba(237,66,69,.3); }
.dv-btn:disabled { opacity: .45; cursor: default; }

/* Empty */
.dv-empty {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: .75rem;
    padding: 5rem 1rem; color: var(--text-muted); font-size: .9rem;
    text-align: center;
}
.dv-empty svg { width: 44px; height: 44px; opacity: .3; }

/* Responsive: collapse table columns */
@media(max-width:900px) {
    .dv-table-head { display: none; }
    .dv-row { grid-template-columns: 1fr auto; grid-template-rows: auto auto; }
    .dv-td-key { grid-column: 1; grid-row: 1; border-right: none; border-bottom: 1px solid var(--border); padding-bottom: .5rem; }
    .dv-td-val { grid-column: 1; grid-row: 2; border-right: none; }
    .dv-td-act { grid-column: 2; grid-row: 1 / 3; align-self: center; border-right: none; }
}
@media(max-width:560px) {
    .dv-row { grid-template-columns: 1fr; grid-template-rows: auto auto auto; }
    .dv-td-act { grid-column: 1; grid-row: 3; justify-content: flex-start; border-top: 1px solid var(--border); }
}

/* Spin animation */
@keyframes _dvspin { to { transform: rotate(360deg); } }
.dv-spin { animation: _dvspin .8s linear infinite; display: inline-block; }

/* ── Pagination ───────────────────────────────────────────────────────────── */
.dv-pagination {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: .65rem;
    padding: .7rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg3);
}
.dv-pg-info { font-size: .74rem; color: var(--text-muted); white-space: nowrap; }
.dv-pg-controls { display: flex; align-items: center; gap: .2rem; }
.dv-pg-pages    { display: flex; align-items: center; gap: .2rem; flex-wrap: wrap; }
.dv-pg-btn {
    min-width: 30px; height: 30px; padding: 0 .45rem;
    border-radius: 7px; background: transparent;
    border: 1px solid transparent; color: var(--text-muted);
    font-size: .8rem; font-weight: 600; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    text-decoration: none;
    transition: all .15s;
}
.dv-pg-btn svg { width: 13px; height: 13px; }
.dv-pg-btn:hover:not(:disabled) { background: var(--bg2); border-color: var(--border); color: var(--text); }
.dv-pg-btn:disabled { opacity: .35; cursor: default; }
.dv-pg-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.dv-pg-ellipsis {
    min-width: 30px; height: 30px; display: flex; align-items: center;
    justify-content: center; font-size: .8rem; color: var(--text-muted);
}
.dv-pg-size {
    height: 30px; background: var(--bg2); border: 1px solid var(--border);
    border-radius: 7px; padding: 0 .5rem; font-size: .74rem;
    color: var(--text-muted); cursor: pointer; outline: none;
}
.dv-pg-size:focus { border-color: rgba(88,101,242,.5); }
@media(max-width:560px) {
    .dv-pagination { justify-content: center; }
    .dv-pg-info { width: 100%; text-align: center; }
}
</style>

<script>
const _dbt = {
    saved:   '<%= t("owner.db_saved") %>',
    deleted: '<%= t("owner.db_deleted") %>',
    error:   '<%= t("owner.bl_error") %>',
    addBtn:  '<%= t("owner.db_add_btn") %>',
    entries: '<%= t("owner.db_entries") %>',
};

// HTML escape helpers — required when writing into innerHTML
const _esc     = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const _escAttr = s => _esc(s).replace(/"/g,'&quot;');

// Auto-resize textarea to fit its content
function _autoResize(ta) {
    ta.style.height = 'auto';
    ta.style.height = ta.scrollHeight + 'px';
}
document.addEventListener('input', e => {
    if (e.target.classList.contains('dv-val-input')) _autoResize(e.target);
});

// ── Expand/collapse long values ───────────────────────────────────────────
function toggleVal(btn) {
    const span = btn.closest('.dv-val-text');
    const full  = span.dataset.full || '';
    const isTruncated = span.dataset.truncated === 'true';

    if (isTruncated) {
        span.dataset.truncated = 'false';
        const textNodes = [...span.childNodes].filter(n => n.nodeType === Node.TEXT_NODE);
        textNodes.forEach(n => n.remove());
        span.insertBefore(document.createTextNode(full), btn);
        btn.classList.add('expanded');
        btn.innerHTML = '<i data-lucide="chevrons-left"></i>';
    } else {
        span.dataset.truncated = 'true';
        const textNodes = [...span.childNodes].filter(n => n.nodeType === Node.TEXT_NODE);
        textNodes.forEach(n => n.remove());
        span.insertBefore(document.createTextNode(full.slice(0, 90) + '…'), btn);
        btn.classList.remove('expanded');
        btn.innerHTML = '<i data-lucide="chevrons-right"></i>';
    }
    if (window.lucide) lucide.createIcons();
}

// ── Inline edit ───────────────────────────────────────────────────────────
function startEdit(btn) {
    const row   = btn.closest('.dv-row');
    const span  = row.querySelector('.dv-val-text');
    const input = row.querySelector('.dv-val-input');

    input.value = span.dataset.full ?? input.value;

    row.classList.add('is-editing');
    span.style.display  = 'none';
    input.style.display = '';
    _autoResize(input);
    input.focus();
    input.setSelectionRange(0, input.value.length);

    row.querySelector('.dv-btn-edit').style.display   = 'none';
    row.querySelector('.dv-btn-save').style.display   = '';
    row.querySelector('.dv-btn-cancel').style.display = '';
}

function cancelEdit(btn) {
    const row   = btn.closest('.dv-row');
    const span  = row.querySelector('.dv-val-text');
    const input = row.querySelector('.dv-val-input');

    input.value = span.dataset.full ?? input.value;

    row.classList.remove('is-editing');
    span.style.display  = '';
    input.style.display = 'none';
    row.querySelector('.dv-btn-edit').style.display   = '';
    row.querySelector('.dv-btn-save').style.display   = 'none';
    row.querySelector('.dv-btn-cancel').style.display = 'none';
}

async function saveEntry(btn) {
    const row   = btn.closest('.dv-row');
    const key   = row.dataset.key;
    const value = row.querySelector('.dv-val-input').value;

    btn.disabled = true;
    try {
        const r = await fetch('/dev-console/database/set', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ key, value }),
        });
        const d = await r.json();
        if (!d.success) { showMsg(null, d.message, 'error'); return; }

        const span = row.querySelector('.dv-val-text');
        const short = value.length > 90;
        span.dataset.full      = value;
        span.dataset.truncated = String(short);
        span.innerHTML = (short ? _esc(value.slice(0, 90)) + '…' : _esc(value))
            + (short ? '<button class="dv-expand-btn" onclick="toggleVal(this)"><i data-lucide="chevrons-right"></i></button>' : '');
        if (window.lucide) lucide.createIcons();

        row.querySelector('.dv-val-input').value = value;
        showMsg(null, _dbt.saved, 'success');
        cancelEdit(btn);
    } catch {
        showMsg(null, _dbt.error, 'error');
    } finally {
        btn.disabled = false;
    }
}

async function deleteEntry(btn) {
    const row = btn.closest('.dv-row');
    const key = row.dataset.key;
    if (!confirm(`Delete "${key}"?`)) return;

    btn.disabled = true;
    try {
        const r = await fetch(`/dev-console/database/delete/${encodeURIComponent(key)}`, { method: 'POST' });
        const d = await r.json();
        if (!d.success) { showMsg(null, d.message, 'error'); btn.disabled = false; return; }
        row.remove();
        showMsg(null, _dbt.deleted, 'success');
    } catch {
        showMsg(null, _dbt.error, 'error');
        btn.disabled = false;
    }
}

// ── Add entry ─────────────────────────────────────────────────────────────
async function addEntry() {
    const keyEl  = document.getElementById('dvNewKey');
    const valEl  = document.getElementById('dvNewValue');
    const addBtn = document.getElementById('dvAddBtn');
    const key    = keyEl.value.trim();
    const value  = valEl.value;

    if (!key) { showMsg(null, 'Key is required.', 'error'); keyEl.focus(); return; }

    addBtn.disabled = true;
    addBtn.innerHTML = '<i data-lucide="loader-2" class="dv-spin"></i>';
    if (window.lucide) lucide.createIcons();

    try {
        const r = await fetch('/dev-console/database/set', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ key, value }),
        });
        const d = await r.json();
        if (!d.success) { showMsg(null, d.message, 'error'); return; }

        showMsg(null, _dbt.saved, 'success');
        setTimeout(() => location.reload(), 500);
    } catch {
        showMsg(null, _dbt.error, 'error');
    } finally {
        addBtn.disabled = false;
        addBtn.innerHTML = `<i data-lucide="plus"></i> <span>${_dbt.addBtn}</span>`;
        if (window.lucide) lucide.createIcons();
    }
}

// ── Search — debounce 400ms lalu navigate ke URL baru ────────────────────
let _dvSearchTimer;
document.getElementById('dvSearch')?.addEventListener('input', function () {
    clearTimeout(_dvSearchTimer);
    const q = this.value.trim();
    _dvSearchTimer = setTimeout(() => {
        const url = new URL(window.location);
        url.searchParams.set('q', q);
        url.searchParams.set('page', '1');
        window.location.href = url.toString();
    }, 400);
});

// ── Change page size ──────────────────────────────────────────────────────
function dvChangePageSize(size) {
    const url = new URL(window.location);
    url.searchParams.set('limit', size);
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
}

// ── Keyboard shortcuts ────────────────────────────────────────────────────
document.getElementById('dvNewValue')?.addEventListener('keydown', e => { if (e.key === 'Enter') addEntry(); });
document.getElementById('dvNewKey')?.addEventListener('keydown',   e => { if (e.key === 'Enter') document.getElementById('dvNewValue')?.focus(); });
document.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
        const s = document.querySelector('.dv-row.is-editing .dv-btn-save');
        if (s) s.click();
    }
    if (e.key === 'Escape') {
        const c = document.querySelector('.dv-row.is-editing .dv-btn-cancel');
        if (c) c.click();
    }
});
</script>

