<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="dash-layout">
<%- include('../partials/owner-sidebar', { activePage: 'commands' }) %>
<main class="dash-main">

    <div class="cm-header">
        <div class="cm-hicon"><i data-lucide="terminal-square"></i></div>
        <div>
            <h1 class="cm-title">Command Manager</h1>
            <p class="cm-sub"><%= slashCmds.length %> slash &middot; <%= msgCmds.length %> message commands loaded</p>
        </div>
    </div>

    <!-- Slash Commands -->
    <div class="cm-section-title"><i data-lucide="zap"></i> Slash Commands</div>
    <% if (slashCmds.length === 0) { %>
        <div class="cm-empty"><i data-lucide="inbox"></i><span>No slash commands loaded.</span></div>
    <% } else { %>
    <div class="cm-card">
        <div class="cm-table-head">
            <div class="cm-th cm-th-name">Name</div>
            <div class="cm-th cm-th-desc">Description</div>
            <div class="cm-th cm-th-opts">Options</div>
        </div>
        <% slashCmds.slice().sort((a,b) => a.name.localeCompare(b.name)).forEach(function(cmd) { %>
        <div class="cm-row">
            <div class="cm-row-name"><span class="cm-slash">/</span><%= cmd.name %></div>
            <div class="cm-row-desc"><%= cmd.description || '—' %></div>
            <div class="cm-row-opts">
                <% if (cmd.options > 0) { %>
                <span class="cm-opts-badge"><%= cmd.options %> opt</span>
                <% } else { %>—<% } %>
            </div>
        </div>
        <% }); %>
    </div>
    <% } %>

    <!-- Message Commands -->
    <div class="cm-section-title" style="margin-top:1.75rem;"><i data-lucide="message-square"></i> Message Commands</div>
    <% if (msgCmds.length === 0) { %>
        <div class="cm-empty"><i data-lucide="inbox"></i><span>No message commands loaded.</span></div>
    <% } else { %>
    <div class="cm-card">
        <div class="cm-table-head">
            <div class="cm-th cm-th-name">Name</div>
            <div class="cm-th cm-th-desc">Description</div>
            <div class="cm-th cm-th-alias">Aliases</div>
        </div>
        <% msgCmds.slice().sort((a,b) => a.name.localeCompare(b.name)).forEach(function(cmd) { %>
        <div class="cm-row">
            <div class="cm-row-name"><%= cmd.name %></div>
            <div class="cm-row-desc"><%= cmd.description || '—' %></div>
            <div class="cm-row-alias">
                <% if (cmd.aliases && cmd.aliases.length > 0) { %>
                    <% cmd.aliases.forEach(function(a) { %><span class="cm-alias-tag"><%= a %></span><% }); %>
                <% } else { %>—<% } %>
            </div>
        </div>
        <% }); %>
    </div>
    <% } %>

</main>
</div>

<style>
.cm-header {
    display: flex; align-items: center; gap: .9rem;
    margin-bottom: 1.75rem;
}
.cm-hicon {
    width: 46px; height: 46px; border-radius: 13px; flex-shrink: 0;
    background: rgba(88,101,242,.18); color: #7289da;
    display: flex; align-items: center; justify-content: center;
}
.cm-hicon svg { width: 22px; height: 22px; }
.cm-title { font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; margin: 0; }
.cm-sub   { font-size: .8rem; color: var(--text-muted); margin: .1rem 0 0; }

.cm-section-title {
    display: flex; align-items: center; gap: .5rem;
    font-size: .72rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .1em;
    margin-bottom: .85rem;
}
.cm-section-title svg { width: 14px; height: 14px; }

.cm-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden;
}
.cm-table-head {
    display: flex; align-items: center;
    background: var(--bg3); border-bottom: 1px solid var(--border);
    padding: .55rem 1rem;
}
.cm-th {
    font-size: .7rem; font-weight: 700; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .06em;
}
.cm-th-name  { width: 180px; flex-shrink: 0; }
.cm-th-desc  { flex: 1; padding: 0 .75rem; }
.cm-th-opts, .cm-th-alias { width: 120px; text-align: right; flex-shrink: 0; }

.cm-row {
    display: flex; align-items: center;
    padding: .65rem 1rem;
    border-bottom: 1px solid var(--border);
    transition: background .15s;
}
.cm-row:last-child { border-bottom: none; }
.cm-row:hover { background: rgba(88,101,242,.04); }
.cm-row-name {
    font-size: .875rem; font-weight: 700; color: var(--text);
    width: 180px; flex-shrink: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.cm-slash { color: #7289da; margin-right: 1px; }
.cm-row-desc {
    font-size: .82rem; color: var(--text-muted);
    flex: 1; padding: 0 .75rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.cm-row-opts, .cm-row-alias {
    width: 120px; text-align: right; flex-shrink: 0;
    font-size: .78rem; color: var(--text-muted);
    display: flex; justify-content: flex-end; flex-wrap: wrap; gap: .3rem;
}
.cm-opts-badge {
    background: rgba(88,101,242,.15); color: #949cf7;
    border-radius: 5px; padding: .1rem .45rem;
    font-size: .68rem; font-weight: 700;
}
.cm-alias-tag {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 5px; padding: .1rem .45rem;
    font-size: .68rem; font-weight: 600; color: var(--text-muted);
}

.cm-empty {
    display: flex; align-items: center; gap: .65rem;
    padding: 2.5rem 1rem; color: var(--text-muted); font-size: .88rem;
    justify-content: center;
}
.cm-empty svg { width: 24px; height: 24px; opacity: .4; }

@media(max-width:640px) {
    /* Hide table header, reflow each row as a mini-card */
    .cm-table-head { display: none; }
    .cm-row {
        flex-direction: column; align-items: flex-start;
        gap: .2rem; padding: .75rem 1rem;
    }
    .cm-row-name {
        width: 100%; white-space: normal;
        overflow: visible; text-overflow: unset;
        font-size: .875rem;
    }
    .cm-row-desc {
        width: 100%; padding: 0; flex: unset;
        white-space: normal; overflow: visible; text-overflow: unset;
        font-size: .78rem; color: var(--text-muted);
    }
    .cm-row-opts, .cm-row-alias {
        width: auto; text-align: left;
        justify-content: flex-start; margin-top: .15rem;
    }
}
</style>

<%- include('../partials/footer') %>
