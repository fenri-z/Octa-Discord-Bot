<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<% const _bu = (typeof botUser !== 'undefined' && botUser) ? botUser : { username: 'Bot', avatarUrl: 'https://cdn.discordapp.com/embed/avatars/0.png' }; %>

<div class="dash-layout">
<%- include('../partials/owner-sidebar', { activePage: 'broadcast' }) %>
<main class="dash-main">

    <div class="bc-header">
        <div class="bc-hicon"><i data-lucide="megaphone"></i></div>
        <div>
            <h1 class="bc-title">Broadcast Message</h1>
            <p class="bc-sub">Send a message to all servers the bot is in</p>
        </div>
    </div>

    <div class="bc-notice" style="margin-bottom:1.25rem;">
        <i data-lucide="info"></i>
        <span>The message will be sent to the first accessible text channel in each server. Servers where the bot lacks permission will be counted as failed.</span>
    </div>

    <!-- Main layout: form left, preview right -->
    <div class="bc-layout">

        <!-- Left: form -->
        <div class="bc-form-col">

            <!-- Plain Text -->
            <div class="bc-section">
                <div class="bc-section-head">
                    <span class="bc-section-head-left">
                        <i data-lucide="message-square"></i> Plain Text
                    </span>
                    <span class="bc-char" id="bcChar">0 / 2000</span>
                </div>
                <div class="bc-section-body">
                    <textarea id="bcText" class="textarea" rows="4" style="width:100%;resize:vertical;min-height:90px;max-height:320px;"
                        placeholder="Type your broadcast message here..." maxlength="2000" data-flt-ignore
                        oninput="onBcInput(this);livePreview()"></textarea>
                </div>
            </div>

            <!-- Embed Builder -->
            <div class="bc-section">
                <div class="bc-section-head">
                    <span class="bc-section-head-left">
                        <i data-lucide="layers"></i> Embed Builder
                        <span style="font-size:.72rem;font-weight:400;color:var(--text-muted);">(optional)</span>
                    </span>
                    <div class="bc-color-row">
                        <span style="font-size:.72rem;color:var(--text-muted);white-space:nowrap;">Accent</span>
                        <input type="color" id="ebColor" class="bc-color-pick" value="#5865F2" data-flt-ignore oninput="syncColorHex(this);livePreview()">
                        <input type="text"  id="ebColorHex" class="input" value="#5865F2" maxlength="7" data-flt-ignore style="width:80px;padding:.3rem .5rem;font-size:.8rem;" oninput="syncColorFromHex(this)">
                    </div>
                </div>
                <div class="bc-section-body">

                    <div>
                        <label class="bc-label">Author</label>
                        <input type="text" id="ebAuthor" class="input" placeholder="Author name" maxlength="256" data-flt-ignore oninput="livePreview()">
                    </div>

                    <div class="bc-field-row">
                        <div>
                            <label class="bc-label">Title</label>
                            <input type="text" id="ebTitle" class="input" placeholder="Embed title" maxlength="256" data-flt-ignore oninput="livePreview()">
                        </div>
                        <div>
                            <label class="bc-label">Title URL</label>
                            <input type="url" id="ebUrl" class="input" placeholder="https://..." data-flt-ignore oninput="livePreview()">
                        </div>
                    </div>

                    <div>
                        <label class="bc-label" style="display:flex;justify-content:space-between;">
                            <span>Description</span>
                            <span id="ebDescCount" style="font-weight:400;text-transform:none;letter-spacing:0;">0 / 4096</span>
                        </label>
                        <textarea id="ebDesc" class="textarea" rows="4" style="width:100%;resize:vertical;min-height:80px;"
                            placeholder="Embed description..." maxlength="4096" data-flt-ignore
                            oninput="onDescInput();livePreview()"></textarea>
                    </div>

                    <div class="bc-field-row">
                        <div>
                            <label class="bc-label">Thumbnail URL</label>
                            <input type="url" id="ebThumb" class="input" placeholder="https://..." data-flt-ignore oninput="livePreview()">
                        </div>
                        <div>
                            <label class="bc-label">Image URL</label>
                            <input type="url" id="ebImage" class="input" placeholder="https://..." data-flt-ignore oninput="livePreview()">
                        </div>
                    </div>

                    <div>
                        <label class="bc-label">Footer Text</label>
                        <input type="text" id="ebFooter" class="input" placeholder="Footer text" maxlength="2048" data-flt-ignore oninput="livePreview()">
                    </div>

                    <label style="display:flex;align-items:center;gap:.5rem;font-size:.85rem;color:var(--text-muted);cursor:pointer;">
                        <input type="checkbox" id="ebTimestamp" data-flt-ignore onchange="livePreview()" style="accent-color:var(--accent);">
                        <span>Add timestamp</span>
                    </label>

                </div>
            </div>

            <!-- Send -->
            <div class="bc-send-row">
                <button class="btn btn-primary bc-send" onclick="sendBroadcast()">
                    <i data-lucide="send"></i> Send to All Guilds
                </button>
            </div>

        </div><!-- /bc-form-col -->

        <!-- Right: preview -->
        <div class="bc-preview-col preview-panel">
            <div class="preview-label">PREVIEW</div>
            <div class="dc-window">
                <div class="dc-channel-bar">
                    <span class="dc-channel-hash">#</span>
                    <span>general</span>
                </div>
                <div class="dc-messages">
                    <div class="dc-message">
                        <div class="dc-avatar">
                            <img src="<%= botUser.avatarUrl %>" alt=""
                                 onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                        </div>
                        <div class="dc-msg-body">
                            <div class="dc-username-row">
                                <%= botUser.username %>
                                <span class="dc-app-badge">
                                    <svg width="9" height="9" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <path d="M1.5 6L4.5 9L10.5 3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                    APP
                                </span>
                                <span class="dc-timestamp">Today at 12:00</span>
                            </div>
                            <div id="bcPreviewPlain" class="dc-plain-msg" style="display:none;"></div>
                            <div id="bcPreviewEmbed" class="dc-embed" style="display:none;">
                                <div id="bcPreviewPill" class="dc-embed-pill" style="background:#5865F2;"></div>
                                <div class="dc-embed-body">
                                    <div class="dc-embed-main">
                                        <div class="dc-embed-content">
                                            <div id="bcPreviewAuthor" class="dc-embed-author" style="display:none;"></div>
                                            <div id="bcPreviewTitle"  class="dc-embed-title"  style="display:none;"></div>
                                            <div id="bcPreviewDesc"   class="dc-embed-desc"   style="display:none;"></div>
                                        </div>
                                        <div id="bcPreviewThumbWrap" class="dc-embed-thumb" style="display:none;">
                                            <img id="bcPreviewThumb" src="" alt="">
                                        </div>
                                    </div>
                                    <div id="bcPreviewImageWrap" class="dc-embed-image" style="display:none;">
                                        <img id="bcPreviewImage" src="" alt="">
                                    </div>
                                    <div id="bcPreviewFooter" class="dc-embed-footer" style="display:none;"></div>
                                </div>
                            </div>
                            <div id="bcPreviewEmpty" class="dc-embed-empty">Fill in fields above to see preview</div>
                        </div>
                    </div>
                </div>
            </div>
        </div><!-- /bc-preview-col -->

    </div><!-- /bc-layout -->

</main>
</div>

<style>
.bc-header { display: flex; align-items: center; gap: .9rem; margin-bottom: 1.25rem; }
.bc-hicon {
    width: 46px; height: 46px; border-radius: 13px; flex-shrink: 0;
    background: rgba(255,115,250,.14); color: #FF73FA;
    display: flex; align-items: center; justify-content: center;
}
.bc-hicon svg { width: 22px; height: 22px; }
.bc-title { font-size: 1.4rem; font-weight: 800; letter-spacing: -.02em; margin: 0; }
.bc-sub   { font-size: .8rem; color: var(--text-muted); margin: .1rem 0 0; }

.bc-notice {
    display: flex; align-items: flex-start; gap: .65rem;
    background: rgba(88,101,242,.07); border: 1px solid rgba(88,101,242,.18);
    border-radius: 10px; padding: .85rem 1rem;
    font-size: .8rem; color: var(--text-muted); line-height: 1.55;
}
.bc-notice svg { width: 15px; height: 15px; color: #7289da; flex-shrink: 0; margin-top: .1rem; }

/* Layout */
.bc-layout { display: flex; gap: 1.25rem; align-items: flex-start; }
.bc-form-col { flex: 1; min-width: 0; }
.bc-preview-col { width: 420px; flex-shrink: 0; position: sticky; top: calc(var(--navbar-h, 64px) + 1rem); }
@media (max-width: 1000px) { .bc-layout { flex-direction: column; } .bc-preview-col { width: 100%; position: static; } }

/* Sections */
.bc-section {
    background: var(--bg2); border: 1.5px solid var(--border);
    border-radius: 12px; margin-bottom: .75rem; overflow: hidden;
}
.bc-section-head {
    display: flex; align-items: center; justify-content: space-between; gap: .5rem;
    padding: .6rem 1rem; background: var(--bg3); border-bottom: 1px solid var(--border);
    font-size: .82rem; font-weight: 700;
}
.bc-section-head-left { display: flex; align-items: center; gap: .4rem; }
.bc-section-head svg { width: 13px; height: 13px; color: var(--accent); }
.bc-section-body { padding: 1rem; display: flex; flex-direction: column; gap: .75rem; }

.bc-label { font-size: .7rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: .3rem; display: block; }
.bc-char { font-size: .73rem; color: var(--text-muted); }
.bc-char.warn { color: #FEE75C; }
.bc-char.over { color: #ED4245; }
.bc-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
.bc-color-row { display: flex; gap: .45rem; align-items: center; }
.bc-color-pick { width: 32px; height: 32px; border-radius: 7px; border: 1px solid var(--border); padding: 2px; cursor: pointer; background: none; flex-shrink: 0; }

.bc-send-row { display: flex; justify-content: flex-end; margin-bottom: 1.1rem; }
</style>

<script>
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── Char counter ──────────────────────────────────────────────────────────────
function onBcInput(el) {
    const len = el.value.length;
    const charEl = document.getElementById('bcChar');
    charEl.textContent = len + ' / 2000';
    charEl.className = 'bc-char' + (len > 1900 ? (len >= 2000 ? ' over' : ' warn') : '');
}

function onDescInput() {
    const n = document.getElementById('ebDesc').value.length;
    document.getElementById('ebDescCount').textContent = n + ' / 4096';
}

// ── Color sync ────────────────────────────────────────────────────────────────
function syncColorHex(picker) {
    document.getElementById('ebColorHex').value = picker.value;
}
function syncColorFromHex(input) {
    const val = input.value.trim();
    if (/^#[0-9a-fA-F]{6}$/.test(val)) {
        document.getElementById('ebColor').value = val;
        livePreview();
    }
}

// ── Discord Markdown renderer ─────────────────────────────────────────────────
function discordMarkdown(raw) {
    if (!raw) return '';
    let s = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    const blocks = [], inlines = [];
    s = s.replace(/```(\w*)?\n?([\s\S]*?)```/g, (_,__,code) => { const i=blocks.length; blocks.push(`<div class="dmd-pre">${code.trimEnd()}</div>`); return `\x00B${i}\x00`; });
    s = s.replace(/`([^`\n]+)`/g, (_,c) => { const i=inlines.length; inlines.push(`<code class="dmd-code">${c}</code>`); return `\x00I${i}\x00`; });
    s = s.replace(/^### (.+)$/gm,'<div class="dmd-h3">$1</div>');
    s = s.replace(/^## (.+)$/gm, '<div class="dmd-h2">$1</div>');
    s = s.replace(/^# (.+)$/gm,  '<div class="dmd-h1">$1</div>');
    s = s.replace(/^&gt; (.*)$/gm,'<div class="dmd-blockquote">$1</div>');
    s = s.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>');
    s = s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
    s = s.replace(/\*([^*\n]+)\*/g,'<em>$1</em>');
    s = s.replace(/__(.+?)__/g,'<u>$1</u>');
    s = s.replace(/_([^_\n]+)_/g,'<em>$1</em>');
    s = s.replace(/~~(.+?)~~/g,'<s>$1</s>');
    s = s.replace(/\|\|(.+?)\|\|/g,'<span class="dmd-spoiler" onclick="this.classList.toggle(\'revealed\')">$1</span>');
    s = s.replace(/@(everyone|here)\b/g,'<span class="dmd-mention dmd-mention-all">@$1</span>');
    s = s.replace(/&lt;@!?(\d{17,20})&gt;/g,'<span class="dmd-mention">@User</span>');
    s = s.replace(/&lt;@&amp;(\d{17,20})&gt;/g,'<span class="dmd-mention">@Role</span>');
    s = s.replace(/&lt;#(\d{17,20})&gt;/g,'<span class="dmd-mention">#channel</span>');
    s = s.replace(/(https?:\/\/[^\s<"]+)/g,'<a class="dmd-link" href="$1" target="_blank" rel="noopener">$1</a>');
    blocks.forEach((b,i) => { s = s.replace(`\x00B${i}\x00`, b); });
    inlines.forEach((b,i) => { s = s.replace(`\x00I${i}\x00`, b); });
    s = s.replace(/\n/g,'<br>');
    return s;
}

// ── Live preview ──────────────────────────────────────────────────────────────
function livePreview() {
    const text   = document.getElementById('bcText').value.trim();
    const color  = document.getElementById('ebColor').value || '#5865F2';
    const author = document.getElementById('ebAuthor').value.trim();
    const title  = document.getElementById('ebTitle').value.trim();
    const url    = document.getElementById('ebUrl').value.trim();
    const desc   = document.getElementById('ebDesc').value.trim();
    const thumb  = document.getElementById('ebThumb').value.trim();
    const image  = document.getElementById('ebImage').value.trim();
    const footer = document.getElementById('ebFooter').value.trim();
    const ts     = document.getElementById('ebTimestamp').checked;

    const hasEmbed = author || title || desc || footer || image || thumb;
    const hasAny   = text || hasEmbed;

    // Plain text
    const plainEl = document.getElementById('bcPreviewPlain');
    plainEl.style.display = text ? '' : 'none';
    if (text) plainEl.innerHTML = discordMarkdown(text);

    // Empty state
    document.getElementById('bcPreviewEmpty').style.display = hasAny ? 'none' : '';

    // Embed
    document.getElementById('bcPreviewEmbed').style.display = hasEmbed ? '' : 'none';
    if (hasEmbed) {
        document.getElementById('bcPreviewPill').style.background = color;

        const authEl = document.getElementById('bcPreviewAuthor');
        authEl.style.display = author ? '' : 'none';
        if (author) authEl.textContent = author;

        const titleEl = document.getElementById('bcPreviewTitle');
        titleEl.style.display = title ? '' : 'none';
        if (title) titleEl.innerHTML = url
            ? `<a href="${esc(url)}" target="_blank" rel="noopener">${esc(title)}</a>`
            : esc(title);

        const descEl = document.getElementById('bcPreviewDesc');
        descEl.style.display = desc ? '' : 'none';
        if (desc) descEl.textContent = desc;

        const imgWrap = document.getElementById('bcPreviewImageWrap');
        const imgEl   = document.getElementById('bcPreviewImage');
        imgWrap.style.display = image ? '' : 'none';
        if (image) imgEl.src = image;

        const thumbWrap = document.getElementById('bcPreviewThumbWrap');
        const thumbEl   = document.getElementById('bcPreviewThumb');
        thumbWrap.style.display = thumb ? '' : 'none';
        if (thumb) thumbEl.src = thumb;

        const footerEl = document.getElementById('bcPreviewFooter');
        const parts = [];
        if (footer) parts.push(esc(footer));
        if (ts) { const now = new Date(); parts.push('Today at ' + now.toLocaleTimeString('en-US', { hour:'numeric', minute:'2-digit', hour12:true })); }
        footerEl.style.display = parts.length ? '' : 'none';
        footerEl.innerHTML = parts.join('<span class="dc-footer-sep"> · </span>');
    }
}

// ── Send ──────────────────────────────────────────────────────────────────────
async function sendBroadcast() {
    const text   = document.getElementById('bcText').value.trim();
    const author = document.getElementById('ebAuthor').value.trim();
    const title  = document.getElementById('ebTitle').value.trim();
    const desc   = document.getElementById('ebDesc').value.trim();
    const footer = document.getElementById('ebFooter').value.trim();
    const image  = document.getElementById('ebImage').value.trim();
    const thumb  = document.getElementById('ebThumb').value.trim();

    const hasEmbed = author || title || desc || footer || image || thumb;

    if (!text && !hasEmbed) {
        showMsg(null, 'Please fill in plain text or embed fields.', 'error');
        return;
    }

    const btn = document.querySelector('.bc-send');
    btn.disabled = true;
    btn.innerHTML = '<i data-lucide="loader-2" class="bc-spin"></i> Sending...';
    if (window.lucide) lucide.createIcons();

    let body;
    if (hasEmbed) {
        body = {
            mode: 'embed',
            message: text,
            embed: {
                color:       document.getElementById('ebColor').value,
                author,
                title,
                url:         document.getElementById('ebUrl').value.trim(),
                description: desc,
                thumbnail:   thumb,
                image,
                footer,
                timestamp:   document.getElementById('ebTimestamp').checked,
            },
        };
    } else {
        body = { mode: 'text', message: text };
    }

    try {
        const r = await fetch('/dev-console/broadcast', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
        });
        const d = await r.json();
        if (d.success) {
            showMsg(null, `Broadcast sent! ${d.sent} delivered · ${d.failed} failed · ${d.total} total guilds`, 'success');
        } else {
            showMsg(null, d.message, 'error');
        }
    } catch {
        showMsg(null, 'Network error.', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="send"></i> Send to All Guilds';
        if (window.lucide) lucide.createIcons();
    }
}

const _s = document.createElement('style');
_s.textContent = `
@keyframes bc-spin { to { transform: rotate(360deg); } }
.bc-spin { animation: bc-spin .8s linear infinite; display:inline-block; }
.bc-preview-col .dc-plain-msg .dmd-pre { background:rgba(0,0,0,.2); border:1px solid rgba(255,255,255,.06); border-radius:4px; padding:.5rem .75rem; font-family:monospace; font-size:.82rem; overflow-x:auto; white-space:pre; }
.bc-preview-col .dc-plain-msg .dmd-code { background:rgba(0,0,0,.2); border-radius:3px; padding:.1em .25em; font-family:monospace; font-size:.875em; }
.bc-preview-col .dc-plain-msg .dmd-mention { background:rgba(88,101,242,.28); color:#bcc0f0; border-radius:3px; padding:0 3px; font-weight:500; }
.bc-preview-col .dc-plain-msg .dmd-mention-all { background:rgba(250,168,26,.25); color:#faa81a; }
.bc-preview-col .dc-plain-msg .dmd-blockquote { border-left:4px solid rgba(255,255,255,.15); padding-left:.75rem; margin:.25rem 0; color:var(--text-muted); }
.bc-preview-col .dc-plain-msg .dmd-h1 { font-size:1.5rem; font-weight:700; margin:.4rem 0 .2rem; }
.bc-preview-col .dc-plain-msg .dmd-h2 { font-size:1.25rem; font-weight:700; margin:.35rem 0 .15rem; }
.bc-preview-col .dc-plain-msg .dmd-h3 { font-size:1.05rem; font-weight:700; margin:.3rem 0 .1rem; }
.bc-preview-col .dc-plain-msg .dmd-link { color:#00aff4; text-decoration:none; }
.bc-preview-col .dc-embed-title a { color:#00aff4; text-decoration:none; }
`;
document.head.appendChild(_s);
</script>

<%- include('../partials/footer') %>
